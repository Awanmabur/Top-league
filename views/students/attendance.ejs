<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= pageTitle %> — <%= tenant?.name || "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css"/>
  <link rel="stylesheet" href="/css/student-portal.css" />
</head>
<body>

<%- include("./navbar") %>

<main class="main">
  <div class="topbar">
    <div>
      <div class="title">Attendance</div>
      <div class="subtitle">
        View your attendance summary, per-course breakdown, and detailed daily records.
      </div>
    </div>
    <div class="top-actions">
      <a class="btn light" href="/student/dashboard">
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
      </a>
      <button class="btn primary" id="exportAttendanceBtn" type="button">
        <i class="fa-solid fa-file-arrow-down"></i> Export Attendance
      </button>
    </div>
  </div>

  <%-include("../tenant/partials/flash") %>

  <section class="card">
    <div class="section-title">Filters</div>
    <div class="section-sub">Use the tables below to review current attendance data.</div>
  </section>

  <div class="kpi-row">
    <div class="card" style="flex:1;">
      <div class="section-title">Overall Attendance</div>
      <div class="section-sub">Recent attendance snapshot</div>
      <div style="margin-top:8px;">
        <div style="font-size:22px;font-weight:700;"><%= overview.overallPct %>%</div>
        <div class="small-muted">Target: 75%</div>
      </div>
    </div>

    <div class="card" style="flex:1;">
      <div class="section-title">Total Classes</div>
      <div class="section-sub">Recorded sessions</div>
      <div style="margin-top:8px;">
        <div style="font-size:22px;font-weight:700;"><%= overview.total %></div>
        <div class="mini-list" style="margin-top:6px;">
          <div class="mini-item"><span>Attended</span><span style="color:#16a34a;"><%= overview.attended %></span></div>
          <div class="mini-item"><span>Missed</span><span style="color:#dc2626;"><%= overview.missed %></span></div>
          <div class="mini-item"><span>Late</span><span style="color:#f59e0b;"><%= overview.late %></span></div>
        </div>
      </div>
    </div>

    <div class="card" style="flex:1;">
      <div class="section-title">At-Risk Courses</div>
      <div class="section-sub">Below 80% attendance</div>
      <div style="margin-top:8px;">
        <div style="font-size:22px;font-weight:700;"><%= overview.atRiskCount %></div>
        <div class="small-muted">Courses requiring attention</div>
      </div>
    </div>
  </div>

  <div class="content">
    <section class="card">
      <div class="section-title">Attendance by Course</div>
      <div class="section-sub">Current course overview.</div>

      <div style="margin-top:10px;overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="border-bottom:1px solid #e5edff;">
              <th style="text-align:left;padding:6px 4px;">Course</th>
              <th style="text-align:center;padding:6px 4px;">Attendance</th>
              <th style="text-align:center;padding:6px 4px;">Attended / Total</th>
              <th style="text-align:right;padding:6px 4px;">Trend</th>
            </tr>
          </thead>
          <tbody>
            <% if (courseSummary?.length) { %>
              <% courseSummary.forEach(function(c) { %>
                <tr>
                  <td style="padding:6px 4px;">
                    <div><strong><%= c.courseCode %> - <%= c.courseTitle %></strong></div>
                  </td>
                  <td style="text-align:center;">
                    <span class="badge-credits" style="background:<%= c.percentage >= 80 ? '#ecfdf3' : '#fef2f2' %>;color:<%= c.percentage >= 80 ? '#15803d' : '#b91c1c' %>;">
                      <%= c.percentage %>%
                    </span>
                  </td>
                  <td style="text-align:center;"><%= c.attended %> / <%= c.total %></td>
                  <td style="text-align:right;">
                    <span style="color:<%= c.percentage >= 80 ? '#16a34a' : '#dc2626' %>;">
                      <%= c.trend %>
                    </span>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="4">No attendance summary found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <aside>
      <section class="card">
        <div class="section-title">Detailed Records</div>
        <div class="section-sub">Most recent attendance entries.</div>

        <div class="notif-list" style="margin-top:10px;">
          <% if (records?.length) { %>
            <% records.slice(0, 20).forEach(function(r) { %>
              <div class="notif-item">
                <div class="notif-icon"><i class="fa-solid fa-user-check"></i></div>
                <div>
                  <div class="notif-title"><%= r.courseCode %> - <%= r.courseTitle %></div>
                  <div class="notif-meta">
                    <%= r.date ? new Date(r.date).toDateString() : "-" %> • <%= r.status %>
                    <%= r.remark ? " • " + r.remark : "" %>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="small-muted">No attendance records found.</div>
          <% } %>
        </div>
      </section>
    </aside>
  </div>
</main>
</div>

<script src="/js/navbar.js"></script>
<script>
document.getElementById("exportAttendanceBtn")?.addEventListener("click", function () {
  window.print();
});
</script>
</body>
</html>