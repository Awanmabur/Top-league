<!-- ======================
     MOBILE GLASS TOP NAV
======================= -->
<%
  const currentPath =
    (typeof originalUrl !== "undefined" && originalUrl) ||
    (typeof url !== "undefined" && url) ||
    "";
  const tenantAccess = locals.tenantAccess || {};
  const modelList = Array.isArray(locals.availableModels) ? locals.availableModels : [];
  const modelSet = new Set(modelList);

  function isActive(path, exact = false) {
    if (!currentPath) return false;
    if (exact) return currentPath === path;
    return currentPath === path || currentPath.startsWith(path + "/");
  }

  function navClass(path, options = {}) {
    return isActive(path, !!options.exact) ? "navbutton active" : "navbutton";
  }

  function hasAnyModel() {
    return Array.from(arguments).some((name) => modelSet.has(name));
  }

  function visibleItems(items) {
    return items.filter((item) => !item.hidden);
  }

  const showSubjectSelection = hasAnyModel("Subject", "CourseRegistration", "RegistrationWindow");
  const showSubjects = hasAnyModel("Subject", "CourseRegistration");
  const showTimetable = hasAnyModel("Timetable", "TimetableEntry", "ClassTimetable", "Schedule");
  const showAssignments = hasAnyModel("Assignment");
  const showExams = hasAnyModel("Exam");
  const showResults = hasAnyModel("Result");
  const showTranscript = hasAnyModel("Transcript", "Result");
  const showFinance = hasAnyModel("Invoice", "Payment", "FeeStructure", "Receipt");
  const showAttendance = hasAnyModel("Attendance");
  const showHostel = hasAnyModel("Hostel", "HostelAllocation", "HostelApplication");
  const showLibrary = hasAnyModel("LibraryBook", "LibraryLoan", "LibraryReservation");
  const showJobs = hasAnyModel("Job", "Opportunity");
  const showEvents = hasAnyModel("Event");
  const showNotifications = hasAnyModel("Notification", "Announcement");
  const showSupport =
    tenantAccess?.featureFlags?.helpdesk !== false &&
    hasAnyModel("SupportTicket", "Ticket");

  const learningItems = visibleItems([
    { label: "Dashboard", icon: "fa-house", href: "/student/dashboard", hidden: false },
    { label: "Subject Selection", icon: "fa-list-check", href: "/student/subject-selection", hidden: !showSubjectSelection },
    { label: "My Subjects", icon: "fa-book-open-reader", href: "/student/subjects", hidden: !showSubjects },
    { label: "Timetable", icon: "fa-calendar-week", href: "/student/timetable", hidden: !showTimetable },
    { label: "Assignments", icon: "fa-file-pen", href: "/student/assignments", hidden: !showAssignments },
    { label: "Exams", icon: "fa-clipboard-list", href: "/student/exams", hidden: !showExams },
  ]);

  const recordItems = visibleItems([
    { label: "Results", icon: "fa-award", href: "/student/results", hidden: !showResults },
    { label: "Transcript", icon: "fa-file-pdf", href: "/student/transcript", hidden: !showTranscript },
    { label: "Attendance", icon: "fa-user-check", href: "/student/attendance", hidden: !showAttendance },
    { label: "Finance", icon: "fa-sack-dollar", href: "/student/finance", hidden: !showFinance },
  ]);

  const campusItems = visibleItems([
    { label: "Hostel", icon: "fa-bed", href: "/student/hostel", hidden: !showHostel },
    { label: "Library", icon: "fa-book", href: "/student/library", hidden: !showLibrary },
    { label: "Events", icon: "fa-calendar-days", href: "/student/events", hidden: !showEvents },
    { label: "Jobs", icon: "fa-briefcase", href: "/student/jobs", hidden: !showJobs },
    { label: "Notifications", icon: "fa-bell", href: "/student/notifications", hidden: !showNotifications },
    { label: "Support", icon: "fa-headset", href: "/student/support", hidden: !showSupport },
  ]);

  const accountItems = visibleItems([
    { label: "Profile", icon: "fa-user", href: "/student/profile", hidden: false },
    { label: "Logout", icon: "fa-right-from-bracket", href: "/logout", exact: true, hidden: false },
  ]);
%>

<header class="mglass-nav" id="mglassNav">
  <div class="mglass-left">
    <a class="mglass-home" href="/student/dashboard" aria-label="Home">
      <i class="fa fa-house"></i>
    </a>
    <div class="mglass-title"><%= tenant?.name || "Classic Academy" %></div>
  </div>

  <button class="mglass-menu" id="mobileMenuBtn" type="button" aria-label="Open menu">
    <i class="fa fa-bars"></i>
  </button>
</header>

<div class="app">
  <div class="sidebar-backdrop" id="sidebarBackdrop" aria-hidden="true"></div>

  <aside class="sidebar" id="sidebar">
    <button type="button" id="sbToggle" class="sbToggle" aria-label="Toggle sidebar">
      <i class="fa fa-angle-left"></i>
    </button>

    <div class="brand">
      <div class="brand-logo">CS</div>
      <div class="brand-meta">
        <h1 class="brand-title"><%= tenant?.name || "Classic Academy" %></h1>
        <div class="brand-sub">Student Portal</div>
      </div>
    </div>

    <nav class="nav">
      <% if (learningItems.length) { %>
        <div class="navcat">LEARNING</div>
        <div class="group">
          <% learningItems.forEach(function(item) { %>
            <a class="<%= navClass(item.href, { exact: item.exact }) %>" href="<%= item.href %>" data-label="<%= item.label %>">
              <i class="fa <%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <% if (recordItems.length) { %>
        <div class="navcat">RECORDS</div>
        <div class="group">
          <% recordItems.forEach(function(item) { %>
            <a class="<%= navClass(item.href, { exact: item.exact }) %>" href="<%= item.href %>" data-label="<%= item.label %>">
              <i class="fa <%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <% if (campusItems.length) { %>
        <div class="navcat">CAMPUS</div>
        <div class="group">
          <% campusItems.forEach(function(item) { %>
            <a class="<%= navClass(item.href, { exact: item.exact }) %>" href="<%= item.href %>" data-label="<%= item.label %>">
              <i class="fa <%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <% if (accountItems.length) { %>
        <div class="navcat">ACCOUNT</div>
        <div class="group">
          <% accountItems.forEach(function(item) { %>
            <a class="<%= navClass(item.href, { exact: item.exact }) %>" href="<%= item.href %>" data-label="<%= item.label %>">
              <i class="fa <%= item.icon %>"></i>
              <span><%= item.label %></span>
            </a>
          <% }) %>
        </div>
      <% } %>

      <div class="navfoot">Portal: <strong>Student</strong></div>
    </nav>
  </aside>

