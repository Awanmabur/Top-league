<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= pageTitle %> — <%= tenant?.name || "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css"/>
  <link rel="stylesheet" href="/css/student-portal.css" />
</head>
<body data-portal="student">
<%- include("./navbar") %>

<main class="main">
  <div class="topbar">
    <div>
      <div class="title">Events & Announcements</div>
      <div class="subtitle">
        Track academic, student, administrative, and social events across the school.
      </div>
    </div>
    <div class="top-actions">
      <button class="btn light" type="button" disabled>
        <i class="fa-solid fa-calendar-plus"></i> Add to Calendar
      </button>
      <button class="btn primary" type="button" disabled>
        <i class="fa-solid fa-bell"></i> Subscribe to Alerts
      </button>
    </div>
  </div>

  <%-include("../tenant/partials/flash") %>

  <section class="card">
    <div class="section-title">Filters</div>
    <div class="section-sub">Filter by event type and location.</div>

    <div class="filters-row" style="margin-top:10px;">
      <div>
        <label class="small-muted">Event type</label><br/>
        <select id="eventType" class="select">
          <option value="all" selected>All types</option>
          <option value="academic">Academic</option>
          <option value="club">Clubs &amp; Societies</option>
          <option value="admin">Administrative</option>
          <option value="sports">Sports</option>
        </select>
      </div>
      <div>
        <label class="small-muted">Location</label><br/>
        <select id="eventLocation" class="select">
          <option value="all" selected>All locations</option>
          <option value="main">Main School</option>
          <option value="city">City Centre</option>
        </select>
      </div>
    </div>
  </section>

  <div class="content">
      <section class="card">
        <div class="section-title">Upcoming Events</div>
      <div class="section-sub">School calendar.</div>

      <div style="margin-top:10px;overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;" id="eventsTable">
          <thead>
            <tr style="border-bottom:1px solid #e5edff;">
              <th style="text-align:left;padding:6px 4px;">Date</th>
              <th style="text-align:left;padding:6px 4px;">Title</th>
              <th style="text-align:left;padding:6px 4px;">Type</th>
              <th style="text-align:left;padding:6px 4px;">Location</th>
              <th style="text-align:left;padding:6px 4px;">Time</th>
            </tr>
          </thead>
          <tbody>
            <% if (events?.length) { %>
              <% events.forEach(function(ev){ %>
                <tr class="event-row"
                    data-type="<%= String(ev.type || '').toLowerCase() %>"
                    data-location="<%= String(ev.location || '').toLowerCase().includes('city') ? 'city' : 'main' %>">
                  <td><%= ev.date ? new Date(ev.date).toDateString() : "-" %></td>
                  <td>
                    <strong><%= ev.title %></strong>
                    <% if (ev.organizer) { %>
                      <div class="small-muted"><%= ev.organizer %></div>
                    <% } %>
                  </td>
                  <td><%= ev.type %></td>
                  <td><%= ev.location %></td>
                  <td><%= ev.time %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="5">No events found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <aside>
      <section class="card">
        <div class="section-title">Latest announcements</div>
        <div class="section-sub">From school management &amp; faculty.</div>

        <div class="notif-list" style="margin-top:10px;">
          <% if (announcements?.length) { %>
            <% announcements.forEach(function(item){ %>
              <div class="notif-item">
                <div class="notif-icon"><i class="fa-solid fa-bullhorn"></i></div>
                <div>
                  <div class="notif-title"><%= item.title %></div>
                  <div class="notif-meta"><%= item.createdAt ? new Date(item.createdAt).toDateString() : "-" %></div>
                  <div class="small-muted" style="margin-top:4px;"><%= item.message %></div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="small-muted">No announcements found.</div>
          <% } %>
        </div>
      </section>
    </aside>
  </div>
</main>
</div>

<script src="/js/navbar.js"></script>
<script>
(function(){
  const typeSelect = document.getElementById("eventType");
  const locationSelect = document.getElementById("eventLocation");
  const rows = document.querySelectorAll("#eventsTable .event-row");

  function applyFilters() {
    const t = typeSelect.value;
    const l = locationSelect.value;

    rows.forEach(row => {
      const rt = row.getAttribute("data-type");
      const rl = row.getAttribute("data-location");

      let visible = true;
      if (t !== "all" && rt !== t) visible = false;
      if (l !== "all" && rl !== l) visible = false;

      row.style.display = visible ? "" : "none";
    });
  }

  typeSelect?.addEventListener("change", applyFilters);
  locationSelect?.addEventListener("change", applyFilters);
})();
</script>
</body>
</html>
