</head>

<body>
    <header class="top fadeIn">
        <div class="brand">
            <div class="mark" aria-hidden="true"></div>
            <div class="brandText">Classic <span>Schedule</span></div>
        </div>
        <div class="navRight">
            <div class="search" aria-label="Search (visual only)">
                <span style="opacity:.75">Search</span>
                <input placeholder="" />
                <svg class="svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M10 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16Zm11 3-6-6" />
                </svg>
            </div>
            <div class="avatar" title="Account">CK</div>
        </div>
    </header>

    <main class="wrap">
        <section class="hero fadeIn">
            <div class="heroLeft">
                <div class="heroIcon" aria-hidden="true">
                    <svg class="svg" viewBox="0 0 24 24">
                        <path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm13 6H6v12h14V8ZM8 10h4v4H8v-4Z" />
                    </svg>
                </div>
                <div>
                    <h1 class="heroTitle">Schedule a meeting</h1>
                    <p class="heroSub">Book a Classic Academy / Classic Campus demo, onboarding, or support session.
                        Choose a date and time — we’ll send a Zoom + Google Calendar invite.</p>
                </div>
            </div>
            <div class="pillRow">
                <span class="pill">Zoom + Google Calendar</span>
                <span class="pill" id="tzPill">Africa/Kampala</span>
            </div>
        </section>

        <section class="layout">
            <!-- LEFT: Calendar -->
            <div class="card fadeIn">
                <div class="cardPad">
                    <div class="prefs" aria-label="Preferences">
                        <div class="pref">
                            <label for="product">Product</label>
                            <select id="product">
                                <option>Classic Academy</option>
                                <option>Classic Campus</option>
                                <option>Both</option>
                            </select>
                        </div>
                        <div class="pref">
                            <label for="purpose">Purpose</label>
                            <select id="purpose">
                                <option>Demo</option>
                                <option>Onboarding</option>
                                <option>Support</option>
                            </select>
                        </div>
                        <div class="pref">
                            <label for="duration">Duration</label>
                            <select id="duration">
                                <option value="30">30 minutes</option>
                                <option value="45">45 minutes</option>
                                <option value="60">60 minutes</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="calTop">
                    <div class="calMonth">
                        <div class="miniIcon" aria-hidden="true">
                            <svg class="svg" viewBox="0 0 24 24">
                                <path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm13 6H6v12h14V8Z" />
                            </svg>
                        </div>
                        <span id="monthTitle">—</span>
                    </div>
                    <div class="calNav">
                        <button class="iconBtn" id="prevMonth" type="button" aria-label="Previous month">‹</button>
                        <button class="iconBtn" id="nextMonth" type="button" aria-label="Next month">›</button>
                    </div>
                </div>

                <div class="dow" aria-hidden="true">
                    <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span>
                </div>

                <div class="calGridWrap">
                    <div class="colPill" id="colPill" aria-hidden="true"></div>
                    <div class="days" id="days"></div>
                </div>
            </div>

            <!-- MIDDLE -->
            <div class="card fadeIn">
                <div class="tabs" aria-label="Sections">
                    <div class="tab" id="tabOverview">Overview</div>
                    <div class="tab active" id="tabSchedule">Schedule</div>
                    <div class="tab" id="tabAgenda">Agenda</div>
                </div>

                <div class="pane" id="paneOverview">
                    <div class="midHead">Meeting overview</div>
                    <div class="overviewBox">
                        Quick summary of your selection and what happens next.
                        <div class="miniCard">
                            <div class="miniRow"><span>Session</span><strong id="ovMeta">—</strong></div>
                            <div class="miniRow" style="margin-top:6px"><span>Date & time</span><strong
                                    id="ovWhen">—</strong></div>
                            <div class="miniRow" style="margin-top:6px"><span>Timezone</span><strong
                                    id="ovTz">—</strong></div>
                        </div>
                    </div>
                </div>

                <div class="pane active" id="paneSchedule">
                    <div class="midHead" id="slotSub">Pick a time</div>
                    <div class="timeWrap">
                        <div class="timeGrid" id="slots"></div>
                    </div>
                    <div class="hint" id="slotHint">Select an available day to see times.</div>

                    <div class="midFoot">
                        <span style="display:flex;align-items:center;gap:8px">
                            <span
                                style="width:8px;height:8px;border-radius:999px;background:var(--ok);display:inline-block"></span>
                            Available
                            <span
                                style="width:8px;height:8px;border-radius:999px;background:#f97316;display:inline-block;margin-left:10px"></span>
                            Booked
                            <span
                                style="width:8px;height:8px;border-radius:999px;background:var(--past);display:inline-block;margin-left:10px"></span>
                            Past
                        </span>
                        <button class="link" id="refresh" type="button">Refresh</button>
                    </div>
                </div>

                <div class="pane" id="paneAgenda">
                    <div class="midHead">Add an agenda (optional)</div>
                    <div class="agendaBox">
                        Add topics/questions to help us prepare (optional).
                        <textarea id="agendaNotes" placeholder="Example:
• Pricing & rollout plan
• Data migration
• User roles & permissions
• Integrations (Google, SMS, etc.)"></textarea>
                    </div>
                </div>
            </div>

            <!-- RIGHT -->
            <aside class="side fadeIn">
                <div class="sidePad">
                    <div class="hostCard">
                        <div class="hostAvatar" aria-hidden="true">C</div>
                        <div class="hostMeta">
                            <div class="loc">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path
                                        d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7Zm0 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" />
                                </svg>
                                Kampala, Uganda
                            </div>
                            <div class="hostName">Classic Team</div>
                            <div class="hostRole">Academy / Campus Specialist</div>
                        </div>
                    </div>

                    <div class="details" aria-label="Selected details">
                        <div class="dRow">
                            <div class="dIcon" aria-hidden="true">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm13 6H6v12h14V8Z" />
                                </svg>
                            </div>
                            <div>
                                <div class="dValue" id="sumDate">—</div>
                                <div class="dLabel">Date</div>
                            </div>
                        </div>

                        <div class="dRow">
                            <div class="dIcon" aria-hidden="true">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path d="M12 2a10 10 0 1 1 0 20 10 10 0 0 1 0-20Zm1 5h-2v6l5 3 1-2-4-2V7Z" />
                                </svg>
                            </div>
                            <div>
                                <div class="dValue">
                                    <span id="sumTime">—</span>
                                    <small id="sumTz">GMT+3</small>
                                </div>
                                <div class="dLabel">Time</div>
                            </div>
                        </div>

                        <div class="dRow">
                            <div class="dIcon" aria-hidden="true">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm1 5h-2v6l5 3 1-2-4-2Z" />
                                </svg>
                            </div>
                            <div>
                                <div class="dValue"><span id="sumDur">—</span></div>
                                <div class="dLabel">Duration</div>
                            </div>
                        </div>

                        <div class="dRow">
                            <div class="dIcon" aria-hidden="true">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h10v2H4v-2Z" />
                                </svg>
                            </div>
                            <div>
                                <div class="dValue"><span id="sumMeta">Classic Academy • Demo</span></div>
                                <div class="dLabel">Session</div>
                            </div>
                        </div>
                    </div>

                    <form id="form" class="formCard" autocomplete="on">
                        <div id="fieldsWrap">
                            <div class="field">
                                <label for="company">Institution / Organization (optional)</label>
                                <input id="company" placeholder="School / University name" />
                            </div>

                            <div class="field">
                                <label for="name">Your name</label>
                                <input id="name" required placeholder="Full name" autocomplete="name" />
                            </div>

                            <div class="field">
                                <label for="email">Email</label>
                                <input id="email" required type="email" placeholder="you@school.org"
                                    autocomplete="email" />
                            </div>

                            <div class="field">
                                <label for="phone">Phone / WhatsApp (optional)</label>
                                <input id="phone" placeholder="+256 7XX XXX XXX" autocomplete="tel" />
                            </div>

                            <div class="field">
                                <label for="notes">Notes (optional)</label>
                                <textarea id="notes" placeholder="What do you want to cover?"></textarea>
                            </div>

                            <input id="hp" class="hp" tabindex="-1" autocomplete="off" />
                        </div>

                        <button id="bookBtn" class="joinBtn" type="submit" disabled>
                            Book Appointment <span aria-hidden="true">›</span>
                        </button>

                        <div class="status" id="status" role="status" aria-live="polite"></div>

                        <div class="successBox" id="success">
                            <h3>Booked ✅</h3>
                            <div id="successText" style="font-size:13px;opacity:.9"></div>
                            <div class="actions">
                                <a id="zoomJoin" class="btnOutline" target="_blank" rel="noreferrer">Join Zoom</a>
                                <a id="gcalLink" class="btnOutline" target="_blank" rel="noreferrer">Open Calendar</a>
