<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ✅ SEO -->
    <title>Schedule a Demo or Support Call | Classic Academy & Classic Campus</title>
    <meta name="description"
        content="Schedule a meeting with the Classic team for a demo, onboarding, or support for Classic Academy and Classic Campus. Pick a date, choose a time, and join via Zoom — with Google Calendar invite." />
    <meta name="keywords"
        content="Classic Academy, Classic Campus, schedule demo, onboarding meeting, support call, booking, Zoom meeting, Google Calendar invite, school ERP, university ERP, LMS, admissions" />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="/" />

    <!-- Open Graph -->
    <meta property="og:title" content="Schedule a Demo or Support Call | Classic Academy & Classic Campus" />
    <meta property="og:description"
        content="Book a meeting with the Classic team. Choose a date and time, receive a Zoom + Google Calendar invite, and join the meeting when it’s time." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="/" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schedule a Demo or Support Call | Classic Academy & Classic Campus" />
    <meta name="twitter:description"
        content="Book a meeting with the Classic team for demo, onboarding, or support. Zoom + Google Calendar invite included." />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg: #f6f7fb;
            --card: #ffffff;
            --text: #0f172a;
            --muted: #6b7280;
            --line: #e7ecf3;

            --primary: #2e2fa6;
            --primary2: #23248b;
            --primarySoft: #dfe9ff;
            --primaryInk: #1b1c6a;

            --yellow: #f2c94c;
            --yellow2: #ffd86b;

            --ok: #16a34a;
            --past: #cbd5e1;
            --danger: #b91c1c;

            --shadow: 0 18px 55px rgba(15, 23, 42, .10);
            --shadow2: 0 10px 26px rgba(15, 23, 42, .08);

            /* ✅ More rounded edges */
            --radius: 26px;
            --radiusMd: 20px;
            --radiusPill: 999px;

            --ring: 0 0 0 4px rgba(46, 47, 166, .14);
        }

        * {
            box-sizing: border-box
        }

        html,
        body {
            height: 100%
        }

        body {
            margin: 0;
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Arial;
            color: var(--text);
            background: var(--bg);
        }

        a {
            color: inherit;
            text-decoration: none
        }

        button,
        input,
        select,
        textarea {
            font: inherit
        }

        :focus-visible {
            outline: none;
            box-shadow: var(--ring);
            border-color: rgba(46, 47, 166, .35) !important;
        }

        /* ✅ Clean animations */
        @media (prefers-reduced-motion: reduce) {
            * {
                transition: none !important;
                animation: none !important;
                scroll-behavior: auto !important
            }
        }

        .fadeIn {
            animation: fade .35s ease both;
        }

        @keyframes fade {
            from {
                opacity: 0;
                transform: translateY(6px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* Top bar */
        .top {
            max-width: 1180px;
            margin: 0 auto;
            padding: 22px 18px 8px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px
        }

        .mark {
            width: 34px;
            height: 34px;
            border-radius: 999px;
            background: radial-gradient(circle at 35% 30%, #fff 0 25%, transparent 26% 100%),
                linear-gradient(135deg, var(--primary), #1f7ae0);
            box-shadow: 0 12px 26px rgba(46, 47, 166, .18);
            transform: translateZ(0);
        }

        .brandText {
            font-weight: 800;
            letter-spacing: -.02em;
            font-size: 22px;
            display: flex;
            gap: 6px;
            align-items: baseline;
        }

        .brandText span:last-child {
            color: var(--primary)
        }

        .navRight {
            display: flex;
            align-items: center;
            gap: 12px;
            color: var(--muted);
            font-size: 14px
        }

        .search {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border: 1px solid var(--line);
            border-radius: var(--radiusPill);
            background: #fff;
            box-shadow: var(--shadow2);
            min-width: 260px;
            transition: transform .14s ease, box-shadow .14s ease;
        }

        .search:focus-within {
            transform: translateY(-1px);
            box-shadow: var(--shadow)
        }

        .search input {
            border: 0;
            outline: none;
            width: 100%;
            font-size: 14px;
            color: var(--text)
        }

        .avatar {
            width: 42px;
            height: 42px;
            border-radius: var(--radiusPill);
            background: linear-gradient(135deg, #e8eefc, #cfe0ff);
            border: 1px solid var(--line);
            display: grid;
            place-items: center;
            box-shadow: var(--shadow2);
            color: var(--primaryInk);
            font-weight: 800;
        }

        .wrap {
            max-width: 1180px;
            margin: 0 auto;
            padding: 6px 18px 30px
        }

        /* Header */
        .hero {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            padding: 14px 0 18px;
        }

        .heroLeft {
            display: flex;
            gap: 14px;
            align-items: flex-start
        }

        .heroIcon {
            width: 48px;
            height: 48px;
            border-radius: var(--radiusMd);
            background: #fff;
            border: 1px solid var(--line);
            box-shadow: var(--shadow2);
            display: grid;
            place-items: center;
            color: var(--primary);
            flex: 0 0 auto;
        }

        .heroTitle {
            font-size: 36px;
            font-weight: 800;
            letter-spacing: -.03em;
            margin: 0;
            line-height: 1.1;
        }

        .heroSub {
            margin: 8px 0 0;
            color: var(--muted);
            font-size: 14px;
            max-width: 62ch
        }

        .pillRow {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: flex-end
        }

        .pill {
            font-size: 12px;
            padding: 7px 10px;
            border: 1px solid var(--line);
            border-radius: var(--radiusPill);
            background: #fff;
            color: var(--muted);
            box-shadow: var(--shadow2);
            white-space: nowrap;
        }

        /* Layout */
        .layout {
            display: grid;
            grid-template-columns: 1.05fr .82fr .95fr;
            gap: 18px;
            align-items: start;
        }

        /* Cards */
        .card {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }

        .cardPad {
            padding: 18px
        }

        /* ✅ Preferences (selects) */
        .prefs {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 14px;
        }

        .pref {
            display: grid;
            gap: 6px
        }

        .prefs label {
            font-size: 12px;
            color: var(--muted);
            font-weight: 700
        }

        .prefs select {
            width: 100%;
            border-radius: var(--radiusMd);
            padding: 12px 14px;
            border: 1px solid var(--line);
            background: #fff;
            box-shadow: var(--shadow2);
            outline: none;
            transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
            appearance: none;
            background-image:
                linear-gradient(45deg, transparent 50%, var(--muted) 50%),
                linear-gradient(135deg, var(--muted) 50%, transparent 50%),
                linear-gradient(to right, transparent, transparent);
            background-position:
                calc(100% - 18px) calc(50% - 4px),
                calc(100% - 12px) calc(50% - 4px),
                calc(100% - 2.6em) 0.5em;
            background-size: 6px 6px, 6px 6px, 1px 1.5em;
            background-repeat: no-repeat;
        }

        .prefs select:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow)
        }

        .prefs select:focus {
            border-color: rgba(46, 47, 166, .35)
        }

        /* Calendar */
        .calTop {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 18px 12px
        }

        .calMonth {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            letter-spacing: -.02em;
            font-size: 22px;
            color: var(--primaryInk)
        }

        .calMonth .miniIcon {
            width: 34px;
            height: 34px;
            border-radius: var(--radiusMd);
            background: #fff8db;
            border: 1px solid #fde7a2;
            display: grid;
            place-items: center;
            color: #a16207;
        }

        .calNav {
            display: flex;
            gap: 8px;
            align-items: center
        }

        .iconBtn {
            width: 40px;
            height: 40px;
            border-radius: var(--radiusPill);
            border: 1px solid var(--line);
            background: #fff;
            box-shadow: var(--shadow2);
            cursor: pointer;
            transition: transform .14s ease, box-shadow .14s ease;
        }

        .iconBtn:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow)
        }

        .iconBtn:active {
            transform: translateY(0)
        }

        .dow {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            padding: 6px 18px 10px;
            color: var(--muted);
            font-size: 12px;
            letter-spacing: .02em;
        }

        .dow span {
            text-align: center;
            padding: 10px 0;
            font-weight: 700
        }

        .calGridWrap {
            position: relative;
            padding: 0 18px 18px
        }

        .colPill {
            position: absolute;
            top: 0;
            bottom: 18px;
            left: 18px;
            border-radius: var(--radiusPill);
            background: #f3f5ff;
            opacity: 0;
            transform: translateX(0);
            transition: opacity .16s ease, transform .16s ease;
            pointer-events: none;
        }

        .days {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .day {
            border: 0;
            background: transparent;
            border-radius: var(--radiusMd);
            height: 44px;
            display: grid;
            place-items: center;
            cursor: pointer;
            color: var(--text);
            position: relative;
            user-select: none;
            transition: transform .14s ease, background .14s ease, box-shadow .14s ease;
        }

        .day:hover {
            background: rgba(15, 23, 42, .04);
            transform: translateY(-1px)
        }

        .day:active {
            transform: translateY(0)
        }

        .day.disabled {
            opacity: .35;
            cursor: not-allowed;
            transform: none !important;
            background: transparent !important
        }

        .day.today {
            outline: 2px solid rgba(46, 47, 166, .18)
        }

        .day.selected {
            background: var(--primary);
            color: #fff;
            box-shadow: 0 14px 28px rgba(46, 47, 166, .18);
        }

        .day .mini {
            position: absolute;
            bottom: -6px;
            width: 6px;
            height: 6px;
            border-radius: 999px;
            background: transparent;
        }

        .day.avail .mini {
            background: var(--ok)
        }

        .day.booked .mini {
            background: #f97316
        }

        .day.past .mini {
            background: var(--past)
        }

        .blank {
            visibility: hidden
        }

        /* Middle tabs */
        .tabs {
            display: flex;
            gap: 28px;
            padding: 18px 18px 8px;
            font-weight: 800;
            color: var(--muted);
            justify-content: center;
            user-select: none;
        }

        .tab {
            position: relative;
            padding-bottom: 10px;
            cursor: pointer;
            transition: color .14s ease, transform .14s ease;
        }

        .tab:hover {
            transform: translateY(-1px)
        }

        .tab.active {
            color: var(--text)
        }

        .tab.active:after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            height: 3px;
            border-radius: var(--radiusPill);
            background: var(--primary);
        }

        .pane {
            display: none
        }

        .pane.active {
            display: block
        }

        .midHead {
            text-align: center;
            padding: 18px 18px 6px;
            color: var(--muted);
            font-weight: 800
        }

        /* Times grid (2 cols, 3 on wide screens) */
        .timeWrap {
            padding: 10px 18px 18px;
        }

        .timeGrid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            align-items: center;
        }

        @media (min-width: 1280px) {
            .timeGrid {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }
        }

        .slot {
            width: 100%;
            border: 1px solid var(--line);
            background: #fff;
            border-radius: var(--radiusPill);
            padding: 12px 14px;
            font-weight: 800;
            color: var(--text);
            box-shadow: var(--shadow2);
            cursor: pointer;
            transition: transform .14s ease, border-color .14s ease, box-shadow .14s ease, background .14s ease;
            text-align: center;
        }

        .slot:hover {
            transform: translateY(-1px);
            border-color: rgba(46, 47, 166, .25);
            box-shadow: var(--shadow)
        }

        .slot:active {
            transform: translateY(0)
        }

        .slot.active {
            background: var(--primary);
            color: #fff;
            border-color: transparent;
            box-shadow: 0 16px 34px rgba(46, 47, 166, .22);
        }

        .hint {
            padding: 0 18px 18px;
            text-align: center;
            color: var(--muted);
            font-size: 12px;
            min-height: 16px;
        }

        .midFoot {
            border-top: 1px solid var(--line);
            padding: 14px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            color: var(--muted);
            font-size: 12px;
        }

        .link {
            border: 0;
            background: transparent;
            color: var(--primary);
            font-weight: 800;
            cursor: pointer;
            padding: 0;
            transition: transform .14s ease;
        }

        .link:hover {
            text-decoration: underline;
            transform: translateY(-1px)
        }

        .overviewBox,
        .agendaBox {
            padding: 14px 18px 18px;
            color: var(--muted);
            font-size: 13px;
            line-height: 1.6;
        }

        .miniCard {
            margin-top: 12px;
            border: 1px solid var(--line);
            background: #fff;
            border-radius: var(--radiusMd);
            box-shadow: var(--shadow2);
            padding: 12px;
            color: var(--text);
        }

        .miniRow {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            font-size: 12px;
            color: var(--muted)
        }

        .miniRow strong {
            color: var(--text)
        }

        .agendaBox textarea {
            width: 100%;
            border-radius: var(--radiusMd);
            padding: 12px 14px;
            border: 1px solid var(--line);
            outline: none;
            min-height: 130px;
            resize: vertical;
            margin-top: 10px;
            box-shadow: var(--shadow2);
            transition: box-shadow .14s ease, transform .14s ease;
        }

        .agendaBox textarea:focus {
            box-shadow: var(--shadow);
            transform: translateY(-1px)
        }

        /* Right panel */
        .side {
            border-radius: 30px;
            background: linear-gradient(180deg, var(--primary), var(--primary2));
            color: #fff;
            box-shadow: 0 24px 60px rgba(46, 47, 166, .24);
            border: 1px solid rgba(255, 255, 255, .10);
            overflow: hidden;
            position: sticky;
            top: 12px;
        }

        .sidePad {
            padding: 18px
        }

        .hostCard {
            background: var(--primarySoft);
            color: var(--primaryInk);
            border-radius: var(--radiusMd);
            padding: 14px;
            display: flex;
            gap: 12px;
            align-items: center;
            box-shadow: 0 18px 40px rgba(0, 0, 0, .10);
            margin-top: 12px;
        }

        .hostAvatar {
            width: 52px;
            height: 52px;
            border-radius: var(--radiusPill);
            background: linear-gradient(135deg, #fff, #cfe0ff);
            display: grid;
            place-items: center;
            font-weight: 800;
            color: var(--primaryInk);
            border: 1px solid rgba(46, 47, 166, .15);
            flex: 0 0 auto;
        }

        .hostMeta {
            display: grid;
            gap: 2px
        }

        .loc {
            font-size: 12px;
            color: rgba(27, 28, 106, .75);
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 800;
        }

        .hostName {
            font-weight: 900;
            letter-spacing: -.01em
        }

        .hostRole {
            font-size: 13px;
            color: rgba(27, 28, 106, .75);
            font-weight: 800
        }

        .details {
            margin-top: 18px;
            display: grid;
            gap: 14px
        }

        .dRow {
            display: grid;
            grid-template-columns: 44px 1fr;
            gap: 12px;
            align-items: center
        }

        .dIcon {
            width: 44px;
            height: 44px;
            border-radius: var(--radiusPill);
            border: 1px solid rgba(255, 255, 255, .18);
            background: rgba(255, 255, 255, .10);
            display: grid;
            place-items: center;
        }

        .dLabel {
            font-size: 12px;
            color: rgba(255, 255, 255, .72);
            margin-top: 2px;
            font-weight: 700
        }

        .dValue {
            font-weight: 900;
            letter-spacing: -.01em
        }

        .dValue small {
            font-weight: 800;
            color: rgba(255, 255, 255, .75);
            margin-left: 6px
        }

        /* Form area */
        .formCard {
            margin-top: 18px;
            background: rgba(255, 255, 255, .10);
            border: 1px solid rgba(255, 255, 255, .14);
            border-radius: var(--radiusMd);
            padding: 14px;
            backdrop-filter: blur(10px);
        }

        .field {
            display: grid;
            gap: 6px;
            margin-bottom: 10px
        }

        .field label {
            font-size: 12px;
            color: rgba(255, 255, 255, .82);
            font-weight: 800
        }

        .field input,
        .field textarea {
            width: 100%;
            border-radius: var(--radiusMd);
            padding: 12px 14px;
            border: 1px solid rgba(255, 255, 255, .18);
            background: rgba(255, 255, 255, .14);
            color: #fff;
            outline: none;
            transition: transform .14s ease, box-shadow .14s ease;
        }

        .field input::placeholder,
        .field textarea::placeholder {
            color: rgba(255, 255, 255, .65)
        }

        .field input:focus,
        .field textarea:focus {
            transform: translateY(-1px);
            box-shadow: 0 0 0 4px rgba(255, 255, 255, .10)
        }

        .field textarea {
            min-height: 80px;
            resize: vertical
        }

        .hp {
            display: none !important
        }

        /* CTA (Book -> Join Meeting) */
        .joinBtn {
            margin-top: 14px;
            width: 100%;
            border: 0;
            border-radius: var(--radiusPill);
            padding: 14px 16px;
            background: linear-gradient(135deg, var(--yellow), var(--yellow2));
            color: #2b2b2b;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 18px 34px rgba(0, 0, 0, .18);
            transition: transform .14s ease, filter .14s ease, opacity .14s ease;
        }

        .joinBtn:hover {
            transform: translateY(-1px);
            filter: brightness(1.02)
        }

        .joinBtn:active {
            transform: translateY(0)
        }

        .joinBtn:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none
        }

        .status {
            margin-top: 10px;
            font-size: 12px;
            color: rgba(255, 255, 255, .86);
            min-height: 16px;
            font-weight: 700;
        }

        .status.error {
            color: #ffd1d1
        }

        .successBox {
            margin-top: 12px;
            background: rgba(255, 255, 255, .10);
            border: 1px solid rgba(255, 255, 255, .14);
            border-radius: var(--radiusMd);
            padding: 14px;
            display: none;
        }

        .successBox h3 {
            margin: 0 0 6px
        }

        .actions {
            margin-top: 10px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap
        }

        .btnOutline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 12px;
            border-radius: var(--radiusPill);
            border: 1px solid rgba(255, 255, 255, .22);
            background: rgba(255, 255, 255, .10);
            color: #fff;
            font-weight: 900;
            transition: transform .14s ease, border-color .14s ease;
        }

        .btnOutline:hover {
            border-color: rgba(255, 255, 255, .35);
            transform: translateY(-1px)
        }

        .btnOutline:active {
            transform: translateY(0)
        }

        .bookAnother {
            margin-top: 10px;
            display: inline-block;
            color: rgba(255, 255, 255, .92);
            font-size: 12px;
            font-weight: 900;
            text-decoration: underline;
            cursor: pointer;
        }

        .svg {
            width: 18px;
            height: 18px;
            fill: currentColor;
            opacity: .92
        }

        /* ✅ Responsive: headings + selects become 2 columns on phone */
        @media (max-width: 1060px) {
            .layout {
                grid-template-columns: 1fr
            }

            .side {
                position: static
            }

            .search {
                display: none
            }
        }

        @media (max-width: 640px) {
            .top {
                padding: 16px 14px 8px
            }

            .wrap {
                padding: 6px 14px 26px
            }

            .hero {
                padding: 10px 0 14px
            }

            .heroTitle {
                font-size: 26px;
                line-height: 1.08
            }

            .heroSub {
                font-size: 13px
            }

            .brandText {
                font-size: 20px
            }

            /* ✅ 2 columns for selects on phone */
            .prefs {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .prefs .pref:last-child {
                grid-column: 1 / -1;
                /* duration takes full width (2 rows total) */
            }

            /* calendar spacing */
            .days {
                gap: 10px
            }
        }

        @media (max-width: 420px) {

            /* ✅ Optionally 1 column for very small phones */
            .prefs {
                grid-template-columns: 1fr
            }

            .prefs .pref:last-child {
                grid-column: auto
            }

            .heroTitle {
                font-size: 24px
            }
        }
    </style>

    <!-- ✅ Structured data (SEO) -->
    <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Schedule a Demo or Support Call | Classic Academy & Classic Campus",
