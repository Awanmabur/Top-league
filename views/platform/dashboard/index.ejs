<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title><%= dashboardMeta?.title || "Platform Dashboard" %> - Classic Academy</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;color:#0f172a}
    *{box-sizing:border-box;min-width:0}.main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
    .title{font-size:24px;font-weight:800;color:#083454}.subtitle{font-size:13px;color:#6b7280;line-height:1.6;max-width:70ch}
    .grid{display:grid;gap:14px}.grid-4{grid-template-columns:repeat(4,minmax(0,1fr))}.grid-2{grid-template-columns:minmax(0,2fr) minmax(0,1fr)}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .kpi-label{font-size:12px;color:#64748b}.kpi-value{font-size:24px;font-weight:800;color:#083454;margin-top:6px}.kpi-note{font-size:12px;color:#64748b;margin-top:6px}
    .section-title{font-size:16px;font-weight:800;color:#083454}.section-sub{font-size:13px;color:#6b7280;line-height:1.6}
    .modules{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-top:14px}
    .module{display:flex;flex-direction:column;gap:8px;padding:14px;border-radius:12px;border:1px solid #e2ebff;background:#fbfdff;text-decoration:none;color:#0f172a}
    .module:hover{border-color:#cbdafe;box-shadow:0 10px 24px rgba(15,23,42,.08)}.module i{color:#0a6fbf;font-size:18px}
    .module-title{font-size:15px;font-weight:800}.module-meta{font-size:12px;color:#64748b}
    .pill-row,.shortcut-list,.list{display:flex;flex-wrap:wrap;gap:10px}.pill{display:inline-flex;align-items:center;gap:8px;padding:10px 12px;border-radius:999px;background:#eef4ff;color:#0a3d62;font-size:13px;font-weight:700}
    .shortcut{display:inline-flex;align-items:center;gap:8px;padding:10px 12px;border-radius:10px;background:#0a3d62;color:#fff;text-decoration:none;font-weight:700}
    .list{flex-direction:column;margin-top:12px}.list-item{display:flex;justify-content:space-between;gap:12px;padding:10px 0;border-bottom:1px solid #edf2ff;font-size:13px}.list-item:last-child{border-bottom:none}
    .muted{color:#64748b}.alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    @media (max-width:1100px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.grid-2{grid-template-columns:1fr}}
    @media (max-width:700px){.main{padding:16px}.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.modules{grid-template-columns:repeat(2,minmax(0,1fr))}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div class="topbar">
      <div>
        <div class="title"><%= dashboardMeta?.title || "Platform Dashboard" %></div>
        <div class="subtitle"><%= dashboardMeta?.subtitle || "" %></div>
      </div>
      <div class="pill-row">
        <span class="pill"><i class="fa-solid fa-user-shield"></i> <%= user?.role || "Platform User" %></span>
        <span class="pill"><i class="fa-solid fa-building-columns"></i> <%= stats?.tenantCount || 0 %> schools</span>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <section class="grid grid-4">
      <% (focusCards || []).forEach(function(card) { %>
        <article class="card">
          <div class="kpi-label"><%= card.label %></div>
          <div class="kpi-value"><%= card.value %></div>
          <div class="kpi-note"><%= card.note %></div>
        </article>
      <% }) %>
    </section>

    <section class="grid grid-2">
      <section class="card">
        <div class="section-title">Workspace</div>
        <div class="section-sub">Only the modules available to your role are shown here.</div>

        <div class="modules">
          <% modules.forEach(function(module) { %>
            <a class="module" href="<%= module.href %>">
              <i class="fa-solid <%= module.icon %>"></i>
              <div class="module-title"><%= module.title %></div>
              <div><%= module.description %></div>
              <div class="module-meta"><%= module.meta %></div>
            </a>
          <% }) %>
        </div>
      </section>

      <aside class="card">
        <div class="section-title">Quick Actions</div>
        <div class="section-sub">Shortcuts for the things your role can do right now.</div>

        <div class="shortcut-list" style="margin-top:14px;">
          <% if (shortcuts.length) { %>
            <% shortcuts.forEach(function(shortcut) { %>
              <a class="shortcut" href="<%= shortcut.href %>">
                <i class="fa-solid <%= shortcut.icon %>"></i>
                <span><%= shortcut.label %></span>
              </a>
            <% }) %>
          <% } else { %>
            <div class="muted">No write actions are available for this role.</div>
          <% } %>
        </div>

        <div style="margin-top:18px;">
          <div class="section-title">Recent Schools</div>
          <div class="list">
            <% if (recentTenants?.length) { %>
              <% recentTenants.forEach(function(tenant) { %>
                <div class="list-item">
                  <span><strong><%= tenant.name %></strong><br><span class="muted"><%= tenant.code %></span></span>
                  <span class="muted"><%= tenant.planId?.name || "No plan" %> - <%= tenant.status %></span>
                </div>
              <% }) %>
            <% } else { %>
              <div class="muted">No schools found yet.</div>
            <% } %>
          </div>
        </div>
      </aside>
    </section>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>
