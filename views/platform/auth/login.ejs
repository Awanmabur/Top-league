<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Login - Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>

  <style>
    :root{
      --blue:#0a3d62; --blue2:#083454; --accent:#0a6fbf;
      --bg:#f4f8ff; --card:#fff; --muted:#6b7280; --text:#0f172a;
      --danger:#ef4444; --success:#16a34a; --line:rgba(13,64,96,.12);
      --radius:18px; --shadow:0 12px 40px rgba(0,0,0,.10);
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}
    a{text-decoration:none;color:inherit}
    .wrap{min-height:100vh;display:grid;place-items:center;padding:18px}
    .shell{width:min(1000px,100%);display:grid;grid-template-columns:1.05fr .95fr;gap:14px}
    .panel{
      border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);
      border:1px solid var(--line);background:var(--card);
    }
    .hero{
      background:linear-gradient(135deg,var(--blue),var(--blue2));
      color:#fff;padding:26px;display:flex;flex-direction:column;justify-content:space-between;
      min-height:520px;
    }
    .brand{display:flex;gap:12px;align-items:center}
    .logo{width:48px;height:48px;border-radius:16px;background:rgba(255,255,255,.14);display:grid;place-items:center;font-weight:1000}
    .brand h1{margin:0;font-size:18px}
    .brand p{margin:2px 0 0;font-size:12px;opacity:.8}
    .hero h2{margin:18px 0 6px;font-size:24px;line-height:1.1}
    .hero .desc{margin:0;color:rgba(255,255,255,.85);font-size:13px;max-width:45ch}
    .hero .bullets{margin:18px 0 0;padding:0;list-style:none;display:grid;gap:10px}
    .hero .bullets li{display:flex;gap:10px;align-items:flex-start;font-size:13px;color:rgba(255,255,255,.9)}
    .badge{display:inline-flex;gap:8px;align-items:center;padding:8px 12px;border-radius:999px;
      background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);font-weight:900;font-size:12px;width:max-content
    }

    .form{padding:22px}
    .form h3{margin:0;font-size:18px}
    .muted{color:var(--muted);font-size:12px;margin-top:6px}
    .grid{display:grid;gap:12px;margin-top:16px}
    label{font-size:12px;color:var(--muted);font-weight:800}
    .field{display:grid;gap:6px}
    .input{
      padding:11px 12px;border-radius:14px;border:1px solid var(--line);background:#fff;outline:none;
      display:flex;gap:10px;align-items:center;
    }
    .input input{border:none;outline:none;width:100%;font:inherit;background:transparent}
    .input:focus-within{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .icon{width:18px;text-align:center;color:rgba(15,23,42,.55)}
    .btn{
      border:none;border-radius:14px;padding:11px 12px;font-weight:1000;cursor:pointer;
      display:inline-flex;gap:10px;align-items:center;justify-content:center
    }
    .btn.primary{background:var(--accent);color:#fff}
    .btn.light{background:#fff;border:1px solid var(--line);color:var(--text)}
    .row{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap}
    .help a{color:var(--accent);font-weight:900;font-size:12px}
    .tiny{font-size:12px;color:var(--muted)}
    .err{display:none;color:#b91c1c;font-size:12px;font-weight:900;margin-top:6px}
    .ok{display:none;color:#15803d;font-size:12px;font-weight:900;margin-top:6px}

    @media(max-width:920px){
      .shell{grid-template-columns:1fr}
      .hero{min-height:unset}
    }
  </style>
</head>
<body>
<div class="wrap">
  <div class="shell">
    <section class="panel hero">
      <div>
        <div class="brand">
          <div class="logo">CS</div>
          <div>
            <h1>Classic Academy</h1>
            <p>Platform Administration</p>
          </div>
        </div>

        <h2>Welcome back</h2>
        <p class="desc">Login to manage schools, plans, billing, support, and platform operations.</p>

        <ul class="bullets">
          <li><i class="fa-solid fa-shield-halved"></i><span>Secure access with role-based permissions</span></li>
          <li><i class="fa-solid fa-bell"></i><span>Notifications, alerts, approvals and audit trail</span></li>
          <li><i class="fa-solid fa-chart-line"></i><span>Reports and dashboards across departments</span></li>
        </ul>
      </div>

      <div class="badge"><i class="fa-solid fa-lock"></i> Secure platform access</div>
    </section>

    <section class="panel form">
      <h3>Login</h3>
      <div class="muted">Use your email and password. If you forgot your password, reset it below.</div>
      <% if (error) { %>
        <p style="color:red;"><%= error %></p>
      <% } %>

      <form method="post" action="/login" id="loginForm" class="grid" novalidate>
        <% if (typeof csrfToken !== "undefined" && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <% } %>
        <div class="field">
          <label>Email</label>
          <div class="input">
            <i class="fa-solid fa-user icon"></i>
            <input id="loginId" type="text" name="email" placeholder="email@example.com" autocomplete="username" required/>
          </div>
          <div class="err" id="errId">Please enter your email.</div>
        </div>

        <div class="field">
          <label>Password</label>
          <div class="input">
            <i class="fa-solid fa-key icon"></i>
            <input id="password" type="password" name="password" placeholder="Password" autocomplete="current-password" required/>
            <button type="button" class="btn light" id="togglePw" style="padding:8px 10px;border-radius:12px">
              <i class="fa-regular fa-eye"></i>
            </button>
          </div>
          <div class="err" id="errPw">Password is required.</div>
        </div>

        <div class="row">
          <label style="display:flex;gap:8px;align-items:center;margin:0">
            <input type="checkbox" id="remember"/> <span class="tiny">Remember me</span>
          </label>
          <div class="help"><a href="/forgot-password">Forgot password?</a></div>
        </div>

        <button class="btn primary" type="submit"><i class="fa-solid fa-right-to-bracket"></i> Login</button>
      </form>
    </section>
  </div>
</div>

<script>
  const $ = (id)=>document.getElementById(id);

  $('togglePw').addEventListener('click',()=>{
    const pw=$('password');
    pw.type = pw.type === 'password' ? 'text' : 'password';
    $('togglePw').innerHTML = pw.type === 'password'
      ? '<i class="fa-regular fa-eye"></i>'
      : '<i class="fa-regular fa-eye-slash"></i>';
  });

  $('loginForm').addEventListener('submit',(e)=>{
    const id=$('loginId').value.trim();
    const pw=$('password').value.trim();

    $('errId').style.display = id ? 'none' : 'block';
    $('errPw').style.display = pw ? 'none' : 'block';

    if(!id || !pw) e.preventDefault();
  });
</script>
</body>
</html>
