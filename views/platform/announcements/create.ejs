<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Create Announcement — Classic Academy</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .title{font-size:20px;font-weight:700;color:#083454}
    .subtitle{font-size:13px;color:#6b7280;line-height:1.5}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .form-group{display:flex;flex-direction:column;gap:7px}
    .full{grid-column:1/-1}
    label{font-size:13px;font-weight:700;color:#334155}
    input,select,textarea{width:100%;border:1px solid #dbe3f6;border-radius:10px;padding:11px 12px;background:#fff;font:inherit}
    textarea{min-height:180px}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}
    .btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div>
      <div class="title">Create Announcement</div>
      <div class="subtitle">Send platform-wide messages to all or selected schools.</div>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="alert" style="margin-bottom:14px;"><%= error %></div>
      <% } %>

      <form action="/super-admin/announcements/create" method="POST" class="form-grid">
        <div class="form-group full">
          <label>Title</label>
          <input type="text" name="title" value="<%= old?.title || '' %>" required />
        </div>

        <div class="form-group full">
          <label>Body</label>
          <textarea name="body" required><%= old?.body || '' %></textarea>
        </div>

        <div class="form-group">
          <label>Audience</label>
          <select name="audience">
            <option value="all">All</option>
            <option value="active">Active</option>
            <option value="trial">Trial</option>
            <option value="suspended">Suspended</option>
            <option value="custom">Custom</option>
          </select>
        </div>

        <div class="form-group">
          <label>Channel</label>
          <select name="channel">
            <option value="dashboard">Dashboard</option>
            <option value="email">Email</option>
            <option value="sms">SMS</option>
            <option value="mixed">Mixed</option>
          </select>
        </div>

        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="draft">Draft</option>
            <option value="scheduled">Scheduled</option>
            <option value="published">Published</option>
          </select>
        </div>

        <div class="form-group">
          <label>Publish At</label>
          <input type="datetime-local" name="publishAt" value="<%= old?.publishAt || '' %>" />
        </div>

        <div class="form-group full">
          <label>Target Schools (for custom audience)</label>
          <select name="tenantIds" multiple size="8">
            <% (tenants || []).forEach(function(tenant){ %>
              <option value="<%= tenant._id %>"><%= tenant.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label>Expires At</label>
          <input type="datetime-local" name="expiresAt" value="<%= old?.expiresAt || '' %>" />
        </div>

        <div class="form-group">
          <label style="display:flex;align-items:center;gap:8px;">
            <input type="checkbox" name="pinned" <%= old?.pinned ? 'checked' : '' %> />
            Pin announcement
          </label>
        </div>

        <div class="form-group full">
          <button type="submit" class="btn primary">Save Announcement</button>
        </div>
      </form>
    </div>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>
