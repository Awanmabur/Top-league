<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Announcement Details — Classic Academy</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .title{font-size:22px;font-weight:800;color:#083454}
    .meta{font-size:12px;color:#6b7280;line-height:1.6}
    .bodycopy{font-size:14px;color:#334155;line-height:1.75;white-space:pre-wrap}
    .badge{display:inline-flex;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:800}
    .green{background:#e6f9ee;color:#166534}
    .amber{background:#fffbeb;color:#b45309}
    .gray{background:#f1f5f9;color:#475569}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px}
    .actions{display:flex;gap:10px;flex-wrap:wrap}
    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{padding:6px 10px;border-radius:999px;background:#f1f5f9;color:#334155;font-size:12px}
    @media (max-width:900px){.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <% if (announcement) { %>
      <div class="card">
        <div style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap;">
          <div>
            <div class="title"><%= announcement.title %></div>
            <div class="meta">
              Audience: <%= announcement.audience %> • Channel: <%= announcement.channel %> •
              Created: <%= announcement.createdAt ? new Date(announcement.createdAt).toLocaleString() : '—' %>
            </div>
          </div>
          <span class="badge <%= announcement.status === 'published' ? 'green' : announcement.status === 'scheduled' ? 'amber' : 'gray' %>"><%= announcement.status %></span>
        </div>

        <div class="bodycopy" style="margin-top:16px;"><%= announcement.body %></div>

        <% if (announcement.tenantIds && announcement.tenantIds.length) { %>
          <div style="margin-top:16px;">
            <div class="meta" style="margin-bottom:8px;">Target Schools</div>
            <div class="chips">
              <% announcement.tenantIds.forEach(function(t){ %>
                <span class="chip"><%= t.name || t._id %></span>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="actions" style="margin-top:16px;">
          <% if (announcement.status !== 'published') { %>
            <form action="/super-admin/announcements/<%= announcement._id %>/publish" method="POST">
              <button class="btn" type="submit">Publish</button>
            </form>
          <% } %>
          <a href="/super-admin/announcements" class="btn">Back</a>
        </div>
      </div>
    <% } %>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>
