<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Audit Log Details — Classic Academy</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .title{font-size:20px;font-weight:800;color:#083454}
    .grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .meta-label{font-size:12px;color:#6b7280}
    .meta-value{font-size:14px;font-weight:600;color:#0f172a;margin-top:4px;line-height:1.5}
    .code-box{background:#0f172a;color:#e2e8f0;padding:12px;border-radius:10px;font-size:13px;overflow:auto;white-space:pre-wrap}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px}
    @media (max-width:900px){.grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <% if (log) { %>
      <div class="card">
        <div class="title">Audit Log Details</div>

        <div class="grid" style="margin-top:16px;">
          <div><div class="meta-label">Action</div><div class="meta-value"><%= log.action %></div></div>
          <div><div class="meta-label">Created At</div><div class="meta-value"><%= log.createdAt ? new Date(log.createdAt).toLocaleString() : '—' %></div></div>
          <div><div class="meta-label">Actor</div><div class="meta-value"><%= log.actorName || '—' %></div></div>
          <div><div class="meta-label">Actor Role</div><div class="meta-value"><%= log.actorRole || '—' %></div></div>
          <div><div class="meta-label">Entity Type</div><div class="meta-value"><%= log.entityType || '—' %></div></div>
          <div><div class="meta-label">Entity ID</div><div class="meta-value"><%= log.entityId || '—' %></div></div>
          <div><div class="meta-label">Tenant ID</div><div class="meta-value"><%= log.tenantId || '—' %></div></div>
          <div><div class="meta-label">IP Address</div><div class="meta-value"><%= log.ipAddress || '—' %></div></div>
        </div>

        <div style="margin-top:16px;">
          <div class="meta-label">Description</div>
          <div class="meta-value"><%= log.description || '—' %></div>
        </div>

        <div style="margin-top:16px;">
          <div class="meta-label">Meta</div>
          <div class="code-box"><%= JSON.stringify(log.meta || {}, null, 2) %></div>
        </div>

        <div style="margin-top:16px;">
          <a href="/super-admin/audit-logs" class="btn">Back to Audit Logs</a>
        </div>
      </div>
    <% } %>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>