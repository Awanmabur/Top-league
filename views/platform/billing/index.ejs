<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Billing & Subscriptions — Classic Academy</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
    .title{font-size:20px;font-weight:700;color:#083454}
    .subtitle{font-size:13px;color:#6b7280;line-height:1.5}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px}
    .btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}
    .card{background:#fff;border-radius:12px;padding:14px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .table-wrap{overflow:auto}
    table{width:100%;border-collapse:collapse;min-width:980px}
    th,td{padding:12px 10px;border-bottom:1px solid #edf2ff;text-align:left;font-size:13px}
    th{font-size:12px;text-transform:uppercase;color:#6b7280}
    .badge{display:inline-flex;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:800}
    .green{background:#e6f9ee;color:#166534}
    .amber{background:#fffbeb;color:#b45309}
    .red{background:#fff1f2;color:#b91c1c}
    .section-title{font-size:14px;font-weight:700;color:#083454}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    @media (max-width:900px){.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Billing & Subscriptions</div>
        <div class="subtitle">Manage school subscriptions and review recent platform payments.</div>
      </div>
      <div>
        <a href="/super-admin/billing/payments/create" class="btn primary"><i class="fa-solid fa-receipt"></i> Record Payment</a>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <div class="card">
      <div class="section-title">Schools & Plans</div>
      <div class="table-wrap" style="margin-top:12px;">
        <table>
          <thead>
            <tr>
              <th>School</th>
              <th>Plan</th>
              <th>Status</th>
              <th>Owner Email</th>
              <th>Currency</th>
              <th>Subdomain</th>
            </tr>
          </thead>
          <tbody>
            <% (tenants || []).forEach(function(tenant){ %>
              <tr>
                <td><%= tenant.name %></td>
                <td><%= tenant.planId?.name || '—' %></td>
                <td><span class="badge <%= tenant.status === 'active' ? 'green' : tenant.status === 'trial' ? 'amber' : 'red' %>"><%= tenant.status %></span></td>
                <td><%= tenant.ownerEmail || '—' %></td>
                <td><%= tenant.currency || 'USD' %></td>
                <td><%= tenant.subdomain || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="section-title">Recent Payments</div>
      <div class="table-wrap" style="margin-top:12px;">
        <table>
          <thead>
            <tr>
              <th>School</th>
              <th>Type</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Reference</th>
              <th>Provider</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            <% (recentPayments || []).forEach(function(payment){ %>
              <tr>
                <td><%= payment.tenantId?.name || '—' %></td>
                <td><%= payment.type %></td>
                <td><%= Number(payment.amount || 0).toLocaleString() %> <%= payment.currency || 'USD' %></td>
                <td><span class="badge <%= payment.status === 'completed' ? 'green' : payment.status === 'pending' ? 'amber' : 'red' %>"><%= payment.status %></span></td>
                <td><%= payment.reference || '—' %></td>
                <td><%= payment.provider || 'manual' %></td>
                <td><%= payment.createdAt ? new Date(payment.createdAt).toLocaleString() : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>