<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Add University — Classic Campus</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .title{font-size:20px;font-weight:700;color:#083454}
    .subtitle{font-size:13px;color:#6b7280;line-height:1.5;margin-top:4px}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .section-title{font-size:14px;font-weight:800;color:#0a3d62;margin-bottom:10px}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .form-group{display:flex;flex-direction:column;gap:7px}
    .full{grid-column:1 / -1}
    label{font-size:13px;font-weight:700;color:#334155}
    input,select{width:100%;border:1px solid #dbe3f6;border-radius:10px;padding:11px 12px;background:#fff;font:inherit}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}
    .btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    .help{font-size:12px;color:#6b7280}
    .actions{display:flex;gap:10px;flex-wrap:wrap}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div>
      <div class="title">Add University</div>
      <div class="subtitle">Provision a new tenant university, assign a plan, and send the first admin invitation email.</div>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="alert" style="margin-bottom:14px;"><%= error %></div>
      <% } %>

      <form action="/super-admin/universities/create" method="POST" class="form-grid">
        <div class="full section-title">University Details</div>

        <div class="form-group">
          <label>University Name</label>
          <input type="text" name="name" value="<%= old?.name || '' %>" required />
        </div>

        <div class="form-group">
          <label>Code</label>
          <input type="text" name="code" value="<%= old?.code || '' %>" required />
          <div class="help">Used for the subdomain and tenant database name.</div>
        </div>

        <div class="form-group">
          <label>Country</label>
          <input type="text" name="country" value="<%= old?.country || '' %>" />
        </div>

        <div class="form-group">
          <label>Custom Domain</label>
          <input type="text" name="customDomain" value="<%= old?.customDomain || '' %>" />
        </div>

        <div class="form-group">
          <label>Timezone</label>
          <input type="text" name="timezone" value="<%= old?.timezone || 'Africa/Kampala' %>" />
        </div>

        <div class="form-group">
          <label>Currency</label>
          <input type="text" name="currency" value="<%= old?.currency || 'USD' %>" />
        </div>

        <div class="full section-title" style="margin-top:8px;">Admin / Owner Details</div>

        <div class="form-group">
          <label>Owner Name</label>
          <input type="text" name="ownerName" value="<%= old?.ownerName || '' %>" required />
        </div>

        <div class="form-group">
          <label>Owner Email</label>
          <input type="email" name="ownerEmail" value="<%= old?.ownerEmail || '' %>" required />
        </div>

        <div class="form-group">
          <label>Owner Phone</label>
          <input type="text" name="ownerPhone" value="<%= old?.ownerPhone || '' %>" />
        </div>

        <div class="form-group">
          <label>Trial Ends At</label>
          <input type="date" name="trialEndsAt" value="<%= old?.trialEndsAt || '' %>" />
        </div>

        <div class="full section-title" style="margin-top:8px;">Plan & Status</div>

        <div class="form-group">
          <label>Plan</label>
          <select name="planId" required>
            <option value="">Select plan</option>
            <% (plans || []).forEach(function(plan){ %>
              <option value="<%= plan._id %>" <%= String(old?.planId || '') === String(plan._id) ? 'selected' : '' %>><%= plan.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label>Status</label>
          <select name="status">
            <option value="trial" <%= old?.status === 'trial' ? 'selected' : '' %>>Trial</option>
            <option value="active" <%= old?.status === 'active' ? 'selected' : '' %>>Active</option>
            <option value="suspended" <%= old?.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
            <option value="cancelled" <%= old?.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>

        <div class="form-group full">
          <div class="help">
            The school admin will receive an email invite to set their password. No password will be shown after creation.
          </div>
        </div>

        <div class="form-group full">
          <div class="actions">
            <button type="submit" class="btn primary">
              <i class="fa-solid fa-building-circle-plus"></i> Create University
            </button>
            <a href="/super-admin/universities" class="btn">Cancel</a>
          </div>
        </div>
      </form>
    </div>
  </main>

  <script src="/js/navbar.js"></script>
</body>
</html>