<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
    <title>University Created — Classic Campus</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="/css/navbar.css" />
    <style>
        body {
            margin: 0;
            background: #f5f8ff;
            font-family: Poppins, Segoe UI, Arial, sans-serif;
            color: #0f172a;
            overflow-x: hidden
        }

        * {
            box-sizing: border-box;
            min-width: 0
        }

        .main {
            flex: 1;
            padding: 20px 26px;
            display: flex;
            flex-direction: column;
            gap: 16px
        }

        .card {
            background: #fff;
            border-radius: 12px;
            padding: 18px;
            border: 1px solid #e4ecfb;
            box-shadow: 0 6px 18px rgba(12, 38, 73, .04)
        }

        .title {
            font-size: 22px;
            font-weight: 800;
            color: #083454
        }

        .subtitle {
            font-size: 13px;
            color: #6b7280;
            line-height: 1.6
        }

        .alert {
            padding: 12px 14px;
            border-radius: 10px;
            background: #ecfdf5;
            color: #166534;
            border: 1px solid #bbf7d0
        }

        .code-box {
            background: #0f172a;
            color: #e2e8f0;
            padding: 12px;
            border-radius: 10px;
            font-size: 13px;
            overflow: auto
        }

        .actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap
        }

        .btn {
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid #dbe3f6;
            background: #eef4ff;
            color: #0a3d62;
            text-decoration: none;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            cursor: pointer
        }

        .btn.primary {
            background: #0a3d62;
            color: #fff;
            border-color: #0a3d62
        }

        .btn.secondary {
            background: #fff;
            color: #0a3d62
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px
        }

        .meta-label {
            font-size: 12px;
            color: #6b7280
        }

        .meta-value {
            font-size: 14px;
            font-weight: 600;
            color: #0f172a;
            margin-top: 4px
        }

        form.inline {
            display: inline
        }

        @media (max-width:900px) {
            .grid {
                grid-template-columns: 1fr
            }

            .main {
                padding: 16px
            }
        }
    </style>
</head>

<body>
    <%- include("./navbar") %>

        <main class="main">
            <div class="card">
                <div class="alert">
                    University created successfully and admin invitation email sent.
                </div>

                <div class="title" style="margin-top:14px;">
                    <%= tenant?.name || "University Created" %>
                </div>
                <div class="subtitle">
                    The school admin should check their email and use the secure link to set a password and activate
                    access.
                </div>

                <div class="grid" style="margin-top:16px;">
                    <div>
                        <div class="meta-label">University</div>
                        <div class="meta-value">
                            <%= tenant?.name || "—" %>
                        </div>
                    </div>
                    <div>
                        <div class="meta-label">Code</div>
                        <div class="meta-value">
                            <%= tenant?.code || "—" %>
                        </div>
                    </div>
                    <div>
                        <div class="meta-label">Invited Admin Email</div>
                        <div class="meta-value">
                            <%= invitedEmail || tenant?.ownerEmail || "—" %>
                        </div>
                    </div>
                    <div>
                        <div class="meta-label">Invitation Status</div>
                        <div class="meta-value">
                            <%= inviteSent ? "Sent" : "Pending" %>
                        </div>
                    </div>
                </div>

                <div style="margin-top:16px;">
                    <div class="meta-label">Login URL</div>
                    <div class="code-box">
                        <%= loginUrl || "—" %>
                    </div>
                </div>

                <div style="margin-top:16px;">
                    <div class="meta-label">Next Step</div>
                    <div class="subtitle" style="margin-top:6px;">
                        No password is shown here. The invited admin will create their own password from the email setup
                        link.
                    </div>
                </div>

                <div class="actions" style="margin-top:16px;">
                    <a href="/super-admin/universities" class="btn">
                        <i class="fa-solid fa-arrow-left"></i>
                        Back to Universities
                    </a>

                    <a href="/super-admin/universities/<%= tenant?._id %>" class="btn primary">
                        <i class="fa-solid fa-building"></i>
                        View University
                    </a>

                    <form action="/super-admin/universities/<%= tenant?._id %>/resend-invite" method="POST"
                        class="inline">
                        <button type="submit" class="btn secondary">
                            <i class="fa-solid fa-paper-plane"></i>
                            Resend Invite
                        </button>
                    </form>
                </div>
            </div>
        </main>

        <script src="/js/navbar.js"></script>
</body>

</html>