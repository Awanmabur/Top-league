<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>University Details — Classic Campus</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}
    .title{font-size:20px;font-weight:700;color:#083454}
    .subtitle{font-size:13px;color:#6b7280;line-height:1.5}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .meta-label{font-size:12px;color:#6b7280}
    .meta-value{font-size:14px;font-weight:600;color:#0f172a;margin-top:4px;line-height:1.45;word-break:break-word}
    .badge{display:inline-flex;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:800;text-transform:capitalize}
    .green{background:#e6f9ee;color:#166534}
    .amber{background:#fffbeb;color:#b45309}
    .red{background:#fff1f2;color:#b91c1c}
    .gray{background:#f1f5f9;color:#475569}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}
    .btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}
    .btn.warn{background:#fff;color:#0a3d62}
    .actions{display:flex;gap:10px;flex-wrap:wrap}
    .alert{padding:12px 14px;border-radius:10px;background:#ecfdf5;color:#166534;border:1px solid #bbf7d0}
    .code-box{background:#0f172a;color:#e2e8f0;padding:12px;border-radius:10px;font-size:13px;overflow:auto}
    .module-list{display:flex;flex-wrap:wrap;gap:8px;margin-top:10px}
    .module-chip{padding:7px 10px;border-radius:999px;background:#f8fbff;border:1px solid #dbe7ff;color:#184069;font-size:12px;font-weight:600}
    form.inline{display:inline}
    @media (max-width:900px){.grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div class="topbar">
      <div>
        <div class="title"><%= tenant?.name || "University Details" %></div>
        <div class="subtitle">View tenant information, configuration, plan, access, and provisioning info.</div>
      </div>

      <% if (tenant) { %>
        <div class="actions">
          <a href="/super-admin/universities/<%= tenant._id %>/edit" class="btn">
            <i class="fa-solid fa-pen"></i>
            Edit University
          </a>

          <form action="/super-admin/universities/<%= tenant._id %>/resend-invite" method="POST" class="inline">
            <button type="submit" class="btn primary">
              <i class="fa-solid fa-paper-plane"></i>
              Resend Invite
            </button>
          </form>
        </div>
      <% } %>
    </div>

    <% if (inviteResent) { %>
      <div class="alert">Admin invitation was resent successfully.</div>
    <% } %>

    <% if (error) { %>
      <div class="card">
        <div class="subtitle"><%= error %></div>
      </div>
    <% } %>

    <% if (tenant) { %>
      <div class="card">
        <div class="grid">
          <div>
            <div class="meta-label">University Name</div>
            <div class="meta-value"><%= tenant.name %></div>
          </div>

          <div>
            <div class="meta-label">Status</div>
            <div class="meta-value">
              <span class="badge <%= tenant.status === 'active' ? 'green' : tenant.status === 'trial' ? 'amber' : tenant.status === 'suspended' ? 'red' : 'gray' %>"><%= tenant.status %></span>
            </div>
          </div>

          <div>
            <div class="meta-label">Code</div>
            <div class="meta-value"><%= tenant.code %></div>
          </div>

          <div>
            <div class="meta-label">Subdomain</div>
            <div class="meta-value"><%= tenant.subdomain %></div>
          </div>

          <div>
            <div class="meta-label">Database Name</div>
            <div class="meta-value"><%= tenant.dbName %></div>
          </div>

          <div>
            <div class="meta-label">Custom Domain</div>
            <div class="meta-value"><%= tenant.customDomain || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Owner Name</div>
            <div class="meta-value"><%= tenant.ownerName || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Owner Email</div>
            <div class="meta-value"><%= tenant.ownerEmail || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Owner Phone</div>
            <div class="meta-value"><%= tenant.ownerPhone || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Country</div>
            <div class="meta-value"><%= tenant.country || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Timezone</div>
            <div class="meta-value"><%= tenant.timezone || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Currency</div>
            <div class="meta-value"><%= tenant.currency || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Plan</div>
            <div class="meta-value"><%= tenant.planId?.name || "—" %></div>
          </div>

          <div>
            <div class="meta-label">Profile Enabled</div>
            <div class="meta-value"><%= tenant.settings?.profile?.enabled ? "Yes" : "No" %></div>
          </div>

          <div>
            <div class="meta-label">Profile Verified</div>
            <div class="meta-value"><%= tenant.settings?.profile?.verified ? "Yes" : "No" %></div>
          </div>

          <div>
            <div class="meta-label">Invite Pending</div>
            <div class="meta-value"><%= tenant.meta?.invitePending ? "Yes" : "No" %></div>
          </div>

          <div>
            <div class="meta-label">Created At</div>
            <div class="meta-value"><%= tenant.createdAt ? new Date(tenant.createdAt).toLocaleString() : "—" %></div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="meta-label">Tenant Login URL</div>
        <div class="code-box">https://<%= tenant.customDomain || tenant.subdomain %>/login</div>
      </div>

      <div class="card">
        <div class="meta-label">Enabled Modules</div>
        <div class="module-list">
          <% if (Array.isArray(tenant?.settings?.modules) && tenant.settings.modules.length) { %>
            <% tenant.settings.modules.forEach(function(moduleName){ %>
              <span class="module-chip"><%= moduleName %></span>
            <% }) %>
          <% } else { %>
            <span class="module-chip">No modules assigned</span>
          <% } %>
        </div>
      </div>
    <% } %>
  </main>

  <script src="/js/navbar.js"></script>
</body>
</html>