<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Edit Plan — Classic Campus</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .title{font-size:20px;font-weight:700;color:#083454}
    .subtitle{font-size:13px;color:#6b7280;line-height:1.5}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .form-group{display:flex;flex-direction:column;gap:7px}
    .full{grid-column:1/-1}
    label{font-size:13px;font-weight:700;color:#334155}
    input,select,textarea{width:100%;border:1px solid #dbe3f6;border-radius:10px;padding:11px 12px;background:#fff;font:inherit}
    textarea{min-height:110px}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}
    .btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}
    .btn.danger{background:#fff1f2;color:#b91c1c;border-color:#fecdd3}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    .check-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .actions{display:flex;gap:10px;flex-wrap:wrap}
    @media (max-width:900px){.form-grid,.check-grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div>
      <div class="title">Edit Plan</div>
      <div class="subtitle">Update billing model, limits, modules, and feature flags.</div>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="alert" style="margin-bottom:14px;"><%= error %></div>
      <% } %>

      <form action="/super-admin/plans/<%= plan?._id %>/edit" method="POST" class="form-grid">
        <div class="form-group">
          <label>Plan Name</label>
          <input type="text" name="name" value="<%= plan?.name || '' %>" required />
        </div>

        <div class="form-group">
          <label>Plan Code</label>
          <input type="text" name="code" value="<%= plan?.code || '' %>" />
        </div>

        <div class="form-group full">
          <label>Description</label>
          <textarea name="description"><%= plan?.description || '' %></textarea>
        </div>

        <div class="form-group">
          <label>Billing Model</label>
          <select name="billingModel" required>
            <option value="school_only" <%= plan?.billingModel === 'school_only' ? 'selected' : '' %>>School Only</option>
            <option value="student_only" <%= plan?.billingModel === 'student_only' ? 'selected' : '' %>>Student Only</option>
            <option value="mixed_split" <%= plan?.billingModel === 'mixed_split' ? 'selected' : '' %>>Mixed Split</option>
          </select>
        </div>

        <div class="form-group">
          <label>Billing Interval</label>
          <select name="billingInterval">
            <option value="monthly" <%= plan?.billingInterval === 'monthly' ? 'selected' : '' %>>Monthly</option>
            <option value="termly" <%= plan?.billingInterval === 'termly' ? 'selected' : '' %>>Termly</option>
            <option value="semester" <%= plan?.billingInterval === 'semester' ? 'selected' : '' %>>Semester</option>
            <option value="yearly" <%= plan?.billingInterval === 'yearly' ? 'selected' : '' %>>Yearly</option>
            <option value="custom" <%= plan?.billingInterval === 'custom' ? 'selected' : '' %>>Custom</option>
          </select>
        </div>

        <div class="form-group">
          <label>Price Per School</label>
          <input type="number" step="0.01" name="pricePerSchool" value="<%= plan?.pricePerSchool || 0 %>" />
        </div>

        <div class="form-group">
          <label>Price Per Student</label>
          <input type="number" step="0.01" name="pricePerStudent" value="<%= plan?.pricePerStudent || 0 %>" />
        </div>

        <div class="form-group">
          <label>Platform Share Percent</label>
          <input type="number" step="0.01" name="platformSharePercent" value="<%= plan?.platformSharePercent || 0 %>" />
        </div>

        <div class="form-group">
          <label>Currency</label>
          <input type="text" name="currency" value="<%= plan?.currency || 'USD' %>" />
        </div>

        <div class="form-group">
          <label>Trial Days</label>
          <input type="number" name="trialDays" value="<%= plan?.trialDays || 0 %>" />
        </div>

        <div class="form-group">
          <label>Sort Order</label>
          <input type="number" name="sortOrder" value="<%= plan?.sortOrder || 0 %>" />
        </div>

        <div class="form-group">
          <label>Max Students</label>
          <input type="number" name="maxStudents" value="<%= plan?.maxStudents || 0 %>" />
        </div>

        <div class="form-group">
          <label>Max Staff</label>
          <input type="number" name="maxStaff" value="<%= plan?.maxStaff || 0 %>" />
        </div>

        <div class="form-group full">
          <label>Enabled Modules (comma separated)</label>
          <input type="text" name="enabledModules" value="<%= Array.isArray(plan?.enabledModules) ? plan.enabledModules.join(', ') : '' %>" />
        </div>

        <div class="form-group full">
          <label>Feature Flags</label>
          <div class="check-grid">
            <label><input type="checkbox" name="customDomain" <%= plan?.featureFlags?.customDomain ? 'checked' : '' %> /> Custom Domain</label>
            <label><input type="checkbox" name="apiAccess" <%= plan?.featureFlags?.apiAccess ? 'checked' : '' %> /> API Access</label>
            <label><input type="checkbox" name="prioritySupport" <%= plan?.featureFlags?.prioritySupport ? 'checked' : '' %> /> Priority Support</label>
            <label><input type="checkbox" name="whiteLabel" <%= plan?.featureFlags?.whiteLabel ? 'checked' : '' %> /> White Label</label>
            <label><input type="checkbox" name="advancedReports" <%= plan?.featureFlags?.advancedReports ? 'checked' : '' %> /> Advanced Reports</label>
            <label><input type="checkbox" name="isPublic" <%= plan?.isPublic ? 'checked' : '' %> /> Public Plan</label>
            <label><input type="checkbox" name="isActive" <%= plan?.isActive ? 'checked' : '' %> /> Active Plan</label>
          </div>
        </div>

        <div class="form-group full">
          <div class="actions">
            <button type="submit" class="btn primary">Save Changes</button>
            <a href="/super-admin/plans" class="btn">Cancel</a>
          </div>
        </div>
      </form>

      <form action="/super-admin/plans/<%= plan?._id %>/delete" method="POST" onsubmit="return confirm('Delete this plan?');" style="margin-top:12px;">
        <button type="submit" class="btn danger">Delete Plan</button>
      </form>
    </div>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>