            outline: none;
            resize: vertical;
        }

        .cform input:focus,
        .cform textarea:focus {
            border-color: rgba(74, 144, 226, .65);
            box-shadow: 0 0 0 4px rgba(74, 144, 226, .12);
        }

        .cform .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: .8rem;
        }

        .form-actions {
            display: flex;
            gap: .6rem;
            flex-wrap: nowrap;
            margin-top: .25rem;
            align-items: center;
        }

        .form-actions>* {
            flex: 1 1 0;
        }

        @media (max-width: 520px) {
            .form-actions {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .6rem;
            }

            .form-actions .btn,
