    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Outfit:wght@100..900&display=swap");

        :root {
            --primary: #4a90e2;
            --accent: #d97800;
            --highlight: #009f8b;

            --ink: #0f172a;
            --muted: #475569;

            --page-pad: clamp(1rem, 4vw, 6rem);
            --section-gap: clamp(1.2rem, 2.6vw, 2rem);

            --shadow2: 0 18px 50px rgba(15, 23, 42, .12);
            --shadow3: 0 10px 30px rgba(15, 23, 42, .10);

            --radius: 22px;
        }

        html {
            scroll-behavior: smooth;
        }

        a {
            text-decoration: none;
        }

        section,
        footer {
            scroll-margin-top: 120px;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            background: #e0f7fa;
            color: #333;
            overflow-x: clip;
            -webkit-overflow-scrolling: touch;
            padding-top: 112px;
        }

        @media (max-width: 600px) {
            body {
                padding-top: 102px;
            }
        }

        /* LOADER */
        #loader {
            position: fixed;
            inset: 0;
            background: #e0f7fa;
            display: flex;
            flex-direction: column;
            gap: 14px;
            align-items: center;
            justify-content: center;
            z-index: 9999;
            padding: 1.2rem;
            text-align: center;
        }

        .academylogo {
            width: min(220px, 70vw);
        }

        .academylogo img {
            width: 100%;
            height: auto;
            display: block;
        }

        .loader {
            position: relative;
            width: 18px;
            height: 28px;
            perspective: 500px;
            animation: flip 2s infinite;
        }

        .loader:nth-child(3) {
            animation-delay: 0.2s;
        }

        .loader:nth-child(4) {
            animation-delay: 0.4s;
        }

        .loader:nth-child(5) {
            animation-delay: 0.6s;
        }

        .loader:nth-child(6) {
            animation-delay: 0.8s;
        }

        .face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            border-radius: 4px;
        }

        .front {
            background: var(--primary);
        }

        .back {
            background: #d35400;
            transform: rotateY(180deg);
        }

        @keyframes flip {

            0%,
            100% {
                transform: rotateY(0deg);
            }

            50% {
                transform: rotateY(180deg);
            }
        }

        /* NAVBAR */
        .header {
            position: fixed;
            top: 14px;
            left: var(--page-pad);
            right: var(--page-pad);
            padding: .65rem .85rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, .70);
            border: 1px solid rgba(255, 255, 255, .78);
            backdrop-filter: blur(12px);
            box-shadow: 0 16px 46px rgba(15, 23, 42, .10);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .8rem;
            z-index: 2000;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: .75rem;
            min-width: 0;
            color: var(--ink);
        }

        .brand-mark {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            object-fit: cover;
            border: 1px solid rgba(15, 23, 42, .10);
            background: rgba(255, 255, 255, .85);
            flex: 0 0 auto;
        }

        .brand-txt {
            display: grid;
            line-height: 1.05;
            min-width: 0;
        }

        .brand-name {
            font-weight: 900;
            letter-spacing: -.02em;
            color: var(--ink);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .brand-sub {
            font-size: .86rem;
            color: var(--muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .navbar {
            display: flex;
            align-items: center;
            gap: .35rem;
        }

        .navbar a {
            padding: .55rem .75rem;
            border-radius: 999px;
            color: #1d4ed8;
            font-weight: 600;
            font-size: 1.02rem;
            transition: background .2s ease, transform .2s ease, color .2s ease;
            white-space: nowrap;
        }

        .navbar a:hover {
            background: rgba(74, 144, 226, .10);
            transform: translateY(-1px);
            color: var(--ink);
        }

        .nav-pill {
            border: 1px solid rgba(74, 144, 226, .35);
            background: rgba(74, 144, 226, .10);
            color: #0f172a !important;
            font-weight: 800;
        }

        .nav-pill:hover {
            background: rgba(74, 144, 226, .18);
            border-color: rgba(74, 144, 226, .45);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: .55rem;
            flex: 0 0 auto;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .45rem;
            padding: 0.72rem 1rem;
            background-color: var(--primary);
            color: white;
            border: 1px solid var(--primary);
            border-radius: 999px;
            font-weight: 800;
            transition: background-color .25s ease, transform .2s ease, box-shadow .2s ease;
            cursor: pointer;
            user-select: none;
            box-shadow: 0 10px 28px rgba(74, 144, 226, .18);
            white-space: nowrap;
        }

        .btn:hover {
            background-color: transparent;
            color: var(--primary);
            transform: translateY(-1px);
            box-shadow: 0 14px 34px rgba(15, 23, 42, .12);
        }

        .btn.ghost {
            background: rgba(255, 255, 255, .72);
            border: 1px solid rgba(15, 23, 42, .12);
            color: var(--ink);
            box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
        }

        .btn.ghost:hover {
            background: rgba(255, 255, 255, .88);
            color: var(--ink);
        }

        .btn-sm {
            padding: .55rem .8rem !important;
            font-size: .95rem !important;
            box-shadow: none !important;
        }

        .menu-btn {
            width: 44px;
            height: 44px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, .12);
            background: rgba(255, 255, 255, .78);
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
        }

        .menu-btn i {
            color: var(--ink);
            font-size: 1.05rem;
        }

        @media (max-width: 1024px) {
            .brand-sub {
                display: none;
            }

            .menu-btn {
                display: inline-flex;
            }

            .navbar {
                position: absolute;
                top: calc(100% + .65rem);
                left: 0;
                right: 0;
                margin: 0 .25rem;
                padding: .75rem;
                background: rgba(74, 144, 226, .96);
                border: 1px solid rgba(255, 255, 255, .35);
                border-radius: 20px;
                backdrop-filter: blur(12px);
                display: grid;
                gap: .4rem;
                transform: translateY(-8px);
                opacity: 0;
                pointer-events: none;
                transition: transform .2s ease, opacity .2s ease;
            }

            .navbar.active {
                transform: translateY(0);
                opacity: 1;
                pointer-events: auto;
            }

            .navbar a {
                color: #fff;
                border-radius: 16px;
                padding: .85rem .85rem;
                background: rgba(255, 255, 255, .08);
            }

            .navbar a:hover {
                background: rgba(255, 255, 255, .14);
                transform: none;
                color: #fff;
            }

            .nav-pill {
                background: rgba(255, 255, 255, .18);
                border-color: rgba(255, 255, 255, .35);
                color: #fff !important;
            }
        }

        /* REVEAL */
        .reveal {
            opacity: 0;
            transform: translateY(14px);
            transition: all .7s ease;
        }

        .reveal.in {
            opacity: 1;
            transform: translateY(0);
        }

        @media (prefers-reduced-motion: reduce) {
            .reveal {
                opacity: 1;
                transform: none;
                transition: none;
            }

            * {
                scroll-behavior: auto !important;
            }
        }

        /* PAGE HERO */
        .page-hero {
            position: relative;
            margin: 0 var(--page-pad);
            margin-bottom: 1.2rem;
            border-radius: calc(var(--radius) + 6px);
            overflow: hidden;
            background:
                radial-gradient(900px 420px at 10% 15%, rgba(74, 144, 226, .20), transparent 60%),
                radial-gradient(760px 420px at 90% 0%, rgba(217, 120, 0, .14), transparent 58%),
                radial-gradient(760px 520px at 80% 110%, rgba(0, 159, 139, .12), transparent 56%),
                rgba(255, 255, 255, .40);
            border: 1px solid rgba(255, 255, 255, .70);
            backdrop-filter: blur(14px);
            box-shadow: 0 20px 70px rgba(15, 23, 42, .12);
            padding: clamp(1.1rem, 2.5vw, 2rem);
        }

        .page-hero-grid {
            display: grid;
            grid-template-columns: 1.15fr .85fr;
            gap: clamp(1rem, 2.6vw, 2rem);
            align-items: center;
        }

        .kicker {
            display: inline-flex;
            gap: .55rem;
            align-items: center;
            color: #1b2a4e;
            font-weight: 900;
            padding: .45rem .8rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, .82);
            border: 1px solid rgba(255, 255, 255, .90);
            box-shadow: 0 12px 30px rgba(15, 23, 42, .08);
            width: fit-content;
        }

        .page-hero h1 {
            margin-top: .85rem;
            font-size: clamp(1.55rem, 2.55vw, 2.45rem);
            line-height: 1.15;
            letter-spacing: -.02em;
            color: var(--ink);
        }

        .page-hero h1 span {
            color: var(--primary);
        }

        .page-hero p {
            margin-top: .75rem;
            color: #24324f;
            font-size: clamp(1rem, 1.2vw, 1.08rem);
            max-width: 70ch;
        }

        .hero-actions {
            margin-top: 1rem;
            display: flex;
            flex-wrap: wrap;
            gap: .6rem;
        }

        .hero-mini {
            margin-top: 1.05rem;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: .7rem;
            max-width: 720px;
        }

        .mini {
            border-radius: 16px;
            padding: .75rem .8rem;
            background: rgba(255, 255, 255, .72);
            border: 1px solid rgba(255, 255, 255, .85);
            box-shadow: 0 14px 34px rgba(15, 23, 42, .08);
        }

        .mini strong {
            display: block;
            color: var(--ink);
            letter-spacing: -.01em;
        }

        .mini span {
            display: block;
            margin-top: .15rem;
            font-size: .9rem;
            color: var(--muted);
        }

        .hero-panel {
            background: rgba(255, 255, 255, .72);
            border: 1px solid rgba(255, 255, 255, .85);
            border-radius: 22px;
            box-shadow: 0 18px 55px rgba(15, 23, 42, .10);
            overflow: hidden;
        }

        .hero-panel-top {
            padding: .95rem 1rem;
            border-bottom: 1px solid rgba(15, 23, 42, .08);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
        }

        .hero-panel-top strong {
            color: var(--ink);
            letter-spacing: -.01em;
        }

        .hero-pill {
            display: inline-flex;
            gap: .4rem;
            align-items: center;
            padding: .35rem .65rem;
            border-radius: 999px;
            background: rgba(74, 144, 226, .10);
            border: 1px solid rgba(74, 144, 226, .20);
            font-weight: 900;
            color: #0f172a;
            font-size: .85rem;
            white-space: nowrap;
        }

        .hero-panel-body {
            padding: 1rem;
        }

        .hero-panel-list {
            list-style: none;
            display: grid;
            gap: .55rem;
            margin: 0;
            padding: 0;
        }

        .hero-panel-list li {
            display: flex;
            gap: .55rem;
            align-items: flex-start;
            color: #0f172a;
            font-size: .95rem;
        }

        .hero-panel-list li i {
            color: #16a34a;
            margin-top: .2rem;
        }

        @media (max-width: 920px) {
            .page-hero-grid {
                grid-template-columns: 1fr;
            }

            .hero-mini {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 520px) {
            .hero-actions {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .6rem;
            }

            .hero-actions .btn {
                width: 100%;
                padding: .62rem .7rem;
                font-size: .95rem;
                box-shadow: none;
            }
        }

        /* FEATURE CATEGORIES */
        .fcats {
            margin: 1.2rem var(--page-pad) 0 var(--page-pad);
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
            border-radius: 25px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            padding: 1.25rem 1.2rem;
            border: 1px solid rgba(255, 255, 255, .55);
        }

        .fcats-head {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .fcats-head h2 {
            color: var(--ink);
            font-size: clamp(1.35rem, 2.1vw, 1.9rem);
            letter-spacing: -.01em;
            margin: 0;
        }

        .fcats-head p {
            margin: .2rem 0 0 0;
            color: var(--muted);
            max-width: 80ch;
        }

        .fcats-tools {
            display: flex;
            gap: .6rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .search {
            position: relative;
            min-width: min(360px, 82vw);
            flex: 1 1 320px;
        }

        .search input {
            width: 100%;
            padding: .85rem 1rem .85rem 2.65rem;
            border-radius: 999px;
            border: 1px solid rgba(74, 144, 226, .35);
            background: rgba(255, 255, 255, .80);
            outline: none;
        }

        .search i {
            position: absolute;
            left: 1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #1f2a44;
            opacity: .8;
        }

        .chipbar {
            display: flex;
            gap: .5rem;
            flex-wrap: wrap;
            align-items: center;
            justify-content: flex-end;
        }

        .fchip {
            display: inline-flex;
            gap: .4rem;
            align-items: center;
            padding: .5rem .75rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, .75);
            border: 1px solid rgba(15, 23, 42, .10);
            font-weight: 900;
            color: #0f172a;
            cursor: pointer;
            user-select: none;
            transition: transform .2s ease, background .2s ease, border-color .2s ease;
            font-size: .9rem;
            white-space: nowrap;
        }

        .fchip:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .9);
        }

        .fchip.active {
            background: rgba(74, 144, 226, .12);
            border-color: rgba(74, 144, 226, .28);
        }

        .fgrid {
            margin-top: 1rem;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1rem;
        }

        .fcard {
            background: rgba(255, 255, 255, .85);
            border: 1px solid rgba(15, 23, 42, .10);
            border-radius: 24px;
            box-shadow: 0 18px 55px rgba(15, 23, 42, .10);
            padding: 1.1rem;
            overflow: hidden;
            transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
            display: flex;
            flex-direction: column;
            min-height: 100%;
        }

        .fcard:hover {
            transform: translateY(-6px);
            box-shadow: 0 26px 72px rgba(15, 23, 42, .14);
            border-color: rgba(74, 144, 226, .22);
        }

        .fhead {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: .8rem;
        }

        .fico {
            width: 44px;
            height: 44px;
            border-radius: 16px;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            background: rgba(74, 144, 226, .12);
            border: 1px solid rgba(74, 144, 226, .22);
        }

        .fico i {
            color: var(--primary);
            font-size: 1.1rem;
        }

        .ftitle h3 {
            margin: 0;
            color: var(--ink);
            font-size: 1.12rem;
            letter-spacing: -.01em;
            line-height: 1.2;
        }

        .ftitle p {
            margin: .22rem 0 0 0;
            color: var(--muted);
            font-size: .92rem;
        }

        .ftag {
            display: inline-flex;
            align-items: center;
            gap: .4rem;
            padding: .35rem .65rem;
            border-radius: 999px;
            background: rgba(15, 23, 42, .06);
            border: 1px solid rgba(15, 23, 42, .10);
            color: var(--ink);
            font-weight: 900;
            font-size: .8rem;
            white-space: nowrap;
            flex: 0 0 auto;
        }

        .ftag.hot {
            background: rgba(217, 120, 0, .12);
            border-color: rgba(217, 120, 0, .22);
            color: #9a3412;
        }

        .flist {
            list-style: none;
            margin: .85rem 0 0 0;
            padding: 0;
            display: grid;
            gap: .55rem;
        }

        .flist li {
            display: flex;
            gap: .55rem;
            align-items: flex-start;
            color: #1f2937;
            font-size: .95rem;
        }

        .flist li i {
            color: #16a34a;
            margin-top: .2rem;
        }

        .factions {
            margin-top: auto;
            padding-top: .95rem;
            display: flex;
            gap: .55rem;
            flex-wrap: wrap;
        }

        @media (max-width: 1024px) {
            .fgrid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 680px) {
            .fgrid {
                grid-template-columns: 1fr;
            }
        }

        /* DEEP DIVE */
        .deep {
            padding: 2.4rem 0 0 0;
            background:
                radial-gradient(900px 420px at 18% 0%, rgba(74, 144, 226, .10), transparent 60%),
                radial-gradient(760px 420px at 85% 10%, rgba(217, 120, 0, .08), transparent 58%),
                linear-gradient(180deg, rgba(224, 247, 250, .0), rgba(224, 247, 250, .35));
        }

        .deep-wrap {
            margin: 0 var(--page-pad);
            border-radius: 30px;
            background: rgba(255, 255, 255, .58);
            border: 1px solid rgba(255, 255, 255, .78);
            backdrop-filter: blur(14px);
            box-shadow: 0 22px 70px rgba(15, 23, 42, .12);
            overflow: hidden;
        }

        .deep-head {
            padding: 1.6rem 1.6rem 1rem 1.6rem;
            border-bottom: 1px solid rgba(15, 23, 42, .08);
            background:
                radial-gradient(720px 320px at 10% 0%, rgba(74, 144, 226, .10), transparent 62%),
                radial-gradient(720px 320px at 90% 0%, rgba(0, 159, 139, .08), transparent 62%),
                rgba(255, 255, 255, .18);
            text-align: center;
        }

        .deep-head h2 {
            margin: .85rem 0 .35rem 0;
            font-size: clamp(1.45rem, 2.2vw, 2rem);
            color: var(--ink);
            letter-spacing: -.02em;
            line-height: 1.2;
        }

        .deep-head p {
            margin: 0 auto;
            max-width: 920px;
            color: var(--muted);
        }

        .deep-body {
            padding: 1.2rem 1.25rem 1.35rem 1.25rem;
        }

        .tabs {
            display: flex;
            gap: .55rem;
            flex-wrap: wrap;
            justify-content: center;
            margin: .35rem 0 1rem 0;
        }

        .tab {
            border: 1px solid rgba(15, 23, 42, .10);
            background: rgba(255, 255, 255, .78);
            color: var(--ink);
            padding: .55rem .8rem;
            border-radius: 999px;
            font-weight: 900;
            cursor: pointer;
            user-select: none;
            transition: transform .2s ease, background .2s ease, border-color .2s ease;
            display: inline-flex;
            gap: .45rem;
            align-items: center;
            white-space: nowrap;
        }

        .tab:hover {
            transform: translateY(-1px);
        }

        .tab.active {
            background: rgba(74, 144, 226, .12);
            border-color: rgba(74, 144, 226, .24);
        }

        .panel-grid {
            display: grid;
            grid-template-columns: 1.05fr .95fr;
            gap: 1rem;
            align-items: start;
        }

        .panel {
            background: rgba(255, 255, 255, .85);
            border: 1px solid rgba(15, 23, 42, .10);
            border-radius: 24px;
            box-shadow: 0 18px 55px rgba(15, 23, 42, .10);
            padding: 1.15rem;
            overflow: hidden;
        }

        .panel h3 {
            margin: 0 0 .4rem 0;
            color: var(--ink);
            letter-spacing: -.01em;
        }

        .panel p {
            margin: 0 0 .8rem 0;
            color: var(--muted);
        }

        .bullets {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: .55rem;
        }

        .bullets li {
            display: flex;
            gap: .55rem;
            align-items: flex-start;
            color: #1f2937;
        }

        .bullets li i {
            color: #16a34a;
            margin-top: .2rem;
        }

        .shot {
            border-radius: 22px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, .85);
            background: rgba(255, 255, 255, .65);
            box-shadow: 0 22px 70px rgba(15, 23, 42, .14);
        }

        .shot img {
            width: 100%;
            height: auto;
            display: block;
        }

        .panel-cta {
            margin-top: .9rem;
            display: flex;
            gap: .6rem;
            flex-wrap: wrap;
        }

        @media (max-width: 920px) {
            .panel-grid {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 520px) {
            .panel-cta {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: .6rem;
            }

            .panel-cta .btn {
                width: 100%;
            }
        }

        /* FAQ */
        .faq {
            padding: 2.2rem 0 0 0;
            background: linear-gradient(180deg, rgba(255, 255, 255, .55), rgba(224, 247, 250, .25));
        }

        .faq-wrap {
            margin: 0 var(--page-pad);
            background: rgba(255, 255, 255, .25);
            border: 1px solid rgba(255, 255, 255, .55);
            border-radius: 26px;
            box-shadow: 0 18px 50px rgba(15, 23, 42, .12);
            backdrop-filter: blur(18px);
            padding: 1.6rem 1.3rem;
        }

        .faq-head {
            text-align: center;
            max-width: 980px;
            margin: 0 auto 1rem auto;
        }

        .faq-head h2 {
            margin: .35rem 0 .35rem 0;
            font-size: clamp(1.45rem, 2.2vw, 2rem);
            color: var(--ink);
        }

        .faq-head p {
            margin: 0 auto;
            max-width: 860px;
            color: #334155;
        }

        .faq-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
            margin-top: 1rem;
        }

        .qa {
            background: rgba(255, 255, 255, .75);
            border: 1px solid rgba(255, 255, 255, .85);
            border-radius: 22px;
            box-shadow: 0 12px 30px rgba(15, 23, 42, .10);
            padding: 1rem;
        }

        .qa details {
            background: transparent;
        }

        .qa summary {
            cursor: pointer;
            list-style: none;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .75rem;
            font-weight: 1000;
            color: var(--ink);
        }

        .qa summary::-webkit-details-marker {
            display: none;
        }

        .qa summary span {
            display: inline-flex;
            align-items: center;
            gap: .55rem;
        }

        .qa summary i {
            color: var(--primary);
        }

        .qa .caret {
            color: #334155;
            transition: transform .2s ease;
        }

        .qa details[open] .caret {
            transform: rotate(180deg);
        }

        .qa p {
            margin: .75rem 0 0 0;
            color: #475569;
        }

        @media (max-width: 920px) {
            .faq-grid {
                grid-template-columns: 1fr;
            }
        }

        /* FOOTER (same as main) */
        .footer {
            background-color: #f9f9f9;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            font-size: 0.95rem;
            background: rgba(255, 255, 255, 0.3);
            backdrop-filter: blur(10px);
            border-radius: 25px;
            margin: 2rem var(--page-pad);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
            gap: 0;
        }

        .footer div {
            margin: 1rem;
            flex: 1 1 220px;
            min-width: 220px;
        }

        .footer h4 {
            font-size: 1rem;
            margin-bottom: 1rem;
        }

        .footer ul {
            list-style: none;
            padding: 0;
        }

        .footer ul li {
            margin-bottom: 0.5rem;
        }

        .footer ul li a {
            color: #333;
        }

        .footer ul li a:hover {
            text-decoration: underline;
        }

        #toTopBtn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background-color: var(--primary);
            color: white;
            border: none;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.5rem;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            display: none;
            z-index: 1000;
            transition: transform 0.2s ease;
        }

        #toTopBtn:hover {
            transform: scale(1.08);
        }

        .fab-container {
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            position: fixed;
            bottom: 170px;
            right: 20px;
            z-index: 999;
        }

        .whatsapp-icon {
            transition: fill 0.3s ease;
            cursor: pointer;
        }

        .whatsapp-icon:hover {
            fill: white;
        }

        .fab-container:hover {
            height: 100%;
        }

        .fab-container:hover .sub-button:nth-child(2) {
            transform: translateY(-80px);
        }

        .fab-container:hover .sub-button:nth-child(3) {
            transform: translateY(-140px);
        }

        .fab-container:hover .sub-button:nth-child(4) {
            transform: translateY(-200px);
        }

        .fab-container .sub-button {
            position: absolute;
            display: flex;
            align-items: center;
            justify-content: center;
            bottom: 10px;
            right: 10px;
            height: 50px;
            width: 50px;
            background-color: #4ba2ff;
            border-radius: 50%;
            transition: all 0.3s ease;
        }

        .fab-container .sub-button:hover {
            cursor: pointer;
        }

        .fab-container .sub-button .material-icons {
            color: #2e2e2e;
            padding-top: 6px;
        }

        .fab-container .sub-button .material-icons:hover {
            color: #FEFEFE;
        }

        .fab-container .fab {
            position: relative;
            height: 70px;
            width: 70px;
            background-color: #4ba2ff;
            border-radius: 50%;
            z-index: 2;
        }

        .fab-container .fab:before {
            content: " ";
            position: absolute;
            bottom: 0;
            right: 0;
            height: 35px;
            width: 35px;
            background-color: inherit;
            border-radius: 0 0 10px 0;
            z-index: -1;
        }

        .fab-container .fab .fab-content {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100%;
            width: 100%;
            border-radius: 50%;
            cursor: pointer;
            user-select: none;
        }

        .fab-container .fab .fab-content .material-icons {
            color: #2e2e2e;
            font-size: 48px;
        }

        /* Mobile perf */
        @media (max-width: 600px) {

            .header,
            .page-hero,
            .fcats,
            .deep-wrap,
            .faq-wrap,
            .footer,
            .navbar {
                backdrop-filter: none !important;
            }

            .header {
                box-shadow: 0 10px 26px rgba(15, 23, 42, .10);
            }

            .page-hero {
                box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
            }

            .deep-wrap {
                box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
            }
        }

        @media (max-width: 480px) {
            .fab-container {
                bottom: 180px;
            }

            .footer h4 {
                font-size: 1.15rem;
            }
        }
    </style>
</head>

