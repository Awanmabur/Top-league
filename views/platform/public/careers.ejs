  <meta name="twitter:image" content="https://www.classicacademy.app/img/hero.png" />

  <!-- Structured data -->
  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"WebPage",
    "name":"Classic Academy — Careers",
    "url":"https://www.classicacademy.app/careers",
    "isPartOf":{
      "@type":"WebSite",
      "name":"Classic Academy",
      "url":"https://www.classicacademy.app/"
    }
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Outfit:wght@100..900&display=swap");

    :root {
      --primary: #4a90e2;
      --accent: #d97800;
      --highlight: #009f8b;

      --ink: #0f172a;
      --muted: #475569;

      --page-pad: clamp(1rem, 4vw, 6rem);
      --section-gap: clamp(1.2rem, 2.6vw, 2rem);

      --shadow2: 0 18px 50px rgba(15, 23, 42, .12);
      --shadow3: 0 10px 30px rgba(15, 23, 42, .10);

      --radius: 22px;
    }

    html {
      scroll-behavior: smooth;
    }

    a {
      text-decoration: none;
    }

    section,
    footer {
      scroll-margin-top: 120px;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      line-height: 1.6;
      background: #e0f7fa;
      color: #333;
      overflow-x: clip;
      -webkit-overflow-scrolling: touch;
      padding-top: 112px;
    }

    @media (max-width: 600px) {
      body {
        padding-top: 102px;
      }
    }

    /* LOADER */
    #loader {
      position: fixed;
      inset: 0;
      background: #e0f7fa;
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 1.2rem;
      text-align: center;
    }

    .academylogo {
      width: min(220px, 70vw);
    }

    .academylogo img {
      width: 100%;
      height: auto;
      display: block;
    }

    .loader {
      position: relative;
      width: 18px;
      height: 28px;
      perspective: 500px;
      animation: flip 2s infinite;
    }

    .loader:nth-child(3) {
      animation-delay: 0.2s;
    }

    .loader:nth-child(4) {
      animation-delay: 0.4s;
    }

    .loader:nth-child(5) {
      animation-delay: 0.6s;
    }

    .loader:nth-child(6) {
      animation-delay: 0.8s;
    }

    .face {
      position: absolute;
      width: 100%;
      height: 100%;
      backface-visibility: hidden;
      border-radius: 4px;
    }

    .front {
      background: var(--primary);
    }

    .back {
      background: #d35400;
      transform: rotateY(180deg);
    }

    @keyframes flip {

      0%,
      100% {
        transform: rotateY(0deg);
      }

      50% {
        transform: rotateY(180deg);
      }
    }

    /* NAVBAR (same as main) */
    .header {
      position: fixed;
      top: 14px;
      left: var(--page-pad);
      right: var(--page-pad);
      padding: .65rem .85rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .70);
      border: 1px solid rgba(255, 255, 255, .78);
      backdrop-filter: blur(12px);
      box-shadow: 0 16px 46px rgba(15, 23, 42, .10);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .8rem;
      z-index: 2000;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .75rem;
      min-width: 0;
      color: var(--ink);
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      object-fit: cover;
      border: 1px solid rgba(15, 23, 42, .10);
      background: rgba(255, 255, 255, .85);
      flex: 0 0 auto;
    }

    .brand-txt {
      display: grid;
      line-height: 1.05;
      min-width: 0;
    }

    .brand-name {
      font-weight: 900;
      letter-spacing: -.02em;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand-sub {
      font-size: .86rem;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .navbar {
      display: flex;
      align-items: center;
      gap: .35rem;
    }

    .navbar a {
      padding: .55rem .75rem;
      border-radius: 999px;
      color: #1d4ed8;
      font-weight: 600;
      font-size: 1.02rem;
      transition: background .2s ease, transform .2s ease, color .2s ease;
      white-space: nowrap;
    }

    .navbar a:hover {
      background: rgba(74, 144, 226, .10);
      transform: translateY(-1px);
      color: var(--ink);
    }

    .nav-pill {
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(74, 144, 226, .10);
      color: #0f172a !important;
      font-weight: 800;
    }

    .nav-pill:hover {
      background: rgba(74, 144, 226, .18);
      border-color: rgba(74, 144, 226, .45);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: .55rem;
      flex: 0 0 auto;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      padding: 0.72rem 1rem;
      background-color: var(--primary);
      color: white;
      border: 1px solid var(--primary);
      border-radius: 999px;
      font-weight: 800;
      transition: background-color .25s ease, transform .2s ease, box-shadow .2s ease;
      cursor: pointer;
      user-select: none;
      box-shadow: 0 10px 28px rgba(74, 144, 226, .18);
      white-space: nowrap;
    }

    .btn:hover {
      background-color: transparent;
      color: var(--primary);
      transform: translateY(-1px);
      box-shadow: 0 14px 34px rgba(15, 23, 42, .12);
    }

    .btn.ghost {
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(15, 23, 42, .12);
      color: var(--ink);
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .btn.ghost:hover {
      background: rgba(255, 255, 255, .88);
      color: var(--ink);
    }

    .btn-sm {
      padding: .55rem .8rem !important;
      font-size: .95rem !important;
      box-shadow: none !important;
    }

    .menu-btn {
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(15, 23, 42, .12);
      background: rgba(255, 255, 255, .78);
      display: none;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .menu-btn i {
      color: var(--ink);
      font-size: 1.05rem;
    }

    @media (max-width: 1024px) {
      .brand-sub {
        display: none;
      }

      .menu-btn {
        display: inline-flex;
      }

      .navbar {
        position: absolute;
        top: calc(100% + .65rem);
        left: 0;
        right: 0;
        margin: 0 .25rem;
        padding: .75rem;
        background: rgba(74, 144, 226, .96);
        border: 1px solid rgba(255, 255, 255, .35);
        border-radius: 20px;
        backdrop-filter: blur(12px);
        display: grid;
        gap: .4rem;
        transform: translateY(-8px);
        opacity: 0;
        pointer-events: none;
        transition: transform .2s ease, opacity .2s ease;
      }

      .navbar.active {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      .navbar a {
        color: #fff;
        border-radius: 16px;
        padding: .85rem .85rem;
        background: rgba(255, 255, 255, .08);
      }

      .navbar a:hover {
        background: rgba(255, 255, 255, .14);
        transform: none;
        color: #fff;
      }

      .nav-pill {
        background: rgba(255, 255, 255, .18);
        border-color: rgba(255, 255, 255, .35);
        color: #fff !important;
      }
    }

    /* REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(14px);
      transition: all .7s ease;
    }

    .reveal.in {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }

      * {
        scroll-behavior: auto !important;
      }
    }

    /* PAGE HERO */
    .page-hero {
      position: relative;
      margin: 0 var(--page-pad);
      margin-bottom: 1.2rem;
      border-radius: calc(var(--radius) + 6px);
      overflow: hidden;
      background:
        radial-gradient(900px 420px at 10% 15%, rgba(74, 144, 226, .20), transparent 60%),
        radial-gradient(760px 420px at 90% 0%, rgba(217, 120, 0, .14), transparent 58%),
        radial-gradient(760px 520px at 80% 110%, rgba(0, 159, 139, .12), transparent 56%),
        rgba(255, 255, 255, .40);
      border: 1px solid rgba(255, 255, 255, .70);
      backdrop-filter: blur(14px);
      box-shadow: 0 20px 70px rgba(15, 23, 42, .12);
      padding: clamp(1.1rem, 2.5vw, 2rem);
    }

    .kicker {
      display: inline-flex;
      gap: .55rem;
      align-items: center;
      color: #1b2a4e;
      font-weight: 900;
      padding: .45rem .8rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .82);
      border: 1px solid rgba(255, 255, 255, .90);
      box-shadow: 0 12px 30px rgba(15, 23, 42, .08);
      width: fit-content;
    }

    .page-hero h1 {
      margin-top: .85rem;
      font-size: clamp(1.55rem, 2.55vw, 2.45rem);
      line-height: 1.15;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .page-hero h1 span {
      color: var(--primary);
    }

    .page-hero p {
      margin-top: .75rem;
      color: #24324f;
      font-size: clamp(1rem, 1.2vw, 1.08rem);
      max-width: 78ch;
    }

    .hero-actions {
      margin-top: 1rem;
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
    }

    @media (max-width: 520px) {
      .hero-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
      }

      .hero-actions .btn {
        width: 100%;
        padding: .62rem .7rem;
        font-size: .95rem;
        box-shadow: none;
      }
    }

    /* VALUES + BENEFITS */
    .values {
      margin: 0 var(--page-pad);
      background: rgba(255, 255, 255, .55);
      border: 1px solid rgba(255, 255, 255, .75);
      border-radius: 26px;
      box-shadow: var(--shadow2);
      backdrop-filter: blur(14px);
      padding: 1.25rem 1.2rem;
    }

    .values-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
      margin-bottom: .9rem;
    }

    .values-head h2 {
      color: var(--ink);
      font-size: clamp(1.3rem, 2vw, 1.75rem);
      letter-spacing: -.01em;
    }

    .values-head p {
      margin: .25rem 0 0 0;
      color: var(--muted);
      max-width: 78ch;
    }

    .vgrid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: .9rem;
    }

    .vcard {
      background: rgba(255, 255, 255, .85);
      border: 1px solid rgba(15, 23, 42, .10);
      border-radius: 24px;
      box-shadow: 0 18px 55px rgba(15, 23, 42, .10);
      padding: 1.1rem;
      transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
      overflow: hidden;
    }

    .vcard:hover {
      transform: translateY(-6px);
      box-shadow: 0 26px 72px rgba(15, 23, 42, .14);
      border-color: rgba(74, 144, 226, .22);
    }

    .vico {
      width: 44px;
      height: 44px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: rgba(74, 144, 226, .12);
      border: 1px solid rgba(74, 144, 226, .22);
      margin-bottom: .65rem;
    }

    .vico i {
      color: var(--primary);
    }

    .vcard h3 {
      margin: 0;
      color: var(--ink);
      font-size: 1.1rem;
      letter-spacing: -.01em;
    }

    .vcard p {
      margin: .35rem 0 0 0;
      color: var(--muted);
    }

    @media (max-width: 1024px) {
      .vgrid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 680px) {
      .vgrid {
        grid-template-columns: 1fr;
      }
    }

    /* JOBS */
    .jobs {
      padding: 2rem 0 0 0;
      background:
        radial-gradient(900px 420px at 18% 0%, rgba(74, 144, 226, .10), transparent 60%),
        radial-gradient(760px 420px at 85% 10%, rgba(217, 120, 0, .08), transparent 58%),
        linear-gradient(180deg, rgba(224, 247, 250, .0), rgba(224, 247, 250, .35));
    }

    .jobs-wrap {
      margin: 0 var(--page-pad);
      border-radius: 30px;
      background: rgba(255, 255, 255, .58);
      border: 1px solid rgba(255, 255, 255, .78);
      backdrop-filter: blur(14px);
      box-shadow: 0 22px 70px rgba(15, 23, 42, .12);
      overflow: hidden;
    }

    .jobs-head {
      padding: 1.6rem 1.6rem 1rem 1.6rem;
      border-bottom: 1px solid rgba(15, 23, 42, .08);
      background:
        radial-gradient(720px 320px at 10% 0%, rgba(74, 144, 226, .10), transparent 62%),
        radial-gradient(720px 320px at 90% 0%, rgba(0, 159, 139, .08), transparent 62%),
        rgba(255, 255, 255, .18);
      text-align: center;
    }

    .jobs-head h2 {
      margin: .85rem 0 .35rem 0;
      font-size: clamp(1.45rem, 2.2vw, 2rem);
      color: var(--ink);
      letter-spacing: -.02em;
      line-height: 1.2;
    }

    .jobs-head p {
      margin: 0 auto;
      max-width: 920px;
      color: var(--muted);
    }

    .jobs-body {
      padding: 1.2rem 1.25rem 1.35rem 1.25rem;
    }

    .job-tools {
      display: flex;
      gap: .75rem;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1rem;
    }

    .search {
      position: relative;
      min-width: min(360px, 86vw);
      flex: 1 1 320px;
    }

    .search input {
      width: 100%;
      padding: .85rem 1rem .85rem 2.65rem;
      border-radius: 999px;
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(255, 255, 255, .80);
      outline: none;
    }

    .search i {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: #1f2a44;
      opacity: .8;
    }

    .chipbar {
      display: flex;
      gap: .5rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .fchip {
      display: inline-flex;
      gap: .4rem;
      align-items: center;
      padding: .5rem .75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .75);
      border: 1px solid rgba(15, 23, 42, .10);
      font-weight: 900;
      color: #0f172a;
      cursor: pointer;
      user-select: none;
      transition: transform .2s ease, background .2s ease, border-color .2s ease;
      font-size: .9rem;
      white-space: nowrap;
    }

    .fchip:hover {
      transform: translateY(-1px);
      background: rgba(255, 255, 255, .9);
    }

    .fchip.active {
      background: rgba(74, 144, 226, .12);
      border-color: rgba(74, 144, 226, .28);
    }

    .jgrid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .jcard {
      background: rgba(255, 255, 255, .88);
      border: 1px solid rgba(15, 23, 42, .10);
      border-radius: 24px;
      box-shadow: 0 18px 55px rgba(15, 23, 42, .10);
      padding: 1.1rem;
      overflow: hidden;
      transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
      display: flex;
      flex-direction: column;
      min-height: 100%;
    }

    .jcard:hover {
      transform: translateY(-6px);
      box-shadow: 0 26px 72px rgba(15, 23, 42, .14);
      border-color: rgba(74, 144, 226, .22);
    }

    .jtop {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: .75rem;
    }

    .jtitle h3 {
      margin: 0;
      color: var(--ink);
      font-size: 1.15rem;
      letter-spacing: -.01em;
      line-height: 1.2;
    }

    .jtitle p {
      margin: .25rem 0 0 0;
      color: var(--muted);
      font-size: .92rem;
    }

    .jtag {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      padding: .35rem .65rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, .06);
      border: 1px solid rgba(15, 23, 42, .10);
      color: var(--ink);
      font-weight: 900;
      font-size: .8rem;
      white-space: nowrap;
    }

    .jtag.hot {
      background: rgba(217, 120, 0, .12);
      border-color: rgba(217, 120, 0, .22);
      color: #9a3412;
    }

    .jmeta {
      margin-top: .75rem;
      display: flex;
      gap: .5rem;
      flex-wrap: wrap;
    }

    .chip {
      display: inline-flex;
      gap: .35rem;
      align-items: center;
      padding: .32rem .55rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .85);
      border: 1px solid rgba(15, 23, 42, .10);
      font-weight: 900;
      font-size: .86rem;
      color: #0f172a;
    }

    .chip i {
      color: #16a34a;
    }

    .jdesc {
      margin: .75rem 0 0 0;
      color: #475569;
    }

    .jbullets {
      list-style: none;
      margin: .85rem 0 0 0;
      padding: 0;
      display: grid;
      gap: .55rem;
    }

    .jbullets li {
      display: flex;
      gap: .55rem;
      align-items: flex-start;
      color: #1f2937;
      font-size: .95rem;
    }

    .jbullets li i {
      color: #16a34a;
      margin-top: .2rem;
    }

    .jactions {
      margin-top: auto;
      padding-top: .95rem;
      display: flex;
      gap: .55rem;
      flex-wrap: wrap;
    }

    @media (max-width: 920px) {
      .jgrid {
        grid-template-columns: 1fr;
      }
    }

    /* APPLY SECTION */
    .apply {
      padding: 2rem 0 0 0;
      background: linear-gradient(180deg, rgba(255, 255, 255, .55), rgba(224, 247, 250, .25));
    }

    .apply-wrap {
      margin: 0 var(--page-pad);
      background: rgba(255, 255, 255, .25);
      border: 1px solid rgba(255, 255, 255, .55);
      border-radius: 26px;
      box-shadow: 0 18px 50px rgba(15, 23, 42, .12);
      backdrop-filter: blur(18px);
      padding: 1.6rem 1.3rem;
    }

    .apply-head {
      text-align: center;
      max-width: 980px;
      margin: 0 auto 1rem auto;
    }

    .apply-head h2 {
      margin: .35rem 0 .35rem 0;
      font-size: clamp(1.45rem, 2.2vw, 2rem);
      color: var(--ink);
    }

    .apply-head p {
      margin: 0 auto;
      max-width: 860px;
      color: #334155;
    }

    .aform {
      margin-top: 1rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      align-items: start;
    }

    .abox {
      background: rgba(255, 255, 255, .78);
      border: 1px solid rgba(255, 255, 255, .88);
      border-radius: 22px;
      box-shadow: 0 12px 30px rgba(15, 23, 42, .10);
      padding: 1.1rem;
    }

    .abox h3 {
      margin: 0 0 .5rem 0;
      color: var(--ink);
    }

    .note {
      display: flex;
      gap: .6rem;
      align-items: flex-start;
      color: #64748b;
      margin-top: .6rem;
    }

    .note i {
      color: #16a34a;
      margin-top: .25rem;
    }

    .form label {
      display: block;
      margin-bottom: .85rem;
    }

    .form span {
      display: block;
      font-weight: 800;
      color: #0f172a;
      margin-bottom: .35rem;
    }

    .form input,
    .form select {
      width: 100%;
      padding: .82rem .95rem;
      border-radius: 999px;
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(255, 255, 255, .80);
      outline: none;
    }

    .form textarea {
      width: 100%;
      padding: .85rem 1rem;
      border-radius: 22px;
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(255, 255, 255, .80);
      outline: none;
      resize: vertical;
    }

    .form input:focus,
    .form select:focus,
    .form textarea:focus {
      border-color: rgba(74, 144, 226, .65);
      box-shadow: 0 0 0 4px rgba(74, 144, 226, .12);
    }

    .form .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .8rem;
    }

    .form-actions {
      display: flex;
      gap: .6rem;
      flex-wrap: nowrap;
      align-items: center;
      margin-top: .25rem;
    }

    .form-actions>* {
      flex: 1 1 0;
    }

    .file {
      border: 1px dashed rgba(15, 23, 42, .18);
      background: rgba(255, 255, 255, .6);
      border-radius: 18px;
      padding: .85rem .9rem;
      display: grid;
      gap: .35rem;
    }

    .file small {
      color: #64748b;
    }

    @media (max-width: 920px) {
      .aform {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 520px) {
      .form .row {
        grid-template-columns: 1fr;
      }

      .form-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
      }

      .form-actions .btn {
        width: 100%;
      }
    }

    /* FOOTER (same as main) */
    .footer {
      background-color: #f9f9f9;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      font-size: 0.95rem;
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(10px);
      border-radius: 25px;
      margin: 2rem var(--page-pad);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      gap: 0;
    }

    .footer div {
      margin: 1rem;
      flex: 1 1 220px;
      min-width: 220px;
    }

    .footer h4 {
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .footer ul {
      list-style: none;
      padding: 0;
    }

    .footer ul li {
      margin-bottom: 0.5rem;
    }

    .footer ul li a {
      color: #333;
    }

    .footer ul li a:hover {
      text-decoration: underline;
    }

    #toTopBtn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background-color: var(--primary);
      color: white;
      border: none;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.5rem;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
      display: none;
      z-index: 1000;
      transition: transform 0.2s ease;
    }

    #toTopBtn:hover {
      transform: scale(1.08);
    }

    .fab-container {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      position: fixed;
      bottom: 170px;
      right: 20px;
      z-index: 999;
    }

    .whatsapp-icon {
      transition: fill 0.3s ease;
      cursor: pointer;
    }

    .whatsapp-icon:hover {
      fill: white;
    }

    .fab-container:hover {
      height: 100%;
    }

    .fab-container:hover .sub-button:nth-child(2) {
      transform: translateY(-80px);
    }

    .fab-container:hover .sub-button:nth-child(3) {
      transform: translateY(-140px);
    }

    .fab-container:hover .sub-button:nth-child(4) {
      transform: translateY(-200px);
    }

    .fab-container .sub-button {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      bottom: 10px;
      right: 10px;
      height: 50px;
      width: 50px;
      background-color: #4ba2ff;
      border-radius: 50%;
      transition: all 0.3s ease;
    }

    .fab-container .sub-button:hover {
      cursor: pointer;
    }

    .fab-container .sub-button .material-icons {
      color: #2e2e2e;
      padding-top: 6px;
    }

    .fab-container .sub-button .material-icons:hover {
      color: #FEFEFE;
    }

    .fab-container .fab {
      position: relative;
      height: 70px;
      width: 70px;
      background-color: #4ba2ff;
      border-radius: 50%;
      z-index: 2;
    }

    .fab-container .fab:before {
      content: " ";
      position: absolute;
      bottom: 0;
      right: 0;
      height: 35px;
      width: 35px;
      background-color: inherit;
      border-radius: 0 0 10px 0;
      z-index: -1;
    }

    .fab-container .fab .fab-content {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 100%;
      border-radius: 50%;
      cursor: pointer;
      user-select: none;
    }

    .fab-container .fab .fab-content .material-icons {
      color: #2e2e2e;
      font-size: 48px;
    }

    /* Mobile perf */
    @media (max-width: 600px) {

      .header,
      .page-hero,
      .values,
      .jobs-wrap,
      .apply-wrap,
      .footer,
      .navbar {
        backdrop-filter: none !important;
      }

      .header {
        box-shadow: 0 10px 26px rgba(15, 23, 42, .10);
      }

      .page-hero {
        box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
      }
    }

    @media (max-width: 480px) {
      .fab-container {
        bottom: 180px;
      }

      .footer h4 {
        font-size: 1.15rem;
      }
    }
  </style>
</head>

