<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- ✅ SEO -->
    <title>Schedule a Demo or Support Call | Classic Academy & Classic Campus</title>
    <meta name="description"
        content="Schedule a meeting with the Classic team for a demo, onboarding, or support for Classic Academy and Classic Campus. Pick a date, choose a time, and join via Zoom — with Google Calendar invite." />
    <meta name="keywords"
        content="Classic Academy, Classic Campus, schedule demo, onboarding meeting, support call, booking, Zoom meeting, Google Calendar invite, school ERP, university ERP, LMS, admissions" />
    <meta name="robots" content="index,follow" />

    <meta name="theme-color" content="#4a90e2" />
    <link rel="icon" href="/img/academylogo.png" />
    <link rel="apple-touch-icon" href="/img/academylogo.png" />
    <link rel="canonical" href="/schedule" />

    <!-- Open Graph -->
    <meta property="og:title" content="Schedule a Demo or Support Call | Classic Academy & Classic Campus" />
    <meta property="og:description"
        content="Book a meeting with the Classic team. Choose a date and time, receive a Zoom + Google Calendar invite, and join the meeting when it’s time." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="/schedule" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Schedule a Demo or Support Call | Classic Academy & Classic Campus" />
    <meta name="twitter:description"
        content="Book a meeting with the Classic team for demo, onboarding, or support. Zoom + Google Calendar invite included." />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box
        }

        :root {
            --primary: #4a90e2;
            --accent: #d97800;
            --highlight: #009f8b;

            --ink: #0f172a;
            --muted: #475569;

            --bg: #e0f7fa;
            --card: rgba(255, 255, 255, .62);
            --cardSolid: #ffffff;
            --line: rgba(15, 23, 42, .12);

            --page-pad: clamp(1rem, 4vw, 6rem);

            --shadow: 0 18px 55px rgba(15, 23, 42, .10);
            --shadow2: 0 10px 26px rgba(15, 23, 42, .08);
            --shadow3: 0 16px 46px rgba(15, 23, 42, .10);

            --radius: 22px;
            --radiusMd: 18px;
            --radiusPill: 999px;

            --ring: 0 0 0 4px rgba(74, 144, 226, .18);

            --ok: #16a34a;
            --past: #cbd5e1;
            --danger: #b91c1c;

            --cta1: #f8d29d;
            --cta2: #d97800;
        }

        html {
            height: 100%;
            scroll-behavior: smooth
        }

        body {
            min-height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            background: var(--bg);
            color: var(--ink);
            overflow-x: clip;
            -webkit-overflow-scrolling: touch;
            padding-top: 112px;
        }

        @media (max-width:600px) {
            body {
                padding-top: 102px;
            }
        }

        a {
            color: inherit;
            text-decoration: none
        }

        button,
        input,
        select,
        textarea {
            font: inherit
        }

        :focus-visible {
            outline: none;
            box-shadow: var(--ring);
            border-color: rgba(74, 144, 226, .45) !important
        }

        /* ✅ Clean animations */
        @media (prefers-reduced-motion: reduce) {
            * {
                transition: none !important;
                animation: none !important;
                scroll-behavior: auto !important
            }
        }

        .fadeIn {
            animation: fade .35s ease both
        }

        @keyframes fade {
            from {
                opacity: 0;
                transform: translateY(6px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        /* NAVBAR (matches main page) */
        .header {
            position: fixed;
            top: 14px;
            left: var(--page-pad);
            right: var(--page-pad);
            padding: .65rem .85rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, .70);
            border: 1px solid rgba(255, 255, 255, .78);
            backdrop-filter: blur(12px);
            box-shadow: var(--shadow3);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: .8rem;
            z-index: 2000;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: .75rem;
            min-width: 0;
            color: var(--ink);
        }

        .brand-mark {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            object-fit: cover;
            border: 1px solid rgba(15, 23, 42, .10);
            background: rgba(255, 255, 255, .85);
            flex: 0 0 auto;
        }

        .brand-txt {
            display: grid;
            line-height: 1.05;
            min-width: 0
        }

        .brand-name {
            font-weight: 900;
            letter-spacing: -.02em;
            color: var(--ink);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .brand-sub {
            font-size: .86rem;
            color: var(--muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .navbar {
            display: flex;
            align-items: center;
            gap: .35rem
        }

        .navbar a {
            padding: .55rem .75rem;
            border-radius: 999px;
            color: #1d4ed8;
            font-weight: 600;
            font-size: 1.02rem;
            transition: background .2s ease, transform .2s ease, color .2s ease;
            white-space: nowrap;
        }

        .navbar a:hover {
            background: rgba(74, 144, 226, .10);
            transform: translateY(-1px);
            color: var(--ink);
        }

        .nav-pill {
            border: 1px solid rgba(74, 144, 226, .35);
            background: rgba(74, 144, 226, .10);
            color: #0f172a !important;
            font-weight: 800;
        }

        .nav-pill:hover {
            background: rgba(74, 144, 226, .18);
            border-color: rgba(74, 144, 226, .45);
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: .55rem;
            flex: 0 0 auto
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .45rem;
            padding: .72rem 1rem;
            background-color: var(--primary);
            color: #fff;
            border: 1px solid var(--primary);
            border-radius: 999px;
            font-weight: 800;
            transition: background-color .25s ease, transform .2s ease, box-shadow .2s ease;
            cursor: pointer;
            user-select: none;
            box-shadow: 0 10px 28px rgba(74, 144, 226, .18);
            white-space: nowrap;
        }

        .btn:hover {
            background-color: transparent;
            color: var(--primary);
            transform: translateY(-1px);
            box-shadow: 0 14px 34px rgba(15, 23, 42, .12);
        }

        .btn-sm {
            padding: .55rem .8rem !important;
            font-size: .95rem !important;
            box-shadow: none !important
        }

        .btn.ghost {
            background: rgba(255, 255, 255, .72);
            border: 1px solid rgba(15, 23, 42, .12);
            color: var(--ink);
            box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
        }

        .btn.ghost:hover {
            background: rgba(255, 255, 255, .88);
            color: var(--ink)
        }

        .menu-btn {
            width: 44px;
            height: 44px;
            border-radius: 999px;
            border: 1px solid rgba(15, 23, 42, .12);
            background: rgba(255, 255, 255, .78);
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
        }

        .menu-btn i {
            color: var(--ink);
            font-size: 1.05rem
        }

        @media (max-width:1024px) {
            .brand-sub {
                display: none
            }

            .menu-btn {
                display: inline-flex
            }

            .navbar {
                position: absolute;
                top: calc(100% + .65rem);
                left: 0;
                right: 0;
                margin: 0 .25rem;
                padding: .75rem;
                background: rgba(74, 144, 226, .96);
                border: 1px solid rgba(255, 255, 255, .35);
                border-radius: 20px;
                backdrop-filter: blur(12px);
                display: grid;
                gap: .4rem;
                transform: translateY(-8px);
                opacity: 0;
                pointer-events: none;
                transition: transform .2s ease, opacity .2s ease;
            }

            .navbar.active {
                transform: translateY(0);
                opacity: 1;
                pointer-events: auto
            }

            .navbar a {
                color: #fff;
                border-radius: 16px;
                padding: .85rem .85rem;
                background: rgba(255, 255, 255, .08);
            }

            .navbar a:hover {
                background: rgba(255, 255, 255, .14);
                transform: none;
                color: #fff
            }

            .nav-pill {
                background: rgba(255, 255, 255, .18);
                border-color: rgba(255, 255, 255, .35);
                color: #fff !important;
            }
        }

        /* PAGE WRAP */
        .wrap {
            max-width: none;
            width: 100%;
            margin: 0;
            padding: 0 var(--page-pad) 2.4rem;
        }

        /* Booking hero (glass like main page) */
        .bookHero {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            margin: 0 0 1rem;
            padding: clamp(1rem, 2.5vw, 1.4rem);
            border-radius: calc(var(--radius) + 6px);
            overflow: hidden;
            background:
                radial-gradient(900px 420px at 10% 15%, rgba(74, 144, 226, .20), transparent 60%),
                radial-gradient(760px 420px at 90% 0%, rgba(217, 120, 0, .14), transparent 58%),
                radial-gradient(760px 520px at 80% 110%, rgba(0, 159, 139, .12), transparent 56%),
                rgba(255, 255, 255, .40);
            border: 1px solid rgba(255, 255, 255, .70);
            backdrop-filter: blur(14px);
            box-shadow: 0 20px 70px rgba(15, 23, 42, .12);
        }

        .heroLeft {
            display: flex;
            gap: 14px;
            align-items: flex-start
        }

        .heroIcon {
            width: 48px;
            height: 48px;
            border-radius: var(--radiusMd);
            background: rgba(255, 255, 255, .82);
            border: 1px solid rgba(15, 23, 42, .10);
            box-shadow: var(--shadow2);
            display: grid;
            place-items: center;
            color: var(--primary);
            flex: 0 0 auto;
        }

        .heroTitle {
            font-size: clamp(1.35rem, 2.25vw, 2.05rem);
            font-weight: 900;
            letter-spacing: -.03em;
            margin: 0;
            line-height: 1.12;
            color: var(--ink);
        }

        .heroSub {
            margin: 8px 0 0;
            color: var(--muted);
            font-size: 14px;
            max-width: 62ch
        }

        .pillRow {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: flex-end
        }

        .pill {
            font-size: 12px;
            padding: 7px 10px;
            border: 1px solid rgba(15, 23, 42, .10);
            border-radius: var(--radiusPill);
            background: rgba(255, 255, 255, .75);
            color: var(--muted);
            box-shadow: var(--shadow2);
            white-space: nowrap;
            backdrop-filter: blur(10px);
        }

        /* Layout */
        .layout {
            display: grid;
            grid-template-columns: 1.05fr .82fr .95fr;
            gap: 18px;
            align-items: start;
        }

        /* Cards */
        .card {
            background: var(--card);
            border: 1px solid rgba(255, 255, 255, .72);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
            overflow: hidden;
        }

        .cardPad {
            padding: 18px
        }

        /* ✅ Preferences (selects) */
        .prefs {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 14px
        }

        .pref {
            display: grid;
            gap: 6px
        }

        .prefs label {
            font-size: 12px;
            color: var(--muted);
            font-weight: 800
        }

        .prefs select {
            width: 100%;
            border-radius: var(--radiusMd);
            padding: 12px 14px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .86);
            box-shadow: var(--shadow2);
            outline: none;
            transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease;
            appearance: none;
            background-image:
                linear-gradient(45deg, transparent 50%, var(--muted) 50%),
                linear-gradient(135deg, var(--muted) 50%, transparent 50%),
                linear-gradient(to right, transparent, transparent);
            background-position:
                calc(100% - 18px) calc(50% - 4px),
                calc(100% - 12px) calc(50% - 4px),
                calc(100% - 2.6em) .5em;
            background-size: 6px 6px, 6px 6px, 1px 1.5em;
            background-repeat: no-repeat;
        }

        .prefs select:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow)
        }

        .prefs select:focus {
            border-color: rgba(74, 144, 226, .45)
        }

        /* Calendar */
        .calTop {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 18px 12px
        }

        .calMonth {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 900;
            letter-spacing: -.02em;
            font-size: 22px;
            color: var(--ink)
        }

        .calMonth .miniIcon {
            width: 34px;
            height: 34px;
            border-radius: var(--radiusMd);
            background: rgba(217, 120, 0, .14);
            border: 1px solid rgba(217, 120, 0, .25);
            display: grid;
            place-items: center;
            color: #a16207;
        }

        .calNav {
            display: flex;
            gap: 8px;
            align-items: center
        }

        .iconBtn {
            width: 40px;
            height: 40px;
            border-radius: var(--radiusPill);
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .86);
            box-shadow: var(--shadow2);
            cursor: pointer;
            transition: transform .14s ease, box-shadow .14s ease;
        }

        .iconBtn:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow)
        }

        .iconBtn:active {
            transform: translateY(0)
        }

        .dow {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            padding: 6px 18px 10px;
            color: var(--muted);
            font-size: 12px;
            letter-spacing: .02em;
        }

        .dow span {
            text-align: center;
            padding: 10px 0;
            font-weight: 800
        }

        .calGridWrap {
            position: relative;
            padding: 0 18px 18px
        }

        .colPill {
            position: absolute;
            top: 0;
            bottom: 18px;
            left: 18px;
            border-radius: var(--radiusPill);
            background: rgba(74, 144, 226, .10);
            opacity: 0;
            transform: translateX(0);
            transition: opacity .16s ease, transform .16s ease;
            pointer-events: none;
        }

        .days {
            display: grid;
            grid-template-columns: repeat(7, minmax(0, 1fr));
            gap: 12px;
            position: relative;
            z-index: 1;
        }

        .day {
            border: 0;
            background: transparent;
            border-radius: var(--radiusMd);
            height: 44px;
            display: grid;
            place-items: center;
            cursor: pointer;
            color: var(--ink);
            position: relative;
            user-select: none;
            transition: transform .14s ease, background .14s ease, box-shadow .14s ease;
        }

        .day:hover {
            background: rgba(15, 23, 42, .04);
            transform: translateY(-1px)
        }

        .day:active {
            transform: translateY(0)
        }

        .day.disabled {
            opacity: .35;
            cursor: not-allowed;
            transform: none !important;
            background: transparent !important
        }

        .day.today {
            outline: 2px solid rgba(74, 144, 226, .22)
        }

        .day.selected {
            background: var(--primary);
            color: #fff;
            box-shadow: 0 14px 28px rgba(74, 144, 226, .22)
        }

        .day .mini {
            position: absolute;
            bottom: -6px;
            width: 6px;
            height: 6px;
            border-radius: 999px;
            background: transparent
        }

        .day.avail .mini {
            background: var(--ok)
        }

        .day.booked .mini {
            background: #f97316
        }

        .day.past .mini {
            background: var(--past)
        }

        .blank {
            visibility: hidden
        }

        /* Middle tabs */
        .tabs {
            display: flex;
            gap: 28px;
            padding: 18px 18px 8px;
            font-weight: 900;
            color: var(--muted);
            justify-content: center;
            user-select: none;
        }

        .tab {
            cursor: pointer;
            padding: 8px 2px;
            border-bottom: 2px solid transparent;
            transition: color .14s ease, border-color .14s ease
        }

        .tab.active {
            color: var(--ink);
            border-color: var(--primary)
        }

        .pane {
            display: none
        }

        .pane.active {
            display: block
        }

        .midHead {
            padding: 14px 18px 10px;
            font-weight: 900;
            letter-spacing: -.01em;
            color: var(--ink);
        }

        .timeWrap {
            padding: 0 18px 18px
        }

        .timeGrid {
            display: grid;
            gap: 10px;
            grid-template-columns: repeat(4, minmax(0, 1fr))
        }

        .slot {
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .86);
            border-radius: var(--radiusMd);
            padding: 12px 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            box-shadow: var(--shadow2);
            transition: transform .14s ease, box-shadow .14s ease, border-color .14s ease, background .14s ease;
        }

        .slot:hover {
            transform: translateY(-1px);
            box-shadow: var(--shadow)
        }

        .slot:active {
            transform: translateY(0)
        }

        .slot.active {
            background: var(--primary);
            color: #fff;
            border-color: transparent;
            box-shadow: 0 16px 34px rgba(74, 144, 226, .22);
        }

        .hint {
            padding: 0 18px 18px;
            text-align: center;
            color: var(--muted);
            font-size: 12px;
            min-height: 16px;
        }

        .midFoot {
            border-top: 1px solid var(--line);
            padding: 14px 18px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            color: var(--muted);
            font-size: 12px;
        }

        .link {
            border: 0;
            background: transparent;
            color: var(--primary);
            font-weight: 900;
            cursor: pointer;
            padding: 0;
            transition: transform .14s ease;
        }

        .link:hover {
            text-decoration: underline;
            transform: translateY(-1px)
        }

        .overviewBox,
        .agendaBox {
            padding: 14px 18px 18px;
            color: var(--muted);
            font-size: 13px;
            line-height: 1.6
        }

        .miniCard {
            margin-top: 12px;
            border: 1px solid var(--line);
            background: rgba(255, 255, 255, .86);
            border-radius: var(--radiusMd);
            box-shadow: var(--shadow2);
            padding: 12px;
            color: var(--ink);
        }

        .miniRow {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            font-size: 12px;
            color: var(--muted)
        }

        .miniRow strong {
            color: var(--ink)
        }

        .agendaBox textarea {
            width: 100%;
            border-radius: var(--radiusMd);
            padding: 12px 14px;
            border: 1px solid var(--line);
            outline: none;
            min-height: 130px;
            resize: vertical;
            margin-top: 10px;
            background: rgba(255, 255, 255, .86);
            box-shadow: var(--shadow2);
            transition: box-shadow .14s ease, transform .14s ease;
        }

        .agendaBox textarea:focus {
            box-shadow: var(--shadow);
            transform: translateY(-1px)
        }

        /* Right panel */
        .side {
            border-radius: 30px;
            background: linear-gradient(180deg, rgba(74, 144, 226, .98), rgba(0, 159, 139, .92));
            color: #fff;
            box-shadow: 0 24px 60px rgba(15, 23, 42, .20);
            border: 1px solid rgba(255, 255, 255, .12);
            overflow: hidden;
            position: sticky;
            top: 12px;
        }

        .sidePad {
            padding: 18px
        }

        .hostCard {
            background: rgba(255, 255, 255, .78);
            color: var(--ink);
            border-radius: var(--radiusMd);
            padding: 14px;
            display: flex;
            gap: 12px;
            align-items: center;
            box-shadow: 0 18px 40px rgba(0, 0, 0, .10);
            margin-top: 12px;
        }

        .hostAvatar {
            width: 52px;
            height: 52px;
            border-radius: var(--radiusPill);
            background: linear-gradient(135deg, rgba(255, 255, 255, .96), rgba(255, 255, 255, .72));
            display: grid;
            place-items: center;
            font-weight: 900;
            color: var(--ink);
            border: 1px solid rgba(15, 23, 42, .10);
            flex: 0 0 auto;
        }

        .hostMeta {
            display: grid;
            gap: 2px
        }

        .loc {
            font-size: 12px;
            color: rgba(15, 23, 42, .72);
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 900;
        }

        .hostName {
            font-weight: 900;
            letter-spacing: -.01em
        }

        .hostRole {
            font-size: 13px;
            color: rgba(15, 23, 42, .72);
            font-weight: 800
        }

        .details {
            margin-top: 18px;
            display: grid;
            gap: 14px
        }

        .dRow {
            display: grid;
            grid-template-columns: 44px 1fr;
            gap: 12px;
            align-items: center
        }

        .dIcon {
            width: 44px;
            height: 44px;
            border-radius: var(--radiusPill);
            border: 1px solid rgba(255, 255, 255, .18);
            background: rgba(255, 255, 255, .10);
            display: grid;
            place-items: center;
        }

        .dLabel {
            font-size: 12px;
            color: rgba(255, 255, 255, .72);
            margin-top: 2px;
            font-weight: 800
        }

        .dValue {
            font-weight: 900;
            letter-spacing: -.01em
        }

        .dValue small {
            font-weight: 900;
            color: rgba(255, 255, 255, .78);
            margin-left: 6px
        }

        /* Form area */
        .formCard {
            margin-top: 18px;
            background: rgba(255, 255, 255, .10);
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: var(--radiusMd);
            padding: 14px;
            backdrop-filter: blur(10px);
        }

        .field {
            display: grid;
            gap: 6px;
            margin-bottom: 10px
        }

        .field label {
            font-size: 12px;
            color: rgba(255, 255, 255, .86);
            font-weight: 900
        }

        .field input,
        .field textarea {
            width: 100%;
            border-radius: var(--radiusMd);
            padding: 12px 14px;
            border: 1px solid rgba(255, 255, 255, .18);
            background: rgba(255, 255, 255, .14);
            color: #fff;
            outline: none;
            transition: transform .14s ease, box-shadow .14s ease;
        }

        .field input::placeholder,
        .field textarea::placeholder {
            color: rgba(255, 255, 255, .68)
        }

        .field input:focus,
        .field textarea:focus {
            transform: translateY(-1px);
            box-shadow: 0 0 0 4px rgba(255, 255, 255, .10)
        }

        .field textarea {
            min-height: 80px;
            resize: vertical
        }

        .hp {
            display: none !important
        }

        /* CTA */
        .joinBtn {
            margin-top: 14px;
            width: 100%;
            border: 0;
            border-radius: var(--radiusPill);
            padding: 14px 16px;
            background: linear-gradient(135deg, var(--cta1), var(--cta2));
            color: #2b2b2b;
            font-weight: 900;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 18px 34px rgba(0, 0, 0, .18);
            transition: transform .14s ease, filter .14s ease, opacity .14s ease;
        }

        .joinBtn:hover {
            transform: translateY(-1px);
            filter: brightness(1.02)
        }

        .joinBtn:active {
            transform: translateY(0)
        }

        .joinBtn:disabled {
            opacity: .55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none
        }

        .status {
            margin-top: 10px;
            font-size: 12px;
            color: rgba(255, 255, 255, .88);
            min-height: 16px;
            font-weight: 800
        }

        .status.error {
            color: #ffd1d1
        }

        .successBox {
            margin-top: 12px;
            background: rgba(255, 255, 255, .10);
            border: 1px solid rgba(255, 255, 255, .16);
            border-radius: var(--radiusMd);
            padding: 14px;
            display: none;
        }

        .successBox h3 {
            margin: 0 0 6px
        }

        .actions {
            margin-top: 10px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap
        }

        .btnOutline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 12px;
            border-radius: var(--radiusPill);
            border: 1px solid rgba(255, 255, 255, .24);
            background: rgba(255, 255, 255, .10);
            color: #fff;
            font-weight: 900;
            transition: transform .14s ease, border-color .14s ease, background .14s ease;
        }

        .btnOutline:hover {
            border-color: rgba(255, 255, 255, .35);
            background: rgba(255, 255, 255, .14);
            transform: translateY(-1px)
        }

        .btnOutline:active {
            transform: translateY(0)
        }

        .bookAnother {
            margin-top: 10px;
            display: inline-block;
            color: rgba(255, 255, 255, .92);
            font-size: 12px;
            font-weight: 900;
            text-decoration: underline;
            cursor: pointer;
        }

        .svg {
            width: 18px;
            height: 18px;
            fill: currentColor;
            opacity: .92
        }

        /* FOOTER (matches main page) */
        .footer {
            background-color: #f9f9f9;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            font-size: .95rem;
            background: rgba(255, 255, 255, .30);
            backdrop-filter: blur(10px);
            border-radius: 25px;
            margin: 2rem var(--page-pad);
            box-shadow: 0 8px 32px rgba(0, 0, 0, .10);
            gap: 0;
        }

        .footer div {
            margin: 1rem;
            flex: 1 1 220px;
            min-width: 220px
        }

        .footer h4 {
            font-size: 1rem;
            margin-bottom: 1rem;
            color: var(--ink)
        }

        .footer ul {
            list-style: none;
            padding: 0
        }

        .footer ul li {
            margin-bottom: .5rem
        }

        .footer ul li a {
            color: #333
        }

        .footer ul li a:hover {
            text-decoration: underline
        }

        #toTopBtn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background-color: var(--primary);
            color: white;
            border: none;
            width: 42px;
            height: 42px;
            border-radius: 999px;
            font-size: 18px;
            cursor: pointer;
            display: none;
            box-shadow: 0 14px 34px rgba(15, 23, 42, .18);
            z-index: 2500;
        }

        #toTopBtn:hover {
            transform: translateY(-1px)
        }

        #toTopBtn:active {
            transform: translateY(0)
        }

        /* ✅ Responsive: layout stacks + selects become 2 columns on phone */
        @media (max-width:1060px) {
            .layout {
                grid-template-columns: 1fr
            }

            .side {
                position: static
            }
        }

        @media (max-width:640px) {
            .wrap {
                padding: 0 var(--page-pad) 2rem
            }

            /* ✅ Make the heading/hero responsive */
            .bookHero {
                gap: 14px;
                flex-direction: column;
                align-items: stretch
            }

            .heroLeft {
                width: 100%
            }

            .pillRow {
                justify-content: flex-start
            }

            .heroTitle {
                font-size: clamp(1.2rem, 6vw, 1.55rem)
            }

            .heroSub {
                font-size: 13px;
                max-width: 100%
            }

            /* ✅ Prevent month heading overflow */
            .calMonth {
                font-size: 20px;
                min-width: 0
            }

            #monthTitle {
                min-width: 0;
                max-width: 220px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis
            }

            .prefs {
                grid-template-columns: repeat(2, minmax(0, 1fr))
            }

            .prefs .pref:last-child {
                grid-column: 1 / -1
            }

            .days {
                gap: 10px
            }

            /* ✅ Schedule grid: 3 cols phone */
            .timeGrid {
                grid-template-columns: repeat(3, minmax(0, 1fr))
            }
        }

        @media (max-width:420px) {
            .prefs {
                grid-template-columns: 1fr
            }

            .prefs .pref:last-child {
                grid-column: auto
            }
        }
    </style>

