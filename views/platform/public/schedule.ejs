                                </div>
                                <div class="dLabel">Time</div>
                            </div>
                        </div>

                        <div class="dRow">
                            <div class="dIcon" aria-hidden="true">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Zm1 5h-2v6l5 3 1-2-4-2Z" />
                                </svg>
                            </div>
                            <div>
                                <div class="dValue"><span id="sumDur">—</span></div>
                                <div class="dLabel">Duration</div>
                            </div>
                        </div>

                        <div class="dRow">
                            <div class="dIcon" aria-hidden="true">
                                <svg class="svg" viewBox="0 0 24 24">
                                    <path d="M4 6h16v2H4V6Zm0 5h16v2H4v-2Zm0 5h10v2H4v-2Z" />
                                </svg>
                            </div>
                            <div>
                                <div class="dValue"><span id="sumMeta">Classic Academy • Demo</span></div>
                                <div class="dLabel">Session</div>
                            </div>
                        </div>
                    </div>

                    <form id="form" class="formCard" autocomplete="on">
