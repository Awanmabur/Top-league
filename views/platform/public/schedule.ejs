                                <path d="M7 2h2v2h6V2h2v2h3v18H4V4h3V2Zm13 6H6v12h14V8Z" />
                            </svg>
                        </div>
                        <span id="monthTitle">—</span>
                    </div>
                    <div class="calNav">
