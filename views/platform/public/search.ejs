        <li><a href="/contact">Customer Support</a></li>
        <li><a href="/schedule">Book a Demo</a></li>
        <li><a href="/faq">FAQ</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li><a href="/terms">Terms</a></li>
      </ul>
    </div>

    <div>
      <h4>Join our school community</h4>
      <ul>
        <li><a href="/schools">Find Schools</a></li>
        <li><a href="/admissions">Admissions</a></li>
        <li><a href="/search">Search</a></li>
        <li><a href="/blog?slug=increase-admissions">Blog</a></li>
        <li><a href="https://chat.whatsapp.com/HRGoS3fMZoZGgXbz1HDw6a?mode=gi_t" target="_blank" rel="noopener">Join whatsapp group</a></li>
      </ul>
    </div>
  </footer>

  <button id="toTopBtn" aria-label="Scroll to top" type="button">↑</button>

  <div class="fab-container" aria-hidden="true">
    <div class="fab shadow">
      <div class="fab-content">
        <span class="material-icons">support_agent</span>
      </div>
    </div>
    <div class="sub-button shadow">
      <a href="tel:+256781977217"><span class="material-icons">phone</span></a>
    </div>
    <div class="sub-button shadow">
      <a href="https://api.whatsapp.com/send?phone=256781977217" target="_blank" rel="noopener">
        <span class="material-icons">
          <svg xmlns="http://www.w3.org/2000/svg" class="whatsapp-icon" viewBox="0 0 448 512" width="35"
            height="35" fill="#2e2e2e" aria-label="WhatsApp Icon">
            <path
              d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zM223.9 438.7c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zM325.1 300.5c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z" />
          </svg>
        </span>
      </a>
    </div>
    <div class="sub-button shadow">
      <a href="/share" target="_blank" rel="noopener"><span class="material-icons">share</span></a>
    </div>
  </div>

  <script src="/pages/search.js"></script>
</body>

