  <!-- Featured Schools -->
  <div class="featured-schoolsp">
    <h2>Featured Schools</h2>
    <p class="schoolsp">
      Explore some of the top-performing schools using Classic Academy platform. These schools stand out for excellence
      in academics, infrastructure, innovation, and student success.
    </p>
  </div>

  <section class="featured-schools">
    <div class="carousel-container">
      <div class="carousel-track" id="featuredTrack">
        <%
          const featuredSchoolsList = Array.isArray(typeof featuredSchools !== "undefined" ? featuredSchools : null)
            ? featuredSchools
            : [];
          const carouselSchools = featuredSchoolsList.length
            ? featuredSchoolsList
            : [{
                name: "Classic Academy",
                type: "Featured School",
                description: "Explore public school profiles, subjects, admissions and updates on Classic Academy.",
                image: "https://images.unsplash.com/photo-1580582932707-520aed937b7b?q=80&w=900&auto=format&fit=crop",
                href: "/schools",
                applyHref: "/schools",
                location: "Browse schools",
                students: 0,
                subjects: 0,
                rating: 0,
                badge: "Featured"
              }];
        %>
        <% carouselSchools.forEach(function(school){ %>
          <div class="card">
            <img src="<%= school.image %>" alt="<%= school.name %>">
            <div class="card-content">
              <span class="school-card-badge"><i class="fa-solid fa-star"></i> <%= school.badge || "Featured" %></span>
              <h3><%= school.name %></h3>
              <p><%= school.description %></p>
              <div class="school-card-meta">
                <% if (school.location) { %>
                  <span><i class="fa-solid fa-location-dot"></i> <%= school.location %></span>
                <% } %>
                <span>
                  <i class="fa-solid fa-layer-group"></i>
                  <%= school.type || "School" %><%= school.subjects ? " - " + Number(school.subjects).toLocaleString() + " subjects" : "" %>
                </span>
                <% if (school.students || school.rating) { %>
                  <span>
                    <i class="fa-solid fa-chart-line"></i>
                    <%= school.students ? Number(school.students).toLocaleString() + " students" : "Public profile" %><%= school.rating ? " - " + school.rating + "/5" : "" %>
                  </span>
                <% } %>
              </div>
              <div class="school-card-actions">
                <a href="<%= school.href %>">Learn More</a>
                <a class="ghost" href="<%= school.applyHref || school.href %>">Apply</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

