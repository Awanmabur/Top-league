      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: rgba(255, 255, 255, .6);
      border: 1px solid rgba(15, 23, 42, .12);
      box-shadow: 0 8px 20px rgba(15, 23, 42, .08);
      transition: transform .2s ease;
    }

    .icon-btn:hover {
      transform: translateY(-2px);
    }

    .icon-btn i {
      color: #0f172a;
    }

    .ccta {
      display: flex;
      gap: .6rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .cmini {
      display: flex;
      gap: .6rem;
      align-items: center;
      margin-top: 1rem;
      color: #64748b;
    }

    .cmini i {
      color: #16a34a;
    }

    .cform label {
      display: block;
      margin-bottom: .85rem;
    }

    .cform span {
      display: block;
      font-weight: 700;
      color: #0f172a;
      margin-bottom: .35rem;
    }

    .cform input {
      width: 100%;
      padding: .82rem .95rem;
      border-radius: 999px;
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(255, 255, 255, .80);
      outline: none;
    }

    .cform textarea {
      width: 100%;
      padding: .85rem 1rem;
      border-radius: 22px;
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(255, 255, 255, .80);
      outline: none;
      resize: vertical;
    }

    .cform input:focus,
    .cform textarea:focus {
      border-color: rgba(74, 144, 226, .65);
      box-shadow: 0 0 0 4px rgba(74, 144, 226, .12);
    }

    .cform .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .8rem;
    }

    .form-actions {
      display: flex;
      gap: .6rem;
      flex-wrap: nowrap;
      margin-top: .25rem;
      align-items: center;
    }

    .form-actions>* {
      flex: 1 1 0;
    }

    @media (max-width: 520px) {
      .form-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
      }

      .form-actions .btn,
      .form-actions button.btn {
        width: 100%;
      }
    }

    .form-note {
      margin: .75rem 0 0 0;
      color: #64748b;
      font-size: .9rem;
    }

    @media (max-width: 860px) {
      .cgrid {
        grid-template-columns: 1fr;
      }

      .cform .row {
        grid-template-columns: 1fr;
      }
    }

    /* FOOTER */
    .footer {
      background-color: #f9f9f9;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      font-size: 0.95rem;
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(10px);
      border-radius: 25px;
      margin: 2rem var(--page-pad);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      gap: 0;
    }

    .footer div {
      margin: 1rem;
      flex: 1 1 220px;
      min-width: 220px;
    }

    .footer h4 {
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .footer ul {
      list-style: none;
      padding: 0;
    }

    .footer ul li {
      margin-bottom: 0.5rem;
    }

    .footer ul li a {
      color: #333;
    }

    .footer ul li a:hover {
      text-decoration: underline;
    }

    #toTopBtn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background-color: var(--primary);
      color: white;
      border: none;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.5rem;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
      display: none;
      z-index: 1000;
      transition: transform 0.2s ease;
    }

    #toTopBtn:hover {
      transform: scale(1.08);
    }

    .fab-container {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      position: fixed;
      bottom: 170px;
      right: 20px;
      z-index: 999;
    }

    .whatsapp-icon {
      transition: fill 0.3s ease;
      cursor: pointer;
    }

    .whatsapp-icon:hover {
      fill: white;
    }

    .fab-container:hover {
      height: 100%;
    }

    .fab-container:hover .sub-button:nth-child(2) {
      transform: translateY(-80px);
    }

    .fab-container:hover .sub-button:nth-child(3) {
      transform: translateY(-140px);
    }

    .fab-container:hover .sub-button:nth-child(4) {
      transform: translateY(-200px);
    }

    .fab-container .sub-button {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      bottom: 10px;
      right: 10px;
      height: 50px;
      width: 50px;
      background-color: #4ba2ff;
      border-radius: 50%;
      transition: all 0.3s ease;
    }

    .fab-container .sub-button:hover {
      cursor: pointer;
    }

    .fab-container .sub-button .material-icons {
      color: #2e2e2e;
      padding-top: 6px;
    }

    .fab-container .sub-button .material-icons:hover {
      color: #FEFEFE;
    }

    .fab-container .fab {
      position: relative;
      height: 70px;
      width: 70px;
      background-color: #4ba2ff;
      border-radius: 50%;
      z-index: 2;
    }

    .fab-container .fab:before {
      content: " ";
      position: absolute;
      bottom: 0;
      right: 0;
      height: 35px;
      width: 35px;
      background-color: inherit;
      border-radius: 0 0 10px 0;
      z-index: -1;
    }

    .fab-container .fab .fab-content {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 100%;
      border-radius: 50%;
      cursor: pointer;
      user-select: none;
    }

    .fab-container .fab .fab-content .material-icons {
      color: #2e2e2e;
      font-size: 48px;
    }

    /* Mobile perf */
    @media (max-width: 600px) {

      .header,
      .hero,
      .features,
      .p4-wrap,
      .tcard,
      .blogs-wrap,
      .cinfo,
      .cform,
      .footer,
      .navbar {
        backdrop-filter: none !important;
      }

      .header {
        box-shadow: 0 10px 26px rgba(15, 23, 42, .10);
      }

      .hero {
        box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
      }

      .p4-wrap {
        box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
      }

      .tcard {
        box-shadow: 0 14px 40px rgba(15, 23, 42, .10);
      }
    }

    @media (max-width: 1024px) {
      .features {
        padding: 1.2rem 1.2rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .orbit-wrapper {
        padding: 2.2rem var(--page-pad);
      }

      .feature-list {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 600px) {
      .feature-list {
        grid-template-columns: none;
        grid-template-rows: repeat(4, minmax(72px, auto));
        grid-auto-flow: column;
        grid-auto-columns: minmax(235px, 82vw);
        overflow-x: auto;
        overscroll-behavior-inline: contain;
        scroll-snap-type: x mandatory;
        padding-bottom: .55rem;
      }

      .feature-item {
        scroll-snap-align: start;
      }
    }

    @media (max-width: 480px) {
      .features {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      }

      .orbit-section {
        height: min(420px, 92vw);
      }

      .orbit-ring {
        width: min(260px, 72vw);
        height: min(260px, 72vw);
      }

      .fab-container {
        bottom: 180px;
      }

      .footer h4 {
        font-size: 1.15rem;
      }
    }

    @media (max-width: 920px) and (orientation: landscape) {
      .orbit-section {
        height: min(420px, 70vw);
      }
    }
  </style>
</head>

