  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Outfit:wght@100..900&display=swap");

    :root {
      --primary: #4a90e2;
      --accent: #d97800;
      --highlight: #009f8b;

      --ink: #0f172a;
      --muted: #475569;

      --page-pad: clamp(1rem, 4vw, 6rem);
      --section-gap: clamp(1.2rem, 2.6vw, 2rem);

      --shadow2: 0 18px 50px rgba(15, 23, 42, .12);
      --shadow3: 0 10px 30px rgba(15, 23, 42, .10);

      --radius: 22px;
    }

    html {
      scroll-behavior: smooth;
    }

    a {
      text-decoration: none;
    }

    section,
    footer,
    .featured-schoolsp,
    .featured-schools {
      scroll-margin-top: 120px;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      line-height: 1.6;
      background: #e0f7fa;
      color: #333;
      overflow-x: clip;
      -webkit-overflow-scrolling: touch;
      padding-top: 112px;
    }

    @media (max-width: 600px) {
      body {
        padding-top: 102px;
      }
    }

    /* LOADER */
    #loader {
      position: fixed;
      inset: 0;
      background: #e0f7fa;
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 1.2rem;
      text-align: center;
    }

    .academylogo {
      width: min(220px, 70vw);
    }

    .academylogo img {
      width: 100%;
      height: auto;
      display: block;
    }

    .loader {
      position: relative;
      width: 18px;
      height: 28px;
      perspective: 500px;
      animation: flip 2s infinite;
    }

    .loader:nth-child(3) {
      animation-delay: 0.2s;
    }

    .loader:nth-child(4) {
      animation-delay: 0.4s;
    }

    .loader:nth-child(5) {
      animation-delay: 0.6s;
    }

    .loader:nth-child(6) {
      animation-delay: 0.8s;
    }

    .face {
      position: absolute;
      width: 100%;
      height: 100%;
      backface-visibility: hidden;
      border-radius: 4px;
    }

    .front {
      background: var(--primary);
    }

    .back {
      background: #d35400;
      transform: rotateY(180deg);
    }

    @keyframes flip {

      0%,
      100% {
        transform: rotateY(0deg);
      }

      50% {
        transform: rotateY(180deg);
      }
    }

    /* NAVBAR */
    .header {
      position: fixed;
      top: 14px;
      left: var(--page-pad);
      right: var(--page-pad);
      padding: .65rem .85rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .70);
      border: 1px solid rgba(255, 255, 255, .78);
      backdrop-filter: blur(12px);
      box-shadow: 0 16px 46px rgba(15, 23, 42, .10);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .8rem;
      z-index: 2000;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .75rem;
      min-width: 0;
      color: var(--ink);
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      object-fit: cover;
      border: 1px solid rgba(15, 23, 42, .10);
      background: rgba(255, 255, 255, .85);
      flex: 0 0 auto;
    }

    .brand-txt {
      display: grid;
      line-height: 1.05;
      min-width: 0;
    }

    .brand-name {
      font-weight: 900;
      letter-spacing: -.02em;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand-sub {
      font-size: .86rem;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .navbar {
      display: flex;
      align-items: center;
      gap: .35rem;
    }

    .navbar a {
      padding: .55rem .75rem;
      border-radius: 999px;
      color: #1d4ed8;
      font-weight: 600;
      font-size: 1.02rem;
      transition: background .2s ease, transform .2s ease, color .2s ease;
      white-space: nowrap;
    }

    .navbar a:hover {
      background: rgba(74, 144, 226, .10);
      transform: translateY(-1px);
      color: var(--ink);
    }

    .nav-pill {
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(74, 144, 226, .10);
      color: #0f172a !important;
      font-weight: 800;
    }

    .nav-pill:hover {
      background: rgba(74, 144, 226, .18);
      border-color: rgba(74, 144, 226, .45);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: .55rem;
      flex: 0 0 auto;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      padding: 0.72rem 1rem;
      background-color: var(--primary);
      color: white;
      border: 1px solid var(--primary);
      border-radius: 999px;
      font-weight: 800;
      transition: background-color .25s ease, transform .2s ease, box-shadow .2s ease;
      cursor: pointer;
      user-select: none;
      box-shadow: 0 10px 28px rgba(74, 144, 226, .18);
      white-space: nowrap;
    }

    .btn:hover {
      background-color: transparent;
      color: var(--primary);
      transform: translateY(-1px);
      box-shadow: 0 14px 34px rgba(15, 23, 42, .12);
    }

    .btn.ghost {
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(15, 23, 42, .12);
      color: var(--ink);
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .btn.ghost:hover {
      background: rgba(255, 255, 255, .88);
      color: var(--ink);
    }

    .btn-sm {
      padding: .55rem .8rem !important;
      font-size: .95rem !important;
      box-shadow: none !important;
    }

    .menu-btn {
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(15, 23, 42, .12);
      background: rgba(255, 255, 255, .78);
      display: none;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .menu-btn i {
      color: var(--ink);
      font-size: 1.05rem;
    }

    @media (max-width: 1024px) {
      .brand-sub {
        display: none;
      }

      .menu-btn {
        display: inline-flex;
      }

      .navbar {
        position: absolute;
        top: calc(100% + .65rem);
        left: 0;
        right: 0;
        margin: 0 .25rem;
        padding: .75rem;
        background: rgba(74, 144, 226, .96);
        border: 1px solid rgba(255, 255, 255, .35);
        border-radius: 20px;
        backdrop-filter: blur(12px);
        display: grid;
        gap: .4rem;
        transform: translateY(-8px);
        opacity: 0;
        pointer-events: none;
        transition: transform .2s ease, opacity .2s ease;
      }

      .navbar.active {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      .navbar a {
        color: #fff;
        border-radius: 16px;
        padding: .85rem .85rem;
        background: rgba(255, 255, 255, .08);
      }

      .navbar a:hover {
        background: rgba(255, 255, 255, .14);
        transform: none;
        color: #fff;
      }

      .nav-pill {
        background: rgba(255, 255, 255, .18);
        border-color: rgba(255, 255, 255, .35);
        color: #fff !important;
      }
    }

    /* Mobile perf */
    @media (max-width: 600px) {

      .header,
      .hero,
      .features,
      .p4-wrap,
      .tcard,
      .blogs-wrap,
      .cinfo,
      .cform,
      .footer,
      .navbar,
      .about-hero,
      .cardx {
        backdrop-filter: none !important;
      }

      .header {
        box-shadow: 0 10px 26px rgba(15, 23, 42, .10);
      }
    }

    /* ===== Inner pages (shared) ===== */
    .about-hero {
      margin: 0 var(--page-pad);
      border-radius: 26px;
      background: rgba(255, 255, 255, .28);
      backdrop-filter: blur(14px);
      border: 1px solid rgba(255, 255, 255, .55);
      box-shadow: 0 18px 50px rgba(15, 23, 42, .12);
      padding: 2rem 2rem;
      display: grid;
      grid-template-columns: 1.25fr .9fr;
      gap: 1.8rem;
      align-items: center;
    }

    .about-hero h1 {
      font-size: 2.2rem;
      color: #0f172a;
      line-height: 1.12;
      margin-top: .6rem;
    }

    .about-hero p {
      margin-top: .65rem;
      color: #475569;
      max-width: 58ch;
    }

    .about-hero .kicker {
      display: inline-flex;
      gap: .55rem;
      align-items: center;
      padding: .45rem .8rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .6);
      border: 1px solid rgba(255, 255, 255, .75);
      color: #1f2a44;
      font-weight: 700;
      font-size: .95rem;
    }

    .about-hero .actions {
      display: flex;
      gap: .75rem;
      flex-wrap: wrap;
      margin-top: 1.1rem;
    }

    .about-hero .actions .btn {
      margin-left: 0;
    }

    .about-hero .media {
      border-radius: 22px;
      overflow: hidden;
      background: rgba(255, 255, 255, .55);
      border: 1px solid rgba(255, 255, 255, .75);
      box-shadow: 0 16px 40px rgba(15, 23, 42, .10);
    }

    .about-hero .media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .page-wrap {
      margin: 0 var(--page-pad);
      padding: 2.2rem 0 2.8rem 0;
    }

    .cardx {
      background: rgba(255, 255, 255, .70);
      border: 1px solid rgba(255, 255, 255, .85);
      border-radius: 22px;
      box-shadow: 0 12px 30px rgba(15, 23, 42, .10);
      padding: 1.2rem 1.15rem;
    }

    .cardx h3 {
      margin: 0;
      color: #0f172a;
      font-size: 1.15rem;
    }

    .cardx p {
      margin-top: .6rem;
      color: #475569;
    }

    .cardx ul {
      list-style: none;
      padding: 0;
      margin: .6rem 0 0 0;
      display: grid;
      gap: .5rem;
    }

    .cardx li {
      display: flex;
      gap: .6rem;
      align-items: flex-start;
      color: #1f2937;
    }

    .cardx li i {
      color: #16a34a;
      margin-top: .25rem;
    }

    @media (max-width: 1024px) {
      .about-hero {
        grid-template-columns: 1fr;
        padding: 1.25rem;
      }

      .about-hero h1 {
        font-size: 1.9rem;
      }
    }

    @media (max-width: 600px) {
      .about-hero h1 {
        font-size: 1.75rem;
      }
    }

    /* FOOTER */
    .footer {
      background-color: #f9f9f9;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      font-size: 0.95rem;
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(10px);
      border-radius: 25px;
      margin: 2rem var(--page-pad);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      gap: 0;
    }

    .footer div {
      margin: 1rem;
      flex: 1 1 220px;
      min-width: 220px;
    }

    .footer h4 {
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .footer ul {
      list-style: none;
      padding: 0;
    }

    .footer ul li {
      margin-bottom: 0.5rem;
    }

    .footer ul li a {
      color: #333;
    }

    .footer ul li a:hover {
      text-decoration: underline;
    }

    #toTopBtn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background-color: var(--primary);
      color: white;
      border: none;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.5rem;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
      display: none;
      z-index: 1000;
      transition: transform 0.2s ease;
    }

    #toTopBtn:hover {
      transform: scale(1.08);
    }

    .fab-container {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      position: fixed;
      bottom: 170px;
      right: 20px;
      z-index: 999;
    }

    .whatsapp-icon {
      transition: fill 0.3s ease;
      cursor: pointer;
    }

    .whatsapp-icon:hover {
      fill: white;
    }

    .fab-container:hover {
      height: 100%;
    }

    .fab-container:hover .sub-button:nth-child(2) {
      transform: translateY(-80px);
    }

    .fab-container:hover .sub-button:nth-child(3) {
      transform: translateY(-140px);
    }

    .fab-container:hover .sub-button:nth-child(4) {
      transform: translateY(-200px);
    }

    .fab-container .sub-button {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      bottom: 10px;
      right: 10px;
      height: 50px;
      width: 50px;
      background-color: #4ba2ff;
      border-radius: 50%;
      transition: all 0.3s ease;
    }

    .fab-container .sub-button:hover {
      cursor: pointer;
    }

    .fab-container .sub-button .material-icons {
      color: #2e2e2e;
      padding-top: 6px;
    }

    .fab-container .sub-button .material-icons:hover {
      color: #FEFEFE;
    }

    .fab-container .fab {
      position: relative;
      height: 70px;
      width: 70px;
      background-color: #4ba2ff;
      border-radius: 50%;
      z-index: 2;
    }

    .fab-container .fab:before {
      content: " ";
      position: absolute;
      bottom: 0;
      right: 0;
      height: 35px;
      width: 35px;
      background-color: inherit;
      border-radius: 0 0 10px 0;
      z-index: -1;
    }

    .fab-container .fab .fab-content {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 100%;
      border-radius: 50%;
      cursor: pointer;
      user-select: none;
    }

    .fab-container .fab .fab-content .material-icons {
      color: #2e2e2e;
      font-size: 48px;
    }
  </style>
</head>

