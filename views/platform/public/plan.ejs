    }

    .p4-chips {
      margin-top: .75rem;
      display: flex;
      flex-wrap: wrap;
      gap: .45rem;
    }

    .p4-chip {
      display: inline-flex;
      gap: .35rem;
      align-items: center;
      padding: .32rem .55rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .85);
      border: 1px solid rgba(15, 23, 42, .10);
