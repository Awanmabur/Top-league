      align-items: center;
      gap: .4rem;
      padding: .35rem .65rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, .06);
      border: 1px solid rgba(15, 23, 42, .10);
      color: var(--ink);
      font-weight: 900;
      font-size: .8rem;
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .p4-tag.hot {
      background: rgba(217, 120, 0, .12);
      border-color: rgba(217, 120, 0, .22);
      color: #9a3412;
    }

    .p4-tag.free {
      background: rgba(0, 159, 139, .12);
      border-color: rgba(0, 159, 139, .22);
      color: #065f46;
    }

    .p4-pricebox {
      margin-top: .85rem;
      padding: .85rem .9rem;
      border-radius: 18px;
      background: rgba(74, 144, 226, .08);
      border: 1px solid rgba(74, 144, 226, .18);
      display: flex;
      align-items: baseline;
      gap: .45rem;
    }

    .p4-price {
      font-size: 1.75rem;
      font-weight: 1000;
      color: var(--ink);
      letter-spacing: -.02em;
    }

    .p4-per {
