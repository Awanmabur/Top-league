  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    @import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=Outfit:wght@100..900&display=swap");

    :root {
      --primary: #4a90e2;
      --accent: #d97800;
      --highlight: #009f8b;

      --ink: #0f172a;
      --muted: #475569;

      --page-pad: clamp(1rem, 4vw, 6rem);
      --section-gap: clamp(1.2rem, 2.6vw, 2rem);

      --shadow2: 0 18px 50px rgba(15, 23, 42, .12);
      --shadow3: 0 10px 30px rgba(15, 23, 42, .10);

      --radius: 22px;
    }

    html {
      scroll-behavior: smooth;
    }

    a {
      text-decoration: none;
    }

    section,
    footer,
    .featured-schoolsp,
    .featured-schools {
      scroll-margin-top: 120px;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      line-height: 1.6;
      background: #e0f7fa;
      color: #333;
      overflow-x: clip;
      -webkit-overflow-scrolling: touch;
      padding-top: 112px;
    }

    @media (max-width: 600px) {
      body {
        padding-top: 102px;
      }
    }

    /* LOADER */
    #loader {
      position: fixed;
      inset: 0;
      background: #e0f7fa;
      display: flex;
      flex-direction: column;
      gap: 14px;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      padding: 1.2rem;
      text-align: center;
    }

    .academylogo {
      width: min(220px, 70vw);
    }

    .academylogo img {
      width: 100%;
      height: auto;
      display: block;
    }

    .loader {
      position: relative;
      width: 18px;
      height: 28px;
      perspective: 500px;
      animation: flip 2s infinite;
    }

    .loader:nth-child(3) {
      animation-delay: 0.2s;
    }

    .loader:nth-child(4) {
      animation-delay: 0.4s;
    }

    .loader:nth-child(5) {
      animation-delay: 0.6s;
    }

    .loader:nth-child(6) {
      animation-delay: 0.8s;
    }

    .face {
      position: absolute;
      width: 100%;
      height: 100%;
      backface-visibility: hidden;
      border-radius: 4px;
    }

    .front {
      background: var(--primary);
    }

    .back {
      background: #d35400;
      transform: rotateY(180deg);
    }

    @keyframes flip {

      0%,
      100% {
        transform: rotateY(0deg);
      }

      50% {
        transform: rotateY(180deg);
      }
    }

    /* NAVBAR */
    .header {
      position: fixed;
      top: 14px;
      left: var(--page-pad);
      right: var(--page-pad);
      padding: .65rem .85rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .70);
      border: 1px solid rgba(255, 255, 255, .78);
      backdrop-filter: blur(12px);
      box-shadow: 0 16px 46px rgba(15, 23, 42, .10);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: .8rem;
      z-index: 2000;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: .75rem;
      min-width: 0;
      color: var(--ink);
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      border-radius: 14px;
      object-fit: cover;
      border: 1px solid rgba(15, 23, 42, .10);
      background: rgba(255, 255, 255, .85);
      flex: 0 0 auto;
    }

    .brand-txt {
      display: grid;
      line-height: 1.05;
      min-width: 0;
    }

    .brand-name {
      font-weight: 900;
      letter-spacing: -.02em;
      color: var(--ink);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand-sub {
      font-size: .86rem;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .navbar {
      display: flex;
      align-items: center;
      gap: .35rem;
    }

    .navbar a {
      padding: .55rem .75rem;
      border-radius: 999px;
      color: #1d4ed8;
      font-weight: 600;
      font-size: 1.02rem;
      transition: background .2s ease, transform .2s ease, color .2s ease;
      white-space: nowrap;
    }

    .navbar a:hover {
      background: rgba(74, 144, 226, .10);
      transform: translateY(-1px);
      color: var(--ink);
    }

    .nav-pill {
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(74, 144, 226, .10);
      color: #0f172a !important;
      font-weight: 800;
    }

    .nav-pill:hover {
      background: rgba(74, 144, 226, .18);
      border-color: rgba(74, 144, 226, .45);
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: .55rem;
      flex: 0 0 auto;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      padding: 0.72rem 1rem;
      background-color: var(--primary);
      color: white;
      border: 1px solid var(--primary);
      border-radius: 999px;
      font-weight: 800;
      transition: background-color .25s ease, transform .2s ease, box-shadow .2s ease;
      cursor: pointer;
      user-select: none;
      box-shadow: 0 10px 28px rgba(74, 144, 226, .18);
      white-space: nowrap;
    }

    .btn:hover {
      background-color: transparent;
      color: var(--primary);
      transform: translateY(-1px);
      box-shadow: 0 14px 34px rgba(15, 23, 42, .12);
    }

    .btn.ghost {
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(15, 23, 42, .12);
      color: var(--ink);
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .btn.ghost:hover {
      background: rgba(255, 255, 255, .88);
      color: var(--ink);
    }

    .btn-sm {
      padding: .55rem .8rem !important;
      font-size: .95rem !important;
      box-shadow: none !important;
    }

    .menu-btn {
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(15, 23, 42, .12);
      background: rgba(255, 255, 255, .78);
      display: none;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .menu-btn i {
      color: var(--ink);
      font-size: 1.05rem;
    }

    @media (max-width: 1024px) {
      .brand-sub {
        display: none;
      }

      .menu-btn {
        display: inline-flex;
      }

      .navbar {
        position: absolute;
        top: calc(100% + .65rem);
        left: 0;
        right: 0;
        margin: 0 .25rem;
        padding: .75rem;
        background: rgba(74, 144, 226, .96);
        border: 1px solid rgba(255, 255, 255, .35);
        border-radius: 20px;
        backdrop-filter: blur(12px);
        display: grid;
        gap: .4rem;
        transform: translateY(-8px);
        opacity: 0;
        pointer-events: none;
        transition: transform .2s ease, opacity .2s ease;
      }

      .navbar.active {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      .navbar a {
        color: #fff;
        border-radius: 16px;
        padding: .85rem .85rem;
        background: rgba(255, 255, 255, .08);
      }

      .navbar a:hover {
        background: rgba(255, 255, 255, .14);
        transform: none;
        color: #fff;
      }

      .nav-pill {
        background: rgba(255, 255, 255, .18);
        border-color: rgba(255, 255, 255, .35);
        color: #fff !important;
      }
    }

    /* HERO (unchanged) */
    .hero {
      position: relative;
      margin: 0 var(--page-pad);
      margin-bottom: 2rem;
      border-radius: calc(var(--radius) + 6px);
      overflow: hidden;
      background:
        radial-gradient(900px 420px at 10% 15%, rgba(74, 144, 226, .20), transparent 60%),
        radial-gradient(760px 420px at 90% 0%, rgba(217, 120, 0, .14), transparent 58%),
        radial-gradient(760px 520px at 80% 110%, rgba(0, 159, 139, .12), transparent 56%),
        rgba(255, 255, 255, .40);
      border: 1px solid rgba(255, 255, 255, .70);
      backdrop-filter: blur(14px);
      box-shadow: 0 20px 70px rgba(15, 23, 42, .12);
      padding: clamp(1.1rem, 2.5vw, 2rem);
      opacity: 0;
      transform: translateY(26px);
      transition: all 0.8s ease;
    }

    .hero.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1.12fr .88fr;
      align-items: center;
      gap: clamp(1rem, 2.6vw, 2rem);
    }

    .hero-kicker {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      padding: .45rem .75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .65);
      border: 1px solid rgba(255, 255, 255, .8);
      color: #1b2a4e;
      font-weight: 800;
      width: fit-content;
      box-shadow: 0 10px 26px rgba(15, 23, 42, .08);
    }

    .hero-content h1 {
      margin-top: .9rem;
      font-size: clamp(1.55rem, 2.55vw, 2.45rem);
      line-height: 1.15;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .hero-content h1 span {
      color: var(--primary);
    }

    .hero-sub {
      margin-top: .75rem;
      color: #24324f;
      font-size: clamp(1rem, 1.2vw, 1.08rem);
      max-width: 64ch;
    }

    .hero-points {
      margin-top: 1rem;
      display: grid;
      gap: .55rem;
      max-width: 68ch;
    }

    .hero-point {
      display: flex;
      gap: .6rem;
      align-items: flex-start;
      color: #0f172a;
      font-size: .98rem;
    }

    .hero-point i {
      color: #16a34a;
      margin-top: .2rem;
    }

    .hero-btn {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      margin-top: 1.1rem;
    }

    @media (max-width: 520px) {
      .hero-btn {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
      }

      .hero-btn .btn {
        width: 100%;
        padding: .62rem .7rem;
        font-size: .95rem;
        box-shadow: none;
      }
    }

    .hero-stats {
      margin-top: 1.1rem;
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: .7rem;
      max-width: 620px;
    }

    .stat {
      border-radius: 16px;
      padding: .75rem .8rem;
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(255, 255, 255, .85);
      box-shadow: 0 14px 34px rgba(15, 23, 42, .08);
    }

    .stat strong {
      display: block;
      font-size: 1.05rem;
      color: var(--ink);
      letter-spacing: -.01em;
    }

    .stat span {
      display: block;
      margin-top: .15rem;
      font-size: .9rem;
      color: var(--muted);
    }

    .hero-media {
      min-width: 280px;
      display: grid;
      gap: .8rem;
      justify-items: center;
    }

    .hero-image {
      width: 100%;
      border-radius: calc(var(--radius) + 6px);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, .85);
      box-shadow: 0 22px 70px rgba(15, 23, 42, .14);
      background: rgba(255, 255, 255, .65);
    }

    .hero-image img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: calc(var(--radius) + 6px);
    }

    .hero-note {
      width: 100%;
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(255, 255, 255, .85);
      border-radius: 18px;
      padding: .85rem .9rem;
      box-shadow: 0 14px 34px rgba(15, 23, 42, .08);
      display: flex;
      gap: .75rem;
      align-items: flex-start;
    }

    .hero-note i {
      color: var(--primary);
      margin-top: .25rem;
    }

    .hero-note p {
      margin: 0;
      color: var(--muted);
      font-size: .95rem;
    }

    @media (max-width: 920px) {
      .hero-inner {
        grid-template-columns: 1fr;
      }

      .hero-stats {
        grid-template-columns: 1fr;
      }
    }

    /* FEATURE TILES */
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
      padding: 1.25rem 2rem;
      text-align: center;
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(10px);
      border-radius: 25px;
      margin: 2rem var(--page-pad);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    .feature {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease;
    }

    .feature.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .feature img {
      width: 50px;
      margin-bottom: 1rem;
    }

    .feature h3 {
      font-size: 1.2rem;
      margin-top: -8px;
      margin-bottom: 6px;
      font-weight: 500;
    }

    .feature p {
      font-size: 1rem;
      color: #555;
    }

    /* FEATURED SCHOOLS */
    .featured-schoolsp {
      text-align: center;
      margin: 0 var(--page-pad);
      padding-top: .5rem;
    }

    .featured-schoolsp h2 {
      font-size: clamp(1.4rem, 2.2vw, 2rem);
      margin-bottom: .7rem;
      color: #111;
    }

    .featured-schoolsp p {
      max-width: 900px;
      margin: 0 auto 1rem auto;
      color: #555;
    }

    .featured-schools {
      background: rgba(255, 255, 255, .55);
      padding: 2.2rem var(--page-pad);
      overflow: hidden;
      margin-top: 1rem;
    }

    .carousel-container {
      width: 100%;
      overflow: hidden;
    }

    .carousel-track {
      display: flex;
      gap: 1.2rem;
      width: max-content;
      padding-bottom: .25rem;
      will-change: transform;
      animation: scrollLeft 40s linear infinite;
    }

    .carousel-container:hover .carousel-track {
      animation-play-state: paused;
    }

    @keyframes scrollLeft {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    .card {
      background: #fff;
      border-radius: 1rem;
      width: 300px;
      min-width: 300px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease;
      flex: 0 0 auto;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
    }

    .card-content {
      padding: 1rem;
    }

    .card h3 {
      font-size: 1.15rem;
      margin-bottom: 0.5rem;
      color: var(--primary);
    }

    .card p {
      font-size: 0.95rem;
      color: #64748b;
      margin-bottom: 1rem;
      text-align: left;
    }

    .card a {
      background-color: var(--primary);
      color: #fff;
      padding: 0.5rem 1rem;
      border-radius: 2rem;
      font-weight: 800;
      align-self: flex-start;
    }

    /* ORBIT */
    .orbit-wrapper {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: flex-start;
      gap: var(--section-gap);
      padding: 3rem var(--page-pad);
    }

    .feature-intro {
      flex: 1 1 100%;
      padding: 0 0 1.2rem 0;
    }

    .feature-intro h3 {
      font-size: clamp(1.4rem, 2vw, 1.75rem);
      color: #111;
      margin-bottom: 0.5rem;
    }

    .feature-intro p {
      font-size: 1rem;
      color: #555;
      max-width: 820px;
    }

    .orbit-section {
      position: relative;
      width: min(500px, 100%);
      height: min(500px, 85vw);
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
      flex: 1 1 420px;
      min-width: 280px;
    }

    .orbit-center {
      width: clamp(90px, 14vw, 150px);
      height: clamp(90px, 14vw, 150px);
      border-radius: 50%;
      background: #eee;
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 2;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    .orbit-center img {
      width: 100%;
      border-radius: 50%;
    }

    .orbit-ring {
      position: absolute;
      width: min(350px, 70vw);
      height: min(350px, 70vw);
      border-radius: 50%;
      animation: spin 30s linear infinite;
    }

    .orbit-ring:hover {
      animation-play-state: paused;
    }

    .orbit-feature {
      position: absolute;
      width: clamp(92px, 16vw, 120px);
      text-align: center;
      transform-origin: center center;
    }

    .orbit-feature-content {
      transform: rotate(calc(-1 * var(--angle)));
    }

    .orbit-feature img {
      width: 40px;
      margin-bottom: 0.5rem;
    }

    .orbit-feature p {
      font-size: 0.9rem;
    }

    @keyframes spin {
      from {
        transform: rotate(0deg);
      }

      to {
        transform: rotate(360deg);
      }
    }

    .feature-list {
      flex: 1 1 420px;
      min-width: 280px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      align-content: start;
    }

    .feature-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .feature-item i {
      color: var(--primary);
      font-size: 1.2rem;
      margin-top: 0.2rem;
    }

    .feature-item div {
      font-size: 0.95rem;
      color: var(--ink);
    }

    /* REVEAL */
    .reveal {
      opacity: 0;
      transform: translateY(14px);
      transition: all .7s ease;
    }

    .reveal.in {
      opacity: 1;
      transform: translateY(0);
    }

    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }

      * {
        scroll-behavior: auto !important;
      }

      .carousel-track {
        animation: none !important;
      }
    }

    /* PRICING */
    .pricing-v4 {
      padding: 3rem 0;
      background:
        radial-gradient(900px 420px at 18% 0%, rgba(74, 144, 226, .10), transparent 60%),
        radial-gradient(760px 420px at 85% 10%, rgba(217, 120, 0, .08), transparent 58%),
