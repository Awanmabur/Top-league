      display: flex;
      gap: .55rem;
      flex-wrap: wrap;
      padding-top: .95rem;
    }

    /* ✅ ONLY for Add-ons card: keep 2 buttons in one row on phone */
    @media (max-width: 520px) {
      .p4-card.addons .p4-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
