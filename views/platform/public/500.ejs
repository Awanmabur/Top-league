<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Server Error | Classic Academy</title>
  <meta name="robots" content="noindex,nofollow" />
  <meta name="theme-color" content="#4a90e2" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      font-family: Segoe UI, Tahoma, Geneva, Verdana, sans-serif;
      color: #0f172a;
      background: #e0f7fa;
      display: grid;
      place-items: center;
      padding: 24px;
    }
    .error-page {
      width: min(760px, 100%);
      background: #fff;
      border: 1px solid rgba(15, 23, 42, .08);
      border-radius: 18px;
      box-shadow: 0 20px 60px rgba(15, 23, 42, .12);
      padding: clamp(24px, 5vw, 44px);
    }
    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: #0a3d62;
      font-weight: 800;
      text-decoration: none;
    }
    .brand img {
      width: 40px;
      height: 40px;
      object-fit: contain;
    }
    .eyebrow {
      margin-top: 30px;
      color: #4a90e2;
      font-weight: 800;
      letter-spacing: .08em;
      text-transform: uppercase;
      font-size: 12px;
    }
    h1 {
      margin: 10px 0 8px;
      font-size: clamp(34px, 8vw, 64px);
      line-height: 1;
      color: #083454;
    }
    p {
      margin: 0;
      color: #475569;
      font-size: 16px;
      line-height: 1.7;
      max-width: 58ch;
    }
    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 26px;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 0;
      border-radius: 999px;
      padding: 12px 16px;
      background: #0a3d62;
      color: #fff;
      text-decoration: none;
      font-weight: 800;
    }
    .btn.light {
      background: #eef7ff;
      color: #0a3d62;
    }
  </style>
</head>
<body>
  <main class="error-page">
    <a class="brand" href="/">
      <img src="/img/academylogo.png" alt="Classic Academy logo">
      <span>Classic Academy</span>
    </a>
    <div class="eyebrow">Error 500</div>
    <h1>Something went wrong.</h1>
    <p>The page could not load because the server hit a problem. Please try again, or go back to the main site.</p>
    <div class="actions">
      <a class="btn" href="/"><i class="fa-solid fa-house"></i> Home</a>
      <a class="btn light" href="/contact"><i class="fa-solid fa-headset"></i> Contact Support</a>
    </div>
  </main>
</body>
</html>
