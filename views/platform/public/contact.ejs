<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Classic Academy — Contact</title>

    <!-- ✅ PRODUCTION SEO (classicacademy.app) -->
    <meta name="description"
        content="Contact Classic Academy for demos, pricing, onboarding, and support. Fast responses for schools in Uganda & South Sudan." />
    <meta name="keywords"
        content="Classic Academy contact, school management system support, admissions software demo, school ERP Uganda, school software South Sudan" />
    <meta name="robots" content="index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:1" />
    <meta name="theme-color" content="#4a90e2" />
    <meta name="application-name" content="Classic Academy" />
    <meta name="format-detection" content="telephone=no" />

    <link rel="canonical" href="https://www.classicacademy.app/contact" />
    <link rel="icon" href="https://www.classicacademy.app/img/academylogo.png" />
    <link rel="apple-touch-icon" href="https://www.classicacademy.app/img/academylogo.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Classic Academy" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content="Classic Academy — Contact" />
    <meta property="og:description" content="Talk to our team. Book a demo, ask questions, and get support fast." />
