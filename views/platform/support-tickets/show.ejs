<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Support Ticket Details — Classic Campus</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .grid{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(320px,1fr);gap:16px}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .title{font-size:20px;font-weight:800;color:#083454}
    .meta{font-size:12px;color:#6b7280;line-height:1.6}
    .badge{display:inline-flex;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:800}
    .green{background:#e6f9ee;color:#166534}
    .amber{background:#fffbeb;color:#b45309}
    .red{background:#fff1f2;color:#b91c1c}
    .gray{background:#f1f5f9;color:#475569}
    .message{border:1px solid #e2ebff;border-radius:12px;padding:12px;background:#fdfdff}
    .message + .message{margin-top:10px}
    .msg-head{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .msg-body{margin-top:8px;font-size:13px;color:#334155;line-height:1.7;white-space:pre-wrap}
    label{font-size:13px;font-weight:700;color:#334155}
    input,select,textarea{width:100%;border:1px solid #dbe3f6;border-radius:10px;padding:11px 12px;background:#fff;font:inherit}
    textarea{min-height:120px}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    .stack{display:flex;flex-direction:column;gap:14px}
    @media (max-width:1000px){.grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <% if (ticket) { %>
      <div class="card">
        <div class="title"><%= ticket.ticketNo %> — <%= ticket.subject %></div>
        <div class="meta">
          University: <%= ticket.tenantId?.name || '—' %> • Category: <%= ticket.category %> •
          Priority: <%= ticket.priority %> • Status: <%= ticket.status %>
        </div>
      </div>

      <div class="grid">
        <section class="stack">
          <div class="card">
            <div style="font-weight:800;color:#083454;margin-bottom:12px;">Conversation</div>
            <% (ticket.messages || []).forEach(function(msg){ %>
              <div class="message">
                <div class="msg-head">
                  <strong><%= msg.senderName || msg.senderType %></strong>
                  <span class="meta"><%= msg.createdAt ? new Date(msg.createdAt).toLocaleString() : '—' %></span>
                </div>
                <div class="meta"><%= msg.senderEmail || '' %></div>
                <div class="msg-body"><%= msg.body %></div>
              </div>
            <% }) %>
          </div>

          <div class="card">
            <div style="font-weight:800;color:#083454;margin-bottom:12px;">Reply</div>
            <form action="/super-admin/support-tickets/<%= ticket._id %>/reply" method="POST">
              <label>Message</label>
              <textarea name="body" required></textarea>
              <div style="margin-top:12px;">
                <button type="submit" class="btn">Send Reply</button>
              </div>
            </form>
          </div>
        </section>

        <aside class="stack">
          <div class="card">
            <div style="font-weight:800;color:#083454;margin-bottom:12px;">Ticket Info</div>
            <div class="meta">Requester: <%= ticket.requesterName || '—' %></div>
            <div class="meta">Email: <%= ticket.requesterEmail || '—' %></div>
            <div class="meta">Assigned To: <%= ticket.assignedTo?.name || '—' %></div>
            <div class="meta">Created: <%= ticket.createdAt ? new Date(ticket.createdAt).toLocaleString() : '—' %></div>
          </div>

          <div class="card">
            <form action="/super-admin/support-tickets/<%= ticket._id %>/assign" method="POST">
              <label>Assign To</label>
              <select name="assignedTo">
                <option value="">Unassigned</option>
                <% (agents || []).forEach(function(agent){ %>
                  <option value="<%= agent._id %>" <%= String(ticket?.assignedTo?._id || '') === String(agent._id) ? 'selected' : '' %>><%= agent.name || (agent.firstName + ' ' + agent.lastName) %></option>
                <% }) %>
              </select>
              <div style="margin-top:12px;">
                <button type="submit" class="btn">Assign</button>
              </div>
            </form>
          </div>

          <div class="card">
            <form action="/super-admin/support-tickets/<%= ticket._id %>/status" method="POST">
              <label>Status</label>
              <select name="status">
                <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
                <option value="pending" <%= ticket.status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
                <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>Closed</option>
              </select>
              <div style="margin-top:12px;">
                <button type="submit" class="btn">Update Status</button>
              </div>
            </form>
          </div>
        </aside>
      </div>
    <% } %>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>