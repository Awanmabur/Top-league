<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title>Create Support Ticket — Classic Campus</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <style>
    body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}
    *{box-sizing:border-box;min-width:0}
    .main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}
    .title{font-size:20px;font-weight:700;color:#083454}
    .subtitle{font-size:13px;color:#6b7280;line-height:1.5}
    .card{background:#fff;border-radius:12px;padding:16px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}
    .form-group{display:flex;flex-direction:column;gap:7px}
    .full{grid-column:1/-1}
    label{font-size:13px;font-weight:700;color:#334155}
    input,select,textarea{width:100%;border:1px solid #dbe3f6;border-radius:10px;padding:11px 12px;background:#fff;font:inherit}
    textarea{min-height:140px}
    .btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}
    .btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}
    .alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.main{padding:16px}}
  </style>
</head>
<body>
  <%- include("./navbar") %>

  <main class="main">
    <div>
      <div class="title">Create Support Ticket</div>
      <div class="subtitle">Create a new support issue on behalf of a university or internal platform request.</div>
    </div>

    <div class="card">
      <% if (error) { %>
        <div class="alert" style="margin-bottom:14px;"><%= error %></div>
      <% } %>

      <form action="/super-admin/support-tickets/create" method="POST" class="form-grid">
        <div class="form-group">
          <label>Ticket No</label>
          <input type="text" name="ticketNo" value="<%= old?.ticketNo || '' %>" />
        </div>

        <div class="form-group">
          <label>University</label>
          <select name="tenantId" required>
            <option value="">Select university</option>
            <% (tenants || []).forEach(function(tenant){ %>
              <option value="<%= tenant._id %>" <%= String(old?.tenantId || '') === String(tenant._id) ? 'selected' : '' %>><%= tenant.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label>Requester Name</label>
          <input type="text" name="requesterName" value="<%= old?.requesterName || '' %>" />
        </div>

        <div class="form-group">
          <label>Requester Email</label>
          <input type="email" name="requesterEmail" value="<%= old?.requesterEmail || '' %>" />
        </div>

        <div class="form-group">
          <label>Category</label>
          <select name="category">
            <option value="technical">Technical</option>
            <option value="billing">Billing</option>
            <option value="account">Account</option>
            <option value="setup">Setup</option>
            <option value="feature_request">Feature Request</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label>Priority</label>
          <select name="priority">
            <option value="low">Low</option>
            <option value="medium" selected>Medium</option>
            <option value="high">High</option>
            <option value="urgent">Urgent</option>
          </select>
        </div>

        <div class="form-group full">
          <label>Subject</label>
          <input type="text" name="subject" value="<%= old?.subject || '' %>" required />
        </div>

        <div class="form-group full">
          <label>Message</label>
          <textarea name="message" required><%= old?.message || '' %></textarea>
        </div>

        <div class="form-group full">
          <button type="submit" class="btn primary">Create Ticket</button>
        </div>
      </form>
    </div>
  </main>

  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>