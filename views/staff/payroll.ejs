<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= pageTitle || "Payroll" %> - <%= tenant?.name || "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
</head>
<body>
  <%- include("./navbar") %>
  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Payroll</div>
        <div class="subtitle">Your recent payroll and payment items.</div>
      </div>
    </div>

    <section class="card">
      <div class="mini-list">
        <% if (items?.length) { %>
          <% items.forEach(function(item) { %>
            <div class="mini-item">
              <span><%= item.title || item.period || item.name || "Payroll item" %></span>
              <span><%= item.amount ? Number(item.amount).toLocaleString() : "-" %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div class="small-muted">No payroll items available.</div>
        <% } %>
      </div>
    </section>
  </main>
  </div>
  <script src="/js/navbar.js"></script>
</body>
</html>
