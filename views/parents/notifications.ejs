<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant && tenant.name) ? tenant.name : "Classic Academy" %> — Notifications</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous"
        referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css"/>
  <link rel="stylesheet" href="/css/parent-portal.css" />

  <style>
    .toolbar{
      margin-top:16px;
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      align-items:center;
      justify-content:space-between;
    }

    .toolbar-left,
    .toolbar-right{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      align-items:center;
    }

    .search-box,
    .filter-box{
      display:flex;
      align-items:center;
      gap:10px;
      background:#fff;
      border:1px solid var(--line);
      border-radius:14px;
      padding:10px 12px;
      box-shadow:var(--shadow);
      min-height:46px;
    }

    .search-box{
      min-width:280px;
      flex:1;
    }

    .search-box i,
    .filter-box i{
      color:var(--primary);
    }

    .search-box input,
    .filter-box select{
      width:100%;
      border:none;
      outline:none;
      background:transparent;
      color:var(--text);
      font:inherit;
    }

    .summary-grid{
      margin-top:16px;
      display:grid;
      grid-template-columns:repeat(4,minmax(0,1fr));
      gap:12px;
    }

    .summary-box{
      border:1px solid var(--line);
      border-radius:14px;
      padding:12px;
      background:#fbfdff;
    }

    .summary-label{
      color:var(--muted);
      font-size:12px;
    }

    .summary-value{
      margin-top:6px;
      font-size:24px;
      font-weight:1000;
      letter-spacing:-.02em;
    }

    .page-grid{
      margin-top:16px;
      display:grid;
      grid-template-columns:1.25fr .85fr;
      gap:14px;
    }

    .notification-stack{
      display:grid;
      gap:14px;
    }

    .notification-card{
      border:1px solid var(--line);
      border-radius:18px;
      background:#fff;
      box-shadow:var(--shadow);
      padding:16px;
      position:relative;
    }

    .notification-card.unread{
      border-color:#bfd3ff;
      box-shadow:0 0 0 3px rgba(29,78,216,.05), var(--shadow);
    }

    .notification-card.unread::before{
      content:"";
      position:absolute;
      top:18px;
      left:18px;
      width:10px;
      height:10px;
      border-radius:999px;
      background:var(--primary);
    }

    .notification-card.unread .notification-head{
      padding-left:18px;
    }

    .notification-head{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
      flex-wrap:wrap;
    }

    .notification-title{
      font-size:17px;
      font-weight:1000;
      line-height:1.25;
    }

    .notification-meta{
      color:var(--muted);
      font-size:12px;
      margin-top:6px;
      line-height:1.6;
    }

    .badge-row{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
    }

    .badge-soft{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:7px 10px;
      border-radius:999px;
      background:#f8fbff;
      border:1px solid var(--line);
      font-size:12px;
      font-weight:800;
      color:var(--text);
    }

    .badge-soft.unread{
      background:#eef4ff;
      border-color:#bfd3ff;
      color:var(--primary-2);
    }

    .notification-body{
      margin-top:14px;
      color:var(--text);
      font-size:14px;
      line-height:1.75;
      white-space:pre-line;
    }

    .notification-footer{
      margin-top:14px;
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .inline-form{
      margin:0;
      display:inline-flex;
    }

    .side-stack{
      display:grid;
      gap:14px;
    }

    .metric-list{
      margin-top:12px;
      display:grid;
      gap:10px;
    }

    .metric-item{
      display:flex;
      justify-content:space-between;
      gap:12px;
      border-bottom:1px solid #eef4fb;
      padding-bottom:8px;
      font-size:13px;
      color:var(--muted);
    }

    .metric-item:last-child{
      border-bottom:none;
      padding-bottom:0;
    }

    .metric-item strong{
      color:var(--text);
      text-align:right;
    }

    .list{
      margin-top:12px;
      display:flex;
      flex-direction:column;
      gap:10px;
    }

    .list-item{
      display:flex;
      gap:10px;
      align-items:flex-start;
      border:1px solid var(--line);
      border-radius:14px;
      padding:10px;
      background:#fff;
    }

    .list-icon{
      width:34px;
      height:34px;
      border-radius:12px;
      background:#e8f0ff;
      display:flex;
      align-items:center;
      justify-content:center;
      color:var(--primary);
      flex-shrink:0;
    }

    .list-title{
      font-weight:1000;
    }

    .list-meta{
      color:var(--muted);
      font-size:12px;
      margin-top:2px;
    }

    .list-text{
      color:var(--muted);
      font-size:13px;
      margin-top:6px;
      line-height:1.5;
    }

    .empty-state{
      margin-top:16px;
    }

    @media (max-width: 1180px){
      .page-grid{
        grid-template-columns:1fr;
      }

      .summary-grid{
        grid-template-columns:repeat(2,minmax(0,1fr));
      }
    }

    @media (max-width: 720px){
      .toolbar{
        flex-direction:column;
        align-items:stretch;
      }

      .toolbar-left,
      .toolbar-right{
        width:100%;
      }

      .search-box,
      .filter-box{
        width:100%;
        min-width:0;
      }

      .summary-grid{
        grid-template-columns:1fr;
      }

      .notification-head{
        flex-direction:column;
      }

      .badge-row{
        justify-content:flex-start;
      }

      .metric-item{
        flex-direction:column;
      }

      .metric-item strong{
        text-align:left;
      }
    }
  </style>
</head>
<body data-portal="parent">
  <%
    const t = tenant || {};
    const rows = Array.isArray(notifications) ? notifications : [];
    const tenantName = t.name || "Classic Academy";
    const tenantCode = (t.code || "CC").toString();
    const s = stats || { total: 0, unread: 0, read: 0 };
    const opts = options || { types: [] };

    const filtered = rows.filter(function(item){
      const q = String(filters?.q || "").trim().toLowerCase();
      const status = String(filters?.status || "").trim().toLowerCase();
      const type = String(filters?.type || "").trim().toLowerCase();

      const matchQ = !q || [
        item.title,
        item.body,
        item.type
      ].join(" ").toLowerCase().includes(q);

      const itemStatus = item.read ? "read" : "unread";
      const matchStatus = !status || itemStatus === status;
      const matchType = !type || String(item.type || "").toLowerCase() === type;

      return matchQ && matchStatus && matchType;
    });
  %>

    <%-include("./navbar") %>

    <main class="main">
      <div class="topbar">
        <div>
          <div class="title">Notifications</div>
          <div class="subtitle">
            Track school alerts, account messages, reminders and activity updates sent to your parent account.
          </div>
        </div>

        <div class="top-actions">
          <div class="chip">
            <i class="fa-solid fa-bell"></i>
            <span>Unread</span>
            <b><%= Number(s.unread || 0) %></b>
          </div>

          <form method="POST" action="/parent/notifications/read-all" class="inline-form">
            <button class="btn primary" type="submit">
              <i class="fa-solid fa-check-double"></i> Mark all read
            </button>
          </form>
        </div>
      </div>

      <% if (error) { %>
        <section class="card empty-state">
          <div class="empty">
            <div class="empty-icon"><i class="fa-solid fa-bell"></i></div>
            <div class="empty-title">Unable to load notifications</div>
            <div class="empty-text"><%= error %></div>
          </div>
        </section>
      <% } else { %>

        <form method="GET" action="/parent/notifications" class="toolbar">
          <div class="toolbar-left">
            <div class="search-box">
              <i class="fa-solid fa-magnifying-glass"></i>
              <input type="text" name="q" value="<%= filters?.q || '' %>" placeholder="Search title, message or type" />
            </div>
          </div>

          <div class="toolbar-right">
            <div class="filter-box">
              <i class="fa-solid fa-envelope-open"></i>
              <select name="status">
                <option value="">All statuses</option>
                <option value="unread" <%= String(filters?.status || '') === 'unread' ? 'selected' : '' %>>Unread</option>
                <option value="read" <%= String(filters?.status || '') === 'read' ? 'selected' : '' %>>Read</option>
              </select>
            </div>

            <div class="filter-box">
              <i class="fa-solid fa-tag"></i>
              <select name="type">
                <option value="">All types</option>
                <% (opts.types || []).forEach(function(type){ %>
                  <option value="<%= type %>" <%= String(filters?.type || '') === String(type) ? 'selected' : '' %>><%= type %></option>
                <% }); %>
              </select>
            </div>

            <button class="btn primary" type="submit">
              <i class="fa-solid fa-filter"></i> Apply
            </button>
          </div>
        </form>

        <div class="summary-grid">
          <div class="summary-box">
            <div class="summary-label">Total</div>
            <div class="summary-value"><%= Number(s.total || 0) %></div>
          </div>
          <div class="summary-box">
            <div class="summary-label">Unread</div>
            <div class="summary-value"><%= Number(s.unread || 0) %></div>
          </div>
          <div class="summary-box">
            <div class="summary-label">Read</div>
            <div class="summary-value"><%= Number(s.read || 0) %></div>
          </div>
          <div class="summary-box">
            <div class="summary-label">Types</div>
            <div class="summary-value"><%= (opts.types || []).length %></div>
          </div>
        </div>

        <div class="page-grid">
          <section class="notification-stack">
            <% if (!filtered.length) { %>
              <section class="card empty-state">
                <div class="empty">
                  <div class="empty-icon"><i class="fa-solid fa-bell"></i></div>
                  <div class="empty-title">No notifications found</div>
                  <div class="empty-text">Try changing your search or filters to see more results.</div>
                </div>
              </section>
            <% } else { %>
              <% filtered.forEach(function(item){ %>
                <article class="notification-card <%= item.read ? '' : 'unread' %>">
                  <div class="notification-head">
                    <div>
                      <div class="notification-title"><%= item.title %></div>
                      <div class="notification-meta">
                        Received: <strong><%= item.createdLabel %></strong>
                        <% if (item.readLabel) { %>
                          <span class="dot">•</span>
                          Read: <strong><%= item.readLabel %></strong>
                        <% } %>
                      </div>
                    </div>

                    <div class="badge-row">
                      <span class="badge-soft">
                        <i class="fa-solid fa-tag"></i> <%= item.type || "general" %>
                      </span>
                      <span class="badge-soft <%= item.read ? '' : 'unread' %>">
                        <i class="fa-solid <%= item.read ? 'fa-envelope-open' : 'fa-envelope' %>"></i>
                        <%= item.read ? 'Read' : 'Unread' %>
                      </span>
                    </div>
                  </div>

                  <div class="notification-body"><%= item.body || item.excerpt || "" %></div>

                  <div class="notification-footer">
                    <% if (!item.read) { %>
                      <form method="POST" action="/parent/notifications/<%= item._id %>/read" class="inline-form">
                        <button class="btn-xs" type="submit">
                          <i class="fa-solid fa-check"></i> Mark as read
                        </button>
                      </form>
                    <% } %>

                    <% if (item.actionUrl) { %>
                      <a class="btn-xs" href="<%= item.actionUrl %>">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i> <%= item.actionLabel || "Open" %>
                      </a>
                    <% } %>

                    <a class="btn-xs" href="/parent/support">
                      <i class="fa-solid fa-headset"></i> Support
                    </a>
                  </div>
                </article>
              <% }); %>
            <% } %>
          </section>

          <aside class="side-stack">
            <section class="card">
              <div class="section-title">Notification Summary</div>
              <div class="section-sub">Quick breakdown of your parent account messages.</div>

              <div class="metric-list">
                <div class="metric-item">
                  <span>Total notifications</span>
                  <strong><%= Number(s.total || 0) %></strong>
                </div>
                <div class="metric-item">
                  <span>Unread notifications</span>
                  <strong><%= Number(s.unread || 0) %></strong>
                </div>
                <div class="metric-item">
                  <span>Read notifications</span>
                  <strong><%= Number(s.read || 0) %></strong>
                </div>
                <div class="metric-item">
                  <span>Distinct types</span>
                  <strong><%= (opts.types || []).length %></strong>
                </div>
              </div>
            </section>

            <section class="card">
              <div class="section-title">Latest Activity</div>
              <div class="section-sub">Most recent messages sent to your account.</div>

              <% if (!rows.length) { %>
                <div class="empty small" style="margin-top:12px;">
                  <div class="empty-title">No activity yet</div>
                  <div class="empty-text">Notifications will appear here when they are sent.</div>
                </div>
              <% } else { %>
                <div class="list">
                  <% rows.slice(0, 6).forEach(function(item){ %>
                    <div class="list-item">
                      <div class="list-icon">
                        <i class="fa-solid fa-bell"></i>
                      </div>
                      <div>
                        <div class="list-title"><%= item.title %></div>
                        <div class="list-meta"><%= item.createdLabel %> • <%= item.type || "general" %></div>
                        <div class="list-text"><%= item.excerpt || "" %></div>
                      </div>
                    </div>
                  <% }); %>
                </div>
              <% } %>
            </section>
          </aside>
        </div>
      <% } %>
    </main>
  </div>
<script src="/js/navbar.js"></script>
</body>
</html>
