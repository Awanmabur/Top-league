<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>
    <%= pageTitle %> — <%= tenant?.name || "CampusSaaS" %>
  </title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
</head>

<body>

  <%- include("./navbar") %>

    <main class="main">
      <div class="topbar">
        <div>
          <div class="title">Student Dashboard</div>
          <div class="subtitle">
            High-level overview of your academics, timetable, attendance and campus status.
          </div>
        </div>
        <div class="top-actions">
          <a class="btn light" href="/student/course-registration">
            <i class="fa-solid fa-list-check"></i> Register Courses
          </a>
          <a class="btn primary" href="/student/courses">
            <i class="fa-solid fa-book-open-reader"></i> Go to My Courses
          </a>
        </div>
      </div>

       
      <%-include("./.././partials/flash") %>

        <div class="kpi-row">
          <div class="card">
            <div class="section-title">Open Invoices</div>
            <div class="section-sub">Pending finance items</div>
            <div style="margin-top:8px;">
              <div style="font-size:22px;font-weight:800;">
                <%= stats.invoicesOpen %>
              </div>
              <div class="small-muted">Outstanding student finance items</div>
            </div>
          </div>

          <div class="card">
            <div class="section-title">Fees Status</div>
            <div class="section-sub">Student Finance</div>
            <div style="margin-top:8px;">
              <div style="font-size:22px;font-weight:800;">UGX <%= Number(stats.feesDue || 0).toLocaleString() %>
              </div>
              <div class="small-muted">Outstanding balance</div>
            </div>
          </div>

          <div class="card">
            <div class="section-title">Attendance (Recent)</div>
            <div class="section-sub">All registered courses</div>
            <div style="margin-top:8px;">
              <div style="font-size:22px;font-weight:800;">
                <%= stats.attendanceRate %>%
              </div>
              <div class="small-muted">
                Target: 75% •
                <span style="color:<%= stats.attendanceRate >= 75 ? '#16a34a' : '#dc2626' %>;">
                  <%= stats.attendanceRate>= 75 ? 'On track' : 'Needs attention' %>
                </span>
              </div>
            </div>
          </div>

          <div class="card">
            <div class="section-title">Campus Status</div>
            <div class="section-sub">Services overview</div>
            <div style="margin-top:8px;">
              <div style="font-size:22px;font-weight:800;">
                <%= stats.upcomingEvents %>
              </div>
              <div class="small-muted">Upcoming events</div>
            </div>
          </div>
        </div>

        <div class="content" style="margin-top:4px;">
          <section class="card">
            <div class="profile-top">
              <div class="avatar">
                <%= studentName.split(" ").map(v => v[0]).slice(0,2).join("").toUpperCase() %></div>
        <div>
          <div class=" profile-name">
                  <%= studentName %>
              </div>
              <div class="profile-id">Student ID: <%= meta.studentNumber %>
              </div>
              <div class="profile-row">
                <span>
                  <%= meta.program %> • <%= meta.level %>
                </span>
                <span class="pill-status">
                  <i class="fa-solid fa-circle-check"></i>
                  <%= student?.status || "Good standing" %>
                </span>
              </div>
            </div>
        </div>

        <div class="profile-row" style="margin-top:10px;">
          <span><i class="fa-solid fa-calendar-days"></i>
            <%= meta.academicYear %> • <%= meta.semester %>
          </span>
          <span><i class="fa-solid fa-location-dot"></i>
            <%= tenant?.name || "Main Campus" %>
          </span>
          <span><i class="fa-solid fa-clock"></i> Local time: <span id="localTimeLabel">--:--</span></span>
        </div>

        <div style="margin-top:14px;">
          <div class="section-title">Current courses</div>
          <div class="section-sub">Enrolled this semester.</div>
          <div class="course-list">
            <% if (registeredCourses?.length) { %>
              <% registeredCourses.forEach(function(c) { %>
                <div class="course-item">
                  <div>
                    <div class="course-title">
                      <%= c.courseCode %> - <%= c.courseTitle %>
                    </div>
                    <div class="course-meta">
                      <%= c.schedule %>
                    </div>
                  </div>
                  <div class="course-actions">
                    <span class="badge-mode">
                      <%= c.mode %>
                    </span>
                    <span>Progress: <%= c.progress %>%</span>
                  </div>
                </div>
                <% }) %>
                  <% } else { %>
                    <div class="small-muted">No active registered courses found.</div>
                    <% } %>
          </div>
        </div>

        <div style="margin-top:14px;">
          <div class="section-title">Upcoming tasks</div>
          <div class="section-sub">From your LMS courses.</div>
          <div class="notif-list">
            <% if (upcomingAssignments?.length) { %>
              <% upcomingAssignments.forEach(function(task) { %>
                <div class="notif-item">
                  <div class="notif-icon"><i class="fa-solid fa-file-pen"></i></div>
                  <div>
                    <div class="notif-title">
                      <%= task.courseCode ? task.courseCode + " • " : "" %>
                        <%= task.title %>
                    </div>
                    <div class="notif-meta">
                      Due: <%= task.dueDate ? new Date(task.dueDate).toDateString() : "Not set" %>
                        <%= task.weight ? " • Weight: " + task.weight : "" %>
                    </div>
                  </div>
                </div>
                <% }) %>
                  <% } else { %>
                    <div class="small-muted">No upcoming tasks found.</div>
                    <% } %>
          </div>
        </div>
        </section>

        <aside>
          <section class="card">
            <div class="section-title">Announcements</div>
            <div class="section-sub">Latest campus updates.</div>

            <div class="notif-list" style="margin-top:10px;">
              <% if (announcements?.length) { %>
                <% announcements.forEach(function(item) { %>
                  <div class="notif-item">
                    <div class="notif-icon"><i class="fa-solid fa-bullhorn"></i></div>
                    <div>
                      <div class="notif-title">
                        <%= item.title || "Announcement" %>
                      </div>
                      <div class="notif-meta">
                        <%= item.createdAt ? new Date(item.createdAt).toDateString() : "" %>
                      </div>
                    </div>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div class="small-muted">No announcements available.</div>
                      <% } %>
            </div>
          </section>

          <section class="card" style="margin-top:16px;">
            <div class="section-title">Status Overview</div>
            <div class="section-sub">Quick view of your campus-wide status.</div>

            <div class="mini-list" style="margin-top:8px;">
              <div class="mini-item"><span>Academic status</span><span>
                  <%= student?.status || "Active" %>
                </span></div>
              <div class="mini-item"><span>Registration</span><span>
                  <%= registeredCourses?.length ? "Registered" : "Pending" %>
                </span></div>
              <div class="mini-item"><span>Finance</span><span>
                  <%= stats.feesDue> 0 ? "Outstanding balance" : "Cleared" %>
                </span></div>
              <div class="mini-item"><span>Hostel</span><span>
                  <%= stats.hostelAssigned ? "Allocated" : "Not allocated" %>
                </span></div>
              <div class="mini-item"><span>Library</span><span>
                  <%= stats.libraryBorrowed %> borrowed
                </span></div>
            </div>

            <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:8px;">
              <a class="btn-xs" href="/student/finance"><i class="fa-solid fa-sack-dollar"></i> Go to Finance</a>
              <a class="btn-xs" href="/student/hostel"><i class="fa-solid fa-bed"></i> Hostel details</a>
              <a class="btn-xs" href="/student/support"><i class="fa-solid fa-headset"></i> Contact support</a>
            </div>
          </section>

          <section class="card" style="margin-top:16px;">
            <div class="section-title">Recent results</div>
            <div class="section-sub">Latest published results.</div>

            <div class="mini-list" style="margin-top:8px;">
              <% if (currentResults?.length) { %>
                <% currentResults.forEach(function(r) { %>
                  <div class="mini-item">
                    <span>
                      <%= r.courseCode || r.courseTitle %>
                    </span>
                    <span>
                      <%= r.grade || r.score %>
                    </span>
                  </div>
                  <% }) %>
                    <% } else { %>
                      <div class="small-muted">No results published yet.</div>
                      <% } %>
            </div>
          </section>
        </aside>
        </div>
    </main>
    </div>

    <script src="/js/navbar.js"></script>
    <script>
      (function () {
        const timeLabel = document.getElementById("localTimeLabel");
        function updateClock() {
          const now = new Date();
          const hh = String(now.getHours()).padStart(2, "0");
          const mm = String(now.getMinutes()).padStart(2, "0");
          if (timeLabel) timeLabel.textContent = hh + ":" + mm;
        }
        updateClock();
        setInterval(updateClock, 60000);
      })();
    </script>
</body>

</html>