<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= pageTitle %> — <%= tenant?.name || "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css"/>
  <link rel="stylesheet" href="/css/student-portal.css" />
</head>
<body>
<%- include("./navbar") %>

<main class="main">
  <div class="topbar">
    <div>
      <div class="title">Support Tickets</div>
      <div class="subtitle">
        Raise requests to the school support team and track their status in one place.
      </div>
    </div>
    <div class="top-actions">
      <a class="btn light" href="/student/dashboard">
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
      </a>
      <button class="btn primary" id="newTicketBtn">
        <i class="fa-solid fa-plus"></i> New Ticket
      </button>
    </div>
  </div>

  <%-include("./.././partials/flash") %>

  <section class="card">
    <div class="section-title">Filters</div>
    <div class="section-sub">Filter your tickets by status, category or search term.</div>

    <div class="filters-row" style="margin-top:10px;">
      <div>
        <label class="small-muted">Status</label><br/>
        <select id="filterStatus" class="select">
          <option value="all" selected>All statuses</option>
          <option value="open">Open</option>
          <option value="in-progress">In progress</option>
          <option value="resolved">Resolved</option>
          <option value="closed">Closed</option>
        </select>
      </div>

      <div>
        <label class="small-muted">Category</label><br/>
        <select id="filterCategory" class="select">
          <option value="all" selected>All categories</option>
          <option value="finance">Finance &amp; Fees</option>
          <option value="registration">Registration &amp; Courses</option>
          <option value="hostel">Hostel &amp; Accommodation</option>
          <option value="it">IT &amp; Portal</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div style="min-width:220px;flex:1;">
        <label class="small-muted">Search</label><br/>
        <input type="text" id="filterSearch" class="select"
               style="width:100%;padding:7px 10px;"
               placeholder="Search by ticket ID, title or description..." />
      </div>
    </div>
  </section>

  <div class="content">
    <section class="card">
      <div class="section-title">My tickets</div>
      <div class="section-sub">Latest support requests you have raised.</div>

      <div class="mini-list" style="margin-top:10px;">
        <div class="mini-item"><span>Total tickets</span><span id="statTotal"><%= stats.total %></span></div>
        <div class="mini-item"><span>Open</span><span id="statOpen"><%= stats.open %></span></div>
        <div class="mini-item"><span>In progress</span><span id="statInProgress"><%= stats.inProgress %></span></div>
        <div class="mini-item"><span>Resolved / Closed</span><span id="statClosed"><%= stats.closed %></span></div>
      </div>

      <div style="margin-top:12px;overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;" id="ticketsTable">
          <thead>
            <tr style="border-bottom:1px solid #e5edff;">
              <th style="text-align:left;padding:6px 4px;">Ticket</th>
              <th style="text-align:left;padding:6px 4px;">Status</th>
              <th style="text-align:left;padding:6px 4px;">Category</th>
              <th style="text-align:left;padding:6px 4px;">Created</th>
              <th style="text-align:left;padding:6px 4px;">Last update</th>
            </tr>
          </thead>
          <tbody>
            <% if (tickets?.length) { %>
              <% tickets.forEach(function(t){ %>
                <tr class="ticket-row"
                    data-id="<%= t.id %>"
                    data-status="<%= t.status %>"
                    data-category="<%= t.category %>"
                    data-title="<%= t.title.replace(/"/g, '&quot;') %>"
                    data-created="<%= t.created ? new Date(t.created).toISOString() : '' %>"
                    data-updated="<%= t.updated ? new Date(t.updated).toISOString() : '' %>"
                    data-priority="<%= t.priority %>"
                    data-description="<%= (t.description || '').replace(/"/g, '&quot;') %>"
                    data-thread='<%- JSON.stringify(t.thread || []) %>'>
                  <td style="padding:6px 4px;cursor:pointer;" data-cell="ticket-main">
                    <div><strong><%= t.id %></strong></div>
                    <div class="small-muted ticket-title"><%= t.title %></div>
                  </td>
                  <td><%= t.status %></td>
                  <td><%= t.category %></td>
                  <td><%= t.created ? new Date(t.created).toDateString() : "-" %></td>
                  <td><%= t.updated ? new Date(t.updated).toDateString() : "-" %></td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr><td colspan="5">No support tickets found.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

    <aside>
      <section class="card" id="ticketDetailsCard">
        <div class="section-title">Ticket details</div>
        <div class="section-sub">Select a ticket from the left to view full conversation.</div>
        <div id="ticketDetailsBody" style="margin-top:10px;font-size:13px;">
          <p class="small-muted">No ticket selected yet. Click on any ticket in the list to see details, status, and messages.</p>
        </div>
      </section>
    </aside>
  </div>

  <div class="content" style="margin-top:16px;">
    <section class="card">
      <div class="section-title">Support channels &amp; response times</div>
      <div class="section-sub">How support works for different categories.</div>

      <div class="mini-list" style="margin-top:8px;">
        <div class="mini-item"><span>IT &amp; Portal issues</span><span>Response in 4 working hours</span></div>
        <div class="mini-item"><span>Finance &amp; Fees</span><span>Response in 1–2 working days</span></div>
        <div class="mini-item"><span>Registration &amp; Courses</span><span>Response in 1 working day</span></div>
        <div class="mini-item"><span>Hostel &amp; Accommodation</span><span>Response in 1 working day</span></div>
      </div>
    </section>

    <section class="card">
      <div class="section-title">Tips for faster resolution</div>
      <div class="section-sub">Help support understand your issue quickly.</div>

      <ul class="mini-list" style="margin-top:8px;">
        <li class="mini-item"><span>Attach details</span><span>Include screenshots or exact error messages</span></li>
        <li class="mini-item"><span>One issue per ticket</span><span>Makes it easier to track and close</span></li>
        <li class="mini-item"><span>Check FAQs</span><span>Some issues have quick self-service fixes</span></li>
      </ul>
    </section>
  </div>
</main>
</div>

<div id="ticketNewModal" class="modal-backdrop" style="display:none;">
  <div class="modal-card">
    <div class="modal-header">
      <div class="modal-title">Create new ticket</div>
      <button class="modal-close" type="button" onclick="closeNewModal()">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="section-sub">Describe your issue. Support will respond via this portal and email.</div>

    <form style="margin-top:10px;font-size:13px;">
      <div style="margin-bottom:8px;">
        <label class="small-muted">Category</label><br/>
        <select class="select" style="width:100%;">
          <option value="finance">Finance &amp; Fees</option>
          <option value="registration">Registration &amp; Courses</option>
          <option value="hostel">Hostel &amp; Accommodation</option>
          <option value="it" selected>IT &amp; Portal</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div style="margin-bottom:8px;">
        <label class="small-muted">Subject</label><br/>
        <input type="text" class="select" style="width:100%;padding:7px 10px;" placeholder="Short summary of your issue" />
      </div>
      <div style="margin-bottom:8px;">
        <label class="small-muted">Description</label><br/>
        <textarea style="width:100%;min-height:80px;border-radius:12px;border:1px solid #dbe3f6;padding:8px 10px;font-family:inherit;font-size:13px;background:#f9fbff;"
                  placeholder="Explain what happened, any error messages, and what you already tried."></textarea>
      </div>
      <div style="margin-bottom:8px;">
        <label class="small-muted">Priority</label><br/>
        <select class="select" style="width:100%;">
          <option value="Low">Low</option>
          <option value="Medium" selected>Medium</option>
          <option value="High">High</option>
        </select>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn light" onclick="closeNewModal()">Close</button>
        <button type="button" class="btn primary">
          <i class="fa-solid fa-paper-plane"></i> Submit
        </button>
      </div>
    </form>
  </div>
</div>

<script src="/js/navbar.js"></script>
<script>
(function(){
  const ticketsTable = document.getElementById("ticketsTable");
  const detailsBody = document.getElementById("ticketDetailsBody");
  const filterStatus = document.getElementById("filterStatus");
  const filterCategory = document.getElementById("filterCategory");
  const filterSearch = document.getElementById("filterSearch");
  const newTicketBtn = document.getElementById("newTicketBtn");
  const newModal = document.getElementById("ticketNewModal");

  function parseThread(jsonText) {
    try { return JSON.parse(jsonText); } catch { return []; }
  }

  function renderTicketDetails(row) {
    if (!row) {
      detailsBody.innerHTML = '<p class="small-muted">No ticket selected yet. Click on any ticket in the list to see details, status, and messages.</p>';
      return;
    }

    const id = row.getAttribute("data-id");
    const status = row.getAttribute("data-status");
    const category = row.getAttribute("data-category");
    const created = row.getAttribute("data-created");
    const updated = row.getAttribute("data-updated");
    const priority = row.getAttribute("data-priority");
    const description = row.getAttribute("data-description");
    const thread = parseThread(row.getAttribute("data-thread") || "[]");

    let threadHtml = "";
    if (!thread.length) {
      threadHtml = '<div class="small-muted">No conversation messages recorded yet.</div>';
    } else {
      threadHtml = '<div class="registered-list" style="margin-top:8px;">';
      thread.forEach(msg => {
        threadHtml += `
          <div class="reg-item">
            <div><strong>${msg.from}</strong> <span class="small-muted">• ${msg.time || ""}</span></div>
            <div class="small-muted" style="margin-top:4px;">${msg.body || ""}</div>
          </div>`;
      });
      threadHtml += "</div>";
    }

    detailsBody.innerHTML = `
      <div class="mini-list">
        <div class="mini-item"><span>Ticket ID</span><span>${id}</span></div>
        <div class="mini-item"><span>Status</span><span>${status}</span></div>
        <div class="mini-item"><span>Category</span><span>${category}</span></div>
        <div class="mini-item"><span>Priority</span><span>${priority}</span></div>
        <div class="mini-item"><span>Created</span><span>${created ? new Date(created).toDateString() : "-"}</span></div>
        <div class="mini-item"><span>Last update</span><span>${updated ? new Date(updated).toDateString() : "-"}</span></div>
      </div>
      <div style="margin-top:12px;">
        <div class="section-title" style="font-size:13px;">Issue summary</div>
        <p class="small-muted" style="margin-top:4px;">${description || ""}</p>
      </div>
      <div style="margin-top:12px;">
        <div class="section-title" style="font-size:13px;">Conversation</div>
        ${threadHtml}
      </div>`;
  }

  function applyFilters() {
    const statusFilter = filterStatus.value;
    const categoryFilter = filterCategory.value;
    const query = (filterSearch.value || "").toLowerCase().trim();

    let firstVisible = null;
    ticketsTable.querySelectorAll(".ticket-row").forEach(row => {
      const status = row.getAttribute("data-status");
      const category = row.getAttribute("data-category");
      const title = (row.getAttribute("data-title") || "").toLowerCase();
      const desc = (row.getAttribute("data-description") || "").toLowerCase();
      const id = (row.getAttribute("data-id") || "").toLowerCase();

      let visible = true;
      if (statusFilter !== "all" && status !== statusFilter) visible = false;
      if (categoryFilter !== "all" && category !== categoryFilter) visible = false;
      if (query && !id.includes(query) && !title.includes(query) && !desc.includes(query)) visible = false;

      row.style.display = visible ? "" : "none";
      if (visible && !firstVisible) firstVisible = row;
    });

    renderTicketDetails(firstVisible);
  }

  ticketsTable?.querySelectorAll(".ticket-row").forEach(row => {
    row.querySelector('[data-cell="ticket-main"]')?.addEventListener("click", () => renderTicketDetails(row));
  });

  filterStatus?.addEventListener("change", applyFilters);
  filterCategory?.addEventListener("change", applyFilters);
  filterSearch?.addEventListener("input", applyFilters);

  newTicketBtn?.addEventListener("click", () => { newModal.style.display = "flex"; });
  window.closeNewModal = function(){ newModal.style.display = "none"; };

  applyFilters();
})();
</script>
</body>
</html>