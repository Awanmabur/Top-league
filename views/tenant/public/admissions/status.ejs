<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Application Status — CampusSaaS</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>

  <style>
    :root{
      --blue:#0a3d62; --blue2:#083454; --accent:#0a6fbf;
      --bg:#f4f8ff; --card:#fff; --muted:#6b7280; --text:#0f172a;
      --success:#16a34a; --danger:#ef4444; --warn:#f59e0b; --info:#4f46e5;
      --radius:16px; --line:rgba(13,64,96,.12); --shadow:0 10px 30px rgba(0,0,0,.08);
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}
    a{color:inherit}

    .wrap{max-width:1180px;margin:0 auto;padding:16px}
    .topbar{
      background:linear-gradient(135deg,var(--blue),var(--blue2));
      color:#fff;border-radius:18px;padding:14px 14px;
      display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:flex-start;
      box-shadow:var(--shadow)
    }
    .brand{display:flex;gap:10px;align-items:center;text-decoration:none}
    .logo{width:40px;height:40px;border-radius:12px;background:rgba(255,255,255,.14);display:grid;place-items:center;font-weight:1000}
    .brand h1{font-size:16px;margin:0;line-height:1.1}
    .sub{font-size:12px;opacity:.75;margin-top:2px}

    .btn{
      border:none;border-radius:12px;padding:10px 12px;font-weight:900;cursor:pointer;
      display:inline-flex;gap:8px;align-items:center;text-decoration:none
    }
    .btn.primary{background:var(--accent);color:#fff}
    .btn.light{background:#fff;border:1px solid rgba(255,255,255,.25);color:#0f172a}
    .btn.ghost{background:transparent;border:1px solid rgba(255,255,255,.25);color:#fff}
    .btn.danger{background:#fee2e2;border:1px solid rgba(239,68,68,.25);color:#b91c1c}
    .btn.small{padding:8px 10px;border-radius:10px;font-size:12px}
    .btn:hover{filter:brightness(.98)}

    .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
    .card-head{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;align-items:center;padding:12px 14px;border-bottom:1px solid var(--line)}
    .card-title{font-weight:1000}
    .card-sub{font-size:12px;color:var(--muted);margin-top:3px}
    .card-body{padding:14px}

    .search{margin-top:12px}
    .row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{
      padding:10px 12px;border-radius:12px;border:1px solid var(--line);background:#fff;outline:none; width:100%;
    }
    .textarea{min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .field{display:grid;gap:6px}
    .field label{font-size:12px;color:var(--muted);font-weight:900}
    .muted{color:var(--muted);font-size:12px}
    .strong{font-weight:1000}
    .divider{height:1px;background:var(--line);margin:12px 0}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:1000}
    .p-ok{background:#ecfdf3;color:#15803d}
    .p-bad{background:#fee2e2;color:#b91c1c}
    .p-warn{background:#fff7ed;color:#92400e}
    .p-info{background:#eef2ff;color:#3730a3}

    .grid-kpi{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:12px}
    .kpi{padding:14px}
    .kpi .label{font-size:12px;color:var(--muted);font-weight:900}
    .kpi .value{font-size:22px;font-weight:1000;margin-top:6px}
    .kpi .hint{font-size:12px;color:var(--muted);margin-top:4px}

    .grid-main{display:grid;grid-template-columns:1.45fr .55fr;gap:12px;margin-top:12px}

    .tabs{display:flex;gap:8px;flex-wrap:wrap}
    .tab{border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:1000;font-size:12px}
    .tab.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pane{display:none}
    .pane.active{display:block;margin-top:10px}

    .file-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
    .file{
      border:1px solid var(--line);border-radius:12px;padding:10px;background:#fff;
      display:flex;justify-content:space-between;gap:10px;align-items:flex-start
    }
    .file .meta{display:grid;gap:2px;min-width:0}
    .file .name{font-weight:1000;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .file .desc{font-size:12px;color:var(--muted)}
    .tag{font-size:11px;font-weight:1000;border-radius:999px;padding:4px 8px;border:1px solid var(--line);background:#fff}
    .tag.ok{background:#ecfdf3;border-color:rgba(22,163,74,.25);color:#15803d}
    .tag.req{background:#fff7ed;border-color:rgba(245,158,11,.25);color:#92400e}
    .tag.miss{background:#fee2e2;border-color:rgba(239,68,68,.25);color:#b91c1c}

    .table-wrap{overflow:auto;border:1px solid var(--line);border-radius:12px}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:860px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:top}
    th{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}

    .timeline{display:grid;gap:10px}
    .event{border:1px solid var(--line);border-radius:12px;padding:10px;background:#fff}
    .event .top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .event .title{font-weight:1000}
    .event .meta{font-size:12px;color:var(--muted);margin-top:4px}

    /* Modals */
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:18px;z-index:9999}
    .modal-backdrop.show{display:flex}
    .modal{width:min(860px,100%);background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--line)}
    .modal-title{font-weight:1000}
    .modal-body{padding:16px}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 16px;border-top:1px solid var(--line)}

    @media(max-width:1050px){
      .grid-main{grid-template-columns:1fr}
      .grid-kpi{grid-template-columns:1fr 1fr}
      .file-grid{grid-template-columns:1fr}
    }
    @media(max-width:650px){
      .grid-kpi{grid-template-columns:1fr}
      table{min-width:720px}
    }
  </style>
</head>

<body>
<%
  // SAFE VARS
  const tenantName = (typeof tenant !== "undefined" && tenant && tenant.name) ? String(tenant.name) : "Classic Campus";
  const csrf = (typeof csrfToken !== "undefined" && csrfToken) ? csrfToken : null;

  const q = (typeof query !== "undefined" && query) ? String(query) : "";

  const app = (typeof result !== "undefined" && result) ? result : null;
  const errorMsg = (typeof error !== "undefined" && error) ? String(error) : "";

  const docs = (typeof documents !== "undefined" && Array.isArray(documents)) ? documents : [];
  const payments = (typeof paymentHistory !== "undefined" && Array.isArray(paymentHistory)) ? paymentHistory : [];
  const timeline = (typeof auditTrail !== "undefined" && Array.isArray(auditTrail)) ? auditTrail : [];

  const s = (v, d="") => (v === null || v === undefined) ? d : String(v);

  const status = app ? s(app.status, "submitted") : "submitted";
  const stageLabel =
    status === "accepted" ? "Accepted" :
    status === "rejected" ? "Rejected" :
    status === "under_review" ? "Under Review" :
    status === "interview" ? "Interview" :
    "Submitted";

  const stageClass =
    status === "accepted" ? "p-ok" :
    status === "rejected" ? "p-bad" :
    status === "under_review" ? "p-warn" :
    "p-info";

  const payStatus = app ? s(app.paymentStatus, "") : "";
  const payLabel = payStatus === "paid" ? "Paid" : (payStatus === "partial" ? "Partial" : "Not Paid");
  const payClass = payStatus === "paid" ? "p-ok" : (payStatus === "partial" ? "p-warn" : "p-bad");

  // required docs
  const REQUIRED = [
    { key:"idDocument", label:"National ID / Passport", required:true },
    { key:"passportPhoto", label:"Passport Photo", required:true },
    { key:"transcript", label:"Transcript / Results Slip", required:true },
    { key:"certificates", label:"Certificates", required:false }
  ];

  const hasDoc = (key) => docs.some(d => s(d.key) === key || s(d.type) === key);
%>

<div class="wrap">

  <!-- TOP -->
  <div class="topbar">
    <a class="brand" href="/">
      <div class="logo">CS</div>
      <div>
        <h1><%= tenantName %></h1>
        <div class="sub">Application Status & Review (Student)</div>
      </div>
    </a>

    <div class="row">
      <a class="btn ghost small" href="/apply"><i class="fa-solid fa-file-circle-plus"></i> New Application</a>
      <button class="btn ghost small" type="button" id="btnPrint"><i class="fa-solid fa-print"></i> Print</button>
      <button class="btn ghost small" type="button" id="btnHelp"><i class="fa-solid fa-headset"></i> Help</button>
    </div>
  </div>

  <!-- SEARCH -->
  <div class="card search">
    <div class="card-head">
      <div>
        <div class="card-title">Check Application Status</div>
        <div class="card-sub">Search using Application ID (APP-YYYY-xxxxxx) or your Email/Phone.</div>
      </div>
      <% if (app) { %>
        <div class="row">
          <span class="pill <%= stageClass %>"><i class="fa-solid fa-circle-info"></i> <%= stageLabel %></span>
          <button class="btn light small" type="button" id="btnCopy"><i class="fa-solid fa-copy"></i> Copy ID</button>
        </div>
      <% } %>
    </div>

    <div class="card-body">
      <% if (errorMsg) { %>
        <div style="color:#b91c1c;font-weight:1000;margin-bottom:10px"><%= errorMsg %></div>
      <% } %>

      <form method="POST" action="/admissions/status" class="row">
        <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
        <input class="input" name="q" placeholder="APP-2026-481029 or email/phone" value="<%= q %>" style="flex:1;min-width:260px"/>
        <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Check</button>
      </form>

      <div class="muted" style="margin-top:10px">
        Tip: After you apply, redirect applicant here with their Application ID so they see everything immediately.
      </div>
    </div>
  </div>

  <% if (app) { %>

    <!-- KPIs -->
    <div class="grid-kpi">
      <div class="card kpi">
        <div class="label">Stage</div>
        <div class="value"><%= stageLabel %></div>
        <div class="hint">Current workflow stage</div>
      </div>
      <div class="card kpi">
        <div class="label">Application ID</div>
        <div class="value" style="font-size:18px"><%= s(app.applicationId,"—") %></div>
        <div class="hint">Use this to check status any time</div>
      </div>
      <div class="card kpi">
        <div class="label">Payment</div>
        <div class="value"><%= payLabel %></div>
        <div class="hint">Application fee status</div>
      </div>
    </div>

    <div class="grid-main">
      <!-- LEFT MAIN -->
      <section class="card">
        <div class="card-head">
          <div>
            <div class="card-title">Your Application</div>
            <div class="card-sub">
              Submitted:
              <%= app.createdAt ? new Date(app.createdAt).toLocaleString() : "—" %>
              • Program:
              <b>
                <%= (app.program1 && app.program1.code) ? s(app.program1.code)+" — " : "" %>
                <%= (app.program1 && (app.program1.name || app.program1.title)) ? s(app.program1.name || app.program1.title) : s(app.programName,"") %>
              </b>
            </div>
          </div>

          <div class="row">
            <span class="pill <%= payClass %>"><i class="fa-solid fa-coins"></i> <%= payLabel %></span>
            <button class="btn light small" type="button" id="btnEditBasic"><i class="fa-solid fa-pen"></i> Edit Info</button>
          </div>
        </div>

        <div class="card-body">
          <!-- Tabs -->
          <div class="tabs" id="tabs">
            <button class="tab active" data-pane="pane-basic"><i class="fa-solid fa-user"></i> Basic Info</button>
            <button class="tab" data-pane="pane-docs"><i class="fa-solid fa-folder-open"></i> Documents</button>
            <button class="tab" data-pane="pane-pay"><i class="fa-solid fa-coins"></i> Payment</button>
            <button class="tab" data-pane="pane-interview"><i class="fa-solid fa-video"></i> Interview</button>
            <button class="tab" data-pane="pane-decision"><i class="fa-solid fa-gavel"></i> Decision</button>
            <button class="tab" data-pane="pane-audit"><i class="fa-solid fa-clock-rotate-left"></i> Timeline</button>
          </div>

          <!-- BASIC INFO -->
          <div class="pane active" id="pane-basic">
            <div class="muted">You can update basic details. Admissions will still verify everything.</div>
            <div class="divider"></div>

            <form method="POST" action="/admissions/status/update" id="basicForm">
              <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
              <input type="hidden" name="applicationId" value="<%= s(app.applicationId) %>">

              <div class="row" style="gap:12px">
                <div class="field" style="flex:1;min-width:240px">
                  <label>Full Name</label>
                  <input class="input basic" name="fullName" value="<%= s(app.fullName, (s(app.firstName)+" "+s(app.lastName)).trim()) %>" disabled>
                </div>
                <div class="field" style="flex:1;min-width:240px">
                  <label>Phone</label>
                  <input class="input basic" name="phone" value="<%= s(app.phone) %>" disabled>
                </div>
              </div>

              <div class="row" style="gap:12px;margin-top:12px">
                <div class="field" style="flex:1;min-width:240px">
                  <label>Email</label>
                  <input class="input basic" type="email" name="email" value="<%= s(app.email) %>" disabled>
                </div>
                <div class="field" style="flex:1;min-width:240px">
                  <label>Nationality</label>
                  <input class="input basic" name="nationality" value="<%= s(app.nationality) %>" disabled>
                </div>
              </div>

              <div class="field" style="margin-top:12px">
                <label>Address</label>
                <input class="input basic" name="address" value="<%= s(app.address) %>" disabled>
              </div>

              <div class="divider"></div>
              <div class="row" style="justify-content:flex-end">
                <button class="btn light" type="button" id="btnCancelEdit" style="display:none"><i class="fa-solid fa-xmark"></i> Cancel</button>
                <button class="btn primary" type="submit" id="btnSaveBasic" style="display:none"><i class="fa-solid fa-check"></i> Save</button>
              </div>
            </form>
          </div>

          <!-- DOCUMENTS -->
          <div class="pane" id="pane-docs">
            <div class="muted">Upload missing documents or replace unclear scans.</div>
            <div class="divider"></div>

            <div class="file-grid">
              <% REQUIRED.forEach(r => { const ok = hasDoc(r.key); %>
                <div class="file">
                  <div class="meta">
                    <div class="name"><%= r.label %></div>
                    <div class="desc"><%= r.required ? "Required" : "Optional" %></div>
                  </div>

                  <div class="row" style="justify-content:flex-end">
                    <% if (ok) { %>
                      <span class="tag ok">Uploaded</span>
                      <button
                        class="btn light small js-upload"
                        type="button"
                        data-doc-key="<%= r.key %>"
                        data-doc-label="<%= r.label %>"
                        data-mode="replace"
                      >
                        <i class="fa-solid fa-arrows-rotate"></i> Replace
                      </button>
                    <% } else { %>
                      <span class="tag <%= r.required ? "miss" : "req" %>"><%= r.required ? "Missing" : "Not provided" %></span>
                      <button
                        class="btn primary small js-upload"
                        type="button"
                        data-doc-key="<%= r.key %>"
                        data-doc-label="<%= r.label %>"
                        data-mode="upload"
                      >
                        <i class="fa-solid fa-upload"></i> Upload
                      </button>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>

            <div class="divider"></div>
            <div class="row">
              <button class="btn light small" type="button" data-open-modal="mUploadAny">
                <i class="fa-solid fa-paperclip"></i> Upload Additional
              </button>
            </div>

            <div class="divider"></div>

            <div class="muted"><b>Your uploaded files</b></div>
            <div class="table-wrap" style="margin-top:10px">
              <table>
                <thead>
                  <tr>
                    <th>Type</th>
                    <th>File</th>
                    <th>Verification</th>
                    <th>Uploaded</th>
                    <th style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!docs.length) { %>
                    <tr><td colspan="5" class="muted">No files recorded yet.</td></tr>
                  <% } else { %>
                    <% docs.forEach(d => { const v=s(d.verification,"pending"); %>
                      <tr>
                        <td class="strong"><%= s(d.label, s(d.type, s(d.key,"Document"))) %></td>
                        <td class="muted"><%= s(d.originalName, s(d.filename,"—")) %></td>
                        <td>
                          <% if (v === "verified") { %><span class="pill p-ok"><i class="fa-solid fa-check"></i> Verified</span><% } %>
                          <% if (v === "pending") { %><span class="pill p-warn"><i class="fa-solid fa-hourglass-half"></i> Pending</span><% } %>
                          <% if (v === "rejected") { %><span class="pill p-bad"><i class="fa-solid fa-xmark"></i> Rejected</span><% } %>
                        </td>
                        <td class="muted"><%= d.createdAt ? new Date(d.createdAt).toLocaleString() : "—" %></td>
                        <td style="text-align:right;">
                          <% if (d.url) { %>
                            <a class="btn light small" href="<%= d.url %>" target="_blank" rel="noreferrer"><i class="fa-solid fa-eye"></i> View</a>
                          <% } else { %>
                            <button
                              class="btn light small js-preview"
                              type="button"
                              data-doc-key="<%= s(d.key, s(d.type,'')) %>"
                            >
                              <i class="fa-solid fa-eye"></i> Preview
                            </button>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- PAYMENT -->
          <div class="pane" id="pane-pay">
            <div class="row" style="justify-content:space-between;">
              <div>
                <div class="strong">Application Fee</div>
                <div class="muted">Pay and keep receipt for records.</div>
              </div>
              <span class="pill <%= payClass %>"><i class="fa-solid fa-coins"></i> <%= payLabel %></span>
            </div>

            <div class="divider"></div>

            <div class="row">
              <button class="btn primary small" type="button" data-open-modal="mPay">
                <i class="fa-solid fa-credit-card"></i> Pay Now
              </button>
              <button class="btn light small" type="button" data-open-modal="mHelp">
                <i class="fa-solid fa-envelope"></i> Ask about payment
              </button>
            </div>

            <div class="divider"></div>

            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Txn</th>
                    <th>Method</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th style="text-align:right;">Receipt</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!payments.length) { %>
                    <tr><td colspan="6" class="muted">No payment history yet.</td></tr>
                  <% } else { %>
                    <% payments.forEach(p => { const st=s(p.status,"pending"); %>
                      <tr>
                        <td class="strong"><%= s(p.reference, s(p.txnId,"—")) %></td>
                        <td class="muted"><%= s(p.method,"—") %></td>
                        <td class="muted"><%= s(p.currency,"UGX") %> <%= s(p.amount,"0") %></td>
                        <td>
                          <% if (st === "success") { %><span class="pill p-ok"><i class="fa-solid fa-check"></i> Success</span><% } %>
                          <% if (st === "pending") { %><span class="pill p-warn"><i class="fa-solid fa-hourglass-half"></i> Pending</span><% } %>
                          <% if (st === "failed") { %><span class="pill p-bad"><i class="fa-solid fa-xmark"></i> Failed</span><% } %>
                        </td>
                        <td class="muted"><%= p.createdAt ? new Date(p.createdAt).toLocaleString() : "—" %></td>
                        <td style="text-align:right;">
                          <% if (p.receiptUrl) { %>
                            <a class="btn light small" href="<%= p.receiptUrl %>" target="_blank" rel="noreferrer"><i class="fa-solid fa-receipt"></i> Receipt</a>
                          <% } else { %>
                            <button class="btn light small" type="button" disabled><i class="fa-solid fa-receipt"></i> Receipt</button>
                          <% } %>
                        </td>
                      </tr>
                    <% }) %>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <!-- INTERVIEW -->
          <div class="pane" id="pane-interview">
            <div class="row" style="justify-content:space-between;">
              <div>
                <div class="strong">Interview & Screening</div>
                <div class="muted">Admissions will schedule if required.</div>
              </div>
              <% const iStatus = app ? s(app.interviewStatus,"pending") : "pending"; %>
              <% if (iStatus === "scheduled") { %>
                <span class="pill p-ok"><i class="fa-solid fa-video"></i> Scheduled</span>
              <% } else { %>
                <span class="pill p-warn"><i class="fa-solid fa-hourglass-half"></i> Pending</span>
              <% } %>
            </div>

            <div class="divider"></div>

            <div class="row" style="gap:12px">
              <div class="card kpi" style="box-shadow:none;flex:1">
                <div class="label">Date & Time</div>
                <div class="value" style="font-size:16px"><%= app && app.interviewAt ? new Date(app.interviewAt).toLocaleString() : "Not scheduled" %></div>
                <div class="hint">Check often</div>
              </div>
              <div class="card kpi" style="box-shadow:none;flex:1">
                <div class="label">Location / Link</div>
                <div class="value" style="font-size:16px"><%= s(app.interviewLocation,"—") %></div>
                <div class="hint">Meet/Zoom/Office</div>
              </div>
            </div>

            <div class="divider"></div>
            <button class="btn light small" type="button" data-open-modal="mHelp"><i class="fa-solid fa-envelope"></i> Ask about interview</button>
          </div>

          <!-- DECISION -->
          <div class="pane" id="pane-decision">
            <div class="row" style="justify-content:space-between;">
              <div>
                <div class="strong">Decision</div>
                <div class="muted">Decision appears here once finalized.</div>
              </div>

              <% if (status === "accepted") { %>
                <span class="pill p-ok"><i class="fa-solid fa-check"></i> Accepted</span>
              <% } else if (status === "rejected") { %>
                <span class="pill p-bad"><i class="fa-solid fa-xmark"></i> Rejected</span>
              <% } else { %>
                <span class="pill p-warn"><i class="fa-solid fa-hourglass-half"></i> Pending</span>
              <% } %>
            </div>

            <div class="divider"></div>

            <div class="field">
              <label>Decision Notes</label>
              <textarea class="textarea" disabled><%= s(app.decisionNotes,"") %></textarea>
            </div>

            <div class="divider"></div>
            <div class="row">
              <% if (app.offerLetterUrl) { %>
                <a class="btn light small" href="<%= s(app.offerLetterUrl) %>" target="_blank" rel="noreferrer"><i class="fa-solid fa-envelope"></i> Offer Letter</a>
              <% } else { %>
                <button class="btn light small" type="button" disabled><i class="fa-solid fa-envelope"></i> Offer Letter</button>
              <% } %>

              <% if (app.admissionLetterUrl) { %>
                <a class="btn primary small" href="<%= s(app.admissionLetterUrl) %>" target="_blank" rel="noreferrer"><i class="fa-solid fa-file-signature"></i> Admission Letter</a>
              <% } else { %>
                <button class="btn light small" type="button" disabled><i class="fa-solid fa-file-signature"></i> Admission Letter</button>
              <% } %>
            </div>
          </div>

          <!-- TIMELINE -->
          <div class="pane" id="pane-audit">
            <div class="muted">History of updates from admissions and system events.</div>
            <div class="divider"></div>

            <div class="timeline" id="auditList">
              <% if (!timeline.length) { %>
                <div class="event">
                  <div class="top">
                    <div>
                      <div class="title">Application submitted</div>
                      <div class="meta"><%= app.createdAt ? new Date(app.createdAt).toLocaleString() : "—" %></div>
                    </div>
                    <span class="pill p-info"><i class="fa-solid fa-user"></i> System</span>
                  </div>
                </div>
              <% } else { %>
                <% timeline.forEach(t => { %>
                  <div class="event">
                    <div class="top">
                      <div>
                        <div class="title"><%= s(t.title, s(t.action,"Update")) %></div>
                        <div class="meta"><%= t.createdAt ? new Date(t.createdAt).toLocaleString() : s(t.meta,"") %></div>
                      </div>
                      <span class="pill p-info"><i class="fa-solid fa-user"></i> <%= s(t.by, "Admissions") %></span>
                    </div>
                  </div>
                <% }) %>
              <% } %>
            </div>
          </div>

        </div>
      </section>

      <!-- RIGHT SIDE HELP -->
      <aside class="card">
        <div class="card-head">
          <div>
            <div class="card-title">Quick Actions</div>
            <div class="card-sub">Fix missing items quickly</div>
          </div>
        </div>

        <div class="card-body">
          <div class="row">
            <span class="pill <%= stageClass %>"><i class="fa-solid fa-circle-info"></i> <%= stageLabel %></span>
            <span class="pill <%= payClass %>"><i class="fa-solid fa-coins"></i> <%= payLabel %></span>
          </div>

          <div class="divider"></div>
          <div class="muted">
            Upload missing documents and keep your contact details correct. If you paid and it’s not updated, message admissions with your transaction reference.
          </div>

          <div class="divider"></div>
          <div class="row">
            <button class="btn primary small" type="button" data-open-modal="mUploadAny"><i class="fa-solid fa-upload"></i> Upload Docs</button>
            <button class="btn light small" type="button" data-open-modal="mPay"><i class="fa-solid fa-credit-card"></i> Pay</button>
            <button class="btn light small" type="button" data-open-modal="mHelp"><i class="fa-solid fa-envelope"></i> Message</button>
          </div>
        </div>
      </aside>
    </div>

  <% } %>

</div>

<!-- Upload (specific) -->
<div class="modal-backdrop" id="mUpload">
  <div class="modal" style="width:min(680px,100%)">
    <div class="modal-header">
      <div class="modal-title">Upload / Replace Document</div>
      <button class="btn light small" type="button" data-close-modal="mUpload"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="modal-body" method="POST" action="/admissions/status/documents" enctype="multipart/form-data">
      <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
      <input type="hidden" name="applicationId" value="<%= app ? s(app.applicationId) : '' %>">
      <input type="hidden" name="docKey" id="uKey" value="">

      <div class="field">
        <label>Document</label>
        <input class="input" id="uLabel" value="" disabled>
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Select File</label>
        <input class="input" type="file" name="file" required accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*">
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Note to Admissions (optional)</label>
        <textarea class="textarea" name="note" placeholder="e.g. clearer scan / corrected document"></textarea>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mUpload">Cancel</button>
        <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Upload</button>
      </div>
    </form>
  </div>
</div>

<!-- Upload any -->
<div class="modal-backdrop" id="mUploadAny">
  <div class="modal" style="width:min(680px,100%)">
    <div class="modal-header">
      <div class="modal-title">Upload Additional Document</div>
      <button class="btn light small" type="button" data-close-modal="mUploadAny"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="modal-body" method="POST" action="/admissions/status/documents" enctype="multipart/form-data">
      <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
      <input type="hidden" name="applicationId" value="<%= app ? s(app.applicationId) : '' %>">

      <div class="field">
        <label>Document Type</label>
        <select class="select" name="docKey" required>
          <option value="">Select</option>
          <option value="idDocument">National ID / Passport</option>
          <option value="passportPhoto">Passport Photo</option>
          <option value="transcript">Transcript / Results Slip</option>
          <option value="certificates">Certificates</option>
          <option value="recommendation">Recommendation Letter</option>
          <option value="medical">Medical Form</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Select File</label>
        <input class="input" type="file" name="file" required accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*">
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Note (optional)</label>
        <textarea class="textarea" name="note" placeholder="Describe what this is."></textarea>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mUploadAny">Cancel</button>
        <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Upload</button>
      </div>
    </form>
  </div>
</div>

<!-- Pay -->
<div class="modal-backdrop" id="mPay">
  <div class="modal" style="width:min(720px,100%)">
    <div class="modal-header">
      <div class="modal-title">Pay Application Fee</div>
      <button class="btn light small" type="button" data-close-modal="mPay"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="modal-body" method="POST" action="/admissions/pay">
      <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
      <input type="hidden" name="applicationId" value="<%= app ? s(app.applicationId) : '' %>">

      <div class="field">
        <label>Method</label>
        <select class="select" name="method" required>
          <option value="momo">Mobile Money</option>
          <option value="bank">Bank</option>
          <option value="card">Card</option>
        </select>
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Phone (for Mobile Money)</label>
        <input class="input" name="phone" placeholder="+256..." value="<%= app ? s(app.phone) : '' %>">
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mPay">Cancel</button>
        <button class="btn primary" type="submit"><i class="fa-solid fa-lock"></i> Proceed</button>
      </div>
    </form>
  </div>
</div>

<!-- Help -->
<div class="modal-backdrop" id="mHelp">
  <div class="modal" style="width:min(720px,100%)">
    <div class="modal-header">
      <div class="modal-title">Message Admissions</div>
      <button class="btn light small" type="button" data-close-modal="mHelp"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form class="modal-body" method="POST" action="/admissions/status/message">
      <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
      <input type="hidden" name="applicationId" value="<%= app ? s(app.applicationId) : '' %>">

      <div class="field">
        <label>Message</label>
        <textarea class="textarea" name="message" required placeholder="Write your question..."></textarea>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mHelp">Cancel</button>
        <button class="btn primary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/status.js" defer></script>
</body>
</html>
