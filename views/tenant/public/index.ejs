<script>
  // Year
  document.getElementById('y').textContent = new Date().getFullYear();

  // Clean hamburger
  const hamburger = document.getElementById('hamburger');
  const mobilePanel = document.getElementById('mobilePanel');

  function openMenu(){
    hamburger.classList.add('open');
    hamburger.setAttribute('aria-expanded','true');
    mobilePanel.style.display = 'block';
    mobilePanel.setAttribute('aria-hidden','false');
  }
  function closeMenu(){
    hamburger.classList.remove('open');
    hamburger.setAttribute('aria-expanded','false');
    mobilePanel.style.display = 'none';
    mobilePanel.setAttribute('aria-hidden','true');
  }
  function isOpen(){ return hamburger.classList.contains('open'); }

  hamburger.addEventListener('click', (e)=>{
    e.stopPropagation();
    isOpen() ? closeMenu() : openMenu();
  });

  mobilePanel.querySelectorAll('a').forEach(a=>{
    a.addEventListener('click', ()=> closeMenu());
  });

  document.addEventListener('click', (e)=>{
    if(!isOpen()) return;
    const within = mobilePanel.contains(e.target) || hamburger.contains(e.target);
    if(!within) closeMenu();
  });

  document.addEventListener('keydown', (e)=>{
    if(e.key === 'Escape' && isOpen()) closeMenu();
  });

  // Tabs inside admissions card
  const tabs = document.querySelectorAll('.tab');
  const applyForm = document.getElementById('applyForm');
  const statusForm = document.getElementById('statusForm');
  const infoTab = document.getElementById('infoTab');

  tabs.forEach(t=>{
    t.addEventListener('click', ()=>{
      tabs.forEach(x=>x.classList.remove('active'));
      t.classList.add('active');

      const id = t.dataset.tab;
      applyForm.style.display = (id==='applyTab') ? 'grid' : 'none';
      statusForm.style.display = (id==='statusTab') ? 'grid' : 'none';
      infoTab.style.display = (id==='infoTab') ? 'grid' : 'none';

      document.getElementById('applyOk').style.display='none';
      document.getElementById('statusOk').style.display='none';
    });
  });

  // Validation helpers
  const isEmail = (v)=>/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
  function showErr(id, ok){
    const el = document.getElementById(id);
    if(el) el.style.display = ok ? 'none' : 'block';
  }

  // Apply form submit (UI only)
  applyForm.addEventListener('submit',(e)=>{
    e.preventDefault();
    const name = document.getElementById('a_name').value.trim();
    const email = document.getElementById('a_email').value.trim();
    const phone = document.getElementById('a_phone').value.trim();
    const level = document.getElementById('a_level').value.trim();
    const intake = document.getElementById('a_intake').value.trim();

    showErr('e_a_name', !!name);
    showErr('e_a_email', isEmail(email));
    showErr('e_a_phone', !!phone);
    showErr('e_a_level', !!level);
    showErr('e_a_intake', !!intake);

    if(!name || !isEmail(email) || !phone || !level || !intake) return;

    document.getElementById('applyOk').style.display='block';
  });

  // Status form submit (UI only)
  statusForm.addEventListener('submit',(e)=>{
    e.preventDefault();
    const appid = document.getElementById('s_appid').value.trim();
    const email = document.getElementById('s_email').value.trim();

    showErr('e_s_appid', !!appid);
    showErr('e_s_email', isEmail(email));
    if(!appid || !isEmail(email)) return;

    document.getElementById('statusOk').style.display='block';
  });
</script>

