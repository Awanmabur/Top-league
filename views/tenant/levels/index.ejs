<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Levels</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}.toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}.input{min-width:220px}.textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}.view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff}.view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}.strong{font-weight:900}.grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}.grid-2{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(280px,.7fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}.ok{background:#ecfdf3;color:#15803d}.bad{background:#fee2e2;color:#b91c1c}
    .table-wrap{overflow-x:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px}.table-wrap table{width:100%;min-width:1080px;border-collapse:separate;border-spacing:0;background:#fff}.table-wrap th,.table-wrap td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}.table-wrap th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr.row-clickable{cursor:pointer}tr:hover td{background:rgba(10,111,191,.04)}.actions{display:flex;gap:6px;justify-content:flex-end}.btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px}.btn-xs:hover{background:rgba(10,111,191,.06)}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}.flash{padding:12px 14px;border-radius:12px;font-weight:700}.flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}.flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}.topbar > div:first-child{min-width:0;flex:1 1 auto}.top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}.modal-backdrop.show{display:flex}.modal{width:min(1080px,100%);max-height:calc(100dvh - 40px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}.modal.sm{width:min(880px,100%)}.modal > form{display:flex;flex-direction:column;min-height:0;flex:1 1 auto}.modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}.modal-title{font-weight:900;font-size:18px;color:#0f172a}.modal-body{padding:18px 20px;overflow-y:auto;flex:1 1 auto}.modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}.modal-layout{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(320px,.9fr);gap:18px;align-items:start}.modal-panel{border:1px solid rgba(13,64,96,.10);border-radius:18px;padding:16px;background:#fcfdff}.panel-title{font-size:13px;font-weight:900;color:#0f172a;margin-bottom:2px}.panel-sub{font-size:12px;color:#6b7280;margin-bottom:14px}.form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}.field{display:flex;flex-direction:column;gap:6px}.field.full{grid-column:1 / -1}.field label{font-size:12px;font-weight:800;color:#475569}.help{font-size:12px;color:#6b7280}.char-count{font-size:12px;color:#6b7280;text-align:right}.note-box{padding:12px 14px;border-radius:14px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03);font-size:12px;color:#475569;line-height:1.5}.section-divider{height:1px;background:rgba(13,64,96,.10);margin:14px 0}.mini-list{display:grid;gap:10px;margin-top:10px}.mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}.mini-item .left{display:grid;gap:2px}.pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}.pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}.page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}.page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}.page-link.disabled{pointer-events:none;opacity:.45}.json-data{display:none!important}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}.modal-layout{grid-template-columns:1fr}}@media (max-width:900px){.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}@media (max-width:720px){.form-grid{grid-template-columns:1fr}}@media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>
    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap"><% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %><% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %></div>
      <% } %>

      <div class="topbar">
        <div><div class="title">Levels</div><div class="subtitle">Manage academic levels per school unit and campus. Levels remain part of the tenant academic structure.</div></div>
        <div class="top-actions"><button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button><button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Level</button></div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div><div class="muted">Levels configured</div></div>
        <div class="card"><div class="section-title">Active</div><div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div><div class="muted">Operational levels</div></div>
        <div class="card"><div class="section-title">Inactive</div><div class="kpi-value" style="color:#b91c1c"><%= kpis?.inactive || 0 %></div><div class="muted">Hidden levels</div></div>
        <div class="card"><div class="section-title">Sections</div><div class="kpi-value"><%= kpis?.sections || 0 %></div><div class="muted">Streams under levels</div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/levels">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search level, code, campus..." />
            <select class="select" name="schoolUnitCode"><option value="">All School Units</option><% (schoolUnitOptions || []).forEach(function(item){ %><option value="<%= item.code %>" <%= query?.schoolUnitCode === item.code ? 'selected' : '' %>><%= item.name %></option><% }) %></select>
            <select class="select" name="campusCode"><option value="">All Campuses</option><% (campusOptions || []).forEach(function(item){ %><option value="<%= item.campusCode %>" <%= query?.campusCode === item.campusCode ? 'selected' : '' %>><%= item.schoolUnitName %> • <%= item.campusName %></option><% }) %></select>
            <select class="select" name="status"><option value="">All Status</option><option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option><option value="inactive" <%= query?.status === 'inactive' ? 'selected' : '' %>>Inactive</option></select>
          </div>
          <div class="right"><a class="btn light" href="/admin/levels"><i class="fa-solid fa-rotate-left"></i> Reset</a><button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button></div>
        </form>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;"><div><div class="section-title">Levels Table</div><div class="section-sub">Showing <%= levels.length %> of <%= query?.total || 0 %> records.</div></div><div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div></div>
          <div style="margin-top:10px;"><div class="table-wrap"><table><thead><tr><th>Level</th><th>School Unit</th><th>Campus</th><th>Sections / Streams</th><th>Status</th><th style="text-align:right;">Actions</th></tr></thead><tbody id="tbodyLevels"></tbody></table></div></div>
          <div class="pagination"><div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div><div class="pagination-links"><%
            const currentPage = Number(query?.page || 1);
            const totalPages = Number(query?.totalPages || 1);
            function buildPageUrl(targetPage) {
              const params = new URLSearchParams();
              if (query?.q) params.set("q", query.q);
              if (query?.schoolUnitCode) params.set("schoolUnitCode", query.schoolUnitCode);
              if (query?.campusCode) params.set("campusCode", query.campusCode);
              if (query?.status) params.set("status", query.status);
              params.set("page", String(targetPage));
              return "/admin/levels?" + params.toString();
            }
            const startPage = Math.max(1, currentPage - 2);
            const endPage = Math.min(totalPages, currentPage + 2);
          %><a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>"><i class="fa-solid fa-angle-left"></i></a><% for (let p = startPage; p <= endPage; p++) { %><a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a><% } %><a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>"><i class="fa-solid fa-angle-right"></i></a></div></div>
        </section>

        <aside class="card"><div class="section-title">Architecture Note</div><div class="section-sub">Levels are not a separate standalone collection.</div><div class="note-box">A level belongs to <strong>school unit → campus</strong> and lives inside the tenant academic structure. Subjects, learners, timetable, exams and attendance should attach to that structure instead of duplicating it.</div><div class="mini-list"><div class="mini-item"><div class="left"><div class="strong">Primary example</div><div class="muted">Campus → P1 → Stream A / B</div></div><i class="fa-solid fa-school"></i></div><div class="mini-item"><div class="left"><div class="strong">Secondary example</div><div class="muted">Campus → S5 → Stream A / B</div></div><i class="fa-solid fa-graduation-cap"></i></div></div></aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit"><div class="modal"><div class="modal-header"><div class="modal-title" id="mTitleBar">Add Level</div><button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button></div>
    <form id="levelForm" method="POST" action="/admin/levels"><% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
      <div class="modal-body"><div class="modal-layout">
        <section class="modal-panel"><div class="panel-title">Level Information</div><div class="panel-sub">Placement and identity for the level.</div>
          <div class="form-grid">
            <div class="field full"><label for="mName">Level Name</label><input class="input" id="mName" name="name" placeholder="e.g. P1, S1, BABY" required /></div>
            <div class="field"><label for="mCode">Level Code</label><input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" /></div>
            <div class="field"><label for="mStatus">Status</label><select class="select" id="mStatus" name="status"><option value="active">Active</option><option value="inactive">Inactive</option></select></div>
            <div class="field"><label for="mSchoolUnitCode">School Unit</label><select class="select" id="mSchoolUnitCode" name="schoolUnitCode"><% (schoolUnitOptions || []).forEach(function(item){ %><option value="<%= item.code %>"><%= item.name %></option><% }) %></select></div>
            <div class="field"><label for="mCampusCode">Campus</label><select class="select" id="mCampusCode" name="campusCode"></select></div>
            <div class="field full"><label for="mSectionsText">Default Sections / Streams</label><textarea class="textarea" id="mSectionsText" name="sectionsText" maxlength="1000" placeholder="A, B or Red, Blue"></textarea><div class="help">Separate sections with commas, pipes or new lines. Leave blank to auto-seed defaults for the category.</div><div class="char-count" id="sectionsCount">0 / 1000</div></div>
          </div>
        </section>
        <section class="modal-panel"><div class="panel-title">Level Profile</div><div class="panel-sub">Optional academic notes used across modules.</div>
          <div class="note-box">Because levels already live under each campus in the tenant structure, this module updates the embedded academic tree instead of creating a duplicate standalone level collection.</div>
          <div class="form-grid" style="margin-top:12px;"><div class="field full"><label for="mTitle">Profile Title</label><input class="input" id="mTitle" name="title" maxlength="120" placeholder="e.g. Primary One" /></div><div class="field"><label for="mCurriculum">Curriculum</label><input class="input" id="mCurriculum" name="curriculum" maxlength="120" placeholder="e.g. UNEB" /></div><div class="field"><label for="mAdmissionsNote">Admissions Note</label><input class="input" id="mAdmissionsNote" name="admissionsNote" maxlength="1200" placeholder="Any admissions note" /></div><div class="field full"><label for="mDescription">Description</label><textarea class="textarea" id="mDescription" name="description" maxlength="2000" placeholder="Describe the level..."></textarea><div class="char-count" id="descCount">0 / 2000</div></div><div class="field full"><label for="mFeesNote">Fees Note</label><textarea class="textarea" id="mFeesNote" name="feesNote" maxlength="1200" placeholder="Any fees note"></textarea></div></div>
        </section>
      </div></div>
      <div class="modal-footer"><button class="btn light" type="button" data-close-modal="mEdit">Cancel</button><button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Level</button></div>
    </form></div></div>

  <div class="modal-backdrop" id="mView"><div class="modal sm"><div class="modal-header"><div class="modal-title">Level Details</div><button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button></div>
    <div class="modal-body"><div class="form-grid"><div class="field"><label>Level</label><div class="view-input" id="vName">—</div></div><div class="field"><label>Code</label><div class="view-input" id="vCode">—</div></div><div class="field"><label>School Unit</label><div class="view-input" id="vSchoolUnit">—</div></div><div class="field"><label>Campus</label><div class="view-input" id="vCampus">—</div></div><div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div><div class="field"><label>Sections / Streams</label><div class="view-input" id="vSections">—</div></div><div class="field full"><label>Profile Title</label><div class="view-input" id="vTitle">—</div></div><div class="field"><label>Curriculum</label><div class="view-input" id="vCurriculum">—</div></div></div><div class="section-divider"></div><div class="field"><label>Description</label><div class="view-input multiline" id="vDescription">—</div></div><div class="field" style="margin-top:12px;"><label>Admissions Note</label><div class="view-input multiline" id="vAdmissionsNote">—</div></div><div class="field" style="margin-top:12px;"><label>Fees Note</label><div class="view-input multiline" id="vFeesNote">—</div></div></div>
    <div class="modal-footer"><button class="btn light" type="button" id="viewActivateBtn"><i class="fa-solid fa-circle-check"></i> Activate</button><button class="btn light" type="button" id="viewDeactivateBtn"><i class="fa-solid fa-circle-minus"></i> Deactivate</button><button class="btn light" type="button" data-close-modal="mView">Close</button><button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button></div>
  </div></div>

  <form id="rowActionForm" method="POST" style="display:none;"><% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %><input type="hidden" name="status" id="rowStatusField"></form>
  <textarea id="levelsData" class="json-data" aria-hidden="true"><%- JSON.stringify(levels || []) %></textarea>
  <textarea id="structureData" class="json-data" aria-hidden="true"><%- JSON.stringify(structure || []) %></textarea>
  <script src="/js/navbar.js"></script>
  <script src="/js/levels.js"></script>
</body>
</html>
