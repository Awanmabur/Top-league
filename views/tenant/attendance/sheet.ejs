<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Attendance Sheet</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:wrap}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap}
    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    table{width:100%;min-width:1200px;border-collapse:separate;border-spacing:0}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .status-group{display:flex;gap:6px;flex-wrap:wrap}
    .status-btn{padding:8px 10px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-weight:800;font-size:12px}
    .status-btn.active-present{background:#ecfdf3;color:#15803d;border-color:#86efac}
    .status-btn.active-absent{background:#fee2e2;color:#b91c1c;border-color:#fca5a5}
    .status-btn.active-late{background:#fef9c3;color:#92400e;border-color:#fde68a}
    .status-btn.active-excused{background:#eef2ff;color:#3730a3;border-color:#c7d2fe}
    .note-input{min-width:220px}
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Attendance Sheet</div>
          <div class="subtitle">Choose a course and one session time, then mark everyone inline and save all at once.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/attendance"><i class="fa-solid fa-table"></i> Standard View</a>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/attendance/sheet">
          <div class="left">
            <select class="select" name="course" required>
              <option value="">Select Course</option>
              <% (courses || []).forEach(function(c){ %>
                <option value="<%= c._id %>" <%= String(selectedCourse?._id || '') === String(c._id) ? 'selected' : '' %>>
                  <%= (c.code ? (c.code + ' — ') : '') + (c.title || c.name || 'Course') %>
                </option>
              <% }) %>
            </select>

            <input class="input" type="datetime-local" name="sessionAt" value="<%= sessionAtValue || '' %>" required />
          </div>

          <div class="right">
            <button class="btn primary" type="submit"><i class="fa-solid fa-bolt"></i> Load Sheet</button>
          </div>
        </form>
      </section>

      <% if (selectedCourse && sessionAtValue) { %>
        <section class="card" style="margin-top:12px;">
          <div style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap;">
            <div>
              <div class="section-title">Current Session</div>
              <div class="section-sub">
                <strong><%= (selectedCourse.code ? selectedCourse.code + ' — ' : '') + (selectedCourse.title || selectedCourse.name || 'Course') %></strong>
                • <%= new Date(sessionAtValue).toLocaleString() %>
              </div>
            </div>

            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <button class="btn light" type="button" id="markAllPresent">Mark All Present</button>
              <button class="btn light" type="button" id="markAllAbsent">Mark All Absent</button>
              <button class="btn light" type="button" id="markAllLate">Mark All Late</button>
              <button class="btn light" type="button" id="markAllExcused">Mark All Excused</button>
            </div>
          </div>

          <form method="POST" action="/admin/attendance/sheet" id="sheetForm" style="margin-top:12px;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
            <input type="hidden" name="course" value="<%= selectedCourse._id %>">
            <input type="hidden" name="sessionAt" value="<%= sessionAtValue %>">

            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:60px;">#</th>
                    <th style="width:280px;">Student</th>
                    <th style="width:180px;">Reg No</th>
                    <th style="width:420px;">Status</th>
                    <th style="width:320px;">Notes</th>
                  </tr>
                </thead>
                <tbody>
                  <% if ((roster || []).length) { %>
                    <% roster.forEach(function(s, idx){ 
                      const keyById = "s:" + String(s._id);
                      const keyByReg = "r:" + String(s.regNo || "");
                      const existing = existingMap[keyById] || existingMap[keyByReg] || {};
                      const st = existing.status || "present";
                      const nt = existing.notes || "";
                    %>
                      <tr>
                        <td><%= idx + 1 %></td>
                        <td>
                          <div class="strong"><%= s.fullName || 'Student' %></div>
                          <div class="muted"><%= s.email || '—' %></div>
                          <input type="hidden" name="rows[<%= idx %>][student]" value="<%= s._id %>">
                          <input type="hidden" name="rows[<%= idx %>][regNo]" value="<%= s.regNo || '' %>">
                        </td>
                        <td><%= s.regNo || '—' %></td>
                        <td>
                          <div class="status-group" data-row-status>
                            <button type="button" class="status-btn <%= st === 'present' ? 'active-present' : '' %>" data-status="present">Present</button>
                            <button type="button" class="status-btn <%= st === 'absent' ? 'active-absent' : '' %>" data-status="absent">Absent</button>
                            <button type="button" class="status-btn <%= st === 'late' ? 'active-late' : '' %>" data-status="late">Late</button>
                            <button type="button" class="status-btn <%= st === 'excused' ? 'active-excused' : '' %>" data-status="excused">Excused</button>
                            <input type="hidden" name="rows[<%= idx %>][status]" value="<%= st %>" class="row-status-value">
                          </div>
                        </td>
                        <td>
                          <input class="input note-input" name="rows[<%= idx %>][notes]" value="<%= nt %>" placeholder="Optional note">
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="5">
                        <div class="muted">No students found for this sheet.</div>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap;margin-top:14px;">
              <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Sheet</button>
            </div>
          </form>
        </section>
      <% } else { %>
        <section class="card" style="margin-top:12px;">
          <div class="muted">Choose a course and session date/time to load the attendance sheet.</div>
        </section>
      <% } %>
    </main>
  </div>

  <script src="/js/navbar.js"></script>
  <script>
    (function () {
      function applyStatusToGroup(group, status) {
        const hidden = group.querySelector(".row-status-value");
        if (hidden) hidden.value = status;

        group.querySelectorAll(".status-btn").forEach(function (btn) {
          btn.classList.remove("active-present", "active-absent", "active-late", "active-excused");
          if (btn.dataset.status === status) {
            btn.classList.add("active-" + status);
          }
        });
      }

      document.querySelectorAll("[data-row-status]").forEach(function (group) {
        group.addEventListener("click", function (e) {
          const btn = e.target.closest(".status-btn");
          if (!btn) return;
          applyStatusToGroup(group, btn.dataset.status);
        });
      });

      function markAll(status) {
        document.querySelectorAll("[data-row-status]").forEach(function (group) {
          applyStatusToGroup(group, status);
        });
      }

      const allPresent = document.getElementById("markAllPresent");
      const allAbsent = document.getElementById("markAllAbsent");
      const allLate = document.getElementById("markAllLate");
      const allExcused = document.getElementById("markAllExcused");

      if (allPresent) allPresent.addEventListener("click", function () { markAll("present"); });
      if (allAbsent) allAbsent.addEventListener("click", function () { markAll("absent"); });
      if (allLate) allLate.addEventListener("click", function () { markAll("late"); });
      if (allExcused) allExcused.addEventListener("click", function () { markAll("excused"); });
    })();
  </script>
</body>
</html>
