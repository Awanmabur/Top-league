<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Attendance</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1500px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}
    .col-check{width:48px}
    .col-student{width:260px}
    .col-reg{width:140px}
    .col-class{width:180px}
    .col-subject{width:200px}
    .col-session{width:180px}
    .col-status{width:140px}
    .col-notes{width:220px}
    .col-actions{width:320px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .student-main{min-width:0}
    .student-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .student-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1080px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(560px,100%)}
    .modal.md{width:min(920px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}
    .json-data{display:none !important}

    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width: 680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width: 520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left > *,.toolbar .right > *{max-width:100%}table{min-width:1500px}}
    @media print{body *{visibility:hidden !important}#printArea, #printArea *{visibility:visible !important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Attendance</div>
          <div class="subtitle">Mark, update, import and manage student attendance by subject.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/tenant/attendance/sheet"><i class="fa-solid fa-table-list"></i> Attendance Sheet</a>
          <a class="btn light" href="/tenant/attendance/import-template"><i class="fa-solid fa-download"></i> Import Template</a>
          <a class="btn light" href="/tenant/attendance/export?<%= new URLSearchParams({
            q: query?.q || '',
            subject: query?.subject || '',
            classGroup: query?.classGroup || '',
            status: query?.status || '',
            academicYear: query?.academicYear || '',
            term: query?.term || '',
            from: query?.from || '',
            to: query?.to || ''
          }).toString() %>"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</a>
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Mark Attendance</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Present</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.present || 0 %></div>
          <div class="muted">Attended</div>
        </div>
        <div class="card">
          <div class="section-title">Absent</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.absent || 0 %></div>
          <div class="muted">Not present</div>
        </div>
        <div class="card">
          <div class="section-title">Late / Excused</div>
          <div class="kpi-value" style="color:#92400e"><%= (kpis?.late || 0) + (kpis?.excused || 0) %></div>
          <div class="muted">Special cases</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/tenant/attendance">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search student, reg no, email..." />

            <select class="select" name="classGroup">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= String(c._id) %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>><%= c.name || c.code || 'Class' %></option>
              <% }) %>
            </select>

            <select class="select" name="subject">
              <option value="">All Subjects</option>
              <% (subjects || []).forEach(function(s){ %>
                <option value="<%= String(s._id) %>" <%= String(query?.subject || '') === String(s._id) ? 'selected' : '' %>><%= s.title || s.code || 'Subject' %></option>
              <% }) %>
            </select>

            <input class="input" name="academicYear" value="<%= query?.academicYear || '' %>" placeholder="Academic Year" />

            <select class="select" name="term">
              <option value="">All Terms</option>
              <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
              <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
              <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
            </select>

            <input class="input" type="datetime-local" name="from" value="<%= query?.from || '' %>" />
            <input class="input" type="datetime-local" name="to" value="<%= query?.to || '' %>" />

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="present" <%= query?.status === 'present' ? 'selected' : '' %>>Present</option>
              <option value="absent" <%= query?.status === 'absent' ? 'selected' : '' %>>Absent</option>
              <option value="late" <%= query?.status === 'late' ? 'selected' : '' %>>Late</option>
              <option value="excused" <%= query?.status === 'excused' ? 'selected' : '' %>>Excused</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/tenant/attendance"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">record(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkPresent" type="button"><i class="fa-solid fa-circle-check"></i> Present</button>
            <button class="btn-xs" id="bulkAbsent" type="button"><i class="fa-solid fa-circle-xmark"></i> Absent</button>
            <button class="btn-xs" id="bulkLate" type="button"><i class="fa-solid fa-clock"></i> Late</button>
            <button class="btn-xs" id="bulkExcused" type="button"><i class="fa-solid fa-notes-medical"></i> Excused</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Attendance Records</div>
              <div class="section-sub">Showing <%= records.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-student">Student</th>
                    <th class="col-reg">Reg No</th>
                    <th class="col-class">Class</th>
                    <th class="col-subject">Subject</th>
                    <th class="col-session">Session</th>
                    <th class="col-status">Status</th>
                    <th class="col-notes">Notes</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyAttendance"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong><%= query?.perPage || 20 %></strong>
            </div>

            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.subject) params.set("subject", query.subject);
                  if (query?.classGroup) params.set("classGroup", query.classGroup);
                  if (query?.status) params.set("status", query.status);
                  if (query?.academicYear) params.set("academicYear", query.academicYear);
                  if (query?.term) params.set("term", query.term);
                  if (query?.from) params.set("from", query.from);
                  if (query?.to) params.set("to", query.to);
                  params.set("page", String(targetPage));
                  return "/tenant/attendance?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast mark helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Mark Present</div>
                <div class="muted">Open form preset to Present</div>
              </div>
              <button class="btn-xs" id="quickPresent" type="button"><i class="fa-solid fa-circle-check"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Mark Absent</div>
                <div class="muted">Open form preset to Absent</div>
              </div>
              <button class="btn-xs" id="quickAbsent" type="button"><i class="fa-solid fa-circle-xmark"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Import CSV</div>
                <div class="muted">Bulk upload attendance</div>
              </div>
              <button class="btn-xs" id="btnImportSide" type="button" onclick="document.getElementById('btnImport').click()"><i class="fa-solid fa-file-import"></i></button>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section-title">Import Format</div>
          <div class="note" style="margin-top:10px;">
            Required columns:<br>
            <strong>regNo, subjectCode, sessionAt, status</strong><br><br>
            Optional:<br>
            notes
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Mark Attendance</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="attendanceForm" method="POST" action="/tenant/attendance">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Student</label>
              <select class="select" id="mStudent" name="student">
                <option value="">— Select Student —</option>
                <% (students || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.fullName || 'Student' %><%= s.regNo ? (' — ' + s.regNo) : '' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Reg No</label>
              <input class="input" id="mRegNo" name="regNo" placeholder="Use if student not selected" />
            </div>

            <div class="field">
              <label>Class</label>
              <select class="select" id="mClassGroup" name="classGroup">
                <option value="">— Select Class —</option>
                <% (classes || []).forEach(function(c){ %>
                  <option value="<%= String(c._id) %>"><%= c.name || c.code || 'Class' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Subject</label>
              <select class="select" id="mSubject" name="subject" required>
                <option value="">— Select Subject —</option>
                <% (subjects || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.title || s.code || 'Subject' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Teacher</label>
              <select class="select" id="mTeacher" name="teacher">
                <option value="">— Select Teacher —</option>
                <% (staffList || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' — ' + s.role) : '' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Academic Year</label>
              <input class="input" id="mAcademicYear" name="academicYear" placeholder="e.g. 2026" />
            </div>

            <div class="field">
              <label>Term</label>
              <select class="select" id="mTerm" name="term">
                <option value="1">Term 1</option>
                <option value="2">Term 2</option>
                <option value="3">Term 3</option>
              </select>
            </div>

            <div class="field">
              <label>Session Date/Time</label>
              <input class="input" id="mSessionAt" name="sessionAt" type="datetime-local" required />
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="present">Present</option>
                <option value="absent">Absent</option>
                <option value="late">Late</option>
                <option value="excused">Excused</option>
              </select>
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes</label>
            <textarea class="textarea" id="mNotes" name="notes" maxlength="500"></textarea>
            <div class="muted" id="notesCount">0 / 500</div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn light" id="btnSaveAndNew" type="button"><i class="fa-solid fa-plus"></i> Save & New</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal md">
      <div class="modal-header">
        <div class="modal-title">Attendance Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Student</label>
            <div class="view-input" id="vStudent">—</div>
          </div>

          <div class="field">
            <label>Reg No</label>
            <div class="view-input" id="vRegNo">—</div>
          </div>

          <div class="field">
            <label>Email</label>
            <div class="view-input" id="vEmail">—</div>
          </div>

          <div class="field">
            <label>Class</label>
            <div class="view-input" id="vClassGroup">—</div>
          </div>

          <div class="field">
            <label>Subject</label>
            <div class="view-input" id="vSubject">—</div>
          </div>

          <div class="field">
            <label>Teacher</label>
            <div class="view-input" id="vTeacher">—</div>
          </div>

          <div class="field">
            <label>Academic</label>
            <div class="view-input" id="vAcademic">—</div>
          </div>

          <div class="field">
            <label>Session</label>
            <div class="view-input" id="vSession">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Notes</label>
          <div class="view-input multiline" id="vNotes">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" id="viewPresentBtn"><i class="fa-solid fa-circle-check"></i> Present</button>
        <button class="btn light" type="button" id="viewAbsentBtn"><i class="fa-solid fa-circle-xmark"></i> Absent</button>
        <button class="btn light" type="button" id="viewLateBtn"><i class="fa-solid fa-clock"></i> Late</button>
        <button class="btn light" type="button" id="viewExcusedBtn"><i class="fa-solid fa-notes-medical"></i> Excused</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Attendance CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form method="POST" action="/tenant/attendance/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="field">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="classGroup" id="hsClassGroup">
    <input type="hidden" name="subject" id="hsSubject">
    <input type="hidden" name="teacher" id="hsTeacher">
    <input type="hidden" name="student" id="hsStudent">
    <input type="hidden" name="regNo" id="hsRegNo">
    <input type="hidden" name="academicYear" id="hsAcademicYear">
    <input type="hidden" name="term" id="hsTerm">
    <input type="hidden" name="sessionAt" id="hsSessionAt">
    <input type="hidden" name="status" id="hsStatus">
    <input type="hidden" name="notes" id="hsNotes">
  </form>

  <form id="deleteForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/tenant/attendance/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionValue">
    <input type="hidden" name="status" id="bulkStatusValue">
    <input type="hidden" name="ids" id="bulkIds">
  </form>

  <textarea id="attendanceData" class="json-data" aria-hidden="true"><%- JSON.stringify((records || []).map(function(r){
    const sessionAt = r.sessionAt ? new Date(r.sessionAt).toISOString().slice(0,16) : '';
    const sessionAtLabel = r.sessionAt ? new Date(r.sessionAt).toLocaleString() : '';
    return {
      id: String(r._id || ''),
      studentId: r.student?._id ? String(r.student._id) : '',
      studentName: r.student?.fullName || '',
      regNo: r.student?.regNo || '',
      email: r.student?.email || '',
      classGroupId: r.classGroup?._id ? String(r.classGroup._id) : '',
      className: r.classGroup?.name || '',
      subjectId: r.subject?._id ? String(r.subject._id) : '',
      subjectName: r.subject?.title || r.subject?.code || '',
      teacherId: r.teacher?._id ? String(r.teacher._id) : '',
      teacherName: r.teacher?.fullName || r.teacher?.name || '',
      academicYear: r.academicYear || '',
      term: Number(r.term || 1),
      sessionAt,
      sessionAtLabel,
      status: r.status || 'present',
      notes: r.notes || ''
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/attendance.js"></script>
</body>
</html>