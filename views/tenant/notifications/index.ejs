<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant && tenant.name) || "Classic Academy" %> • Notifications</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1050px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-type{width:120px}
    .col-title{width:360px}
    .col-audience{width:120px}
    .col-link{width:170px}
    .col-created{width:170px}
    .col-status{width:120px}
    .col-actions{width:220px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .program-main{min-width:0}
    .program-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .program-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1020px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(860px,100%)}
    .modal.md{width:min(920px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:950px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
      .no-print{display:none !important}
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && ((messages.success && messages.success.length) || (messages.error && messages.error.length))) { %>
        <div class="flash-wrap no-print">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar no-print">
        <div>
          <div class="title">Notifications</div>
          <div class="subtitle">Create, view, import, export, print and manage notifications.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <form method="POST" action="/admin/notifications/mark-all-read" style="display:inline">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
            <button class="btn light" type="submit"><i class="fa-solid fa-check-double"></i> Mark All Read</button>
          </form>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> New Notification</button>
        </div>
      </div>

      <div class="grid-4 no-print">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= (kpis && kpis.total) || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Unread</div>
          <div class="kpi-value" style="color:#b91c1c"><%= (kpis && kpis.unread) || 0 %></div>
          <div class="muted">Needs review</div>
        </div>
        <div class="card">
          <div class="section-title">Read</div>
          <div class="kpi-value" style="color:#15803d"><%= (kpis && kpis.read) || 0 %></div>
          <div class="muted">Already opened</div>
        </div>
        <div class="card">
          <div class="section-title">Scheduled Live</div>
          <div class="kpi-value" style="color:#3730a3"><%= (kpis && kpis.scheduledLive) || 0 %></div>
          <div class="muted">Visible now</div>
        </div>
      </div>

      <section class="card no-print" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/notifications">
          <div class="left">
            <input class="input" name="q" value="<%= (filters && filters.q) || '' %>" placeholder="Search title, message, entity..." />

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="unread" <%= filters && filters.status === 'unread' ? 'selected' : '' %>>Unread</option>
              <option value="read" <%= filters && filters.status === 'read' ? 'selected' : '' %>>Read</option>
            </select>

            <select class="select" name="type">
              <option value="">All Types</option>
              <option value="info" <%= filters && filters.type === 'info' ? 'selected' : '' %>>Info</option>
              <option value="success" <%= filters && filters.type === 'success' ? 'selected' : '' %>>Success</option>
              <option value="warning" <%= filters && filters.type === 'warning' ? 'selected' : '' %>>Warning</option>
              <option value="danger" <%= filters && filters.type === 'danger' ? 'selected' : '' %>>Danger</option>
            </select>

            <select class="select" name="audience">
              <option value="">All Audiences</option>
              <option value="admin" <%= filters && filters.audience === 'admin' ? 'selected' : '' %>>Admin</option>
              <option value="staff" <%= filters && filters.audience === 'staff' ? 'selected' : '' %>>Staff</option>
              <option value="student" <%= filters && filters.audience === 'student' ? 'selected' : '' %>>Student</option>
              <option value="all" <%= filters && filters.audience === 'all' ? 'selected' : '' %>>All</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/notifications"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">notification(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkRead" type="button"><i class="fa-solid fa-check"></i> Mark Read</button>
            <button class="btn-xs" id="bulkUnread" type="button"><i class="fa-regular fa-circle"></i> Mark Unread</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Notifications Table</div>
              <div class="section-sub">Showing <%= items.length %> of <%= (pagination && pagination.total) || 0 %> records.</div>
            </div>
            <div class="muted">
              Page <%= (pagination && pagination.page) || 1 %> of <%= (pagination && pagination.pages) || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check no-print"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-type">Type</th>
                    <th class="col-title">Title & Message</th>
                    <th class="col-audience">Audience</th>
                    <th class="col-link">Link</th>
                    <th class="col-created">Created</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions no-print" style="text-align:right;">Actions</th>
                  </tr>
                </thead>

                <tbody id="tbodyNotifications">
                  <% if (items && items.length) { %>
                    <% items.forEach(function(n){ 
                      var id = String(n._id || '');
                      var title = n.title || '';
                      var message = n.message || '';
                      var type = n.type || 'info';
                      var audience = n.audience || 'admin';
                      var url = n.url || '';
                      var isRead = !!n.isRead;
                      var createdAtRaw = n.createdAt || '';
                      var deliverAtRaw = n.deliverAt || '';
                      var expiresAtRaw = n.expiresAt || '';
                      var createdAtLabel = n.createdAt ? new Date(n.createdAt).toLocaleString() : '—';
                      var deliverAtLabel = n.deliverAt ? new Date(n.deliverAt).toLocaleString() : '—';
                      var expiresAtLabel = n.expiresAt ? new Date(n.expiresAt).toLocaleString() : '—';
                      var statusLabel = isRead ? 'Read' : 'Unread';
                      var nextRead = isRead ? 'unread' : 'read';
                      var preview = message.length > 140 ? message.slice(0, 140) + '…' : message;
                      var typeLabel = type.charAt(0).toUpperCase() + type.slice(1);
                    %>
                      <tr
                        class="row-clickable"
                        data-id="<%= id %>"
                        data-title="<%= title %>"
                        data-message="<%= message %>"
                        data-type="<%= type %>"
                        data-type-label="<%= typeLabel %>"
                        data-audience="<%= audience %>"
                        data-url="<%= url %>"
                        data-created="<%= createdAtRaw %>"
                        data-created-label="<%= createdAtLabel %>"
                        data-deliver="<%= deliverAtRaw %>"
                        data-deliver-label="<%= deliverAtLabel %>"
                        data-expires="<%= expiresAtRaw %>"
                        data-expires-label="<%= expiresAtLabel %>"
                        data-status="<%= isRead ? 'read' : 'unread' %>"
                        data-status-label="<%= statusLabel %>"
                        data-next-read="<%= nextRead %>"
                      >
                        <td class="col-check no-print">
                          <input type="checkbox" class="rowCheck" data-id="<%= id %>" />
                        </td>

                        <td class="col-type">
                          <% if (type === 'success') { %>
                            <span class="pill ok"><i class="fa-solid fa-circle-check"></i> Success</span>
                          <% } else if (type === 'warning') { %>
                            <span class="pill warn"><i class="fa-solid fa-triangle-exclamation"></i> Warning</span>
                          <% } else if (type === 'danger') { %>
                            <span class="pill bad"><i class="fa-solid fa-circle-xmark"></i> Danger</span>
                          <% } else { %>
                            <span class="pill info"><i class="fa-solid fa-circle-info"></i> Info</span>
                          <% } %>
                        </td>

                        <td class="col-title">
                          <div class="program-main">
                            <div class="program-title" title="<%= title || '—' %>"><%= title || '—' %></div>
                            <div class="program-sub" title="<%= message || '—' %>"><%= preview || '—' %></div>
                          </div>
                        </td>

                        <td class="col-audience">
                          <span class="cell-ellipsis" title="<%= audience || '—' %>"><%= audience || '—' %></span>
                        </td>

                        <td class="col-link">
                          <span class="cell-ellipsis" title="<%= url || '—' %>"><%= url || '—' %></span>
                        </td>

                        <td class="col-created">
                          <span class="cell-ellipsis"><%= createdAtLabel %></span>
                        </td>

                        <td class="col-status">
                          <% if (isRead) { %>
                            <span class="pill ok"><i class="fa-solid fa-envelope-open"></i> Read</span>
                          <% } else { %>
                            <span class="pill bad"><i class="fa-solid fa-envelope"></i> Unread</span>
                          <% } %>
                        </td>

                        <td class="col-actions no-print">
                          <div class="actions">
                            <button class="btn-xs actView" type="button" title="View"><i class="fa-solid fa-eye"></i></button>
                            <button class="btn-xs actToggleRead" type="button" title="Toggle Read"><i class="fa-solid fa-check"></i></button>
                            <button class="btn-xs actDelete" type="button" title="Delete"><i class="fa-solid fa-trash"></i></button>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  <% } else { %>
                    <tr>
                      <td colspan="8" style="padding:18px;">
                        <div class="muted">No notifications found.</div>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="pagination no-print">
            <div class="muted">
              Rows per page: <strong><%= (pagination && pagination.limit) || 20 %></strong>
            </div>

            <div class="pagination-links">
              <%
                var currentPage = Number((pagination && pagination.page) || 1);
                var totalPages = Number((pagination && pagination.pages) || 1);

                function buildPageUrl(targetPage) {
                  var params = new URLSearchParams();
                  if (filters && filters.q) params.set("q", filters.q);
                  if (filters && filters.status) params.set("status", filters.status);
                  if (filters && filters.type) params.set("type", filters.type);
                  if (filters && filters.audience) params.set("audience", filters.audience);
                  params.set("page", String(targetPage));
                  return "/admin/notifications?" + params.toString();
                }

                var startPage = Math.max(1, currentPage - 2);
                var endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (var p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card no-print" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast notification helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Broadcast to Admins</div>
                <div class="muted">Pre-fill audience as admin</div>
              </div>
              <button class="btn-xs" id="quickAdmin" type="button"><i class="fa-solid fa-user-shield"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Broadcast to Staff</div>
                <div class="muted">Pre-fill audience as staff</div>
              </div>
              <button class="btn-xs" id="quickStaff" type="button"><i class="fa-solid fa-users"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Broadcast to Students</div>
                <div class="muted">Pre-fill audience as student</div>
              </div>
              <button class="btn-xs" id="quickStudent" type="button"><i class="fa-solid fa-user-graduate"></i></button>
            </div>
          </div>

        <div class="note" style="margin-top:12px;">
          <div class="muted" style="font-weight:700;margin-bottom:6px;">CSV import headers:</div>
          <code>title, message, type, audience, url, deliverAt, expiresAt</code>
        </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal md">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">New Notification</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="notificationForm" method="POST" action="/admin/notifications/new">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Audience</label>
              <select class="select" id="mAudience" name="audience" required>
                <option value="admin">Admin</option>
                <option value="staff">Staff</option>
                <option value="student">Student</option>
                <option value="all">All</option>
              </select>
            </div>

            <div class="field">
              <label>Type</label>
              <select class="select" id="mType" name="type" required>
                <option value="info">Info</option>
                <option value="success">Success</option>
                <option value="warning">Warning</option>
                <option value="danger">Danger</option>
              </select>
            </div>

            <div class="field">
              <label>Link (optional)</label>
              <input class="input" id="mUrl" name="url" placeholder="/admin/invoices/123 or https://..." />
            </div>

            <div class="field">
              <label>Deliver At (optional)</label>
              <input class="input" id="mDeliverAt" name="deliverAt" type="datetime-local" />
            </div>

            <div class="field">
              <label>Expires At (optional)</label>
              <input class="input" id="mExpiresAt" name="expiresAt" type="datetime-local" />
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Title</label>
            <input class="input" id="mTitleInput" name="title" maxlength="160" required />
            <div class="muted" id="titleCount">0 / 160</div>
          </div>

          <div class="field" style="margin-top:12px;">
            <label>Message</label>
            <textarea class="textarea" id="mMessage" name="message" maxlength="2000" required></textarea>
            <div class="muted" id="messageCount">0 / 2000</div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-paper-plane"></i> Send Notification</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Notification Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Type</label>
            <div class="view-input" id="vType">—</div>
          </div>

          <div class="field">
            <label>Audience</label>
            <div class="view-input" id="vAudience">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Created</label>
            <div class="view-input" id="vCreated">—</div>
          </div>

          <div class="field">
            <label>Deliver At</label>
            <div class="view-input" id="vDeliverAt">—</div>
          </div>

          <div class="field">
            <label>Expires At</label>
            <div class="view-input" id="vExpiresAt">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Title</label>
          <div class="view-input" id="vTitle">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Message</label>
          <div class="view-input multiline" id="vMessage">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Link</label>
          <div class="view-input multiline" id="vLink">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Notifications</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form method="POST" action="/admin/notifications/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="note">
            Upload a UTF-8 CSV file with headers:<br>
            <code>title,message,type,audience,url,deliverAt,expiresAt</code>
          </div>

          <div class="field" style="margin-top:12px;">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-file-import"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/notifications/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkAction">
    <input type="hidden" name="ids" id="bulkIds">
  </form>

  <script src="/js/navbar.js"></script>
  <script src="/js/notifications.js"></script>
</body>
</html>