<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Applicants</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <% if (csrfToken) { %>
    <meta name="csrf-token" content="<%= csrfToken %>">
  <% } %>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(300px,.4fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1460px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-applicant{width:320px}
    .col-application{width:190px}
    .col-program{width:260px}
    .col-stage{width:150px}
    .col-docs{width:130px}
    .col-payment{width:120px}
    .col-submitted{width:140px}
    .col-actions{width:220px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .app-main{min-width:0}
    .app-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .app-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .avatar{
      width:38px;
      height:38px;
      border-radius:12px;
      display:grid;
      place-items:center;
      font-weight:900;
      color:#0a3d62;
      background:rgba(10,111,191,.10);
      flex:0 0 auto;
    }

    .row-flex{display:flex;gap:10px;align-items:center;min-width:0}

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1020px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(940px,100%)}
    .modal.lg{width:min(1020px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1460px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
      .no-print{display:none !important}
      table{min-width:unset}
    }
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Applicants</div>
          <div class="subtitle">Review, export, print, import and manage admission applications.</div>
        </div>

        <div class="top-actions no-print">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <a class="btn primary" href="/admissions/apply"><i class="fa-solid fa-plus"></i> New Applicant</a>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Pending</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.pending || 0 %></div>
          <div class="muted">Submitted or under review</div>
        </div>
        <div class="card">
          <div class="section-title">Accepted</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.accepted || 0 %></div>
          <div class="muted">Accepted or converted</div>
        </div>
        <div class="card">
          <div class="section-title">Rejected</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.rejected || 0 %></div>
          <div class="muted">Closed applications</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/admissions/applicants">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, app ID, email, phone..." />

            <select class="select" name="section">
              <option value="">All Sections</option>
              <% (programs || []).forEach(function(p){ %>
                <option value="<%= String(p._id) %>" <%= String(query?.section || query?.program || '') === String(p._id) ? 'selected' : '' %>>
                  <%= (p.code ? p.code + ' — ' : '') + (p.name || p.className || 'Section') %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="status">
              <option value="">All Stage</option>
              <option value="submitted" <%= query?.status === 'submitted' ? 'selected' : '' %>>Submitted</option>
              <option value="under_review" <%= query?.status === 'under_review' ? 'selected' : '' %>>Under Review</option>
              <option value="accepted" <%= query?.status === 'accepted' ? 'selected' : '' %>>Accepted</option>
              <option value="rejected" <%= query?.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
              <option value="converted" <%= query?.status === 'converted' ? 'selected' : '' %>>Converted</option>
            </select>
          </div>

          <div class="right no-print">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/admissions/applicants"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">applicant(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkReview" type="button"><i class="fa-solid fa-magnifying-glass"></i> Move to Review</button>
            <button class="btn-xs" id="bulkAccept" type="button"><i class="fa-solid fa-check"></i> Accept</button>
            <button class="btn-xs" id="bulkReject" type="button"><i class="fa-solid fa-xmark"></i> Reject</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Applicants Table</div>
              <div class="section-sub">Showing <%= applicants.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check no-print"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-applicant">Applicant</th>
                    <th class="col-application">Application</th>
                    <th class="col-program">Section</th>
                    <th class="col-stage">Stage</th>
                    <th class="col-docs">Docs</th>
                    <th class="col-payment">Payment</th>
                    <th class="col-submitted">Submitted</th>
                    <th class="col-actions no-print" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyApplicants"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination no-print">
            <div class="muted">
              Rows per page: <strong><%= query?.perPage || 20 %></strong>
            </div>

            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.section || query?.program) params.set("section", query.section || query.program);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/admin/admissions/applicants?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">High-speed admissions workflow.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Pending Review</div>
                <div class="muted">Open submitted and under-review records</div>
              </div>
              <a class="btn-xs" href="/admin/admissions/applicants?status=under_review"><i class="fa-solid fa-hourglass-half"></i></a>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Accepted Applicants</div>
                <div class="muted">Review ready-to-convert records</div>
              </div>
              <a class="btn-xs" href="/admin/admissions/applicants?status=accepted"><i class="fa-solid fa-check"></i></a>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Download Template</div>
                <div class="muted">Use correct columns for CSV import</div>
              </div>
              <button class="btn-xs" id="btnTemplate" type="button"><i class="fa-solid fa-file-csv"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Applicant Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Applicant</label><div class="view-input" id="vName">—</div></div>
          <div class="field"><label>Application ID</label><div class="view-input" id="vApplicationId">—</div></div>
          <div class="field"><label>Stage</label><div class="view-input" id="vStatus">—</div></div>
          <div class="field"><label>Email</label><div class="view-input" id="vEmail">—</div></div>
          <div class="field"><label>Phone</label><div class="view-input" id="vPhone">—</div></div>
          <div class="field"><label>Submitted</label><div class="view-input" id="vSubmitted">—</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vProgram">—</div></div>
          <div class="field"><label>Intake</label><div class="view-input" id="vIntake">—</div></div>
          <div class="field"><label>Payment</label><div class="view-input" id="vPayment">—</div></div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Documents</label>
          <div class="view-input multiline" id="vDocs">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Admin Notes</label>
          <textarea class="textarea" id="vNote" maxlength="1200" placeholder="Internal note for next action..."></textarea>
          <div class="muted" id="noteCount">0 / 1200</div>
        </div>
      </div>

      <div class="modal-footer no-print">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn light" type="button" id="btnOpenDetail"><i class="fa-solid fa-up-right-from-square"></i> Full View</button>
        <button class="btn light" type="button" id="btnMoveReview"><i class="fa-solid fa-magnifying-glass"></i> Review</button>
        <button class="btn primary" type="button" id="btnQuickAccept"><i class="fa-solid fa-check"></i> Accept</button>
        <button class="btn light" type="button" id="btnQuickReject"><i class="fa-solid fa-xmark"></i> Reject</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Applicants CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="importForm" method="POST" action="/admin/admissions/applicants/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="note">
            Required headers:
            <strong>firstName,lastName,email,phone,sectionName,term,status</strong>
          </div>

          <div class="field" style="margin-top:12px;">
            <label>CSV File</label>
            <input class="input" type="file" name="file" id="importFile" accept=".csv,text/csv" required />
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-file-import"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="bulkForm" method="POST" action="/admin/admissions/applicants/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkAction">
    <input type="hidden" name="message" id="bulkMessage">
  </form>

  <textarea id="applicantsData" class="json-data" aria-hidden="true"><%- JSON.stringify((applicants || []).map(function(a){
    const fullName = (a.fullName || [a.firstName, a.middleName, a.lastName].filter(Boolean).join(' ')).trim();
    const docs = {
      passportPhoto: !!(a.passportPhoto && (a.passportPhoto.url || a.passportPhoto.secure_url || a.passportPhoto.publicId || a.passportPhoto.public_id)),
      idDocument: !!(a.idDocument && (a.idDocument.url || a.idDocument.secure_url || a.idDocument.publicId || a.idDocument.public_id)),
      transcript: !!(a.transcript && (a.transcript.url || a.transcript.secure_url || a.transcript.publicId || a.transcript.public_id)),
      otherDocsCount: Array.isArray(a.otherDocs) ? a.otherDocs.length : 0
    };
    return {
      id: String(a._id || ''),
      name: fullName || '—',
      email: a.email || '',
      phone: a.phone || '',
      applicationId: a.applicationId || '',
      intake: a.intake || '',
      status: a.status || 'submitted',
      programLabel: (a.section1 || a.program1) ? (((a.section1 || a.program1).name || (a.section1 || a.program1).className || 'Section')) : '—',
      paymentLabel: 'N/A',
      submittedAt: a.createdAt || null,
      docs: docs,
      adminNotes: a.adminNotes || a.notes || '',
      openUrl: '/admin/admissions/applicants/' + encodeURIComponent(String(a._id || ''))
    };
  })) %></textarea>

  <script src="/js/navbar.js" defer></script>
  <script src="/js/admin-admissions-applicants.js" defer></script>
</body>
</html>

