<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Admin • Admissions — <%= (tenant && tenant.name) ? tenant.name : "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>

  <!-- Font Awesome -->
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>
<link rel="stylesheet" href="/css/navbar.css" />


<%-include("../partials/header") %>
  <!-- Shared CSS (keep your existing file) -->
   
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:240px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .grid-2{display:grid;grid-template-columns:1.2fr .8fr;gap:12px}

    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .neutral{background:#f3f4f6;color:#111827}

    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1220px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .btn-xs.primary{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .btn-xs.primary:hover{filter:brightness(.97)}

    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .pipe-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin-top:10px}
    .col{border:1px solid rgba(13,64,96,.10);border-radius:14px;background:#fff;overflow:hidden;min-height:240px}
    .col-head{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);display:flex;justify-content:space-between;align-items:center}
    .col-body{padding:10px 12px;display:grid;gap:10px}
    .cardlet{padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}

    .pager{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-top:12px;flex-wrap:wrap}
    .pager a{display:inline-flex;gap:8px;align-items:center;text-decoration:none}
    .pager .pbtn{padding:8px 10px;border-radius:12px;border:1px solid rgba(13,64,96,.14);background:#fff}
    .pager .pbtn.disabled{opacity:.5;pointer-events:none}

    @media(max-width:980px){
      .grid-4{grid-template-columns:1fr 1fr}
      .grid-2{grid-template-columns:1fr}
      .pipe-grid{grid-template-columns:1fr}
      .input{min-width:190px}
    }
    @media(max-width:560px){ .grid-4{grid-template-columns:1fr} }
  </style>

  <%
    // ---------- Safe locals ----------
    const safe = (v)=> (v===null||v===undefined) ? "" : String(v);
    const arr = (v)=> Array.isArray(v) ? v : [];
    const A = arr(applicants);
    const P = arr(programs);

    const q = safe(query && query.q);
    const qSection = safe(query && (query.section || query.program));
    const qStatus = safe(query && query.status);

    const page = (pagination && Number(pagination.page)) || 1;
    const pages = (pagination && Number(pagination.pages)) || 1;
    const total = (pagination && Number(pagination.total)) || A.length;

    const fmtDate = (d)=>{
      if(!d) return "";
      const x = new Date(d);
      if(Number.isNaN(x.getTime())) return "";
      return x.toLocaleDateString(undefined, {year:"numeric", month:"short", day:"2-digit"});
    };

    const sectionLabel = (sec)=>{
      if(!sec) return "—";
      if(typeof sec === "string") return sec;
      return sec.name || sec.className || sec.code || "—";
    };

    const statusToPill = (s)=>{
      const v = String(s||"").toLowerCase();
      if(v==="converted") return {cls:"ok", icon:"fa-user-graduate", text:"Converted"};
      if(v==="accepted")  return {cls:"ok", icon:"fa-check", text:"Accepted"};
      if(v==="rejected")  return {cls:"bad", icon:"fa-xmark", text:"Rejected"};
      if(v==="interview") return {cls:"warn", icon:"fa-video", text:"Interview"};
      if(v==="reviewed")  return {cls:"warn", icon:"fa-magnifying-glass", text:"Reviewed"};
      if(v==="under_review") return {cls:"warn", icon:"fa-magnifying-glass", text:"Under Review"};
      if(v==="received" || v==="submitted" || !v) return {cls:"info", icon:"fa-inbox", text:"Received"};
      return {cls:"neutral", icon:"fa-circle", text:safe(s)};
    };

    const docsMeta = (a)=>{
      const reqDocs = [
        {k:"passportPhoto", label:"Passport"},
        {k:"idDocument", label:"ID"},
        {k:"transcript", label:"Transcript"},
      ];
      let ok=0, miss=[];
      for(const d of reqDocs){
        const o = a && a[d.k];
        if(o && (o.url || o.secure_url)) ok++;
        else miss.push(d.label);
      }
      const other = Array.isArray(a && a.otherDocs) ? a.otherDocs.length : 0;
      return { ok, total:reqDocs.length, miss, other };
    };

    const countBy = (fn)=> A.reduce((n,x)=> n + (fn(x)?1:0), 0);
    const cReceived = countBy(x=> ["","received","submitted"].includes(String(x?.status||"").toLowerCase()));
    const cReview   = countBy(x=> ["under_review","reviewed"].includes(String(x?.status||"").toLowerCase()));
    const cInter    = countBy(x=> ["interview"].includes(String(x?.status||"").toLowerCase()));
    const cAcc      = countBy(x=> ["accepted","converted"].includes(String(x?.status||"").toLowerCase()));

    const buildQS = (overrides={})=>{
      const params = {
        q: q || "",
        section: qSection || "",
        status: qStatus || "",
        page: String(page || 1),
        ...overrides
      };
      const pairs = Object.entries(params)
        .filter(([k,v]) => v !== "" && v !== null && v !== undefined)
        .map(([k,v]) => `${encodeURIComponent(k)}=${encodeURIComponent(String(v))}`);
      return pairs.length ? `?${pairs.join("&")}` : "";
    };
  %>
</head>
<body data-portal="tenant">

<div class="app">
<%-include("../partials/navbar") %>
  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Admissions Management</div>
        <div class="subtitle">Review applications, manage intake cycles, run interviews, issue offers and admit students.</div>
      </div>
      <div class="top-actions">
        <button class="btn light" id="btnExport"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
        <a class="btn light" href="/apply" target="_blank" rel="noopener"><i class="fa-solid fa-link"></i> Public Apply</a>
        <a class="btn primary" href="/admin/admissions" title="Refresh"><i class="fa-solid fa-rotate"></i> Refresh</a>
      </div>
    </div>

    <div class="grid-4">
      <div class="card">
        <div class="section-title">New / Received</div>
        <div class="kpi-value" id="kNew"><%= cReceived %></div>
        <div class="muted">Submitted</div>
      </div>
      <div class="card">
        <div class="section-title">Under Review</div>
        <div class="kpi-value" style="color:#0a6fbf" id="kReview"><%= cReview %></div>
        <div class="muted">Screening</div>
      </div>
      <div class="card">
        <div class="section-title">Interviews</div>
        <div class="kpi-value" style="color:#92400e" id="kInter"><%= cInter %></div>
        <div class="muted">Scheduled / done</div>
      </div>
      <div class="card">
        <div class="section-title">Accepted / Converted</div>
        <div class="kpi-value" style="color:#15803d" id="kAcc"><%= cAcc %></div>
        <div class="muted">Offers / admitted</div>
      </div>
    </div>

    <!-- Filters -->
    <section class="card" style="margin-top:12px;">
      <form class="toolbar" method="GET" action="/admin/admissions">
        <div class="left">
          <input class="input" name="q" value="<%= q %>" placeholder="Search applicationId, name, email, phone..." />

          <select class="select" name="section">
            <option value="">All Sections</option>
            <% P.forEach((pr)=> { %>
              <option value="<%= pr._id %>" <%= String(pr._id)===String(qSection) ? "selected" : "" %>>
                <%= safe(pr.name || pr.className || pr.code) %>
              </option>
            <% }) %>
          </select>

          <select class="select" name="status">
            <option value="" <%= !qStatus ? "selected" : "" %>>All Stages</option>
            <option value="received" <%= qStatus==="received" ? "selected" : "" %>>Received</option>
            <option value="under_review" <%= qStatus==="under_review" ? "selected" : "" %>>Under Review</option>
            <option value="interview" <%= qStatus==="interview" ? "selected" : "" %>>Interview</option>
            <option value="accepted" <%= qStatus==="accepted" ? "selected" : "" %>>Accepted</option>
            <option value="converted" <%= qStatus==="converted" ? "selected" : "" %>>Converted</option>
            <option value="rejected" <%= qStatus==="rejected" ? "selected" : "" %>>Rejected</option>
          </select>

          <button class="btn light" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          <a class="btn light" href="/admin/admissions"><i class="fa-solid fa-rotate-left"></i> Reset</a>
        </div>

        <div class="right">
          <div class="chips" id="viewChips">
            <button class="chip active" data-view="list" type="button"><i class="fa-solid fa-list"></i> Applicants</button>
            <button class="chip" data-view="pipeline" type="button"><i class="fa-solid fa-diagram-project"></i> Pipeline</button>
          </div>
          <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
        </div>
      </form>

      <!-- Bulk bar -->
      <div class="bulkbar" id="bulkbar">
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
          <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
          <span class="muted">applicant(s)</span>
        </div>

        <form id="bulkForm" method="POST" action="/admin/admissions/applicants/bulk" style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
          <input type="hidden" name="_csrf" value="<%= safe(csrfToken) %>">
          <input type="hidden" name="ids" id="bulkIds" value="">
          <input type="hidden" name="action" id="bulkAction" value="">
          <input class="input" style="min-width:220px" name="message" placeholder="Optional note (adminNotes)">

          <button class="btn-xs" type="button" data-act="set_under_review"><i class="fa-solid fa-magnifying-glass"></i> Mark Under Review</button>
          <button class="btn-xs" type="button" data-act="accept"><i class="fa-solid fa-check"></i> Mark Accepted</button>
          <button class="btn-xs" type="button" data-act="reject"><i class="fa-solid fa-xmark"></i> Mark Rejected</button>
          <button class="btn-xs" type="button" id="bulkClear"><i class="fa-solid fa-xmark"></i> Clear</button>
        </form>
      </div>
    </section>

    <div class="grid-2" style="margin-top:12px;">
      <!-- List / Pipeline -->
      <section class="card">
        <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
          <div>
            <div class="section-title" id="panelTitle">Applicants</div>
            <div class="section-sub" id="panelSub">Search, screen, and process applications.</div>
          </div>
          <div class="muted" id="resultMeta"><%= total %> total • Page <%= page %>/<%= pages %></div>
        </div>

        <!-- LIST -->
        <div id="view-list" style="margin-top:10px;">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th style="width:42px;"><input type="checkbox" id="checkAll"/></th>
                  <th>Applicant</th>
                  <th>Section</th>
                  <th>Intake</th>
                  <th>Documents</th>
                  <th>Status</th>
                  <th style="width:120px;">Submitted</th>
                  <th style="text-align:right;width:320px;">Actions</th>
                </tr>
              </thead>

              <tbody>
              <% if(!A.length){ %>
                <tr>
                  <td colspan="8" style="padding:18px;">
                    <div class="muted">No applicants match your filters.</div>
                  </td>
                </tr>
              <% } %>

              <% A.forEach((a)=> {
                  const name = safe(a.fullName || [a.firstName,a.middleName,a.lastName].filter(Boolean).join(" "));
                  const pid = a.section1 || a.program1;
                  const prog = sectionLabel(pid);
                  const sm = statusToPill(a.status);
                  const dm = docsMeta(a);
                  const docsText = `${dm.ok}/${dm.total} required` + (dm.other ? ` • ${dm.other} other` : "");
                  const docsPill = (dm.ok===dm.total) ? {cls:"ok", icon:"fa-check", text:"Complete"} : {cls:"warn", icon:"fa-triangle-exclamation", text:"Missing"};
                  const missTip = dm.miss.length ? `Missing: ${dm.miss.join(", ")}` : "All required docs present";
              %>
                <tr data-id="<%= a._id %>"
                    data-name="<%= safe(name) %>"
                    data-app="<%= safe(a.applicationId) %>"
                    data-phone="<%= safe(a.phone) %>"
                    data-email="<%= safe(a.email) %>"
                    data-program="<%= safe(prog) %>"
                    data-intake="<%= safe(a.intake) %>"
                    data-status="<%= safe(a.status) %>"
                    data-miss="<%= safe(dm.miss.join(", ")) %>">
                  <td>
                    <input type="checkbox" class="rowCheck" value="<%= a._id %>">
                  </td>

                  <td>
                    <div class="strong"><%= name || "—" %></div>
                    <div class="muted">
                      <%= safe(a.applicationId) || "—" %>
                      <% if(a.phone){ %> • <%= safe(a.phone) %><% } %>
                      <% if(a.email){ %> • <%= safe(a.email) %><% } %>
                    </div>
                  </td>

                  <td class="muted"><%= prog %></td>
                  <td class="muted"><%= safe(a.intake) || "—" %></td>

                  <td>
                    <span class="pill <%= docsPill.cls %>" title="<%= missTip %>">
                      <i class="fa-solid <%= docsPill.icon %>"></i> <%= docsPill.text %>
                    </span>
                    <div class="muted" title="<%= missTip %>"><%= docsText %></div>
                  </td>

                  <td>
                    <span class="pill <%= sm.cls %>"><i class="fa-solid <%= sm.icon %>"></i> <%= sm.text %></span>
                  </td>

                  <td class="muted"><%= fmtDate(a.createdAt) || "—" %></td>

                  <td>
                    <div class="actions">
                      <button class="btn-xs actQuick" type="button" title="Quick view"><i class="fa-solid fa-eye"></i> Quick</button>
                      <a class="btn-xs" href="/admin/admissions/applicants/<%= a._id %>"><i class="fa-solid fa-folder-open"></i> Open</a>

                      <!-- quick status change -->
                      <form method="POST" action="/admin/admissions/applicants/<%= a._id %>/status" style="display:inline-flex;gap:6px;align-items:center">
                        <input type="hidden" name="_csrf" value="<%= safe(csrfToken) %>">
                        <select class="select" name="status" style="padding:6px 10px;border-radius:10px">
                          <option value="received" <%= String(a.status||"").toLowerCase()==="received" ? "selected":"" %>>Received</option>
                          <option value="under_review" <%= String(a.status||"").toLowerCase()==="under_review" ? "selected":"" %>>Under Review</option>
                          <option value="interview" <%= String(a.status||"").toLowerCase()==="interview" ? "selected":"" %>>Interview</option>
                          <option value="accepted" <%= String(a.status||"").toLowerCase()==="accepted" ? "selected":"" %>>Accepted</option>
                          <option value="rejected" <%= String(a.status||"").toLowerCase()==="rejected" ? "selected":"" %>>Rejected</option>
                        </select>
                        <button class="btn-xs" type="submit" title="Save status"><i class="fa-solid fa-check"></i></button>
                      </form>

                      <!-- Convert (admit) -->
                      <a class="btn-xs primary" href="/admin/admissions/applicants/<%= a._id %>#admit" title="Convert to student (choose class group on view page)">
                        <i class="fa-solid fa-user-graduate"></i>
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          </div>

          <!-- Pagination -->
          <div class="pager">
            <div class="muted">Showing <%= A.length %> of <%= total %></div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <a class="pbtn <%= page<=1 ? "disabled":"" %>" href="/admin/admissions<%= buildQS({ page: String(Math.max(1, page-1)) }) %>">
                <i class="fa-solid fa-arrow-left"></i> Prev
              </a>
              <a class="pbtn <%= page>=pages ? "disabled":"" %>" href="/admin/admissions<%= buildQS({ page: String(Math.min(pages, page+1)) }) %>">
                Next <i class="fa-solid fa-arrow-right"></i>
              </a>
            </div>
          </div>
        </div>

        <!-- PIPELINE -->
        <div id="view-pipeline" style="display:none;margin-top:10px;">
          <div class="note">Pipeline view (server-rendered). Use “Open” to process applicant fully.</div>

          <%
            const STAGES = [
              {key:"received",    label:"Received"},
              {key:"under_review",label:"Under Review"},
              {key:"interview",   label:"Interview"},
              {key:"accepted",    label:"Accepted"},
              {key:"rejected",    label:"Rejected"},
            ];
            const stageBucket = (x)=>{
              const s = String(x?.status||"").toLowerCase();
              if(!s || s==="submitted") return "received";
              if(["reviewed"].includes(s)) return "under_review";
              if(["converted"].includes(s)) return "accepted";
              if(STAGES.find(z=>z.key===s)) return s;
              return "received";
            };
          %>

          <div class="pipe-grid">
            <% STAGES.forEach((st)=> {
                const items = A.filter(x => stageBucket(x)===st.key);
                const p = statusToPill(st.key);
            %>
              <div class="col">
                <div class="col-head">
                  <span class="strong"><%= st.label %></span>
                  <span class="pill <%= p.cls %>"><%= items.length %></span>
                </div>
                <div class="col-body">
                  <% if(!items.length){ %>
                    <div class="muted">No applicants.</div>
                  <% } %>

                  <% items.slice(0, 25).forEach((a)=> {
                      const name = safe(a.fullName || [a.firstName,a.middleName,a.lastName].filter(Boolean).join(" "));
                      const prog = sectionLabel(a.section1 || a.program1);
                      const dm = docsMeta(a);
                  %>
                    <div class="cardlet">
                      <div class="strong"><%= name || "—" %></div>
                      <div class="muted"><%= safe(a.applicationId) || "—" %></div>
                      <div class="muted"><%= prog %></div>
                      <div class="muted">Docs: <%= dm.ok %>/<%= dm.total %></div>
                      <div style="display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;">
                        <button class="btn-xs pipeQuick" type="button"
                                data-id="<%= a._id %>"
                                data-name="<%= safe(name) %>"
                                data-app="<%= safe(a.applicationId) %>"
                                data-phone="<%= safe(a.phone) %>"
                                data-email="<%= safe(a.email) %>"
                                data-program="<%= safe(prog) %>"
                                data-intake="<%= safe(a.intake) %>"
                                data-status="<%= safe(a.status) %>"
                                data-miss="<%= safe(dm.miss.join(", ")) %>">
                          <i class="fa-solid fa-eye"></i> Quick
                        </button>
                        <a class="btn-xs" href="/admin/admissions/applicants/<%= a._id %>"><i class="fa-solid fa-folder-open"></i> Open</a>
                      </div>
                    </div>
                  <% }) %>

                  <% if(items.length>25){ %>
                    <div class="muted">Showing 25 of <%= items.length %> in this stage (use filters for more).</div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="note" style="margin-top:12px;">
          <strong>Included:</strong> server-rendered list, filters, pagination, bulk actions posting to your controller, pipeline view, quick-view modal.
        </div>
      </section>

      <!-- Right Side -->
      <aside class="card">
        <div class="section-title">Quick Actions</div>
        <div class="section-sub">High-frequency admissions tasks.</div>

        <div class="mini-list">
          <div class="mini-item">
            <div class="left"><div class="strong">Open Public Apply Form</div><div class="muted">Test applicant submission</div></div>
            <a class="btn-xs" href="/admissions/apply" target="_blank" rel="noopener"><i class="fa-solid fa-arrow-up-right-from-square"></i></a>
          </div>
          <div class="mini-item">
            <div class="left"><div class="strong">Admissions Reports</div><div class="muted">KPIs & exports (next)</div></div>
            <button class="btn-xs" type="button" id="qReports"><i class="fa-solid fa-chart-column"></i></button>
          </div>
          <div class="mini-item">
            <div class="left"><div class="strong">Intake Management</div><div class="muted">Configure sections and dates</div></div>
            <button class="btn-xs" type="button" id="qIntake"><i class="fa-solid fa-calendar-check"></i></button>
          </div>
        </div>

        <div class="section-title" style="margin-top:14px;">Stage Legend</div>
        <div class="mini-list">
          <div class="mini-item"><div class="left"><div class="strong">Received</div><div class="muted">Submitted</div></div><span class="pill info"><i class="fa-solid fa-inbox"></i></span></div>
          <div class="mini-item"><div class="left"><div class="strong">Under Review</div><div class="muted">Screening</div></div><span class="pill warn"><i class="fa-solid fa-magnifying-glass"></i></span></div>
          <div class="mini-item"><div class="left"><div class="strong">Interview</div><div class="muted">Shortlist / call</div></div><span class="pill warn"><i class="fa-solid fa-video"></i></span></div>
          <div class="mini-item"><div class="left"><div class="strong">Accepted</div><div class="muted">Offer</div></div><span class="pill ok"><i class="fa-solid fa-check"></i></span></div>
          <div class="mini-item"><div class="left"><div class="strong">Rejected</div><div class="muted">Not selected</div></div><span class="pill bad"><i class="fa-solid fa-xmark"></i></span></div>
        </div>
      </aside>
    </div>
  </main>
</div>

<!-- Quick View Modal -->
<div class="modal-backdrop" id="mQuick" style="position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:18px;z-index:9999">
  <div class="modal" style="width:min(920px,100%);background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden">
    <div class="modal-header" style="display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid rgba(13,64,96,.10)">
      <div class="modal-title" id="mTitle" style="font-weight:900">Applicant</div>
      <button class="btn-xs" type="button" id="mClose"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body" style="padding:16px">
      <div class="note" id="mBody"></div>
      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px">
        <a class="btn light" id="mOpen" href="#"><i class="fa-solid fa-folder-open"></i> Open Full</a>
        <a class="btn primary" id="mAdmit" href="#"><i class="fa-solid fa-user-graduate"></i> Admit / Convert</a>
      </div>
    </div>
    <div class="modal-footer" style="display:flex;justify-content:flex-end;gap:10px;padding:14px 16px;border-top:1px solid rgba(13,64,96,.10)">
      <button class="btn light" type="button" id="mCancel">Close</button>
    </div>
  </div>
</div>

<script src="/js/navbar.js"></script>
<script src="/js/admission.js"></script>
</body>
</html>

