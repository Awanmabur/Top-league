<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Admin • Admissions — Application Detail | <%= (tenant && tenant.name) ? tenant.name : "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>

  <!-- Optional external icons CSS (works with style-src https:) -->
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>
<link rel="stylesheet" href="/css/navbar.css" />
  <style>
    :root{
      --blue:#0a3d62; --blue2:#083454; --accent:#0a6fbf;
      --bg:#f4f8ff; --card:#fff; --muted:#6b7280;
      --success:#16a34a; --danger:#ef4444; --warn:#f59e0b; --info:#4f46e5;
      --radius:16px; --line:rgba(13,64,96,.12);
      --shadow:0 10px 30px rgba(0,0,0,.08);
    }
    *{box-sizing:border-box}
 
    .main{flex:1;padding:18px}
    .topbar{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:flex-start}
    .title{font-size:18px;font-weight:1000}
    .subtitle{font-size:12px;color:var(--muted);margin-top:4px}
    .top-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center}

    .btn{border:none;border-radius:12px;padding:10px 12px;font-weight:900;cursor:pointer;display:inline-flex;gap:8px;align-items:center}
    .btn.primary{background:var(--accent);color:#fff}
    .btn.light{background:#fff;border:1px solid var(--line);color:#0f172a}
    .btn.success{background:#ecfdf3;border:1px solid rgba(22,163,74,.25);color:#15803d}
    .btn.danger{background:#fee2e2;border:1px solid rgba(239,68,68,.25);color:#b91c1c}
    .btn.warn{background:#fff7ed;border:1px solid rgba(245,158,11,.25);color:#92400e}
    .btn.small{padding:8px 10px;border-radius:10px;font-size:12px}
    .btn:hover{filter:brightness(.98)}
    .btn[disabled]{opacity:.6;cursor:not-allowed}

    .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
    .card-head{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;align-items:center;padding:12px 14px;border-bottom:1px solid var(--line)}
    .card-title{font-weight:1000}
    .card-sub{font-size:12px;color:var(--muted)}
    .card-body{padding:14px}

    .grid-3-1{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(340px,.85fr);gap:14px;margin-top:12px;align-items:start}
    .grid-2{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900}
    .ok{background:#ecfdf3;color:#15803d}
    .bad{background:#fee2e2;color:#b91c1c}
    .warnpill{background:#fef9c3;color:#92400e}
    .infopill{background:#eef2ff;color:#3730a3}

    .muted{color:var(--muted);font-size:12px}
    .strong{font-weight:1000}
    .divider{height:1px;background:var(--line);margin:12px 0}

    .field{display:grid;gap:6px;min-width:0}
    .field label{font-size:12px;color:var(--muted);font-weight:800}
    .input,.select,.textarea{width:100%;min-width:0;padding:10px 12px;border-radius:12px;border:1px solid var(--line);background:#fff;outline:none}
    .textarea{min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}

    .tabs{display:flex;gap:8px;flex-wrap:wrap;max-width:100%;overflow:auto;padding-bottom:2px;-webkit-overflow-scrolling:touch}
    .tabs::-webkit-scrollbar{height:6px}
    .tabs::-webkit-scrollbar-thumb{background:rgba(13,64,96,.18);border-radius:999px}
    .tab{white-space:nowrap;flex:0 0 auto}
    .tab{border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .tab.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pane{display:none;margin-top:10px}
    .pane.active{display:block}
    .pane,.note,.card-body,.card-head,.card-title,.card-sub{min-width:0}

    .note{padding:12px;border-radius:14px;background:rgba(10,111,191,.06);border:1px dashed rgba(10,111,191,.25)}
    .row{display:flex;gap:10px;align-items:center;flex-wrap:wrap}
    .check-item{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:12px;align-items:center;padding:10px;border:1px solid rgba(13,64,96,.10);border-radius:12px;margin-bottom:8px}
    .avatar{width:42px;height:42px;border-radius:14px;background:rgba(10,111,191,.12);display:grid;place-items:center;font-weight:1000;color:var(--blue);font-size:14px}

    .table-wrap{max-width:100%;overflow-x:auto;overflow-y:hidden;border:1px solid var(--line);border-radius:12px;-webkit-overflow-scrolling:touch}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:980px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:top}
    th{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .right{text-align:right}
    #pane-academics .table-wrap{overflow-x:auto;overflow-y:hidden}
    #pane-academics table{min-width:0 !important;table-layout:auto}

    /* Modal */
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:18px;z-index:9999}
    .modal-backdrop.show{display:flex}
    .modal{width:min(980px,100%);background:#fff;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--line)}
    .modal-title{font-weight:1000}
    .modal-body{padding:16px}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 16px;border-top:1px solid var(--line)}

    .doc-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;min-width:0}
    .doc{min-width:0;overflow:hidden;border:1px solid var(--line);border-radius:14px;padding:12px;background:#fff}
    .doc-top{display:flex;justify-content:space-between;gap:8px;align-items:flex-start;flex-wrap:wrap}
    .doc-top > *{min-width:0;max-width:100%}
    .doc-name{font-weight:1000;overflow-wrap:anywhere;word-break:break-word}
    .doc-meta{font-size:11px;color:var(--muted);margin-top:6px;overflow-wrap:anywhere;word-break:break-word}
    .doc-preview-link{display:block;max-width:100%}
    .doc-preview-img{display:block;width:100%;max-width:100%;height:auto;box-sizing:border-box;border-radius:14px;border:1px solid rgba(13,64,96,.12);object-fit:contain}
    .chip{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;border:1px solid var(--line);background:#fff;cursor:pointer}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .mini{font-size:11px;color:var(--muted);font-weight:800}

    /* Toast */
    .toast-wrap{position:fixed;right:16px;bottom:16px;display:grid;gap:10px;z-index:10000}
    .toast{background:#0f172a;color:#fff;border-radius:14px;padding:10px 12px;box-shadow:0 20px 60px rgba(0,0,0,.25);max-width:360px}
    .toast .t{font-weight:1000;font-size:13px}
    .toast .m{font-size:12px;opacity:.85;margin-top:4px}

    /* Print */
    @media print{
      .sidebar,.top-actions,.tabs,.no-print,.toast-wrap{display:none !important}
      body{background:#fff}
      .card{box-shadow:none}
      .main{padding:0}
      table{min-width:unset}
    }
    @media(max-width:1100px){
      .grid-3-1{grid-template-columns:1fr}
      .doc-grid{grid-template-columns:1fr 1fr}
      table{min-width:860px}
    }
    @media(max-width:650px){
  
      .main{padding:14px}
      .grid-2,.grid-3{grid-template-columns:1fr}
      .doc-grid{grid-template-columns:1fr}
      #pane-academics th,
      #pane-academics td{padding:8px 6px;font-size:11px;overflow-wrap:anywhere;word-break:break-word}
      .check-item{grid-template-columns:minmax(0,1fr) auto}
      table{min-width:760px}
    }
  </style>
</head>

<body data-portal="tenant">
<%
  const tenantName = (tenant && tenant.name) ? String(tenant.name) : "Classic Academy";
  const csrf = (typeof csrfToken !== "undefined" && csrfToken) ? csrfToken : null;

  const a = (typeof applicant !== "undefined" && applicant) ? applicant : null;
  const cls = (typeof sections !== "undefined" && Array.isArray(sections)) ? sections : [];

  const s = (v, d="") => (v === null || v === undefined) ? d : String(v);

  const applicantId = a ? s(a.applicationId, s(a._id)) : "—";
  const fullName = a ? s(a.fullName, (s(a.firstName)+" "+s(a.lastName)).trim()) : "—";

  const email = a ? s(a.email,"—") : "—";
  const phone = a ? s(a.phone,"—") : "—";

  const selectedSection = a ? (a.section1 || a.program1 || null) : null;
  const program1 =
    selectedSection
      ? ((selectedSection.code ? s(selectedSection.code) + " — " : "") + s(selectedSection.name || selectedSection.className,""))
      : s(a && a.programName,"—");

  const statusRaw = a ? s(a.status,"submitted") : "submitted";
  const statusLabel =
    statusRaw === "accepted" || statusRaw === "admitted" ? "Admitted" :
    statusRaw === "rejected" ? "Rejected" :
    statusRaw === "shortlist" || statusRaw === "shortlisted" ? "Shortlisted" :
    statusRaw === "interview" ? "Interview" :
    statusRaw === "under_review" || statusRaw === "review" ? "Under Review" :
    "Submitted";

  const statusPillClass =
    (statusRaw === "accepted" || statusRaw === "admitted") ? "ok" :
    (statusRaw === "rejected") ? "bad" :
    (statusRaw === "shortlist" || statusRaw === "shortlisted") ? "infopill" :
    (statusRaw === "interview" || statusRaw === "under_review" || statusRaw === "review") ? "warnpill" :
    "infopill";

  const payStatus = a ? s(a.paymentStatus,"") : "";
  const payLabel = payStatus === "paid" ? "Paid" : (payStatus === "partial" ? "Partial" : (payStatus ? payStatus : "Not Paid"));
  const payPillClass = payStatus === "paid" ? "ok" : (payStatus === "partial" ? "warnpill" : "bad");

  const docUrl = (key) => {
    if (!a) return "";
    const d = a[key];
    if (!d) return "";
    if (typeof d === "string") return d;
    if (d.url) return s(d.url,"");
    return "";
  };

  const docVerified = (key) => {
    if (!a) return false;
    const d = a[key];
    if (!d || typeof d === "string") return false;
    return !!d.verified;
  };

  const REQUIRED = [
    { key:"idDocument", label:"National ID / Passport", required:true },
    { key:"passportPhoto", label:"Passport Photo", required:true },
    { key:"transcript", label:"Transcript / Results Slip", required:true },
    { key:"certificates", label:"Certificates", required:false }
  ];

  const missingDocs = REQUIRED
    .filter(r => !docUrl(r.key))
    .map(r => ({ key:r.key, label:r.label, required:r.required }));

  const docsTotal = REQUIRED.length;
  const docsUploaded = REQUIRED.filter(r => !!docUrl(r.key)).length;
  const docsVerified = REQUIRED.filter(r => !!docUrl(r.key) && docVerified(r.key)).length;
  const docsShown = docsUploaded;

  const academics =
    (a && Array.isArray(a.academics) && a.academics.length) ? a.academics :
    (a && Array.isArray(a.academicHistory) && a.academicHistory.length) ? a.academicHistory :
    (((a && (a.school || a.qualification || a.yearCompleted || a.grades || a.transcript)) ? [{
      institution: a.school || "—",
      level: a.qualification || a.schoolLevel || "—",
      year: a.yearCompleted || "—",
      results: a.grades || (docUrl("transcript") ? "Transcript uploaded" : "—"),
      verified: !!(a.transcript && a.transcript.verified)
    }] : []));

  const audit =
    (a && Array.isArray(a.auditTrail) && a.auditTrail.length) ? a.auditTrail :
    (a && Array.isArray(a.timeline) && a.timeline.length) ? a.timeline :
    (a && Array.isArray(a.auditEntries) && a.auditEntries.length) ? a.auditEntries :
    (((a && (a.createdAt || a.updatedAt || a.decidedAt || a.interviewWhen)) ? [
      a.createdAt ? { title: "Application submitted", createdAt: a.createdAt, by: a.fullName || "Applicant" } : null,
      a.updatedAt ? { title: "Application updated", createdAt: a.updatedAt, by: "System" } : null,
      a.interviewWhen ? { title: "Interview scheduled", createdAt: a.interviewWhen, by: a.interviewPanel || "Admissions" } : null,
      a.decidedAt ? { title: `Status: ${a.status || "updated"}`, createdAt: a.decidedAt, by: a.decidedByName || "Admissions" } : null,
    ].filter(Boolean) : []));

  const preferredClassId = selectedSection && selectedSection._id ? s(selectedSection._id) : "";

  const encodedMissing = encodeURIComponent(JSON.stringify(missingDocs));

  const initials =
    fullName.split(" ").filter(Boolean).slice(0,2).map(x=>x[0]).join("").toUpperCase() || "AD";
%>

<div class="app">
<%-include("../partials/navbar") %>

  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Application Detail</div>
        <div class="subtitle">Review applicant profile, validate documents, schedule interview, and issue decision.</div>
      </div>

      <div class="top-actions no-print">
        <button class="btn light" type="button" id="btnBack"><i class="fa-solid fa-arrow-left"></i> Back</button>
        <button class="btn light" type="button" id="btnPrint"><i class="fa-solid fa-print"></i> Print</button>

        <form id="formExport" method="POST" action="/admin/admissions/applicants/<%= a ? a._id : '' %>/export" style="margin:0">
          <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
          <button class="btn light" type="submit" <%= a ? "" : "disabled" %>><i class="fa-solid fa-file-arrow-down"></i> Export</button>
        </form>

        <button class="btn warn" type="button" id="btnRequestDocs" data-open-modal="mReq" <%= a ? "" : "disabled" %>>
          <i class="fa-solid fa-file-circle-exclamation"></i> Request Docs
        </button>

        <form id="formShortlist" method="POST" action="/admin/admissions/applicants/<%= a ? a._id : '' %>/shortlist" style="margin:0">
          <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>
          <button class="btn success" type="submit" <%= a ? "" : "disabled" %>><i class="fa-solid fa-star"></i> Shortlist</button>
        </form>

        <button class="btn primary" type="button" id="btnAdmit" <%= a ? "" : "disabled" %>><i class="fa-solid fa-check"></i> Admit</button>
        <button class="btn danger" type="button" id="btnReject" <%= a ? "" : "disabled" %>><i class="fa-solid fa-xmark"></i> Reject</button>
      </div>
    </div>

    <% if (!a) { %>
      <section class="card" style="margin-top:12px">
        <div class="card-body">
          <div style="color:#b91c1c;font-weight:1000">Applicant not found.</div>
          <div class="muted">Return to Applicants List and try again.</div>
        </div>
      </section>
    <% } else { %>

      <!-- CSP-safe data for external JS -->
      <div id="pageData"
           data-applicant-id="<%= encodeURIComponent(String(a._id)) %>"
           data-missing="<%= encodedMissing %>"
           data-dv="<%= docsVerified %>"
           data-du="<%= docsUploaded %>"
           data-dt="<%= docsTotal %>"></div>

      <section class="card" style="margin-top:12px">
        <div class="card-head">
          <div class="row">
            <div class="avatar" id="aAvatar"><%= initials %></div>
            <div>
              <div class="card-title" id="aName"><%= fullName %></div>
              <div class="card-sub" id="aMeta">
                <b><%= applicantId %></b> • <%= program1 || "—" %>
                • Email: <%= email %> • Phone: <%= phone %>
                • Submitted: <%= a.createdAt ? new Date(a.createdAt).toLocaleString() : "—" %>
              </div>
            </div>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <span id="aStagePill" class="pill <%= statusPillClass %>"><i class="fa-solid fa-circle-info"></i> <%= statusLabel %></span>
            <span id="aPayPill" class="pill <%= payPillClass %>"><i class="fa-solid fa-coins"></i> <%= payLabel %></span>
            <span id="aDocsPill" class="pill <%= (docsShown === docsTotal) ? "ok" : "warnpill" %>">
              <i class="fa-solid <%= (docsVerified === docsTotal) ? "fa-check" : "fa-file-circle-exclamation" %>"></i>
              Docs <%= docsShown %>/<%= docsTotal %>
            </span>
          </div>
        </div>

        <div class="card-body">
          <div class="tabs no-print" id="tabs">
            <button class="tab active" type="button" data-pane="pane-profile"><i class="fa-solid fa-id-card"></i> Profile</button>
            <button class="tab" type="button" data-pane="pane-academics"><i class="fa-solid fa-school"></i> Academics</button>
            <button class="tab" type="button" data-pane="pane-docs"><i class="fa-solid fa-folder-open"></i> Documents</button>
            <button class="tab" type="button" data-pane="pane-payment"><i class="fa-solid fa-credit-card"></i> Payment</button>
            <button class="tab" type="button" data-pane="pane-review"><i class="fa-solid fa-clipboard-check"></i> Review & Decision</button>
            <button class="tab" type="button" data-pane="pane-audit"><i class="fa-solid fa-clock-rotate-left"></i> Audit Log</button>
          </div>

          <div class="grid-3-1">
            <!-- Left panes -->
            <div>

              <!-- Profile -->
              <div class="pane active" id="pane-profile">
                <div class="grid-2">
                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-user"></i> Personal Info</div>
                    <div class="divider"></div>
                    <div class="muted">Full Name: <span class="strong"><%= fullName %></span></div>
                    <div class="muted">Gender: <span class="strong"><%= s(a.gender,"—") %></span></div>
                    <div class="muted">DOB: <span class="strong"><%= s(a.dob,"—") %></span></div>
                    <div class="muted">Nationality: <span class="strong"><%= s(a.nationality,"—") %></span></div>
                    <div class="muted">ID/Passport No: <span class="strong"><%= s(a.idNumber, s(a.passportNo,"—")) %></span></div>
                  </div>

                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-phone"></i> Contact</div>
                    <div class="divider"></div>
                    <div class="muted">Email: <span class="strong"><%= email %></span></div>
                    <div class="muted">Phone: <span class="strong"><%= phone %></span></div>
                    <div class="muted">Address: <span class="strong"><%= s(a.address,"—") %></span></div>
                    <div class="muted">Next of Kin: <span class="strong"><%= s(a.guardianName,"—") %></span></div>
                    <div class="muted">Kin Phone: <span class="strong"><%= s(a.guardianPhone,"—") %></span></div>
                  </div>
                </div>

                <div class="divider"></div>

                <div class="grid-2">
                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-graduation-cap"></i> Application Info</div>
                    <div class="divider"></div>
                    <div class="muted">Application ID: <span class="strong"><%= applicantId %></span></div>
                    <div class="muted">Section: <span class="strong"><%= program1 || "—" %></span></div>
                    <div class="muted">Term / Year: <span class="strong"><%= s(a.termName || a.term, "—") %> / <%= s(a.academicYear,"—") %></span></div>
                    <div class="muted">Term: <span class="strong"><%= s(a.term,"—") %></span></div>
                    <div class="muted">Entry Type: <span class="strong"><%= s(a.entryType,"—") %></span></div>
                  </div>

                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-circle-info"></i> Summary</div>
                    <div class="divider"></div>
                    <div class="muted">Applicant notes / statement:</div>
                    <div class="divider"></div>
                    <div class="muted"><%= s(a.statement, s(a.notes,"")) %></div>
                  </div>
                </div>
              </div>

              <!-- Academics -->
              <div class="pane" id="pane-academics">
                <div class="note">
                  <div class="strong"><i class="fa-solid fa-school"></i> Academic History</div>
                  <div class="divider"></div>
                  <div class="table-wrap">
                    <table style="min-width:720px">
                      <thead>
                        <tr>
                          <th>Institution</th>
                          <th>Level</th>
                          <th>Year</th>
                          <th>Results</th>
                          <th class="right">Verified</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% if (!academics.length) { %>
                          <tr><td colspan="5" class="muted">No academic records provided.</td></tr>
                        <% } else { %>
                          <% academics.forEach(r => { %>
                            <tr>
                              <td class="strong"><%= s(r.institution, s(r.inst,"—")) %></td>
                              <td class="muted"><%= s(r.level,"—") %></td>
                              <td class="muted"><%= s(r.year,"—") %></td>
                              <td class="muted"><%= s(r.results, s(r.summary,"—")) %></td>
                              <td class="right">
                                <% const v = !!r.verified; %>
                                <span class="pill <%= v ? "ok" : "warnpill" %>">
                                  <i class="fa-solid <%= v ? "fa-check" : "fa-triangle-exclamation" %>"></i>
                                  <%= v ? "Yes" : "No" %>
                                </span>
                              </td>
                            </tr>
                          <% }) %>
                        <% } %>
                      </tbody>
                    </table>
                  </div>
                  <div class="divider"></div>
                  <div class="muted">Tip: You can add “verify academic record” endpoints later; this UI is ready.</div>
                </div>
              </div>

              <!-- Documents -->
              <div class="pane" id="pane-docs">
                <div class="note">
                  <div class="strong"><i class="fa-solid fa-folder-open"></i> Documents</div>
                  <div class="divider"></div>

                  <div class="tabs no-print" style="margin-bottom:10px" id="docFilters">
                    <button class="chip active" type="button" data-docfilter="all">All</button>
                    <button class="chip" type="button" data-docfilter="missing">Missing</button>
                    <button class="chip" type="button" data-docfilter="uploaded">Uploaded</button>
                    <button class="chip" type="button" data-docfilter="verified">Verified</button>
                  </div>

                  <div class="doc-grid" id="docGrid">
                    <% REQUIRED.forEach(r => { 
                      const url = docUrl(r.key);
                      const uploaded = !!url;
                      const verified = uploaded && docVerified(r.key);
                      const status = verified ? "verified" : (uploaded ? "uploaded" : "missing");
                    %>
                      <div class="doc"
                           data-status="<%= status %>">
                        <div class="doc-top">
                          <div style="min-width:0">
                            <div class="doc-name">
                              <%= r.label %>
                              <span class="mini"><%= r.required ? "(Required)" : "(Optional)" %></span>
                            </div>
                            <div class="doc-meta">
                              <%= uploaded ? ("File attached") : "No file uploaded" %>
                            </div>
                          </div>

                          <% if (verified) { %>
                            <span class="pill ok"><i class="fa-solid fa-check"></i> Verified</span>
                          <% } else if (uploaded) { %>
                            <span class="pill warnpill"><i class="fa-solid fa-hourglass-half"></i> Uploaded</span>
                          <% } else { %>
                            <span class="pill <%= r.required ? "bad" : "warnpill" %>">
                              <i class="fa-solid fa-xmark"></i> <%= r.required ? "Missing" : "Not provided" %>
                            </span>
                          <% } %>
                        </div>

                        <div class="divider"></div>

                        <div class="no-print" style="display:flex;gap:8px;flex-wrap:wrap">
                          <% if (uploaded) { %>
                            <a class="btn light small" href="<%= url %>" target="_blank" rel="noreferrer">
                              <i class="fa-solid fa-eye"></i> View
                            </a>
                          <% } else { %>
                            <button class="btn light small" type="button" data-open-modal="mReq">
                              <i class="fa-solid fa-paper-plane"></i> Request
                            </button>
                          <% } %>

                          <!-- Optional: later you can wire verification endpoints -->
                          <button class="btn success small" type="button" data-ui-only="verify-doc">
                            <i class="fa-solid fa-check"></i> Verify
                          </button>
                        </div>
                      </div>
                    <% }) %>

                    <% const passUrl = docUrl("passportPhoto"); %>
                    <% if (passUrl) { %>
                      <div class="doc" style="grid-column:1/-1" data-status="<%= docVerified('passportPhoto') ? 'verified' : 'uploaded' %>">
                        <div class="doc-top">
                          <div>
                            <div class="doc-name">Passport Photo Preview</div>
                            <div class="doc-meta">Image preview (opens full in new tab)</div>
                          </div>
                          <span class="pill ok"><i class="fa-solid fa-image"></i> Image</span>
                        </div>
                        <div class="divider"></div>
                        <a href="<%= passUrl %>" target="_blank" rel="noreferrer" class="muted doc-preview-link" style="text-decoration:none">
                          <img src="<%= passUrl %>" alt="passport" class="doc-preview-img">
                        </a>
                      </div>
                    <% } %>
                  </div>

                  <div class="divider"></div>

                  <div class="no-print" style="display:flex;gap:8px;flex-wrap:wrap">
                    <button class="btn light" type="button" data-ui-only="upload-doc"><i class="fa-solid fa-upload"></i> Upload Doc</button>
                    <button class="btn success" type="button" data-ui-only="verify-all"><i class="fa-solid fa-check-double"></i> Verify All</button>
                    <button class="btn warn" type="button" data-open-modal="mReq"><i class="fa-solid fa-paper-plane"></i> Request Missing</button>
                  </div>
                </div>
              </div>

              <!-- Payment -->
              <div class="pane" id="pane-payment">
                <div class="grid-2">
                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-receipt"></i> Application Fee</div>
                    <div class="divider"></div>
                    <div class="muted">Status: <span class="strong"><%= payLabel %></span></div>
                    <div class="muted">Amount: <span class="strong"><%= s(a.feeAmount, s(a.applicationFee,"—")) %></span></div>
                    <div class="muted">Method: <span class="strong"><%= s(a.paymentMethod,"—") %></span></div>
                    <div class="muted">Reference: <span class="strong"><%= s(a.paymentRef,"—") %></span></div>
                    <div class="muted">Paid on: <span class="strong"><%= a.paidAt ? new Date(a.paidAt).toLocaleString() : "—" %></span></div>
                    <div class="divider"></div>
                    <div class="muted">If you want “Mark Paid / Waive / Refund” to persist, add endpoints later—UI is ready.</div>
                  </div>

                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-file-invoice"></i> Offer / Deposit</div>
                    <div class="divider"></div>
                    <div class="muted">Offer Letter: <span class="strong"><%= s(a.offerStatus,"Not Issued") %></span></div>
                    <div class="muted">Deposit Required: <span class="strong"><%= s(a.depositAmount,"—") %></span></div>
                    <div class="muted">Deposit Status: <span class="strong"><%= s(a.depositStatus,"—") %></span></div>
                  </div>
                </div>
              </div>

              <!-- Review & Decision -->
              <div class="pane" id="pane-review">
                <div class="grid-2">
                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-clipboard-check"></i> Review Checklist</div>
                    <div class="divider"></div>

                    <!-- UI checklist (optional; persist later if you want) -->
                    <div id="checklist">
                      <div class="check-item">
                        <div class="strong">Identity verified</div>
                        <input type="checkbox" data-ui-only="check"/>
                      </div>
                      <div class="check-item">
                        <div class="strong">Academics reviewed</div>
                        <input type="checkbox" data-ui-only="check"/>
                      </div>
                      <div class="check-item">
                        <div class="strong">Documents complete</div>
                        <input type="checkbox" data-ui-only="check"/>
                      </div>
                      <div class="check-item">
                        <div class="strong">Fee cleared</div>
                        <input type="checkbox" data-ui-only="check"/>
                      </div>
                    </div>

                    <div class="divider"></div>
                    <button class="btn light small no-print" type="button" data-ui-only="save-checklist">
                      <i class="fa-solid fa-check"></i> Save Checklist
                    </button>
                  </div>

                  <div class="note">
                    <div class="strong"><i class="fa-solid fa-calendar"></i> Interview / Screening</div>
                    <div class="divider"></div>
                    <div class="muted">Interview Status: <span class="strong"><%= s(a.interviewStatus,"Not Scheduled") %></span></div>
                    <div class="muted">Date/Time: <span class="strong"><%= s(a.interviewWhen,"—") %></span></div>
                    <div class="muted">Mode: <span class="strong"><%= s(a.interviewMode,"—") %></span></div>
                    <div class="muted">Panel: <span class="strong"><%= s(a.interviewPanel,"—") %></span></div>
                    <div class="divider"></div>

                    <div class="no-print" style="display:flex;gap:8px;flex-wrap:wrap">
                      <button class="btn warn small" type="button" data-open-modal="mInt"><i class="fa-solid fa-calendar-plus"></i> Schedule</button>
                      <button class="btn light small" type="button" data-open-modal="mInt"><i class="fa-solid fa-arrows-rotate"></i> Reschedule</button>
                      <button class="btn danger small" type="button" data-ui-only="cancel-interview"><i class="fa-solid fa-ban"></i> Cancel</button>
                    </div>
                  </div>
                </div>

                <div class="divider"></div>

                <div class="note">
                  <div class="strong"><i class="fa-solid fa-gavel"></i> Decision</div>
                  <div class="divider"></div>

                  <div class="grid-3">
                    <div class="field">
                      <label>Decision (UI selector)</label>
                      <select class="select" id="decValue">
                        <option value="review" <%= (statusRaw==="review"||statusRaw==="under_review") ? "selected":"" %>>Keep Under Review</option>
                        <option value="shortlist" <%= (statusRaw==="shortlist"||statusRaw==="shortlisted") ? "selected":"" %>>Shortlist</option>
                        <option value="interview" <%= (statusRaw==="interview") ? "selected":"" %>>Move to Interview</option>
                        <option value="admitted" <%= (statusRaw==="accepted"||statusRaw==="admitted") ? "selected":"" %>>Admit</option>
                        <option value="rejected" <%= (statusRaw==="rejected") ? "selected":"" %>>Reject</option>
                      </select>
                    </div>
                    <div class="field">
                      <label>Effective Term</label>
                      <input class="input" id="decIntake" value="<%= s(a.academicYear,'') %>" placeholder="e.g. 2026/2027">
                    </div>
                    <div class="field">
                      <label>Section (final)</label>
                      <input class="input" id="decProgram" value="<%= program1 %>" placeholder="Final section">
                    </div>
                  </div>

                  <div class="divider"></div>

                  <div class="field">
                    <label>Decision Notes (internal)</label>
                    <textarea class="textarea" id="decNotes" placeholder="Reasoning, conditions, committee notes..."><%= s(a.decisionNote,"") %></textarea>
                  </div>

                  <div class="divider"></div>

                  <!-- ACCEPT (REAL) -->
                  <form id="formAccept" method="POST" action="/admin/admissions/applicants/<%= a._id %>/accept" class="no-print">
                    <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>

                    <div class="field">
                      <label>Assign Section (required for acceptance)</label>
                      <select class="select" name="section" id="classGroup" required>
                        <option value="">Select section</option>
                        <% cls.forEach(c => { %>
                          <% const cid = c && c._id ? s(c._id) : ""; %>
                          <option value="<%= cid %>" <%= (preferredClassId && preferredClassId === cid) ? "selected" : "" %>>
                            <%= (c.code ? s(c.code) + " — " : "") + s(c.name || c.className,"Section") %>
                          </option>
                        <% }) %>
                      </select>
                    </div>

                    <div class="divider"></div>

                    <div class="field">
                      <label>Decision note (sent with accept)</label>
                      <textarea class="textarea" name="decisionNote" placeholder="Fees paid, verified docs, conditions..."><%= s(a.decisionNote,"") %></textarea>
                    </div>

                    <div class="divider"></div>
                    <div class="row" style="justify-content:flex-end">
                      <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> ACCEPT → Create Student</button>
                    </div>
                  </form>

                  <div class="divider"></div>

                  <!-- REJECT (REAL) -->
                  <form id="formReject" method="POST" action="/admin/admissions/applicants/<%= a._id %>/reject" class="no-print">
                    <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>

                    <div class="field">
                      <label>Rejection reason (optional)</label>
                      <textarea class="textarea" name="decisionNote" id="rejectNote" placeholder="Missing documents / requirements not met..."></textarea>
                    </div>

                    <div class="divider"></div>
                    <div class="row" style="justify-content:flex-end">
                      <button class="btn danger" type="submit"><i class="fa-solid fa-xmark"></i> REJECT</button>
                    </div>
                  </form>

                  <div class="divider"></div>

                  <div class="no-print" style="display:flex;gap:8px;flex-wrap:wrap">
                    <button class="btn light" type="button" data-ui-only="save-decision"><i class="fa-solid fa-floppy-disk"></i> Save Decision</button>
                    <button class="btn primary" type="button" data-open-modal="mLetter"><i class="fa-solid fa-file-signature"></i> Generate Letter</button>
                    <button class="btn success" type="button" id="btnFinalize"><i class="fa-solid fa-check"></i> Finalize</button>
                  </div>

                  <div class="divider"></div>
                  <div class="muted">
                    Finalize behavior:
                    Admitted → submits Accept form (requires Class).
                    Rejected → submits Reject form.
                    Shortlist → submits Shortlist form.
                    Interview → opens Schedule Interview modal.
                  </div>
                </div>
              </div>

              <!-- Audit -->
              <div class="pane" id="pane-audit">
                <div class="note">
                  <div class="strong"><i class="fa-solid fa-clock-rotate-left"></i> Audit Log</div>
                  <div class="divider"></div>

                  <% if (!audit.length) { %>
                    <div class="muted">No audit entries yet.</div>
                  <% } else { %>
                    <% audit.forEach(x => { %>
                      <div class="card" style="box-shadow:none;margin-bottom:10px">
                        <div class="card-body">
                          <div class="strong"><%= s(x.title, s(x.action,"Update")) %></div>
                          <div class="muted">
                            <%= x.createdAt ? new Date(x.createdAt).toLocaleString() : s(x.when,"") %>
                            • by <%= s(x.by,"System") %>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>

            </div>

            <!-- Right panel -->
            <aside class="card">
              <div class="card-head">
                <div>
                  <div class="card-title">Admin Panel</div>
                  <div class="card-sub">Quick actions, internal notes.</div>
                </div>
              </div>

              <div class="card-body">
                <div class="note">
                  <div class="strong"><i class="fa-solid fa-tags"></i> Tags</div>
                  <div class="divider"></div>
                  <div class="tabs no-print" id="tagWrap">
                    <button class="chip" type="button" data-tag="high_priority"><i class="fa-solid fa-bolt"></i> High Priority</button>
                    <button class="chip" type="button" data-tag="needs_docs"><i class="fa-solid fa-file-circle-exclamation"></i> Needs Docs</button>
                    <button class="chip" type="button" data-tag="scholarship"><i class="fa-solid fa-award"></i> Scholarship</button>
                    <button class="chip" type="button" data-tag="international"><i class="fa-solid fa-globe"></i> International</button>
                  </div>
                  <div class="divider"></div>
                  <div class="muted">Selected tags: <span class="strong" id="tagList">None</span></div>
                </div>

                <div class="divider"></div>

                <!-- REAL notes save -->
                <form method="POST" action="/admin/admissions/applicants/<%= a._id %>/notes" class="no-print" id="formAdminNotes">
                  <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>

                  <input type="hidden" name="tags" id="tagsField" value="">

                  <div class="field">
                    <label>Internal Notes</label>
                    <textarea class="textarea" name="adminNotes" id="adminNotes" placeholder="Write internal notes..."><%= s(a.adminNotes,"") %></textarea>
                  </div>
                  <div class="divider"></div>
                  <div class="no-print" style="display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end">
                    <button class="btn light small" type="submit"><i class="fa-solid fa-check"></i> Save Notes</button>
                    <button class="btn light small" type="button" data-ui-only="email"><i class="fa-solid fa-envelope"></i> Email</button>
                    <button class="btn light small" type="button" data-ui-only="sms"><i class="fa-solid fa-comment-sms"></i> SMS</button>
                  </div>
                </form>

                <div class="divider"></div>

                <div class="note">
                  <div class="strong"><i class="fa-solid fa-link"></i> Quick Links</div>
                  <div class="divider"></div>
                  <div class="muted">• <a href="/admin/admissions/applicants">Applicants list</a></div>
                  <div class="muted">• <a href="/admin/students">Students</a></div>
                  <div class="muted">• <a href="/admin/finance">Finance</a></div>
                </div>
              </div>
            </aside>

          </div>
        </div>
      </section>

    <% } %>
  </main>
</div>

<!-- MODAL: Request Docs (REAL) -->
<div class="modal-backdrop" id="mReq" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-label="Request Missing Documents">
    <div class="modal-header">
      <div class="modal-title">Request Missing Documents</div>
      <button class="btn light small" type="button" data-close-modal="mReq"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <% if (a) { %>
      <form class="modal-body" method="POST" action="/admin/admissions/applicants/<%= a._id %>/request-docs" id="reqForm">
        <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>

        <div class="note">
          <div class="strong"><i class="fa-solid fa-file-circle-exclamation"></i> Missing Documents</div>
          <div class="divider"></div>
          <div class="muted" id="missList">—</div>
        </div>

        <div class="divider"></div>

        <input type="hidden" name="missingKeys" id="missingKeys" value="">

        <div class="grid-2">
          <div class="field">
            <label>Send via</label>
            <select class="select" name="via">
              <option value="email" selected>Email</option>
              <option value="sms">SMS</option>
              <option value="both">Email + SMS</option>
            </select>
          </div>
          <div class="field">
            <label>Deadline</label>
            <input class="input" name="deadline" type="date"/>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Message</label>
          <textarea class="textarea" name="message">Hello, please upload the missing documents to complete your admission application.</textarea>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mReq">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-paper-plane"></i> Send</button>
        </div>
      </form>
    <% } else { %>
      <div class="modal-body"><div class="muted">Applicant not loaded.</div></div>
    <% } %>
  </div>
</div>

<!-- MODAL: Schedule Interview (REAL) -->
<div class="modal-backdrop" id="mInt" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-label="Schedule Interview">
    <div class="modal-header">
      <div class="modal-title">Schedule Interview</div>
      <button class="btn light small" type="button" data-close-modal="mInt"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <% if (a) { %>
      <form class="modal-body" method="POST" action="/admin/admissions/applicants/<%= a._id %>/schedule-interview" id="intForm">
        <% if (csrf) { %><input type="hidden" name="_csrf" value="<%= csrf %>"><% } %>

        <div class="grid-2">
          <div class="field">
            <label>Date</label>
            <input class="input" name="date" type="date" required/>
          </div>
          <div class="field">
            <label>Time</label>
            <input class="input" name="time" type="time" required/>
          </div>
        </div>

        <div class="divider"></div>

        <div class="grid-2">
          <div class="field">
            <label>Mode</label>
            <select class="select" name="mode">
              <option value="in-person" selected>In-person</option>
              <option value="online">Online</option>
              <option value="phone">Phone</option>
            </select>
          </div>
          <div class="field">
            <label>Panel / Interviewers</label>
            <input class="input" name="panel" placeholder="Dr. X, Ms. Y, Admissions Officer">
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Notes</label>
          <textarea class="textarea" name="notes" placeholder="Screening questions, requirements..."></textarea>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mInt">Cancel</button>
          <button class="btn warn" type="submit"><i class="fa-solid fa-check"></i> Save</button>
        </div>
      </form>
    <% } else { %>
      <div class="modal-body"><div class="muted">Applicant not loaded.</div></div>
    <% } %>
  </div>
</div>

<!-- MODAL: Generate Letter (UI-only) -->
<div class="modal-backdrop" id="mLetter" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-label="Generate Letter">
    <div class="modal-header">
      <div class="modal-title">Generate Letter</div>
      <button class="btn light small" type="button" data-close-modal="mLetter"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="modal-body">
      <div class="grid-2">
        <div class="field">
          <label>Template</label>
          <select class="select" id="lTemplate">
            <option selected>Offer Letter</option>
            <option>Conditional Offer</option>
            <option>Rejection Letter</option>
            <option>Waitlist Letter</option>
            <option>Document Request</option>
          </select>
        </div>
        <div class="field">
          <label>Output</label>
          <select class="select" id="lOutput">
            <option selected>PDF</option>
            <option>DOCX</option>
            <option>Email Body</option>
          </select>
        </div>
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Letter Notes / Conditions</label>
        <textarea class="textarea" id="lNotes" placeholder="Conditions, deposit deadlines, scholarship details..."></textarea>
      </div>

      <div class="divider"></div>

      <div class="note">
        <div class="strong"><i class="fa-solid fa-circle-info"></i> Preview</div>
        <div class="divider"></div>
        <div class="muted" id="lPreview">
          This is UI-ready. When you add backend templates, this modal can generate PDF/DOCX and attach to the applicant.
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn light" type="button" data-close-modal="mLetter">Cancel</button>
      <button class="btn primary" type="button" id="btnDoLetter"><i class="fa-solid fa-wand-magic-sparkles"></i> Generate</button>
    </div>
  </div>
</div>

<div class="toast-wrap" id="toastWrap" aria-live="polite" aria-atomic="true"></div>

<script src="/js/admin-applicant-detail.js" defer></script>
<script src="/js/navbar.js" defer></script>
</body>
</html>

