<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Admin • Student Statement — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>

  <style>
    :root{
      --blue:#0a3d62; --blue2:#083454; --accent:#0a6fbf;
      --bg:#f4f8ff; --card:#fff; --muted:#6b7280;
      --success:#16a34a; --danger:#ef4444; --warn:#f59e0b; --info:#4f46e5;
      --radius:16px; --line:rgba(13,64,96,.12);
      --shadow:0 10px 30px rgba(0,0,0,.08);
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:#0f172a}

    .app{display:flex;min-height:100vh}
    .sidebar{width:280px;background:linear-gradient(180deg,var(--blue),var(--blue2));color:#fff;padding:18px;position:sticky;top:0;height:100vh}
    .brand{display:flex;gap:10px;align-items:center;padding:8px 8px 16px}
    .logo{width:40px;height:40px;border-radius:12px;background:rgba(255,255,255,.14);display:grid;place-items:center;font-weight:900}
    .brand h1{font-size:16px;margin:0;line-height:1.1}
    .sub{font-size:12px;opacity:.75}
    .nav{display:grid;gap:6px;margin-top:8px}
    .nav-section-title{margin-top:12px;font-size:11px;opacity:.7;text-transform:uppercase;letter-spacing:.08em;padding:8px}
    .nav-item{display:flex;gap:10px;align-items:center;color:#fff;text-decoration:none;padding:10px 12px;border-radius:12px;opacity:.9}
    .nav-item:hover{background:rgba(255,255,255,.08)}
    .nav-item.active{background:rgba(255,255,255,.14);opacity:1}
    .nav-item i{width:18px;text-align:center}

    .main{flex:1;padding:18px}
    .topbar{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:flex-start}
    .title{font-size:18px;font-weight:1000}
    .subtitle{font-size:12px;color:var(--muted);margin-top:4px}
    .top-actions{display:flex;gap:10px;flex-wrap:wrap}

    .btn{border:none;border-radius:12px;padding:10px 12px;font-weight:900;cursor:pointer;display:inline-flex;gap:8px;align-items:center}
    .btn.primary{background:var(--accent);color:#fff}
    .btn.light{background:#fff;border:1px solid var(--line);color:#0f172a}
    .btn:hover{filter:brightness(.98)}
    .btn.small{padding:8px 10px;border-radius:10px;font-size:12px}

    .card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow)}
    .card-head{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;align-items:center;padding:12px 14px;border-bottom:1px solid var(--line)}
    .card-title{font-weight:1000}
    .card-sub{font-size:12px;color:var(--muted)}
    .card-body{padding:14px}

    .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:12px}
    .grid-2{display:grid;grid-template-columns:1.2fr .8fr;gap:12px;margin-top:12px}

    .kpi{padding:14px}
    .kpi .label{font-size:12px;color:var(--muted);font-weight:800}
    .kpi .value{font-size:22px;font-weight:1000;margin-top:6px}
    .kpi .hint{font-size:12px;color:var(--muted);margin-top:4px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900}
    .ok{background:#ecfdf3;color:#15803d}
    .bad{background:#fee2e2;color:#b91c1c}
    .warnpill{background:#fef9c3;color:#92400e}
    .infopill{background:#eef2ff;color:#3730a3}

    .muted{color:var(--muted);font-size:12px}
    .strong{font-weight:1000}
    .divider{height:1px;background:var(--line);margin:12px 0}

    .filters{display:grid;grid-template-columns:1.2fr 1fr 1fr 1fr;gap:10px}
    .field{display:grid;gap:6px}
    .field label{font-size:12px;color:var(--muted);font-weight:800}
    .input,.select{padding:10px 12px;border-radius:12px;border:1px solid var(--line);background:#fff;outline:none}
    .input:focus,.select:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}

    .table-wrap{overflow:auto;border:1px solid var(--line);border-radius:12px}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1100px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:top}
    th{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .right{text-align:right}

    .chipbar{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid var(--line);background:#fff;border-radius:999px;padding:8px 12px;font-weight:900;font-size:12px;cursor:pointer}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}

    /* Print */
    @media print{
      .sidebar,.top-actions,.filters,.chipbar,.no-print{display:none !important}
      body{background:#fff}
      .card{box-shadow:none}
      .main{padding:0}
      table{min-width:unset}
    }

    @media(max-width:1050px){
      .grid-2{grid-template-columns:1fr}
      .grid-4{grid-template-columns:1fr 1fr}
      .filters{grid-template-columns:1fr 1fr}
      table{min-width:900px}
    }
    @media(max-width:650px){
      .sidebar{display:none}
      .main{padding:14px}
      .grid-4{grid-template-columns:1fr}
      .filters{grid-template-columns:1fr}
      table{min-width:780px}
    }
  </style>
</head>
<body data-portal="tenant">

<div class="app">
  <aside class="sidebar">
    <div class="brand">
      <div class="logo">CS</div>
      <div><h1>Classic Academy</h1><div class="sub">Admin Portal</div></div>
    </div>

    <nav class="nav">
      <div class="nav-section-title">Finance</div>
      <a class="nav-item" href="admin-finance.html"><i class="fa-solid fa-coins"></i><span>Finance Dashboard</span></a>
      <a class="nav-item active" href="admin-finance-student-statement.html"><i class="fa-solid fa-file-lines"></i><span>Student Statement</span></a>
      <a class="nav-item" href="admin-finance-invoice-detail.html"><i class="fa-solid fa-file-invoice"></i><span>Invoice Detail</span></a>
      <a class="nav-item" href="admin-finance-receipt.html"><i class="fa-solid fa-receipt"></i><span>Receipt</span></a>

      <div class="nav-section-title">Core</div>
      <a class="nav-item" href="admin-students.html"><i class="fa-solid fa-user-graduate"></i><span>Students</span></a>
    </nav>
  </aside>

  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Student Statement</div>
        <div class="subtitle">Running statement of invoices, waivers, penalties, and payments for a student.</div>
      </div>
      <div class="top-actions">
        <button class="btn light" id="btnBack"><i class="fa-solid fa-arrow-left"></i> Back</button>
        <button class="btn light" id="btnExport"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
        <button class="btn primary" id="btnPrint"><i class="fa-solid fa-print"></i> Print</button>
      </div>
    </div>

    <!-- Summary KPIs -->
    <div class="grid-4">
      <div class="card kpi">
        <div class="label">Student</div>
        <div class="value" id="kStudent">Jonathan Kuipers</div>
        <div class="hint" id="kReg">CS/2025/011</div>
      </div>
      <div class="card kpi">
        <div class="label">Total Billed</div>
        <div class="value" id="kBilled">UGX 0</div>
        <div class="hint">Invoices + penalties</div>
      </div>
      <div class="card kpi">
        <div class="label">Total Paid</div>
        <div class="value" id="kPaid">UGX 0</div>
        <div class="hint">All payments received</div>
      </div>
      <div class="card kpi">
        <div class="label">Current Balance</div>
        <div class="value" id="kBalance">UGX 0</div>
        <div class="hint"><span class="pill warnpill" id="kStatus"><i class="fa-solid fa-circle-half-stroke"></i> Outstanding</span></div>
      </div>
    </div>

    <!-- Filters + Profile -->
    <div class="grid-2">
      <section class="card">
        <div class="card-head">
          <div>
            <div class="card-title">Filters</div>
            <div class="card-sub">Search and filter statement records.</div>
          </div>
          <div class="chipbar no-print" id="chipBar">
            <button class="chip active" data-range="this-sem">This Semester</button>
            <button class="chip" data-range="30">Last 30 Days</button>
            <button class="chip" data-range="90">Last 90 Days</button>
            <button class="chip" data-range="all">All Time</button>
          </div>
        </div>
        <div class="card-body">
          <div class="filters">
            <div class="field">
              <label>Student Search</label>
              <input class="input" id="fStudentSearch" placeholder="Name / Reg No / Email" value="Jonathan Kuipers">
            </div>
            <div class="field">
              <label>Semester</label>
              <select class="select" id="fSemester">
                <option value="all">All</option>
                <option value="2025S1" selected>2025/2026 - Sem 1</option>
                <option value="2024S2">2024/2025 - Sem 2</option>
              </select>
            </div>
            <div class="field">
              <label>Type</label>
              <select class="select" id="fType">
                <option value="all" selected>All</option>
                <option value="invoice">Invoice</option>
                <option value="payment">Payment</option>
                <option value="waiver">Waiver</option>
                <option value="penalty">Penalty</option>
                <option value="refund">Refund</option>
              </select>
            </div>
            <div class="field">
              <label>Status</label>
              <select class="select" id="fStatus">
                <option value="all" selected>All</option>
                <option value="paid">Paid</option>
                <option value="unpaid">Unpaid</option>
                <option value="partial">Partial</option>
                <option value="overdue">Overdue</option>
              </select>
            </div>

            <div class="field">
              <label>From</label>
              <input class="input" id="fFrom" type="date">
            </div>
            <div class="field">
              <label>To</label>
              <input class="input" id="fTo" type="date">
            </div>
            <div class="field">
              <label>Min Amount</label>
              <input class="input" id="fMin" type="number" min="0" placeholder="0">
            </div>
            <div class="field">
              <label>Max Amount</label>
              <input class="input" id="fMax" type="number" min="0" placeholder="Any">
            </div>
          </div>

          <div class="divider"></div>

          <div class="row no-print" style="gap:8px;flex-wrap:wrap">
            <button class="btn light small" id="btnApply"><i class="fa-solid fa-filter"></i> Apply Filters</button>
            <button class="btn light small" id="btnClear"><i class="fa-solid fa-eraser"></i> Clear</button>
            <button class="btn light small" id="btnOpenInvoice"><i class="fa-solid fa-file-invoice"></i> Open Invoice</button>
            <button class="btn light small" id="btnOpenReceipt"><i class="fa-solid fa-receipt"></i> Open Receipt</button>
          </div>
        </div>
      </section>

      <aside class="card">
        <div class="card-head">
          <div>
            <div class="card-title">Student Finance Profile</div>
            <div class="card-sub">Key finance indicators and holds.</div>
          </div>
        </div>
        <div class="card-body">
          <div class="row" style="justify-content:space-between">
            <div>
              <div class="strong">Program</div>
              <div class="muted" id="pProgram">BSc Computing</div>
            </div>
            <span class="pill infopill"><i class="fa-solid fa-user"></i> Active</span>
          </div>

          <div class="divider"></div>

          <div class="row" style="justify-content:space-between">
            <span class="muted">Sponsor</span>
            <span class="strong" id="pSponsor">None</span>
          </div>
          <div class="row" style="justify-content:space-between">
            <span class="muted">Payment Plan</span>
            <span class="strong" id="pPlan">None</span>
          </div>
          <div class="row" style="justify-content:space-between">
            <span class="muted">Registration Hold</span>
            <span class="strong" id="pHold">No</span>
          </div>

          <div class="divider"></div>

          <div class="strong">Admin Actions</div>
          <div class="divider"></div>

          <div class="row no-print" style="gap:8px;flex-wrap:wrap">
            <button class="btn light small" id="btnAddNote"><i class="fa-solid fa-note-sticky"></i> Add Note</button>
            <button class="btn light small" id="btnSetHold"><i class="fa-solid fa-lock"></i> Toggle Hold</button>
            <button class="btn light small" id="btnRemind"><i class="fa-solid fa-bell"></i> Send Reminder</button>
          </div>

          <div class="divider"></div>

          <div class="muted">
            This section becomes real with backend: sponsor accounts, holds, approvals, and audit logs.
          </div>
        </div>
      </aside>
    </div>

    <!-- Statement Table -->
    <section class="card" style="margin-top:12px">
      <div class="card-head">
        <div>
          <div class="card-title">Statement Entries</div>
          <div class="card-sub" id="tableMeta">Showing entries and running balance.</div>
        </div>
        <div class="row no-print">
          <span class="muted" id="countMeta">0 entries</span>
          <button class="btn light small" id="btnCSV"><i class="fa-solid fa-file-csv"></i> Export CSV</button>
        </div>
      </div>
      <div class="card-body">
        <div class="table-wrap">
          <table id="stmtTable">
            <thead>
              <tr>
                <th>Date</th>
                <th>Type</th>
                <th>Reference</th>
                <th>Description</th>
                <th class="right">Debit (UGX)</th>
                <th class="right">Credit (UGX)</th>
                <th class="right">Running Balance</th>
                <th class="right no-print">Actions</th>
              </tr>
            </thead>
            <tbody id="stmtBody"></tbody>
          </table>
        </div>
      </div>
    </section>

  </main>
</div>

<script>
  const $ = (id)=>document.getElementById(id);
  const fmt=(n)=>{ try{return new Intl.NumberFormat('en-US').format(n);}catch(e){return String(n);} };

  // Demo statement dataset (backend later)
  const profile = {
    student:"Jonathan Kuipers",
    reg:"CS/2025/011",
    program:"BSc Computing",
    sponsor:"None",
    plan:"None",
    hold:false
  };

  const entries = [
    // Debit = billed, Credit = paid/waiver/refund(-)
    {date:"2025-11-10", semester:"2025S1", type:"invoice", ref:"INV-0001", desc:"Tuition invoice (Sem 1)", debit:2500000, credit:0, status:"partial"},
    {date:"2025-11-18", semester:"2025S1", type:"payment", ref:"PAY-1001", desc:"Mobile Money payment", debit:0, credit:1500000, status:"paid"},
    {date:"2025-12-01", semester:"2025S1", type:"penalty", ref:"PEN-0007", desc:"Late payment penalty", debit:50000, credit:0, status:"unpaid"},
    {date:"2025-12-03", semester:"2025S1", type:"waiver", ref:"WVR-0022", desc:"Partial scholarship adjustment", debit:0, credit:200000, status:"paid"},
  ];

  function typeBadge(t){
    const map = {
      invoice: `<span class="pill warnpill"><i class="fa-solid fa-file-invoice"></i> Invoice</span>`,
      payment: `<span class="pill ok"><i class="fa-solid fa-coins"></i> Payment</span>`,
      waiver: `<span class="pill infopill"><i class="fa-solid fa-hand-holding-heart"></i> Waiver</span>`,
      penalty:`<span class="pill warnpill"><i class="fa-solid fa-triangle-exclamation"></i> Penalty</span>`,
      refund: `<span class="pill bad"><i class="fa-solid fa-rotate-left"></i> Refund</span>`
    };
    return map[t] || `<span class="pill infopill">${t}</span>`;
  }

  function computeKPIs(rows){
    const billed = rows.reduce((a,r)=>a+(r.debit||0),0);
    const paid = rows.reduce((a,r)=>a+(r.credit||0),0);
    const bal = Math.max(billed - paid, 0);

    $('kStudent').textContent = profile.student;
    $('kReg').textContent = profile.reg;
    $('pProgram').textContent = profile.program;
    $('pSponsor').textContent = profile.sponsor;
    $('pPlan').textContent = profile.plan;
    $('pHold').textContent = profile.hold ? 'Yes' : 'No';

    $('kBilled').textContent = 'UGX ' + fmt(billed);
    $('kPaid').textContent = 'UGX ' + fmt(paid);
    $('kBalance').textContent = 'UGX ' + fmt(bal);

    const statusEl = $('kStatus');
    if(bal<=0){
      statusEl.className='pill ok';
      statusEl.innerHTML='<i class="fa-solid fa-check"></i> Cleared';
    }else{
      statusEl.className='pill warnpill';
      statusEl.innerHTML='<i class="fa-solid fa-circle-half-stroke"></i> Outstanding';
    }
  }

  function passesFilters(r, f){
    if(f.semester!=='all' && r.semester!==f.semester) return false;
    if(f.type!=='all' && r.type!==f.type) return false;
    if(f.status!=='all' && (r.status||'').toLowerCase()!==f.status) return false;

    if(f.from){
      const d=new Date(r.date); const from=new Date(f.from);
      if(d<from) return false;
    }
    if(f.to){
      const d=new Date(r.date); const to=new Date(f.to);
      if(d>to) return false;
    }
    if(f.min!==null && (r.debit||0) < f.min && (r.credit||0) < f.min) {
      // allow either debit or credit to satisfy, otherwise filter out
      return false;
    }
    if(f.max!==null){
      const amt = Math.max(r.debit||0, r.credit||0);
      if(amt>f.max) return false;
    }
    return true;
  }

  function renderTable(rows){
    // Sort by date ascending for running balance
    const sorted = [...rows].sort((a,b)=> new Date(a.date)-new Date(b.date));
    let running = 0; // running balance = billed - paid
    $('stmtBody').innerHTML = sorted.map(r=>{
      running += (r.debit||0) - (r.credit||0);

      const debit = r.debit ? `UGX ${fmt(r.debit)}` : '—';
      const credit = r.credit ? `UGX ${fmt(r.credit)}` : '—';
      const actions = `
        <button class="btn light small" data-open="invoice" data-ref="${r.ref}" title="Open Invoice"><i class="fa-solid fa-file-invoice"></i></button>
        <button class="btn light small" data-open="receipt" data-ref="${r.ref}" title="Open Receipt"><i class="fa-solid fa-receipt"></i></button>
      `;

      return `
        <tr>
          <td class="muted">${r.date}</td>
          <td>${typeBadge(r.type)}</td>
          <td class="strong">${r.ref}</td>
          <td class="muted">${r.desc || '—'}</td>
          <td class="right ${r.debit? 'strong':''}">${debit}</td>
          <td class="right ${r.credit? 'strong':''}">${credit}</td>
          <td class="right strong">UGX ${fmt(Math.max(running,0))}</td>
          <td class="right no-print">${actions}</td>
        </tr>
      `;
    }).join('') || `<tr><td colspan="8" class="muted" style="padding:18px">No statement entries match your filters.</td></tr>`;

    $('countMeta').textContent = `${sorted.length} entries`;
    $('tableMeta').textContent = `Statement period: ${sorted[0]?.date || '—'} to ${sorted[sorted.length-1]?.date || '—'}`;
    computeKPIs(sorted);
  }

  function getFilters(){
    const min = $('fMin').value ? Number($('fMin').value) : null;
    const max = $('fMax').value ? Number($('fMax').value) : null;
    return {
      semester: $('fSemester').value,
      type: $('fType').value,
      status: $('fStatus').value,
      from: $('fFrom').value || '',
      to: $('fTo').value || '',
      min,
      max
    };
  }

  function apply(){
    const f = getFilters();
    const filtered = entries.filter(r=>passesFilters(r,f));
    renderTable(filtered);
  }

  // Chips (quick ranges) - demo only: adjusts date filter bounds
  function setChipActive(btn){
    document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
    btn.classList.add('active');
  }
  $('chipBar').addEventListener('click',(e)=>{
    const btn = e.target.closest('.chip');
    if(!btn) return;
    setChipActive(btn);

    const range = btn.dataset.range;
    $('fFrom').value=''; $('fTo').value='';
    if(range==='this-sem'){
      $('fSemester').value='2025S1';
    } else if(range==='30' || range==='90'){
      const days = Number(range);
      const to = new Date();
      const from = new Date(); from.setDate(to.getDate()-days);
      $('fFrom').value = from.toISOString().slice(0,10);
      $('fTo').value = to.toISOString().slice(0,10);
    } else {
      $('fSemester').value='all';
    }
    apply();
  });

  // Buttons
  $('btnBack').addEventListener('click', ()=>history.back());
  $('btnPrint').addEventListener('click', ()=>window.print());
  $('btnExport').addEventListener('click', ()=>alert('Export (PDF) will be implemented in backend later.'));
  $('btnApply').addEventListener('click', apply);
  $('btnClear').addEventListener('click', ()=>{
    $('fSemester').value='2025S1';
    $('fType').value='all';
    $('fStatus').value='all';
    $('fFrom').value='';
    $('fTo').value='';
    $('fMin').value='';
    $('fMax').value='';
    apply();
  });

  $('btnOpenInvoice').addEventListener('click', ()=>alert('Open Invoice Detail page (link later).'));
  $('btnOpenReceipt').addEventListener('click', ()=>alert('Open Receipt page (link later).'));

  $('btnAddNote').addEventListener('click', ()=>{
    const note = prompt('Add internal finance note:');
    if(note) alert('Saved note (UI). Backend later will store it.');
  });
  $('btnSetHold').addEventListener('click', ()=>{
    profile.hold = !profile.hold;
    $('pHold').textContent = profile.hold ? 'Yes' : 'No';
    alert(profile.hold ? 'Hold applied (UI).' : 'Hold removed (UI).');
  });
  $('btnRemind').addEventListener('click', ()=>alert('Reminder sent (UI). Backend later: email/SMS.'));

  // Table action clicks (invoice/receipt)
  $('stmtBody').addEventListener('click',(e)=>{
    const btn = e.target.closest('button[data-open]');
    if(!btn) return;
    const mode = btn.dataset.open;
    const ref = btn.dataset.ref;
    if(mode==='invoice') alert('Open invoice detail for: ' + ref);
    if(mode==='receipt') alert('Open receipt for: ' + ref);
  });

  // CSV Export (client-side)
  $('btnCSV').addEventListener('click', ()=>{
    const rows = [...document.querySelectorAll('#stmtBody tr')];
    if(!rows.length){ alert('Nothing to export.'); return; }

    const f = getFilters();
    const filtered = entries.filter(r=>passesFilters(r,f)).sort((a,b)=> new Date(a.date)-new Date(b.date));

    let running=0;
    const header = ['Date','Type','Reference','Description','Debit','Credit','RunningBalance'];
    const lines = [header.join(',')];

    filtered.forEach(r=>{
      running += (r.debit||0) - (r.credit||0);
      const line = [
        r.date,
        r.type,
        r.ref,
        (r.desc||'').replaceAll(',',' '),
        r.debit||0,
        r.credit||0,
        Math.max(running,0)
      ].join(',');
      lines.push(line);
    });

    const blob = new Blob([lines.join('\n')], {type:'text/csv;charset=utf-8;'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href=url;
    a.download=`student-statement-${profile.reg}.csv`;
    document.body.appendChild(a);
    a.click();
    a.remove();
    URL.revokeObjectURL(url);
  });

  // init
  apply();
</script>

</body>
</html>

