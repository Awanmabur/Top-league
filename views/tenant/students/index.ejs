<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= tenant?.name || "Classic Academy" %> - Students</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .arch{background:#f1f5f9;color:#334155}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1500px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}
    .col-check{width:48px}
    .col-student{width:230px}
    .col-placement{width:270px}
    .col-docs{width:220px}
    .col-contacts{width:220px}
    .col-status{width:130px}
    .col-hold{width:190px}
    .col-actions{width:250px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .student-main{min-width:0}
    .student-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .student-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar>div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1180px,100%);max-height:calc(100dvh - 40px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(980px,100%)}
    .modal>form{display:flex;flex-direction:column;min-height:0;flex:1 1 auto}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px;color:#0f172a}
    .modal-body{padding:18px 20px;overflow-y:auto;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field{display:flex;flex-direction:column;gap:6px;min-width:0}
    .field.full{grid-column:1 / -1}
    .field label{font-size:12px;font-weight:800;color:#475569}
    .char-count{font-size:12px;color:#6b7280;text-align:right}
    .json-data{display:none!important}
    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
    .tab{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;font-weight:800;cursor:pointer}
    .tab.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .tab-pane{display:none}
    .tab-pane.active{display:block}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}
    .help-note{padding:12px;border-radius:12px;background:rgba(10,111,191,.06);border:1px dashed rgba(10,111,191,.25);font-size:13px;color:#334155}
    .section-box{padding:14px;border:1px dashed rgba(13,64,96,.18);border-radius:14px;background:rgba(10,111,191,.04)}
    .section-title{font-size:14px;font-weight:900;color:#0f172a;margin-bottom:10px}
    .req{color:#b91c1c;font-weight:1000;margin-left:4px}
    .doc-drop{border:2px dashed rgba(13,64,96,.25);border-radius:14px;background:#fff;padding:14px;display:grid;gap:10px;place-items:center;text-align:center}
    .doc-drop.drag{background:rgba(10,111,191,.06);border-color:rgba(10,111,191,.45)}
    .file-list{width:100%;display:grid;gap:8px}
    .file-row{display:flex;gap:10px;align-items:center;justify-content:space-between;padding:10px;border:1px solid rgba(13,64,96,.12);border-radius:12px;background:#fff}
    .file-row .name{font-weight:900;font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .file-row .meta{font-size:12px;color:#6b7280}
    .doc-summary{display:grid;gap:6px}
    .doc-summary strong{font-size:12px}
    .doc-links,.view-docs{display:grid;gap:8px}
    .doc-link{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff;text-decoration:none;color:#0f172a}
    .doc-link:hover{background:rgba(10,111,191,.05)}
    .doc-link .meta{font-size:12px;color:#6b7280}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width:520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left>*,.toolbar .right>*{max-width:100%}}
    @media print{body *{visibility:hidden !important}#printArea,#printArea *{visibility:visible !important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main" id="printArea">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %>
          <% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Students</div>
          <div class="subtitle">Manage student records with the same intake, placement, education, guardian, and document flow used on public admissions.</div>
        </div>
        <div class="top-actions">
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-arrow-up"></i> Import</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Student</button>
        </div>
      </div>

      <div class="grid-4" style="margin-top:12px;">
        <div class="card"><div class="card-body kpi"><div class="label">Total</div><div class="value"><%= kpis?.total || 0 %></div><div class="hint">Matching filter</div></div></div>
        <div class="card"><div class="card-body kpi"><div class="label">Active</div><div class="value" style="color:#15803d"><%= kpis?.active || 0 %></div><div class="hint">Currently active</div></div></div>
        <div class="card"><div class="card-body kpi"><div class="label">On Hold</div><div class="value" style="color:#92400e"><%= kpis?.on_hold || 0 %></div><div class="hint">Needs follow-up</div></div></div>
        <div class="card"><div class="card-body kpi"><div class="label">Archived</div><div class="value" style="color:#64748b"><%= kpis?.archived || 0 %></div><div class="hint">Soft deleted / archived</div></div></div>
      </div>

      <% const termNumbers = Array.from(new Set((terms || []).map(function(term){ const raw = String(term?.term || term?.name || ""); const match = raw.match(/\d+/); return match ? match[0] : ""; }).filter(Boolean))); %>
      <section class="card" style="margin-top:12px;">
        <div class="card-body">
          <form class="toolbar" method="GET" action="/admin/students">
            <div class="left">
              <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, regNo, email, stream..." />
              <select class="select" name="schoolLevel">
                <option value="">All Levels</option>
                <% (schoolLevels || []).forEach(function(level){ %>
                  <option value="<%= level.value %>" <%= query?.schoolLevel===level.value ? 'selected' : '' %>><%= level.label %></option>
                <% }) %>
              </select>
              <select class="select" name="classLevel">
                <option value="">All Class Levels</option>
                <% (classLevels || []).forEach(function(level){ %>
                  <option value="<%= level %>" <%= query?.classLevel===level ? 'selected' : '' %>><%= level %></option>
                <% }) %>
              </select>
              <select class="select" name="term">
                <option value="">All Terms</option>
                <% (termNumbers.length ? termNumbers : ["1","2","3"]).forEach(function(termNo){ %>
                  <option value="<%= termNo %>" <%= String(query?.term||'')===String(termNo) ? 'selected' : '' %>>Term <%= termNo %></option>
                <% }) %>
              </select>
              <select class="select" name="status">
                <option value="">All Statuses</option>
                <option value="active" <%= query?.status==='active' ? 'selected' : '' %>>Active</option>
                <option value="on_hold" <%= query?.status==='on_hold' ? 'selected' : '' %>>On Hold</option>
                <option value="suspended" <%= query?.status==='suspended' ? 'selected' : '' %>>Suspended</option>
                <option value="graduated" <%= query?.status==='graduated' ? 'selected' : '' %>>Graduated</option>
                <option value="archived" <%= query?.status==='archived' ? 'selected' : '' %>>Archived</option>
              </select>
            </div>
            <div class="right">
              <button class="btn light" type="submit"><i class="fa-solid fa-filter"></i> Filter</button>
              <a class="btn light" href="/admin/students"><i class="fa-solid fa-xmark"></i> Clear</a>
              <button class="btn light" type="button" id="quickActive"><i class="fa-solid fa-user-plus"></i> Quick Add</button>
              <button class="btn light" type="button" id="quickHold"><i class="fa-solid fa-user-clock"></i> Add On Hold</button>
              <button class="btn light" type="button" id="quickImport"><i class="fa-solid fa-file-csv"></i> CSV</button>
            </div>
          </form>

          <div class="bulkbar" id="bulkbar">
            <div class="left">
              <div class="strong">Selected <span class="badge-count" id="selCount">0</span></div>
            </div>
            <div class="right">
              <button class="btn light" type="button" id="bulkSetStatus">Set Status</button>
              <button class="btn light" type="button" id="bulkApplyHold">Apply Hold</button>
              <button class="btn light" type="button" id="bulkClearHold">Clear Hold</button>
              <button class="btn light" type="button" id="bulkArchive">Archive</button>
              <button class="btn light" type="button" id="bulkDelete">Delete</button>
              <button class="btn light" type="button" id="bulkClear">Clear</button>
            </div>
          </div>
        </div>
      </section>

      <section class="card" style="margin-top:12px;">
        <div class="card-head">
          <div>
            <div class="card-title">Student Records</div>
            <div class="card-sub">Placement, guardian, and document status in one view.</div>
          </div>
          <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk Actions</button>
        </div>
        <div class="card-body">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                  <th class="col-student">Student</th>
                  <th class="col-placement">Placement</th>
                  <th class="col-docs">Documents</th>
                  <th class="col-contacts">Contacts</th>
                  <th class="col-status">Status</th>
                  <th class="col-hold">Hold</th>
                  <th class="col-actions">Actions</th>
                </tr>
              </thead>
              <tbody id="tbodyStudents"></tbody>
            </table>
          </div>

          <% const page = Number(query?.page || 1); const totalPages = Number(query?.totalPages || 1); function buildPage(n){ const params = new URLSearchParams(); if(query?.q) params.set('q', query.q); if(query?.schoolLevel) params.set('schoolLevel', query.schoolLevel); if(query?.classLevel) params.set('classLevel', query.classLevel); if(query?.term) params.set('term', query.term); if(query?.status) params.set('status', query.status); params.set('page', String(n)); return '/admin/students?' + params.toString(); } %>
          <div class="pagination">
            <div class="muted">Showing page <%= page %> of <%= totalPages %> - <%= query?.total || 0 %> student(s)</div>
            <div class="pagination-links">
              <a class="page-link <%= page <= 1 ? 'disabled' : '' %>" href="<%= page <= 1 ? '#' : buildPage(page - 1) %>">Prev</a>
              <% for(let i=1;i<=totalPages;i++){ if(i===1 || i===totalPages || Math.abs(i-page)<=1){ %>
                <a class="page-link <%= i===page ? 'active' : '' %>" href="<%= buildPage(i) %>"><%= i %></a>
              <% } } %>
              <a class="page-link <%= page >= totalPages ? 'disabled' : '' %>" href="<%= page >= totalPages ? '#' : buildPage(page + 1) %>">Next</a>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <textarea id="studentsData" class="json-data"><%- JSON.stringify(students || []) %></textarea>
  <textarea id="termsData" class="json-data"><%- JSON.stringify(terms || []) %></textarea>
  <textarea id="streamsData" class="json-data"><%- JSON.stringify(streams || []) %></textarea>
  <textarea id="sectionsData" class="json-data"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="qualificationMapData" class="json-data"><%- JSON.stringify(qualificationMap || {}) %></textarea>
  <textarea id="classLevelMap" class="json-data"><%- JSON.stringify(classLevelMap || {}) %></textarea>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" id="rowStatusField" name="status" value="">
  </form>

  <form id="bulkForm" action="/admin/students/bulk" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" id="bulkActionVal" name="action" value="">
    <input type="hidden" id="bulkStatusVal" name="status" value="">
    <input type="hidden" id="bulkHoldTypeVal" name="holdType" value="">
    <input type="hidden" id="bulkHoldReasonVal" name="holdReason" value="">
    <input type="hidden" id="bulkIdsVal" name="ids" value="">
  </form>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal">
      <form id="studentForm" action="/admin/students" method="POST" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <input type="hidden" id="mFullName" name="fullName" value="" />

        <div class="modal-header">
          <div>
            <div class="modal-title" id="mTitleBar">Add Student</div>
            <div class="muted">Use the same fields as the public admissions form, then manage status and holds here.</div>
          </div>
          <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
          <div class="tabs">
            <button class="tab active" type="button" data-tab="personal">Personal Information</button>
            <button class="tab" type="button" data-tab="placement">Academy Placement</button>
            <button class="tab" type="button" data-tab="education">Education Background</button>
            <button class="tab" type="button" data-tab="guardian">Guardian / Next of Kin</button>
            <button class="tab" type="button" data-tab="documents">Documents Upload</button>
            <button class="tab" type="button" data-tab="status">Status</button>
          </div>

          <div class="tab-pane active" id="tab-personal">
            <div class="section-box">
              <div class="section-title"><i class="fa-solid fa-user"></i> Personal Information</div>
              <div class="form-grid">
                <div class="field">
                  <label>First Name <span class="req">*</span></label>
                  <input class="input" id="mFirstName" name="firstName" required />
                </div>
                <div class="field">
                  <label>Middle Name</label>
                  <input class="input" id="mMiddleName" name="middleName" />
                </div>
                <div class="field">
                  <label>Last Name <span class="req">*</span></label>
                  <input class="input" id="mLastName" name="lastName" required />
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field">
                  <label>Gender <span class="req">*</span></label>
                  <select class="select" id="mGender" name="gender" required>
                    <option value="">Select</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
                <div class="field">
                  <label>Date of Birth <span class="req">*</span></label>
                  <input class="input" id="mDob" name="dob" type="date" required />
                </div>
                <div class="field">
                  <label>Nationality <span class="req">*</span></label>
                  <select class="select" id="mNationality" name="nationality" required>
                    <option value="">Select nationality</option>
                    <% ["Ugandan","Kenyan","South Sudanese","Tanzanian","Rwandan","Burundian","Other"].forEach(function(item){ %>
                      <option value="<%= item %>"><%= item %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field">
                  <label>Phone <span class="req">*</span></label>
                  <input class="input" id="mPhone" name="phone" required />
                </div>
                <div class="field">
                  <label>Email <span class="req">*</span></label>
                  <input class="input" id="mEmail" name="email" type="email" required />
                </div>
                <div class="field">
                  <label>Address <span class="req">*</span></label>
                  <input class="input" id="mAddress" name="address" required />
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-placement">
            <div class="section-box">
              <div class="section-title"><i class="fa-solid fa-graduation-cap"></i> Academy Placement</div>
              <div class="form-grid">
                <div class="field">
                  <label>Term <span class="req">*</span></label>
                  <select class="select" id="mTermId" name="termId" required>
                    <option value="">Select term</option>
                    <% (terms || []).forEach(function(term){ %>
                      <option value="<%= term._id %>" data-year="<%= term.year %>" data-term="<%= term.term %>"><%= term.name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="field">
                  <label>Academic Year <span class="req">*</span></label>
                  <select class="select" id="mAcademicYear" name="academicYear" required data-default-options="<%- JSON.stringify(academicYears || []) %>">
                    <option value="">Select</option>
                    <% (academicYears || []).forEach(function(year){ %>
                      <option value="<%= year %>"><%= year %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="field">
                  <label>School Level <span class="req">*</span></label>
                  <select class="select" id="mSchoolLevel" name="schoolLevel" required>
                    <option value="">Select</option>
                    <% (schoolLevels || []).forEach(function(level){ %>
                      <option value="<%= level.value %>"><%= level.label %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field">
                  <label>Class Level <span class="req">*</span></label>
                  <select class="select" id="mClassLevel" name="classLevel" required>
                    <option value="">Select</option>
                    <% (classLevels || []).forEach(function(level){ %>
                      <option value="<%= level %>"><%= level %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="field">
                  <label>Stream <span class="req">*</span></label>
                  <select class="select" id="mStreamId" name="streamId" required>
                    <option value="">Select stream</option>
                    <% (streams || []).forEach(function(stream){ %>
                      <option value="<%= stream._id %>" data-level="<%= stream.levelType %>" data-class-level="<%= stream.classLevel %>" data-class-id="<%= stream.classId %>"><%= stream.name %></option>
                    <% }) %>
                  </select>
                </div>
                <div class="field">
                  <label>Section <span class="req">*</span></label>
                  <select class="select" id="mSection1" name="section1" required>
                    <option value="">Select section</option>
                    <% (sections || []).forEach(function(section){ %>
                      <option value="<%= section._id %>" data-level="<%= section.levelType %>" data-class-level="<%= section.classLevel %>" data-class-id="<%= section.classId %>" data-stream="<%= section.classStream %>"><%= section.name %></option>
                    <% }) %>
                  </select>
                  <div class="muted">Choose the section under the selected stream.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-education">
            <div class="section-box">
              <div class="section-title"><i class="fa-solid fa-school"></i> Education Background</div>
              <div class="form-grid">
                <div class="field">
                  <label>Highest Qualification <span class="req">*</span></label>
                  <select class="select" id="mQualification" name="qualification" required>
                    <option value="">Select</option>
                  </select>
                </div>
                <div class="field">
                  <label>School / Institution <span class="req">*</span></label>
                  <input class="input" id="mSchool" name="school" />
                </div>
                <div class="field">
                  <label>Year Completed <span class="req">*</span></label>
                  <input class="input" id="mYearCompleted" name="yearCompleted" type="number" min="1900" max="2100" />
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field full">
                  <label>Results / Grades Summary</label>
                  <input class="input" id="mGrades" name="grades" />
                  <div class="muted">Optional: admissions can still verify transcripts.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-guardian">
            <div class="section-box">
              <div class="section-title"><i class="fa-solid fa-people-group"></i> Guardian / Next of Kin</div>
              <div class="form-grid">
                <div class="field">
                  <label>Guardian Name <span class="req">*</span></label>
                  <input class="input" id="mGuardianName" name="guardianName" required />
                </div>
                <div class="field">
                  <label>Guardian Phone <span class="req">*</span></label>
                  <input class="input" id="mGuardianPhone" name="guardianPhone" required />
                </div>
                <div class="field">
                  <label>Guardian Email</label>
                  <input class="input" id="mGuardianEmail" name="guardianEmail" type="email" />
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field full">
                  <label>Additional Notes</label>
                  <textarea class="textarea" id="mNotes" name="notes"></textarea>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-documents">
            <div class="section-box">
              <div class="section-title"><i class="fa-solid fa-folder-open"></i> Documents Upload</div>
              <div class="muted" style="margin-bottom:10px">Passport Photo is always mandatory. Transcript is not required only for "No previous education".</div>

              <div class="form-grid">
                <div class="field">
                  <label>Passport Photo <span class="req">*</span></label>
                  <input class="input" type="file" id="mPassportPhoto" name="passportPhoto" accept=".jpg,.jpeg,.png,image/*" />
                  <div class="muted" id="passportPhotoStatus"></div>
                </div>
                <div class="field">
                  <label>National ID / Passport Scan <span class="req">*</span></label>
                  <input class="input" type="file" id="mIdDocument" name="idDocument" accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*" />
                  <div class="muted" id="idDocumentStatus"></div>
                </div>
                <div class="field">
                  <label>Transcript / Results Slip <span class="req">*</span></label>
                  <input class="input" type="file" id="mTranscript" name="transcript" accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*" />
                  <div class="muted" id="transcriptStatus"></div>
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field full">
                  <label>Other Documents (optional)</label>
                  <input class="input" type="file" id="mOtherDocs" name="otherDocs" multiple accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*" />
                  <div class="muted" id="otherDocsStatus"></div>
                </div>
              </div>

              <div style="margin-top:12px">
                <div class="doc-drop" id="dropZone">
                  <div style="font-size:28px"><i class="fa-solid fa-cloud-arrow-up"></i></div>
                  <div class="strong">Drag and drop other documents here</div>
                  <div class="muted">or click to choose files</div>
                  <input id="quickFiles" type="file" multiple accept=".pdf,.jpg,.jpeg,.png,application/pdf,image/*" hidden />
                  <button type="button" class="btn light" id="pickQuick"><i class="fa-solid fa-paperclip"></i> Choose Files</button>
                  <div class="file-list" id="fileList"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-status">
            <div class="section-box">
              <div class="section-title"><i class="fa-solid fa-shield-halved"></i> Status</div>
              <div class="form-grid">
                <div class="field">
                  <label>RegNo</label>
                  <input class="input" id="mRegNo" name="regNo" placeholder="Leave blank to auto-generate" />
                </div>
                <div class="field">
                  <label>Status</label>
                  <select class="select" id="mStatus" name="status">
                    <option value="active">Active</option>
                    <option value="on_hold">On Hold</option>
                    <option value="suspended">Suspended</option>
                    <option value="graduated">Graduated</option>
                    <option value="archived">Archived</option>
                  </select>
                </div>
                <div class="field">
                  <label>Hold Type</label>
                  <input class="input" id="mHoldType" name="holdType" placeholder="Fees, discipline, medical..." />
                </div>
              </div>

              <div class="form-grid" style="margin-top:12px">
                <div class="field full">
                  <label>Hold Reason</label>
                  <textarea class="textarea" id="mHoldReason" name="holdReason" maxlength="200"></textarea>
                  <div class="char-count" id="holdReasonCount">0 / 200</div>
                </div>
              </div>

              <div class="help-note" style="margin-top:12px">Student and parent setup emails are still created automatically when valid emails exist.</div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Student</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Student Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Student</label><div class="view-input" id="vFullName">-</div></div>
          <div class="field"><label>RegNo</label><div class="view-input" id="vRegNo">-</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">-</div></div>
          <div class="field"><label>Term</label><div class="view-input" id="vTerm">-</div></div>
          <div class="field"><label>Academic Year</label><div class="view-input" id="vAcademicYear">-</div></div>
          <div class="field"><label>School Level</label><div class="view-input" id="vSchoolLevel">-</div></div>
          <div class="field"><label>Class Level</label><div class="view-input" id="vClassLevel">-</div></div>
          <div class="field"><label>Stream</label><div class="view-input" id="vStream">-</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vSection">-</div></div>
          <div class="field"><label>Date of Birth</label><div class="view-input" id="vDob">-</div></div>
          <div class="field"><label>Nationality</label><div class="view-input" id="vNationality">-</div></div>
          <div class="field"><label>Email</label><div class="view-input" id="vEmail">-</div></div>
          <div class="field"><label>Phone</label><div class="view-input" id="vPhone">-</div></div>
          <div class="field"><label>Guardian</label><div class="view-input multiline" id="vGuardian">-</div></div>
          <div class="field"><label>Qualification</label><div class="view-input" id="vQualification">-</div></div>
          <div class="field"><label>School / Institution</label><div class="view-input" id="vSchool">-</div></div>
          <div class="field"><label>Year Completed</label><div class="view-input" id="vYearCompleted">-</div></div>
          <div class="field full"><label>Results / Grades Summary</label><div class="view-input multiline" id="vGrades">-</div></div>
          <div class="field full"><label>Address</label><div class="view-input multiline" id="vAddress">-</div></div>
          <div class="field full"><label>Additional Notes</label><div class="view-input multiline" id="vNotes">-</div></div>
          <div class="field full"><label>Hold</label><div class="view-input multiline" id="vHold">-</div></div>
          <div class="field full"><label>Documents</label><div class="view-docs" id="vDocuments"></div></div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" id="viewResendBtn"><i class="fa-solid fa-envelope"></i> Resend Setup</button>
        <button class="btn light" type="button" id="viewArchiveBtn"><i class="fa-solid fa-box-archive"></i> Archive</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <form action="/admin/students/import" method="POST" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-header">
          <div class="modal-title">Import Students</div>
          <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
          <div class="help-note">Use the existing CSV import route for bulk uploads. Manual add/edit now follows the public admissions structure.</div>
          <div class="field" style="margin-top:12px;">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" />
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Import CSV</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/navbar.js"></script>
  <script src="/js/students.js"></script>
</body>
</html>

