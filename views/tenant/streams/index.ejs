<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %>  -  Streams</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}.textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}.strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}.warn{background:#fef9c3;color:#92400e}.bad{background:#fee2e2;color:#b91c1c}
    .table-wrap{overflow-x:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px}
    table{width:100%;min-width:1680px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)} tr.row-clickable{cursor:pointer}
    .col-check{width:48px}.col-stream{width:250px}.col-level{width:130px}.col-class{width:230px}.col-section{width:180px}.col-teacher{width:180px}.col-capacity{width:140px}.col-room{width:140px}.col-status{width:140px}.col-actions{width:230px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .stream-main{min-width:0}.stream-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.stream-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}.badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}.flash{padding:12px 14px;border-radius:12px;font-weight:700}.flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}.flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}.topbar>div:first-child{min-width:0;flex:1 1 auto}.top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1120px,100%);max-height:calc(100dvh - 40px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(980px,100%)} .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px;color:#0f172a}.modal-body{padding:18px 20px;overflow-y:auto;flex:1 1 auto}.modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.field{display:flex;flex-direction:column;gap:6px}.field.full{grid-column:1/-1}.field label{font-size:12px;font-weight:800;color:#475569}
    .char-count{font-size:12px;color:#6b7280;text-align:right}.json-data{display:none!important}
    .mini-list{display:grid;gap:10px;margin-top:10px}.mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}.mini-item .left{display:grid;gap:2px}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width:520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left>*,.toolbar .right>*{max-width:100%}table{min-width:1680px}}
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>
    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %>
          <% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div><div class="title">Streams</div><div class="subtitle">Manage streams as a standalone module attached to classes.</div></div>
        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Stream</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="stream-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div><div class="muted">Matching filter</div></div>
        <div class="card"><div class="stream-title">Active</div><div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div><div class="muted">Running streams</div></div>
        <div class="card"><div class="stream-title">Inactive</div><div class="kpi-value" style="color:#92400e"><%= kpis?.inactive || 0 %></div><div class="muted">Temporarily paused</div></div>
        <div class="card"><div class="stream-title">Archived</div><div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div><div class="muted">Hidden / inactive</div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/streams">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search stream, code, class..." />
            <select class="select" name="schoolUnitId"><option value="">All School Units</option><% (structure || []).forEach(function(su){ %><option value="<%= su.id %>" <%= query?.schoolUnitId===su.id?'selected':'' %>><%= su.name %></option><% }) %></select>
            <select class="select" name="campusId"><option value="">All Locations</option><% (structure || []).forEach(function(su){ (su.campuses || []).forEach(function(c){ %><option value="<%= c.id %>" <%= query?.campusId===c.id?'selected':'' %>><%= su.name %>  -  <%= c.name %></option><% }) }) %></select>
            <select class="select" name="levelType"><option value="">All Levels</option><option value="nursery" <%= query?.levelType==='nursery'?'selected':'' %>>Nursery</option><option value="primary" <%= query?.levelType==='primary'?'selected':'' %>>Primary</option><option value="secondary" <%= query?.levelType==='secondary'?'selected':'' %>>Secondary</option></select>
            <select class="select" name="classId"><option value="">All Classes</option><% (classes || []).forEach(function(c){ %><option value="<%= String(c._id) %>" <%= query?.classId===String(c._id)?'selected':'' %>><%= c.name %>  -  <%= c.sectionName || c.stream || 'A' %>  -  <%= c.academicYear || '' %></option><% }) %></select>
            <select class="select" name="sectionId"><option value="">All Sections</option><% (sections || []).forEach(function(s){ %><option value="<%= String(s._id) %>" <%= query?.sectionId===String(s._id)?'selected':'' %>><%= s.name %><%= s.className ? ('  -  ' + s.className) : '' %></option><% }) %></select>
            <select class="select" name="status"><option value="">All Status</option><option value="active" <%= query?.status==='active'?'selected':'' %>>Active</option><option value="inactive" <%= query?.status==='inactive'?'selected':'' %>>Inactive</option><option value="archived" <%= query?.status==='archived'?'selected':'' %>>Archived</option></select>
          </div>
          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/streams"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap"><strong>Selected</strong><span class="badge-count" id="selCount">0</span><span class="muted">stream(s)</span></div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button">Activate</button>
            <button class="btn-xs" id="bulkDeactivate" type="button">Inactivate</button>
            <button class="btn-xs" id="bulkArchive" type="button">Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button">Delete</button>
            <button class="btn-xs" id="bulkClear" type="button">Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div><div class="stream-title">Streams Table</div><div class="stream-sub">Showing <%= streams.length %> of <%= query?.total || 0 %> records.</div></div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>
          <div style="margin-top:10px;"><div class="table-wrap" id="printArea"><table><thead><tr><th class="col-check"><input type="checkbox" id="checkAll" /></th><th class="col-stream">Stream</th><th class="col-level">Level</th><th class="col-class">Class</th><th class="col-section">Section</th><th class="col-teacher">Teacher</th><th class="col-capacity">Cap / Enrolled</th><th class="col-room">Room</th><th class="col-status">Status</th><th class="col-actions" style="text-align:right;">Actions</th></tr></thead><tbody id="tbodyStreams"></tbody></table></div></div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="stream-title">Quick Actions</div>
          <div class="stream-sub">Fast create helpers.</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Add Stream A</div><div class="muted">Pre-fill as A</div></div><button class="btn-xs" id="quickA" type="button"><i class="fa-solid fa-a"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add Stream B</div><div class="muted">Pre-fill as B</div></div><button class="btn-xs" id="quickB" type="button"><i class="fa-solid fa-b"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add East Stream</div><div class="muted">Pre-fill as East</div></div><button class="btn-xs" id="quickEast" type="button"><i class="fa-solid fa-location-arrow"></i></button></div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal">
      <div class="modal-header"><div class="modal-title" id="mTitleBar">Add Stream</div><button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button></div>
      <form id="streamForm" method="POST" action="/admin/streams">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="form-grid">
            <div class="field"><label>Stream Name</label><input class="input" id="mName" name="name" required /></div>
            <div class="field"><label>Stream Code</label><input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" /></div>
            <div class="field"><label>Status</label><select class="select" id="mStatus" name="status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="archived">Archived</option></select></div>
            <div class="field"><label>School Unit</label><select class="select" id="mSchoolUnitId" name="schoolUnitId"><option value="">- Select School Unit -</option><% (structure || []).forEach(function(su){ %><option value="<%= su.id %>"><%= su.name %></option><% }) %></select></div>
            <div class="field"><label>Location</label><select class="select" id="mCampusId" name="campusId"><option value="">- Select Location -</option></select></div>
            <div class="field"><label>School Level</label><select class="select" id="mLevelType" name="levelType"><option value="">- Select Level -</option><option value="nursery">Nursery</option><option value="primary">Primary</option><option value="secondary">Secondary</option></select></div>
            <div class="field"><label>Class</label><select class="select" id="mClassId" name="classId" required><option value="">- Select Class -</option></select></div>
            <div class="field"><label>Section <span class="muted">(optional)</span></label><select class="select" id="mSectionId" name="sectionId"><option value="">- No Section -</option></select></div>
            <div class="field"><label>Teacher</label><select class="select" id="mClassTeacher" name="classTeacher"><option value="">- Select Teacher -</option><% (staffList || []).forEach(function(s){ %><option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' - ' + s.role) : '' %></option><% }) %></select></div>
            <div class="field"><label>Capacity</label><input class="input" id="mCapacity" name="capacity" type="number" min="0" /></div>
            <div class="field"><label>Enrolled Count</label><input class="input" id="mEnrolledCount" name="enrolledCount" type="number" min="0" /></div>
            <div class="field"><label>Room</label><input class="input" id="mRoom" name="room" /></div>
            <div class="field full"><label>Notes</label><textarea class="textarea" id="mNotes" name="notes" maxlength="1200"></textarea><div class="char-count" id="notesCount">0 / 1200</div></div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button">Save Stream</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header"><div class="modal-title">Stream Details</div><button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button></div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Stream</label><div class="view-input" id="vName">-</div></div>
          <div class="field"><label>Code</label><div class="view-input" id="vCode">-</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">-</div></div>
          <div class="field"><label>Level</label><div class="view-input" id="vLevel">-</div></div>
          <div class="field"><label>Class</label><div class="view-input" id="vClass">-</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vSection">-</div></div>
          <div class="field"><label>Teacher</label><div class="view-input" id="vTeacher">-</div></div>
          <div class="field"><label>Capacity</label><div class="view-input" id="vCapacity">-</div></div>
          <div class="field"><label>Room</label><div class="view-input" id="vRoom">-</div></div>
          <div class="field full"><label>Notes</label><div class="view-input multiline" id="vNotes">-</div></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" id="viewActivateBtn">Activate</button>
        <button class="btn light" type="button" id="viewInactiveBtn">Inactivate</button>
        <button class="btn light" type="button" id="viewArchiveBtn">Archive</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn">Edit</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusField">
  </form>

  <form id="bulkForm" method="POST" action="/admin/streams/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionField">
    <input type="hidden" name="ids" id="bulkIdsField">
  </form>

  <textarea id="streamsData" class="json-data"><%- JSON.stringify((streams || []).map(function(s){
    return {
      id: String(s._id || ''),
      name: s.name || '',
      code: s.code || '',
      schoolUnitId: s.schoolUnitId || '',
      schoolUnitName: s.schoolUnitName || '',
      campusId: s.campusId || '',
      campusName: s.campusName || '',
      levelType: s.levelType || '',
      classId: s.classId?._id ? String(s.classId._id) : String(s.classId || ''),
      className: s.className || s.classId?.name || '',
      sectionId: s.sectionId?._id ? String(s.sectionId._id) : String(s.sectionId || ''),
      sectionName: s.sectionName || s.sectionId?.name || '',
      sectionCode: s.sectionCode || s.sectionId?.code || '',
      teacherId: s.classTeacher?._id ? String(s.classTeacher._id) : (s.classTeacher ? String(s.classTeacher) : ''),
      teacherName: s.classTeacher?.fullName || s.classTeacher?.name || '',
      capacity: Number(s.capacity || 0),
      enrolledCount: Number(s.enrolledCount || 0),
      room: s.room || '',
      status: s.status || 'active',
      notes: s.notes || ''
    };
  })) %></textarea>
  <textarea id="classesData" class="json-data"><%- JSON.stringify((classes || []).map(function(c){
    return {
      id: String(c._id || ''),
      name: c.name || '',
      schoolUnitId: c.schoolUnitId || '',
      campusId: c.campusId || '',
      levelType: c.levelType || '',
      stream: c.sectionName || c.stream || '',
      academicYear: c.academicYear || ''
    };
  })) %></textarea>
  <textarea id="sectionsData" class="json-data"><%- JSON.stringify((sections || []).map(function(s){
    return {
      id: String(s._id || ''),
      name: s.name || '',
      code: s.code || '',
      schoolUnitId: s.schoolUnitId || '',
      campusId: s.campusId || '',
      levelType: s.levelType || '',
      classId: s.classId?._id ? String(s.classId._id) : String(s.classId || ''),
      className: s.className || s.classId?.name || ''
    };
  })) %></textarea>
  <textarea id="structureData" class="json-data"><%- JSON.stringify(structure || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/streams.js"></script>
</body>
</html>

