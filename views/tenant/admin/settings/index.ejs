<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Settings — CampusSaaS</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{
      padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none;width:100%;
    }
    .textarea{min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(320px,.85fr);gap:12px}
    .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .card-block{display:grid;gap:12px}
    .stat-card,.setting-card{
      background:#fff;border:1px solid rgba(13,64,96,.10);border-radius:18px;padding:16px;min-width:0;
    }
    .setting-row{
      display:flex;justify-content:space-between;gap:14px;align-items:flex-start;flex-wrap:wrap;
      padding:14px 0;border-bottom:1px solid rgba(13,64,96,.08);
    }
    .setting-row:last-child{border-bottom:none;padding-bottom:0}
    .setting-info{min-width:0;flex:1 1 300px}
    .setting-control{min-width:240px;flex:0 0 320px;max-width:100%}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .section-tabs{display:flex;gap:8px;flex-wrap:wrap}
    .tab-btn{
      border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px;
    }
    .tab-btn.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .toggle{
      display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 12px;
      border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff
    }
    .switch{position:relative;width:44px;height:26px;border-radius:999px;background:rgba(13,64,96,.16);cursor:pointer;transition:.2s;flex:0 0 auto}
    .switch::after{content:"";position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:.2s}
    .switch.on{background:rgba(22,163,74,.25)}
    .switch.on::after{left:21px}
    .mini-list{display:grid;gap:10px}
    .mini-item{
      display:flex;justify-content:space-between;gap:10px;align-items:center;padding:12px 14px;
      border:1px solid rgba(13,64,96,.10);border-radius:14px;background:#fff
    }
    .modal-backdrop{
      position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;
      padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden
    }
    .modal-backdrop.show{display:flex}
    .modal{
      width:min(900px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto
    }
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .json-data{display:none !important}
    .tab-pane{display:none}
    .tab-pane.active{display:block}
    @media (max-width: 980px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .grid-2,.grid-3,.form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
      .setting-control{flex:1 1 100%;min-width:0}
    }
    @media (max-width: 520px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .top-actions .btn{font-size:12px}
      .modal-backdrop{padding:30px 12px}
      .modal{max-height:calc(100dvh - 60px);border-radius:20px}
      .modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Settings</div>
          <div class="subtitle">Manage school profile, branding, communication defaults, portal rules and integrations.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnResetDefaults" type="button"><i class="fa-solid fa-rotate-left"></i> Reset Defaults</button>
          <button class="btn light" id="btnTestConfig" type="button"><i class="fa-solid fa-vial-circle-check"></i> Test Config</button>
          <button class="btn primary" id="btnOpenEdit" type="button"><i class="fa-solid fa-gear"></i> Edit Settings</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="stat-card">
          <div class="section-title">Profile</div>
          <div class="kpi-value"><%= stats?.profileCompletion || 0 %>%</div>
          <div class="muted">Configuration completeness</div>
        </div>
        <div class="stat-card">
          <div class="section-title">Channels</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= stats?.enabledChannels || 0 %></div>
          <div class="muted">Enabled delivery channels</div>
        </div>
        <div class="stat-card">
          <div class="section-title">Portal Rules</div>
          <div class="kpi-value" style="color:#15803d"><%= stats?.activePolicies || 0 %></div>
          <div class="muted">Active rules and policies</div>
        </div>
        <div class="stat-card">
          <div class="section-title">Integrations</div>
          <div class="kpi-value" style="color:#92400e"><%= stats?.integrations || 0 %></div>
          <div class="muted">Connected services</div>
        </div>
      </div>

      <section class="setting-card" style="margin-top:12px;">
        <div class="toolbar">
          <div class="left">
            <div class="section-tabs" id="sectionTabs">
              <button class="tab-btn active" data-tab="general" type="button">General</button>
              <button class="tab-btn" data-tab="branding" type="button">Branding</button>
              <button class="tab-btn" data-tab="communication" type="button">Communication</button>
              <button class="tab-btn" data-tab="portal" type="button">Portal</button>
              <button class="tab-btn" data-tab="integrations" type="button">Integrations</button>
            </div>
          </div>
          <div class="right">
            <span class="pill ok"><i class="fa-solid fa-circle-check"></i> Saved</span>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card-block">

          <div class="setting-card tab-pane active" id="tab-general">
            <div class="section-title">General Settings</div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">School Name</div>
                <div class="muted">Main institution display name used across portal, emails and receipts.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.schoolName || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">School Email</div>
                <div class="muted">Primary institutional email address.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.schoolEmail || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Phone</div>
                <div class="muted">Primary contact phone number.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.schoolPhone || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Address</div>
                <div class="muted">Official location shown on portal and documents.</div>
              </div>
              <div class="setting-control"><textarea class="textarea" readonly><%= settings?.schoolAddress || '' %></textarea></div>
            </div>
          </div>

          <div class="setting-card tab-pane" id="tab-branding">
            <div class="section-title">Branding</div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Primary Color</div>
                <div class="muted">Main brand color for portal and admin UI.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.primaryColor || '#0a6fbf' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Secondary Color</div>
                <div class="muted">Accent/supporting brand color.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.secondaryColor || '#0d4060' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Logo URL</div>
                <div class="muted">Logo used across the platform.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.logoUrl || '' %>" readonly></div>
            </div>
          </div>

          <div class="setting-card tab-pane" id="tab-communication">
            <div class="section-title">Communication Defaults</div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Default Sender Name</div>
                <div class="muted">Displayed when sending messages and notifications.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.defaultSenderName || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Reply-To Email</div>
                <div class="muted">Used for outgoing mail replies.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.replyToEmail || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Channels</div>
                <div class="muted">Default outbound channels.</div>
              </div>
              <div class="setting-control">
                <div class="mini-list">
                  <div class="mini-item"><span>Portal</span><span class="pill <%= settings?.channels?.portal ? 'ok' : 'info' %>"><%= settings?.channels?.portal ? 'On' : 'Off' %></span></div>
                  <div class="mini-item"><span>Email</span><span class="pill <%= settings?.channels?.email ? 'ok' : 'info' %>"><%= settings?.channels?.email ? 'On' : 'Off' %></span></div>
                  <div class="mini-item"><span>SMS</span><span class="pill <%= settings?.channels?.sms ? 'ok' : 'info' %>"><%= settings?.channels?.sms ? 'On' : 'Off' %></span></div>
                  <div class="mini-item"><span>Push</span><span class="pill <%= settings?.channels?.push ? 'ok' : 'info' %>"><%= settings?.channels?.push ? 'On' : 'Off' %></span></div>
                </div>
              </div>
            </div>
          </div>

          <div class="setting-card tab-pane" id="tab-portal">
            <div class="section-title">Portal Rules</div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Allow Public Admissions</div>
                <div class="muted">Show online application form publicly.</div>
              </div>
              <div class="setting-control">
                <div class="toggle"><span>Public Admissions</span><span class="pill <%= settings?.portal?.allowPublicAdmissions ? 'ok':'info' %>"><%= settings?.portal?.allowPublicAdmissions ? 'Enabled':'Disabled' %></span></div>
              </div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Require Student Login</div>
                <div class="muted">Restrict portal pages to authenticated users.</div>
              </div>
              <div class="setting-control">
                <div class="toggle"><span>Student Login</span><span class="pill <%= settings?.portal?.requireStudentLogin ? 'ok':'info' %>"><%= settings?.portal?.requireStudentLogin ? 'Required':'Optional' %></span></div>
              </div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Maintenance Mode</div>
                <div class="muted">Hide portal temporarily for maintenance.</div>
              </div>
              <div class="setting-control">
                <div class="toggle"><span>Maintenance</span><span class="pill <%= settings?.portal?.maintenanceMode ? 'warn':'ok' %>"><%= settings?.portal?.maintenanceMode ? 'On':'Off' %></span></div>
              </div>
            </div>
          </div>

          <div class="setting-card tab-pane" id="tab-integrations">
            <div class="section-title">Integrations</div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">SMTP</div>
                <div class="muted">Outgoing email delivery service.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.integrations?.smtpHost || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">SMS Provider</div>
                <div class="muted">SMS delivery gateway/provider.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.integrations?.smsProvider || '' %>" readonly></div>
            </div>
            <div class="setting-row">
              <div class="setting-info">
                <div class="strong">Cloud Storage</div>
                <div class="muted">Media/file storage configuration.</div>
              </div>
              <div class="setting-control"><input class="input" value="<%= settings?.integrations?.cloudStorage || '' %>" readonly></div>
            </div>
          </div>

        </section>

        <aside class="setting-card">
          <div class="section-title">Quick Actions</div>
          <div class="mini-list" style="margin-top:10px;">
            <div class="mini-item">
              <div>
                <div class="strong">Edit General</div>
                <div class="muted">School profile and contacts</div>
              </div>
              <button class="btn-xs" id="quickGeneral" type="button"><i class="fa-solid fa-school"></i></button>
            </div>
            <div class="mini-item">
              <div>
                <div class="strong">Edit Branding</div>
                <div class="muted">Colors, logo and look</div>
              </div>
              <button class="btn-xs" id="quickBranding" type="button"><i class="fa-solid fa-palette"></i></button>
            </div>
            <div class="mini-item">
              <div>
                <div class="strong">Edit Communication</div>
                <div class="muted">Default sender and channels</div>
              </div>
              <button class="btn-xs" id="quickCommunication" type="button"><i class="fa-solid fa-envelope"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Edit Settings</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="settingsForm" method="POST" action="/admin/settings">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>School Name</label>
              <input class="input" id="sSchoolName" name="schoolName" />
            </div>
            <div class="field">
              <label>School Email</label>
              <input class="input" id="sSchoolEmail" name="schoolEmail" type="email" />
            </div>
            <div class="field">
              <label>Phone</label>
              <input class="input" id="sSchoolPhone" name="schoolPhone" />
            </div>
            <div class="field">
              <label>Primary Color</label>
              <input class="input" id="sPrimaryColor" name="primaryColor" />
            </div>
            <div class="field">
              <label>Secondary Color</label>
              <input class="input" id="sSecondaryColor" name="secondaryColor" />
            </div>
            <div class="field">
              <label>Logo URL</label>
              <input class="input" id="sLogoUrl" name="logoUrl" />
            </div>
            <div class="field">
              <label>Default Sender Name</label>
              <input class="input" id="sDefaultSenderName" name="defaultSenderName" />
            </div>
            <div class="field">
              <label>Reply-To Email</label>
              <input class="input" id="sReplyToEmail" name="replyToEmail" type="email" />
            </div>
            <div class="field">
              <label>SMTP Host</label>
              <input class="input" id="sSmtpHost" name="smtpHost" />
            </div>
            <div class="field">
              <label>SMS Provider</label>
              <input class="input" id="sSmsProvider" name="smsProvider" />
            </div>
            <div class="field">
              <label>Cloud Storage</label>
              <input class="input" id="sCloudStorage" name="cloudStorage" />
            </div>
            <div class="field">
              <label>School Address</label>
              <textarea class="textarea" id="sSchoolAddress" name="schoolAddress"></textarea>
            </div>
          </div>

          <div class="divider"></div>

          <div class="grid-3">
            <div class="toggle">
              <div>
                <div class="strong">Portal Channel</div>
                <div class="muted">Enable portal delivery</div>
              </div>
              <div class="switch" id="chPortal"></div>
            </div>
            <div class="toggle">
              <div>
                <div class="strong">Email Channel</div>
                <div class="muted">Enable email delivery</div>
              </div>
              <div class="switch" id="chEmail"></div>
            </div>
            <div class="toggle">
              <div>
                <div class="strong">SMS Channel</div>
                <div class="muted">Enable SMS delivery</div>
              </div>
              <div class="switch" id="chSms"></div>
            </div>
            <div class="toggle">
              <div>
                <div class="strong">Push Channel</div>
                <div class="muted">Enable push delivery</div>
              </div>
              <div class="switch" id="chPush"></div>
            </div>
            <div class="toggle">
              <div>
                <div class="strong">Public Admissions</div>
                <div class="muted">Allow public admissions form</div>
              </div>
              <div class="switch" id="pAdmissions"></div>
            </div>
            <div class="toggle">
              <div>
                <div class="strong">Require Login</div>
                <div class="muted">Require student login</div>
              </div>
              <div class="switch" id="pLogin"></div>
            </div>
            <div class="toggle">
              <div>
                <div class="strong">Maintenance Mode</div>
                <div class="muted">Temporarily hide portal</div>
              </div>
              <div class="switch" id="pMaintenance"></div>
            </div>
          </div>

          <input type="hidden" name="channelPortal" id="channelPortal" value="false">
          <input type="hidden" name="channelEmail" id="channelEmail" value="false">
          <input type="hidden" name="channelSms" id="channelSms" value="false">
          <input type="hidden" name="channelPush" id="channelPush" value="false">
          <input type="hidden" name="portalAllowPublicAdmissions" id="portalAllowPublicAdmissions" value="false">
          <input type="hidden" name="portalRequireStudentLogin" id="portalRequireStudentLogin" value="false">
          <input type="hidden" name="portalMaintenanceMode" id="portalMaintenanceMode" value="false">
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <textarea id="settingsData" class="json-data" aria-hidden="true"><%- JSON.stringify(settings || {}) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/settings.js"></script>
</body>
</html>