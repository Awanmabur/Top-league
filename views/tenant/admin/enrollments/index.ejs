<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Enrollments</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <% if (csrfToken) { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none;
    }
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .enrolled{background:#ecfdf3;color:#15803d}
    .deferred{background:#fef9c3;color:#92400e}
    .withdrawn{background:#fee2e2;color:#b91c1c}
    .completed{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{width:100%;min-width:1240px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{
      font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;
      background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap;
    }
    tr:hover td{background:rgba(10,111,191,.04)}

    .col-check{width:48px}
    .col-student{width:300px}
    .col-academic{width:220px}
    .col-program{width:240px}
    .col-status{width:140px}
    .col-created{width:180px}
    .col-actions{width:220px}

    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{
      padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;
    }
    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{
      display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;
      padding:30px 18px;z-index:9999;overflow-y:auto;
    }
    .modal-backdrop.show{display:flex}
    .modal{
      width:min(980px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;
    }
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}

    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{
      display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;
      border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800;
    }
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}

    @media (max-width: 1100px){ .grid-2{grid-template-columns:1fr} }
    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }
    @media (max-width: 680px){ .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))} .input{min-width:160px} }
    @media (max-width: 520px){
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
      table{min-width:1240px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;inset:0;background:#fff;padding:20px;
      }
    }
  </style>
</head>
<body>
  <%
    const safe = (v,d="") => (v===null||v===undefined) ? d : String(v);
    const q = query || {};
    const enrollArr = Array.isArray(enrollments) ? enrollments : [];
    const programsArr = Array.isArray(programs) ? programs : [];
    const classesArr = Array.isArray(classes) ? classes : [];
    const studentsArr = Array.isArray(students) ? students : [];

    const fmtDT = (d)=>{
      if(!d) return "—";
      const x = new Date(d);
      if(isNaN(x.getTime())) return "—";
      return x.toLocaleString();
    };

    const pageMeta = {
      csrf: csrfToken || "",
      routes: {
        create: "/admin/enrollments",
        update: "/admin/enrollments/{id}",
        delete: "/admin/enrollments/{id}/delete",
        bulk: "/admin/enrollments/bulk",
        export: "/admin/enrollments/export.csv"
      },
      enrollments: enrollArr.map(e => ({
        _id: String(e._id || ""),
        student: e.student ? String(e.student._id || "") : "",
        academicYear: e.academicYear || "",
        semester: e.semester || 1,
        intake: e.intake || "",
        program: e.program ? String(e.program._id || "") : "",
        classGroup: e.classGroup ? String(e.classGroup._id || "") : "",
        status: e.status || "enrolled",
        note: e.note || ""
      }))
    };

    function buildPageUrl(targetPage) {
      const params = new URLSearchParams();
      if (q.q) params.set("q", q.q);
      if (q.academicYear) params.set("academicYear", q.academicYear);
      if (q.semester) params.set("semester", q.semester);
      if (q.status) params.set("status", q.status);
      if (q.program) params.set("program", q.program);
      if (q.classGroup) params.set("classGroup", q.classGroup);
      params.set("page", String(targetPage));
      return "/admin/enrollments?" + params.toString();
    }

    const currentPage = Number(q.page || 1);
    const totalPages = Number(q.totalPages || 1);
    const startPage = Math.max(1, currentPage - 2);
    const endPage = Math.min(totalPages, currentPage + 2);

    const pill = (s)=>{
      const v = String(s || "enrolled");
      return `<span class="pill ${v}"><i class="fa-solid ${
        v === "enrolled" ? "fa-circle-check" :
        v === "deferred" ? "fa-clock" :
        v === "withdrawn" ? "fa-ban" :
        "fa-graduation-cap"
      }"></i> ${v}</span>`;
    };
  %>

  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Enrollments</div>
          <div class="subtitle">Create, edit, export, print and bulk update student enrollments.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/students"><i class="fa-solid fa-users"></i> Students</a>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" type="button" data-open="mForm" data-mode="create">
            <i class="fa-solid fa-plus"></i> Enroll Student
          </button>
          <button class="btn light" type="button" data-open="mBulk"><i class="fa-solid fa-layer-group"></i> Bulk Status</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Enrolled</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.enrolled || 0 %></div>
          <div class="muted">Active enrollments</div>
        </div>
        <div class="card">
          <div class="section-title">Deferred</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.deferred || 0 %></div>
          <div class="muted">Deferred studies</div>
        </div>
        <div class="card">
          <div class="section-title">Completed</div>
          <div class="kpi-value" style="color:#3730a3"><%= kpis?.completed || 0 %></div>
          <div class="muted">Finished enrollments</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/enrollments">
          <div class="left">
            <input class="input" name="q" value="<%= safe(q.q) %>" placeholder="Search regNo, name, email, phone" />
            <input class="input" name="academicYear" value="<%= safe(q.academicYear) %>" placeholder="Academic Year e.g. 2025/2026" />
            <input class="input" name="semester" value="<%= safe(q.semester) %>" placeholder="Semester" />

            <select class="select" name="status">
              <option value="">Any Status</option>
              <% ["enrolled","deferred","withdrawn","completed"].forEach(function(s){ %>
                <option value="<%= s %>" <%= String(q.status||"")===s ? "selected" : "" %>><%= s %></option>
              <% }) %>
            </select>

            <select class="select" name="program">
              <option value="">All Programs</option>
              <% programsArr.forEach(function(p){ %>
                <option value="<%= p._id %>" <%= String(q.program||"")===String(p._id) ? "selected" : "" %>>
                  <%= (p.code ? (p.code + " — ") : "") + (p.name || p.title || "Program") %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="classGroup">
              <option value="">All Classes</option>
              <% classesArr.forEach(function(c){ %>
                <option value="<%= c._id %>" <%= String(q.classGroup||"")===String(c._id) ? "selected" : "" %>>
                  <%= (c.code ? (c.code + " — ") : "") + (c.name || c.title || "Class") %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <a class="btn light" href="/admin/enrollments"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Enrollments Table</div>
              <div class="section-sub">Showing <%= enrollArr.length %> of <%= q.total || 0 %> records.</div>
            </div>
            <div class="muted">Selected: <strong id="selCount">0</strong></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll"></th>
                    <th class="col-student">Student</th>
                    <th class="col-academic">Academic</th>
                    <th class="col-program">Program / Class</th>
                    <th class="col-status">Status</th>
                    <th class="col-created">Created</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!enrollArr.length) { %>
                    <tr>
                      <td colspan="7" style="padding:18px;">
                        <div class="muted">No enrollments found.</div>
                      </td>
                    </tr>
                  <% } %>

                  <% enrollArr.forEach(function(e){ %>
                    <tr>
                      <td><input type="checkbox" class="rowChk" value="<%= e._id %>"></td>
                      <td>
                        <div class="strong cell-ellipsis"><%= safe(e.student && (e.student.fullName || e.student.regNo), "—") %></div>
                        <div class="muted cell-ellipsis">
                          <%= safe(e.student && e.student.regNo) %><%= e.student && e.student.email ? (" • " + e.student.email) : "" %>
                        </div>
                      </td>
                      <td>
                        <div class="strong cell-ellipsis"><%= safe(e.academicYear, "—") %></div>
                        <div class="muted cell-ellipsis">Sem <%= safe(e.semester, 1) %><%= e.intake ? (" • " + e.intake) : "" %></div>
                      </td>
                      <td>
                        <div class="cell-ellipsis"><%= safe(e.program && (e.program.code || e.program.name || e.program.title), "—") %></div>
                        <div class="muted cell-ellipsis"><%= safe(e.classGroup && (e.classGroup.code || e.classGroup.name || e.classGroup.title), "—") %></div>
                      </td>
                      <td><%- pill(e.status) %></td>
                      <td class="muted"><%= fmtDT(e.createdAt || e.enrolledAt) %></td>
                      <td>
                        <div class="actions">
                          <button class="btn-xs" type="button" data-open="mForm" data-mode="edit" data-id="<%= e._id %>"><i class="fa-solid fa-pen"></i></button>
                          <button class="btn-xs" type="button" data-open="mDelete" data-id="<%= e._id %>" data-name="<%= safe(e.student && (e.student.fullName || e.student.regNo), 'Enrollment') %>"><i class="fa-solid fa-trash"></i></button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong><%= q.perPage || 10 %></strong>
            </div>

            <div class="pagination-links">
              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Notes</div>
          <div class="section-sub">Fast reminders for admins.</div>

          <div style="display:grid;gap:10px;margin-top:10px;">
            <div style="padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff;">
              <div class="strong">Duplicate protection</div>
              <div class="muted">The same student cannot be enrolled twice in the same academic year and semester.</div>
            </div>

            <div style="padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff;">
              <div class="strong">Bulk status</div>
              <div class="muted">Use the checkboxes, then click Bulk Status to update many rows at once.</div>
            </div>

            <div style="padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff;">
              <div class="strong">Student sync</div>
              <div class="muted">Creating or updating an enrollment also updates the student academic fields.</div>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mForm">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="mFormTitle"><i class="fa-solid fa-plus"></i> Enroll Student</div>
        <button class="btn-xs" type="button" data-close="mForm"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="formMain" method="POST" action="/admin/enrollments">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />

        <div class="modal-body">
          <div class="form-grid">
            <div class="field" style="grid-column:1/-1">
              <label>Student *</label>
              <select class="select" name="student" id="fStudent" required>
                <option value="">— select student —</option>
                <% studentsArr.forEach(function(s){ %>
                  <option value="<%= s._id %>"><%= (s.regNo ? s.regNo + " — " : "") + (s.fullName || "Student") + (s.email ? " (" + s.email + ")" : "") %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Academic Year *</label>
              <input class="input" name="academicYear" id="fAY" placeholder="2025/2026" required />
            </div>

            <div class="field">
              <label>Semester</label>
              <input class="input" name="semester" id="fSem" value="1" />
            </div>

            <div class="field">
              <label>Program *</label>
              <select class="select" name="program" id="fProg" required>
                <option value="">— select —</option>
                <% programsArr.forEach(function(p){ %>
                  <option value="<%= p._id %>"><%= (p.code ? (p.code + " — ") : "") + (p.name || p.title || "Program") %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Class *</label>
              <select class="select" name="classGroup" id="fClass" required>
                <option value="">— select —</option>
                <% classesArr.forEach(function(c){ %>
                  <option value="<%= c._id %>"><%= (c.code ? (c.code + " — ") : "") + (c.name || c.title || "Class") %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" name="status" id="fStatus">
                <option value="enrolled">enrolled</option>
                <option value="deferred">deferred</option>
                <option value="withdrawn">withdrawn</option>
                <option value="completed">completed</option>
              </select>
            </div>

            <div class="field">
              <label>Intake</label>
              <input class="input" name="intake" id="fIntake" placeholder="Jan / May / Aug" />
            </div>

            <div class="field" style="grid-column:1/-1">
              <label>Note</label>
              <textarea class="textarea" name="note" id="fNote" placeholder="Optional note"></textarea>
            </div>
          </div>

          <input type="hidden" id="rowId" value="" />
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close="mForm">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mBulk">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title"><i class="fa-solid fa-layer-group"></i> Bulk Status Update</div>
        <button class="btn-xs" type="button" data-close="mBulk"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="bulkForm" method="POST" action="/admin/enrollments/bulk">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
        <input type="hidden" name="action" value="set_status" />
        <input type="hidden" name="ids" id="bulkIds" value="" />

        <div class="modal-body">
          <div class="muted">Selected: <strong id="bulkCount">0</strong></div>
          <div class="divider"></div>
          <div class="field">
            <label>New Status *</label>
            <select class="select" name="status" required>
              <option value="">— choose —</option>
              <option value="enrolled">enrolled</option>
              <option value="deferred">deferred</option>
              <option value="withdrawn">withdrawn</option>
              <option value="completed">completed</option>
            </select>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close="mBulk">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Apply</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mDelete">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title"><i class="fa-solid fa-triangle-exclamation"></i> Delete Enrollment</div>
        <button class="btn-xs" type="button" data-close="mDelete"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="muted">This will delete the enrollment using soft delete. Continue?</div>
        <div style="margin-top:10px" class="muted">Target: <strong id="delName">—</strong></div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close="mDelete">Cancel</button>
        <form id="delForm" method="POST" action="#">
          <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
