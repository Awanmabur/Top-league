<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Results</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:180px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(320px,.4fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1680px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-student{width:280px}
    .col-reg{width:150px}
    .col-exam{width:220px}
    .col-class{width:180px}
    .col-course{width:220px}
    .col-program{width:220px}
    .col-score{width:130px}
    .col-grade{width:100px}
    .col-status{width:140px}
    .col-actions{width:240px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .student-main{min-width:0}
    .student-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .student-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1020px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(840px,100%)}
    .modal.lg{width:min(1020px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    .dropzone{
      border:2px dashed rgba(13,64,96,.20);
      padding:18px;
      border-radius:16px;
      background:#fbfdff;
      text-align:center;
      cursor:pointer;
    }

    .dropzone.drag{
      border-color:#0a6fbf;
      background:rgba(10,111,191,.04);
    }

    .dropzone input{display:none}

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1680px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Results</div>
          <div class="subtitle">Create, edit, import, export, print and manage examination results.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <a class="btn light" href="/admin/results/export.csv?<%= exportQueryString %>"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</a>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Enter Result</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Published</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.published || 0 %></div>
          <div class="muted">Visible to students</div>
        </div>
        <div class="card">
          <div class="section-title">Draft</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div>
          <div class="muted">Not yet released</div>
        </div>
        <div class="card">
          <div class="section-title">Average Score</div>
          <div class="kpi-value" style="color:#3730a3"><%= kpis?.avgScore || 0 %></div>
          <div class="muted">Current page</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/results">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search student, regNo, exam..." />

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="published" <%= query?.status === 'published' ? 'selected' : '' %>>Published</option>
            </select>

            <select class="select" name="exam">
              <option value="">All Exams</option>
              <% (exams || []).forEach(function(x){ %>
                <option value="<%= x._id %>" <%= String(query?.exam || '') === String(x._id) ? 'selected' : '' %>><%= x.title %></option>
              <% }) %>
            </select>

            <select class="select" name="classGroup">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(x){ %>
                <option value="<%= x._id %>" <%= String(query?.classGroup || '') === String(x._id) ? 'selected' : '' %>><%= x.name || x.title || x.code %></option>
              <% }) %>
            </select>

            <select class="select" name="course">
              <option value="">All Courses</option>
              <% (courses || []).forEach(function(x){ %>
                <option value="<%= x._id %>" <%= String(query?.course || '') === String(x._id) ? 'selected' : '' %>><%= (x.code ? (x.code + ' — ') : '') + (x.title || '') %></option>
              <% }) %>
            </select>

            <select class="select" name="program">
              <option value="">All Programs</option>
              <% (programs || []).forEach(function(x){ %>
                <option value="<%= x._id %>" <%= String(query?.program || '') === String(x._id) ? 'selected' : '' %>><%= (x.code ? (x.code + ' — ') : '') + (x.name || '') %></option>
              <% }) %>
            </select>

            <input class="input" style="min-width:140px" name="academicYear" value="<%= query?.academicYear || '' %>" placeholder="Academic Year" />
            <input class="input" style="min-width:90px" name="semester" value="<%= query?.semester || '' %>" placeholder="Sem" />
            <input class="input" style="min-width:110px" name="minScore" value="<%= query?.minScore || '' %>" placeholder="Min score" />
            <input class="input" style="min-width:110px" name="maxScore" value="<%= query?.maxScore || '' %>" placeholder="Max score" />
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/results"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">result(s)</span>
            <select class="select" id="bulkAction" style="min-width:180px">
              <option value="">Choose action</option>
              <option value="publish">Publish</option>
              <option value="draft">Set Draft</option>
              <option value="delete">Delete</option>
            </select>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkApply" type="button"><i class="fa-solid fa-check"></i> Apply</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Results Table</div>
              <div class="section-sub">Showing <%= results.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-student">Student</th>
                    <th class="col-reg">Reg No</th>
                    <th class="col-exam">Exam</th>
                    <th class="col-class">Class</th>
                    <th class="col-course">Course</th>
                    <th class="col-program">Program</th>
                    <th class="col-score">Score</th>
                    <th class="col-grade">Grade</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyResults"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong><%= query?.perPage || 10 %></strong>
            </div>

            <div class="pagination-links">
              <% const currentPage = Number(query?.page || 1); const totalPages = Number(query?.totalPages || 1); %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = pagination.startPage; p <= pagination.endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Preview & Quick Actions</div>
          <div class="section-sub">Select a row to inspect details fast.</div>

          <div style="margin-top:14px;display:grid;gap:12px">
            <div>
              <div class="muted">Student</div>
              <div class="strong" id="pvStudent">—</div>
              <div class="muted" id="pvRegNo">—</div>
            </div>

            <div>
              <div class="muted">Exam</div>
              <div class="strong" id="pvExam">—</div>
              <div class="muted" id="pvMeta">—</div>
            </div>

            <div>
              <div class="muted">Class / Course / Program</div>
              <div class="strong" id="pvClass">—</div>
              <div class="muted" id="pvCourse">—</div>
              <div class="muted" id="pvProgram">—</div>
            </div>

            <div>
              <div class="muted">Performance</div>
              <div class="strong" id="pvScore">—</div>
              <div class="muted" id="pvGrade">—</div>
              <div class="muted" id="pvRemark">—</div>
            </div>

            <div>
              <div class="muted">Status / Audit</div>
              <div id="pvStatus">—</div>
              <div class="muted" id="pvPub">—</div>
              <div class="muted" id="pvUpdated">—</div>
            </div>
          </div>

          <div style="display:flex;gap:8px;margin-top:14px;flex-wrap:wrap;">
            <button class="btn primary" type="button" id="previewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
            <button class="btn light" type="button" id="previewStatusBtn"><i class="fa-solid fa-arrows-rotate"></i> Status</button>
            <button class="btn light" type="button" id="previewViewBtn"><i class="fa-solid fa-eye"></i> View</button>
            <button class="btn light" type="button" id="previewDeleteBtn"><i class="fa-solid fa-trash"></i> Delete</button>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Enter Result</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="resultForm" method="POST" action="/admin/results">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Exam</label>
              <select class="select" id="mExam" name="exam" required>
                <option value="">— Select exam —</option>
                <% (exams || []).forEach(function(x){ %>
                  <option value="<%= x._id %>"><%= x.title %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Student</label>
              <select class="select" id="mStudent" name="student" required>
                <option value="">— Select student —</option>
              </select>
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
              </select>
            </div>

            <div class="field">
              <label>Score</label>
              <input class="input" id="mScore" name="score" type="number" min="0" step="0.01" />
            </div>

            <div class="field">
              <label>Total Marks</label>
              <input class="input" id="mTotal" name="totalMarks" type="number" disabled />
            </div>

            <div class="field">
              <label>Percentage</label>
              <input class="input" id="mPercentage" disabled />
            </div>

            <div class="field">
              <label>Grade</label>
              <input class="input" id="mGrade" name="grade" placeholder="Auto-generated if blank" />
            </div>

            <div class="field">
              <label>Remark</label>
              <input class="input" id="mRemark" name="remark" placeholder="Auto-generated if blank" />
            </div>

            <div class="field">
              <label>Academic Context</label>
              <div class="view-input multiline" id="mExamMeta">Select an exam to load class, course, program, year and semester.</div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Result</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Result Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Student</label><div class="view-input" id="vStudent">—</div></div>
          <div class="field"><label>Reg No</label><div class="view-input" id="vRegNo">—</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div>
          <div class="field"><label>Exam</label><div class="view-input" id="vExam">—</div></div>
          <div class="field"><label>Class</label><div class="view-input" id="vClass">—</div></div>
          <div class="field"><label>Course</label><div class="view-input" id="vCourse">—</div></div>
          <div class="field"><label>Program</label><div class="view-input" id="vProgram">—</div></div>
          <div class="field"><label>Academic Year</label><div class="view-input" id="vYear">—</div></div>
          <div class="field"><label>Semester</label><div class="view-input" id="vSemester">—</div></div>
          <div class="field"><label>Score</label><div class="view-input" id="vScore">—</div></div>
          <div class="field"><label>Percentage</label><div class="view-input" id="vPercentage">—</div></div>
          <div class="field"><label>Grade</label><div class="view-input" id="vGrade">—</div></div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Remark</label>
          <div class="view-input multiline" id="vRemark">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Audit</label>
          <div class="view-input multiline" id="vAudit">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mStatus">
    <div class="modal sm" style="max-width:520px;">
      <div class="modal-header">
        <div class="modal-title">Change Result Status</div>
        <button class="btn-xs" type="button" data-close-modal="mStatus"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="note">Draft results remain hidden from student view. Published results are visible to students.</div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" id="statusDraftBtn">Set Draft</button>
        <button class="btn primary" type="button" id="statusPublishBtn">Publish</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm" style="max-width:700px;">
      <div class="modal-header">
        <div class="modal-title">Import Results CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="importForm" method="POST" action="/admin/results/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="note" style="margin-bottom:12px;">
            CSV columns: <strong>examId, studentId, score, grade, remark, status</strong>.<br>
            Grade and remark are optional. Status can be <strong>draft</strong> or <strong>published</strong>.
          </div>

          <label class="dropzone" id="importDropzone">
            <input type="file" id="importFile" name="file" accept=".csv,text/csv" required>
            <div><i class="fa-solid fa-file-csv" style="font-size:24px;color:#0a6fbf"></i></div>
            <div class="strong" style="margin-top:8px;">Drop CSV here or click to choose</div>
            <div class="muted" id="importFileName" style="margin-top:4px;">No file selected</div>
          </label>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="statusForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="statusVal" value="">
  </form>

  <form id="deleteForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/results/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionVal">
    <input type="hidden" name="ids" id="bulkIdsVal">
  </form>

  <textarea id="resultsData" class="json-data" aria-hidden="true"><%- JSON.stringify(resultsData || []) %></textarea>

  <script src="/js/navbar.js" defer></script>
  <script src="/js/results.js" defer></script>
</body>
</html>