<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Analytics</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous"
        referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .input:focus,.select:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.4fr) minmax(320px,.6fr);gap:12px}

    .pill{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:4px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:980px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    .right{text-align:right}
    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .section-sub{font-size:12px;color:#6b7280;margin-top:2px}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}

    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
    .tabbtn{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      font-weight:900;
      cursor:pointer;
    }
    .tabbtn.active{
      background:rgba(10,111,191,.10);
      border-color:rgba(10,111,191,.28);
      color:#0a6fbf;
    }

    .pane{display:none;margin-top:12px}
    .pane.active{display:block}

    .chart-card{
      min-height:360px;
      display:flex;
      flex-direction:column;
    }

    .chart-wrap{
      position:relative;
      flex:1 1 auto;
      min-height:280px;
      margin-top:12px;
    }

    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:center;
      padding:10px 12px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      background:#fff;
    }
    .mini-item .left{display:grid;gap:2px}

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      text-decoration:none;
      color:#0f172a;
      display:inline-flex;
      align-items:center;
      gap:6px;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .legend-list{display:grid;gap:10px;margin-top:12px}
    .legend-item{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:10px 12px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      background:#fff;
    }

    .legend-item .meta{
      display:grid;
      gap:2px;
      min-width:0;
      flex:1 1 auto;
    }

    .progress{
      width:100%;
      height:8px;
      border-radius:999px;
      background:rgba(13,64,96,.08);
      overflow:hidden;
      margin-top:8px;
    }

    .progress > span{
      display:block;
      height:100%;
      border-radius:999px;
      background:#0a6fbf;
    }

    .json-data{display:none !important}

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
      .grid-3{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:1fr}
      .input{min-width:160px}
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
      .no-print{display:none !important}
      .pane{display:block !important}
    }
  </style>
</head>
<body>
  <%
    const safe = (v)=> (v === null || v === undefined ? "" : String(v));
    const num = (v)=> {
      const n = Number(v || 0);
      return Number.isFinite(n) ? n : 0;
    };
    const money = (v)=> {
      try { return num(v).toLocaleString(); } catch (_) { return String(num(v)); }
    };
    const pct = (v)=> {
      const n = num(v);
      return (n > 0 ? "+" : "") + n.toFixed(1) + "%";
    };

    const q = query || {};
    const k = kpis || {};
    const t = trends || {};
    const years = Array.isArray(academicYears) ? academicYears : [];
    const rows = Array.isArray(programRows) ? programRows : [];
    const alertsList = Array.isArray(alerts) ? alerts : [];
    const feeParts = Array.isArray(feeBreakdown) ? feeBreakdown : [];
  %>

  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main" id="printArea">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap no-print">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Analytics</div>
          <div class="subtitle">Track growth, finance, admissions performance and operational risk.</div>
        </div>

        <div class="top-actions no-print">
          <button class="btn light" id="btnExport" type="button">
            <i class="fa-solid fa-file-arrow-down"></i> Export CSV
          </button>
          <button class="btn light" id="btnPrint" type="button">
            <i class="fa-solid fa-print"></i> Print
          </button>
          <button class="btn primary" id="btnShare" type="button">
            <i class="fa-solid fa-link"></i> Share
          </button>
        </div>
      </div>

      <div class="grid-4" style="margin-top:12px;">
        <div class="card">
          <div class="section-title">Active Students</div>
          <div class="kpi-value"><%= money(k.activeStudents) %></div>
          <div class="muted">
            <span class="strong" style="color:<%= num(k.activeStudentsDelta) >= 0 ? '#15803d' : '#b91c1c' %>;">
              <%= pct(k.activeStudentsDelta) %>
            </span>
            vs previous period
          </div>
        </div>

        <div class="card">
          <div class="section-title">New Applications</div>
          <div class="kpi-value"><%= money(k.newApplications) %></div>
          <div class="muted">
            <span class="strong" style="color:<%= num(k.newApplicationsDelta) >= 0 ? '#15803d' : '#b91c1c' %>;">
              <%= pct(k.newApplicationsDelta) %>
            </span>
            vs previous period
          </div>
        </div>

        <div class="card">
          <div class="section-title">Revenue Collected</div>
          <div class="kpi-value">UGX <%= money(k.revenueCollected) %></div>
          <div class="muted">
            <span class="strong" style="color:<%= num(k.revenueDelta) >= 0 ? '#15803d' : '#b91c1c' %>;">
              <%= pct(k.revenueDelta) %>
            </span>
            vs previous period
          </div>
        </div>

        <div class="card">
          <div class="section-title">At Risk</div>
          <div class="kpi-value"><%= money(k.atRisk) %></div>
          <div class="muted">Overdue unpaid / partial invoices</div>
        </div>
      </div>

      <section class="card no-print" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/analytics">
          <div class="left">
            <input
              class="input"
              name="search"
              id="search"
              value="<%= safe(q.search) %>"
              placeholder="Search program or metric..."
              maxlength="80"
            />

            <select class="select" name="range">
              <option value="30" <%= String(q.range) === '30' ? 'selected' : '' %>>Last 30 days</option>
              <option value="90" <%= String(q.range) === '90' ? 'selected' : '' %>>Last 90 days</option>
              <option value="180" <%= String(q.range) === '180' ? 'selected' : '' %>>Last 6 months</option>
              <option value="365" <%= String(q.range) === '365' ? 'selected' : '' %>>Last 12 months</option>
            </select>

            <select class="select" name="campus">
              <option value="all" <%= String(q.campus) === 'all' ? 'selected' : '' %>>All Campuses</option>
              <option value="main" <%= String(q.campus) === 'main' ? 'selected' : '' %>>Main Campus</option>
              <option value="city" <%= String(q.campus) === 'city' ? 'selected' : '' %>>City Campus</option>
            </select>

            <select class="select" name="year">
              <% years.forEach(function(y){ %>
                <option value="<%= y %>" <%= String(q.year) === String(y) ? 'selected' : '' %>>
                  Academic Year <%= y %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <a class="btn light" id="btnReset" href="/admin/analytics?range=90&campus=all&year=<%= encodeURIComponent(safe(q.year || years[0] || '2025')) %>">
              <i class="fa-solid fa-rotate-left"></i> Reset
            </a>
            <button class="btn primary" type="submit">
              <i class="fa-solid fa-filter"></i> Apply
            </button>
          </div>
        </form>
      </section>

      <div class="tabs no-print">
        <button class="tabbtn active" data-pane="paneOverview" type="button">Overview</button>
        <button class="tabbtn" data-pane="panePrograms" type="button">Programs</button>
        <button class="tabbtn" data-pane="paneFinance" type="button">Finance</button>
        <button class="tabbtn" data-pane="paneRisk" type="button">Risk</button>
      </div>

      <section class="pane active" id="paneOverview">
        <div class="grid-2">
          <section class="card chart-card">
            <div class="section-title">Applications Trend</div>
            <div class="section-sub">Weekly admissions movement for the selected range.</div>
            <div class="chart-wrap">
              <canvas id="chartApplications"></canvas>
            </div>
          </section>

          <section class="card chart-card">
            <div class="section-title">Payments Trend</div>
            <div class="section-sub">Weekly collection totals for the selected range.</div>
            <div class="chart-wrap">
              <canvas id="chartPayments"></canvas>
            </div>
          </section>
        </div>

        <div class="grid-2" style="margin-top:12px;">
          <section class="card chart-card">
            <div class="section-title">Fee Collection Breakdown</div>
            <div class="section-sub">Collected amounts by fee category.</div>
            <div class="chart-wrap">
              <canvas id="chartFees"></canvas>
            </div>
          </section>

          <aside class="card">
            <div class="section-title">Quick Insights</div>
            <div class="section-sub">Fast operational highlights.</div>

            <div class="mini-list">
              <div class="mini-item">
                <div class="left">
                  <div class="strong">Admissions</div>
                  <div class="muted"><%= money(k.newApplications) %> new applications in selected range.</div>
                </div>
                <span class="pill info"><i class="fa-solid fa-user-plus"></i> Intake</span>
              </div>

              <div class="mini-item">
                <div class="left">
                  <div class="strong">Collections</div>
                  <div class="muted">UGX <%= money(k.revenueCollected) %> collected.</div>
                </div>
                <span class="pill ok"><i class="fa-solid fa-coins"></i> Finance</span>
              </div>

              <div class="mini-item">
                <div class="left">
                  <div class="strong">Risk Exposure</div>
                  <div class="muted"><%= money(k.atRisk) %> overdue invoice records.</div>
                </div>
                <span class="pill <%= num(k.atRisk) > 0 ? 'warn' : 'ok' %>">
                  <i class="fa-solid fa-triangle-exclamation"></i>
                  <%= num(k.atRisk) > 0 ? 'Attention' : 'Stable' %>
                </span>
              </div>
            </div>

            <div class="note" style="margin-top:12px;">
              Use this page for quick monitoring, then drill into Admissions, Invoices, Finance and Programs for action.
            </div>
          </aside>
        </div>
      </section>

      <section class="pane" id="panePrograms">
        <div class="grid-2">
          <section class="card">
            <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
              <div>
                <div class="section-title">Program Performance</div>
                <div class="section-sub">Students, outstanding balance, attendance and pass rate.</div>
              </div>
              <div class="muted" id="programResultMeta"><%= rows.length %> row(s)</div>
            </div>

            <div style="margin-top:10px;">
              <div class="table-wrap">
                <table id="programTable">
                  <thead>
                    <tr>
                      <th style="width:34%;">Program</th>
                      <th class="right" style="width:14%;">Students</th>
                      <th class="right" style="width:20%;">Outstanding (UGX)</th>
                      <th class="right" style="width:16%;">Attendance</th>
                      <th class="right" style="width:16%;">Pass Rate</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!rows.length) { %>
                      <tr>
                        <td colspan="5">
                          <div class="muted">No programs found.</div>
                        </td>
                      </tr>
                    <% } %>

                    <% rows.forEach(function(r){ %>
                      <tr data-label="<%= safe((r.label || '').toLowerCase()) %>">
                        <td>
                          <span class="cell-ellipsis" title="<%= safe(r.label) %>">
                            <strong><%= safe(r.label) %></strong>
                          </span>
                        </td>
                        <td class="right"><%= money(r.students) %></td>
                        <td class="right"><%= money(r.outstanding) %></td>
                        <td class="right">
                          <%= r.attendance === null || r.attendance === undefined ? '—' : (Number(r.attendance).toFixed(1) + '%') %>
                        </td>
                        <td class="right">
                          <%= r.passRate === null || r.passRate === undefined ? '—' : (Number(r.passRate).toFixed(1) + '%') %>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <section class="card chart-card">
            <div class="section-title">Top Programs by Student Volume</div>
            <div class="section-sub">Highest-volume programs in current dataset.</div>
            <div class="chart-wrap">
              <canvas id="chartPrograms"></canvas>
            </div>
          </section>
        </div>
      </section>

      <section class="pane" id="paneFinance">
        <div class="grid-2">
          <section class="card">
            <div class="section-title">Finance Summary</div>
            <div class="section-sub">Collection and exposure snapshot.</div>

            <div class="legend-list">
              <div class="legend-item">
                <div class="meta">
                  <div class="strong">Revenue Collected</div>
                  <div class="muted">Payments captured in selected range</div>
                </div>
                <div class="strong">UGX <%= money(k.revenueCollected) %></div>
              </div>

              <div class="legend-item">
                <div class="meta">
                  <div class="strong">At Risk</div>
                  <div class="muted">Overdue unpaid / partial invoices</div>
                </div>
                <div class="strong"><%= money(k.atRisk) %></div>
              </div>

              <% feeParts.forEach(function(item){ %>
                <div class="legend-item">
                  <div class="meta">
                    <div class="strong"><%= safe(item.label) %></div>
                    <div class="muted">UGX <%= money(item.amount) %></div>
                    <div class="progress"><span style="width:<%= Math.max(0, Math.min(Number(item.pct || 0), 100)) %>%"></span></div>
                  </div>
                  <div class="strong"><%= Number(item.pct || 0) %>%</div>
                </div>
              <% }) %>

              <% if (!feeParts.length) { %>
                <div class="note">No fee breakdown data yet.</div>
              <% } %>
            </div>
          </section>

          <aside class="card">
            <div class="section-title">Quick Actions</div>
            <div class="section-sub">Jump into finance workflows.</div>

            <div class="mini-list">
              <div class="mini-item">
                <div class="left">
                  <div class="strong">Invoices</div>
                  <div class="muted">View and follow up invoice records.</div>
                </div>
                <a class="btn-xs" href="/admin/invoices">
                  <i class="fa-solid fa-file-invoice"></i> Open
                </a>
              </div>

              <div class="mini-item">
                <div class="left">
                  <div class="strong">Create Invoice</div>
                  <div class="muted">Issue a new billing record.</div>
                </div>
                <a class="btn-xs" href="/admin/invoices/new">
                  <i class="fa-solid fa-plus"></i> New
                </a>
              </div>

              <div class="mini-item">
                <div class="left">
                  <div class="strong">Finance Dashboard</div>
                  <div class="muted">Review broader finance activity.</div>
                </div>
                <a class="btn-xs" href="/admin/finance">
                  <i class="fa-solid fa-coins"></i> Open
                </a>
              </div>
            </div>

            <div class="note" style="margin-top:12px;">
              Best practice: follow up overdue invoices daily and monitor large outstanding balances by program.
            </div>
          </aside>
        </div>
      </section>

      <section class="pane" id="paneRisk">
        <div class="grid-3">
          <% if (!alertsList.length) { %>
            <div class="card" style="grid-column:1/-1;">
              <div class="note">
                <strong>All good.</strong> No alerts right now.
              </div>
            </div>
          <% } %>

          <% alertsList.forEach(function(a){ %>
            <div class="card">
              <div style="display:flex;justify-content:space-between;gap:10px;align-items:flex-start;">
                <div>
                  <div class="strong"><%= safe(a.title) %></div>
                  <div class="muted" style="margin-top:4px;"><%= safe(a.meta) %></div>
                </div>
                <span class="pill <%= a.level === 'danger' ? 'bad' : (a.level === 'warn' ? 'warn' : 'info') %>">
                  <i class="fa-solid fa-bell"></i> <%= safe(a.level || 'info') %>
                </span>
              </div>

              <div style="margin-top:12px;">
                <a class="btn-xs" href="<%= safe(a.href || '#') %>">
                  <i class="fa-solid fa-up-right-from-square"></i> Open
                </a>
              </div>
            </div>
          <% }) %>
        </div>
      </section>
    </main>
  </div>

  <script id="analyticsData" type="application/json" class="json-data"><%- JSON.stringify({
    query: q,
    kpis: k,
    trends: t,
    feeBreakdown: feeParts,
    programRows: rows
  }) %></script>

  <script src="/js/navbar.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
  <script src="/vendor/chart.umd.min.js" defer></script>
  <script src="/js/analytics.js" defer></script>
</body>
</html>