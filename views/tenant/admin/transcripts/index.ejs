<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Transcripts</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap
    }
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{
      display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto
    }

    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none
    }
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)
    }

    .view-input{
      min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap
    }
    .view-input.multiline{
      min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55
    }

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(320px,.45fr);gap:12px}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch
    }

    table{
      width:100%;min-width:1200px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed
    }
    th,td{
      padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle
    }
    th{
      font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap
    }
    tr:hover td{background:rgba(10,111,191,.04)}

    .col-check{width:48px}
    .col-student{width:300px}
    .col-type{width:120px}
    .col-range{width:220px}
    .col-issue{width:170px}
    .col-status{width:130px}
    .col-actions{width:280px}

    .cell-ellipsis{
      display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%
    }

    .item-main{min-width:0}
    .item-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .item-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

    .actions{
      display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden
    }
    .btn-xs{
      padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto
    }
    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap
    }
    .bulkbar.show{display:flex}
    .badge-count{
      display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900
    }

    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}

    .modal-backdrop{
      position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto
    }
    .modal-backdrop.show{display:flex}
    .modal{
      width:min(980px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column
    }
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{
      display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff
    }
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{
      display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap
    }

    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}

    .pagination{
      display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap
    }
    .pagination-links{
      display:flex;gap:8px;flex-wrap:wrap;align-items:center
    }
    .page-link{
      display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800
    }
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}

    @media (max-width: 1100px){ .grid-2{grid-template-columns:1fr} }
    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }
    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Transcripts</div>
          <div class="subtitle">Create, preview, issue, print and verify transcripts.</div>
        </div>

        <div class="top-actions">
          <button class="btn primary" type="button" data-action="openCreate"><i class="fa-solid fa-plus"></i> New Transcript</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Draft</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div>
          <div class="muted">Still editable</div>
        </div>
        <div class="card">
          <div class="section-title">Issued</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.issued || 0 %></div>
          <div class="muted">Signed snapshots</div>
        </div>
        <div class="card">
          <div class="section-title">Revoked</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.revoked || 0 %></div>
          <div class="muted">Not valid anymore</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/transcripts">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search student name / reg no..." />

            <select class="select" name="kind">
              <option value="">All Types</option>
              <option value="official" <%= query?.kind === 'official' ? 'selected' : '' %>>Official</option>
              <option value="unofficial" <%= query?.kind === 'unofficial' ? 'selected' : '' %>>Unofficial</option>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="issued" <%= query?.status === 'issued' ? 'selected' : '' %>>Issued</option>
              <option value="revoked" <%= query?.status === 'revoked' ? 'selected' : '' %>>Revoked</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/transcripts"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">transcript(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <select id="bulkAction" class="select">
              <option value="">Bulk actions</option>
              <option value="revoke">Revoke</option>
              <option value="delete">Delete</option>
            </select>
            <button class="btn-xs" type="button" data-action="bulkApply">Apply</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Transcripts Table</div>
              <div class="section-sub">Showing <%= transcripts.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="selectAll" /></th>
                    <th class="col-student">Student</th>
                    <th class="col-type">Type</th>
                    <th class="col-range">Range</th>
                    <th class="col-issue">Issue Number</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% const items = Array.isArray(transcripts) ? transcripts : []; %>
                  <% if (!items.length) { %>
                    <tr>
                      <td colspan="7" style="padding:18px;">
                        <div class="muted">No transcripts found.</div>
                      </td>
                    </tr>
                  <% } %>

                  <% items.forEach(function(t){ 
                    const st = t.status || "draft";
                    const s = t.student || {};
                    const nm = s.fullName || [s.firstName,s.middleName,s.lastName].filter(Boolean).join(" ") || s.name || "Student";
                    const reg = s.regNo || s.studentNo || s.indexNumber || "";
                  %>
                    <tr>
                      <td class="col-check">
                        <input type="checkbox" class="selChk" data-id="<%= t._id %>" />
                      </td>

                      <td class="col-student">
                        <div class="item-main">
                          <div class="item-title"><%= nm %></div>
                          <div class="item-sub"><%= reg ? ("Reg: " + reg) : "Reg: —" %></div>
                        </div>
                      </td>

                      <td class="col-type">
                        <span class="cell-ellipsis"><%= t.kind || "official" %></span>
                      </td>

                      <td class="col-range">
                        <span class="cell-ellipsis">
                          <%= t.academicYearFrom || "Any" %> → <%= t.academicYearTo || "Any" %>, Sem <%= t.semesterFrom ?? 0 %> → <%= t.semesterTo ?? 6 %>
                        </span>
                      </td>

                      <td class="col-issue">
                        <span class="cell-ellipsis"><%= t.issueNumber || "—" %></span>
                      </td>

                      <td class="col-status">
                        <% if (st === "issued") { %>
                          <span class="pill ok"><i class="fa-solid fa-circle-check"></i> Issued</span>
                        <% } else if (st === "revoked") { %>
                          <span class="pill bad"><i class="fa-solid fa-ban"></i> Revoked</span>
                        <% } else { %>
                          <span class="pill warn"><i class="fa-solid fa-pen"></i> Draft</span>
                        <% } %>
                      </td>

                      <td class="col-actions">
                        <div class="actions">
                          <a class="btn-xs" href="/admin/transcripts?tid=<%= t._id %>"><i class="fa-solid fa-eye"></i></a>

                          <button class="btn-xs"
                            type="button"
                            data-action="openEdit"
                            data-id="<%= t._id %>"
                            data-student="<%= (t.student?._id || t.student) %>"
                            data-kind="<%= (t.kind || "official") %>"
                            data-ayfrom="<%= (t.academicYearFrom || "") %>"
                            data-ayto="<%= (t.academicYearTo || "") %>"
                            data-semfrom="<%= (t.semesterFrom ?? 0) %>"
                            data-semto="<%= (t.semesterTo ?? 6) %>"
                            data-incdraft="<%= (t.includeDraftResults ? "1" : "0") %>"
                            data-notes="<%= (t.notes || "") %>"
                            data-status="<%= st %>"
                          ><i class="fa-solid fa-pen"></i></button>

                          <form method="POST" action="/admin/transcripts/<%= t._id %>/clone" style="display:inline">
                            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                            <button class="btn-xs" type="submit"><i class="fa-solid fa-copy"></i></button>
                          </form>

                          <% if (st !== "issued") { %>
                            <button class="btn-xs" type="button" data-action="issue" data-id="<%= t._id %>"><i class="fa-solid fa-certificate"></i></button>
                          <% } %>

                          <% if (st === "issued") { %>
                            <a class="btn-xs" href="/admin/transcripts/<%= t._id %>/print" target="_blank"><i class="fa-solid fa-print"></i></a>
                          <% } %>

                          <button class="btn-xs" type="button" data-action="revoke" data-id="<%= t._id %>"><i class="fa-solid fa-ban"></i></button>
                          <button class="btn-xs" type="button" data-action="delete" data-id="<%= t._id %>"><i class="fa-solid fa-trash"></i></button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>

            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.kind) params.set("kind", query.kind);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/admin/transcripts?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>

          <form id="bulkForm" method="POST" action="/admin/transcripts/bulk" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
            <input type="hidden" name="action" id="bulkActionVal" value="">
            <input type="hidden" name="ids" id="bulkIdsVal" value="">
          </form>

          <form id="issueForm" method="POST" action="#" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          </form>

          <form id="revokeForm" method="POST" action="#" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          </form>

          <form id="deleteForm" method="POST" action="#" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          </form>
        </section>

        <aside class="card" style="min-width:0;">
          <% if (!preview) { %>
            <div class="note">Select a transcript to preview.</div>
          <% } else { %>
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
              <div>
                <div class="section-title">Transcript Preview</div>
                <div class="muted">
                  Type: <strong><%= preview.transcriptMeta.kind || "official" %></strong> •
                  Status: <strong><%= preview.transcriptMeta.status %></strong>
                  <% if (preview.transcriptMeta.issueNumber) { %> • Issue: <strong><%= preview.transcriptMeta.issueNumber %></strong><% } %>
                </div>
              </div>
              <% if (preview.transcriptMeta.status === "issued") { %>
                <a class="btn light" href="/admin/transcripts/<%= preview.transcriptMeta._id %>/print" target="_blank">Print</a>
              <% } %>
            </div>

            <div class="divider"></div>

            <div class="section-title">Student</div>
            <div class="strong" style="margin-top:6px;"><%= preview.student.name %></div>
            <div class="muted">Reg: <strong><%= preview.student.reg || "—" %></strong></div>
            <div class="muted">Program: <strong><%= preview.student.program %></strong></div>

            <div class="divider"></div>

            <div class="section-title">Totals</div>
            <div class="strong" style="margin-top:6px;">CGPA: <%= Number(preview.totals?.cgpa || 0).toFixed(2) %></div>
            <div class="muted">Classification: <strong><%= preview.totals?.classification || "—" %></strong></div>

            <div class="divider"></div>

            <% (preview.semesters || []).forEach(function(s){ %>
              <div class="strong"><%= s.academicYear %> • Semester <%= s.semester %></div>
              <div class="muted">GPA: <strong><%= Number(s.gpa || 0).toFixed(2) %></strong> • Decision: <strong><%= s.decision || "—" %></strong></div>

              <div style="overflow:auto;margin-top:8px">
                <table>
                  <thead>
                    <tr>
                      <th>Course</th><th>CU</th><th>Score</th><th>Grade</th><th>GP</th><th>Pts</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% (s.rows || []).forEach(function(r){ %>
                      <tr>
                        <td><strong><%= r.courseCode %></strong></td>
                        <td><%= r.credits %></td>
                        <td><%= r.score %>/<%= r.total %></td>
                        <td><strong><%= r.grade %></strong></td>
                        <td><%= r.gp %></td>
                        <td><%= Number(r.points || 0).toFixed(2) %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <div class="divider"></div>
            <% }) %>

            <div class="note">
              Issued transcripts are snapshotted and verifiable by QR. Draft previews reflect live results.
            </div>
          <% } %>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="trModal" aria-hidden="true">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="trModalTitle">New Transcript</div>
        <button class="btn-xs" type="button" data-action="closeModal"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="trForm" method="POST" action="/admin/transcripts">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field" style="grid-column:1/-1;">
              <label>Student</label>
              <select class="select" id="mStudent" name="student" required>
                <option value="">— Select Student —</option>
                <% (studentsList || []).forEach(function(s){ 
                  const nm = s.fullName || [s.firstName,s.middleName,s.lastName].filter(Boolean).join(" ") || s.name || "Student";
                  const rg = s.regNo || s.studentNo || s.indexNumber || "";
                %>
                  <option value="<%= s._id %>"><%= nm %> <%= rg ? ("• " + rg) : "" %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Transcript Type</label>
              <select class="select" id="mKind" name="kind">
                <option value="official">Official</option>
                <option value="unofficial">Unofficial</option>
              </select>
            </div>

            <div class="field">
              <label>Include Draft Results</label>
              <label class="view-input" style="justify-content:flex-start;gap:10px;">
                <input type="checkbox" id="mIncludeDraft" name="includeDraftResults" value="1" />
                Include Draft Results
              </label>
            </div>

            <div class="field">
              <label>Academic Year From</label>
              <input class="input" id="mAYFrom" name="academicYearFrom" placeholder="e.g. 2024/2025" />
            </div>

            <div class="field">
              <label>Academic Year To</label>
              <input class="input" id="mAYTo" name="academicYearTo" placeholder="e.g. 2025/2026" />
            </div>

            <div class="field">
              <label>Semester From</label>
              <input class="input" id="mSemFrom" name="semesterFrom" type="number" min="0" max="6" value="0" />
            </div>

            <div class="field">
              <label>Semester To</label>
              <input class="input" id="mSemTo" name="semesterTo" type="number" min="0" max="6" value="6" />
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes</label>
            <textarea class="textarea" id="mNotes" name="notes" placeholder="Internal notes (optional)"></textarea>
          </div>

          <input type="hidden" id="mId" value="" />
          <input type="hidden" id="mStatus" value="" />
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-action="closeModal">Cancel</button>
          <button class="btn primary" type="button" data-action="saveTranscript">Save Transcript</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/navbar.js" defer></script>
  <script src="/js/transcripts.js" defer></script>
</body>
</html>