<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Transcripts</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(320px,.45fr);gap:12px}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1360px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    .col-check{width:48px}.col-student{width:300px}.col-kind{width:120px}.col-range{width:250px}.col-issue{width:170px}.col-status{width:130px}.col-actions{width:320px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .item-main{min-width:0}.item-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.item-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .bulk-generate-panel{display:none;margin-top:12px;padding:12px;border-radius:12px;border:1px solid rgba(13,64,96,.10);background:#fbfdff;gap:8px;align-items:center;flex-wrap:wrap}
    .bulk-generate-panel.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1040px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}
    .term-block{border:1px solid rgba(13,64,96,.10);border-radius:14px;padding:12px;background:#fff;margin-top:10px}
    .term-head{display:flex;justify-content:space-between;gap:8px;flex-wrap:wrap;margin-bottom:8px}
    .subj-table{width:100%;min-width:0}
    .subj-table th,.subj-table td{font-size:12px;padding:8px;border-bottom:1px solid rgba(13,64,96,.08)}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %>
          <% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Transcripts</div>
          <div class="subtitle">Generate, preview, issue, print and verify academy transcripts automatically.</div>
        </div>
        <div class="top-actions">
          <button class="btn light" type="button" data-action="openCreate"><i class="fa-solid fa-plus"></i> Generate Single</button>
          <button class="btn primary" type="button" data-action="toggleBulkGenerate"><i class="fa-solid fa-gears"></i> Bulk Generate</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div><div class="muted">Matching filter</div></div>
        <div class="card"><div class="section-title">Draft</div><div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div><div class="muted">Editable / regeneratable</div></div>
        <div class="card"><div class="section-title">Issued</div><div class="kpi-value" style="color:#15803d"><%= kpis?.issued || 0 %></div><div class="muted">Signed snapshots</div></div>
        <div class="card"><div class="section-title">Revoked</div><div class="kpi-value" style="color:#b91c1c"><%= kpis?.revoked || 0 %></div><div class="muted">No longer valid</div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/transcripts" data-academic-selector>
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search learner name / reg no..." />
            <select class="select" name="classGroup" data-role="class" data-placeholder="All Classes">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= c._id %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>><%= c.name || c.code || 'Class' %></option>
              <% }) %>
            </select>
            <select class="select" name="sectionId" data-role="section" data-placeholder="All Sections" data-selected="<%= query?.sectionId || '' %>">
              <option value="">All Sections</option>
              <% (sections || []).forEach(function(s){ %>
                <option value="<%= s._id || s.id %>" <%= String(query?.sectionId || '') === String(s._id || s.id) ? 'selected' : '' %>><%= s.name || s.code || 'Section' %></option>
              <% }) %>
            </select>
            <select class="select" name="streamId" data-role="stream" data-placeholder="All Streams" data-selected="<%= query?.streamId || '' %>">
              <option value="">All Streams</option>
              <% (streams || []).forEach(function(s){ %>
                <option value="<%= s._id || s.id %>" <%= String(query?.streamId || '') === String(s._id || s.id) ? 'selected' : '' %>><%= s.name || s.code || 'Stream' %></option>
              <% }) %>
            </select>
            <select class="select" name="kind">
              <option value="">All Types</option>
              <option value="official" <%= query?.kind === 'official' ? 'selected' : '' %>>Official</option>
              <option value="unofficial" <%= query?.kind === 'unofficial' ? 'selected' : '' %>>Unofficial</option>
            </select>
            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="issued" <%= query?.status === 'issued' ? 'selected' : '' %>>Issued</option>
              <option value="revoked" <%= query?.status === 'revoked' ? 'selected' : '' %>>Revoked</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/transcripts"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <form id="bulkGeneratePanel" class="bulk-generate-panel" method="POST" action="/admin/transcripts/bulk-generate" data-academic-selector>
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <select class="select" name="classGroup" required data-role="class" data-placeholder="Bulk Generate Class">
            <option value="">Bulk Generate Class</option>
            <% (classes || []).forEach(function(c){ %>
              <option value="<%= c._id %>"><%= c.name || c.code || 'Class' %></option>
            <% }) %>
          </select>
          <select class="select" name="sectionId" data-role="section" data-placeholder="All Sections"><option value="">All Sections</option></select>
          <select class="select" name="streamId" data-role="stream" data-placeholder="All Streams"><option value="">All Streams</option></select>
          <input class="input" name="academicYear" placeholder="Academic Year" style="min-width:140px;" />
          <select class="select" name="termFrom"><option value="1">T1</option><option value="2">T2</option><option value="3">T3</option></select>
          <select class="select" name="termTo"><option value="1">T1</option><option value="2">T2</option><option value="3" selected>T3</option></select>
          <button class="btn primary" type="submit"><i class="fa-solid fa-gears"></i> Generate Bulk</button>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">transcript(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <select id="bulkAction" class="select">
              <option value="">Bulk actions</option>
              <option value="regenerate">Regenerate</option>
              <option value="issue">Issue</option>
              <option value="revoke">Revoke</option>
              <option value="delete">Delete</option>
            </select>
            <button class="btn-xs" type="button" data-action="bulkApply">Apply</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Transcripts Table</div>
              <div class="section-sub">Showing <%= transcripts.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="selectAll" /></th>
                    <th class="col-student">Learner</th>
                    <th class="col-kind">Class</th>
                    <th class="col-kind">Section</th>
                    <th class="col-kind">Stream</th>
                    <th class="col-kind">Type</th>
                    <th class="col-range">Range</th>
                    <th class="col-issue">Issue Number</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% const items = Array.isArray(transcripts) ? transcripts : []; %>
                  <% if (!items.length) { %>
                    <tr><td colspan="10" style="padding:18px;"><div class="muted">No transcripts found.</div></td></tr>
                  <% } %>

                  <% items.forEach(function(t){
                    const st = t.status || "draft";
                    const s = t.student || {};
                    const nm = s.fullName || [s.firstName,s.middleName,s.lastName].filter(Boolean).join(" ") || s.name || "Learner";
                    const reg = s.regNo || s.studentNo || s.indexNumber || "";
                    const classLabel = t.classGroup?.name || t.classGroupName || s.className || "—";
                    const sectionLabel = t.sectionName || t.sectionId?.name || s.section || "—";
                    const streamLabel = t.streamName || t.streamId?.name || s.stream || "—";
                  %>
                    <tr>
                      <td class="col-check"><input type="checkbox" class="selChk" data-id="<%= t._id %>" /></td>
                      <td class="col-student">
                        <div class="item-main">
                          <div class="item-title"><%= nm %></div>
                          <div class="item-sub"><%= reg ? ("Reg: " + reg) : "Reg: —" %></div>
                        </div>
                      </td>
                      <td class="col-kind"><span class="cell-ellipsis"><%= classLabel %></span></td>
                      <td class="col-kind"><span class="cell-ellipsis"><%= sectionLabel %></span></td>
                      <td class="col-kind"><span class="cell-ellipsis"><%= streamLabel %></span></td>
                      <td class="col-kind"><span class="cell-ellipsis"><%= t.kind || "official" %></span></td>
                      <td class="col-range">
                        <span class="cell-ellipsis">
                          <%= t.rangeMode || "auto" %> •
                          <%= t.academicYearFrom || "Auto" %> → <%= t.academicYearTo || "Auto" %>,
                          T<%= t.termFrom ?? 1 %> → T<%= t.termTo ?? 3 %>
                        </span>
                      </td>
                      <td class="col-issue"><span class="cell-ellipsis"><%= t.issueNumber || "—" %></span></td>
                      <td class="col-status">
                        <% if (st === "issued") { %><span class="pill ok"><i class="fa-solid fa-circle-check"></i> Issued</span>
                        <% } else if (st === "revoked") { %><span class="pill bad"><i class="fa-solid fa-ban"></i> Revoked</span>
                        <% } else { %><span class="pill warn"><i class="fa-solid fa-pen"></i> Draft</span><% } %>
                      </td>
                      <td class="col-actions">
                        <div class="actions">
                          <a class="btn-xs" href="/admin/transcripts?tid=<%= t._id %>"><i class="fa-solid fa-eye"></i></a>

                          <button class="btn-xs"
                            type="button"
                            data-action="openEdit"
                            data-id="<%= t._id %>"
                            data-student="<%= (t.student?._id || t.student) %>"
                            data-classgroup="<%= (t.classGroup?._id || t.classGroup || '') %>"
                            data-sectionid="<%= (t.sectionId?._id || t.sectionId || '') %>"
                            data-streamid="<%= (t.streamId?._id || t.streamId || '') %>"
                            data-kind="<%= (t.kind || "official") %>"
                            data-rangemode="<%= (t.rangeMode || "auto") %>"
                            data-ayfrom="<%= (t.academicYearFrom || "") %>"
                            data-ayto="<%= (t.academicYearTo || "") %>"
                            data-termfrom="<%= (t.termFrom ?? 1) %>"
                            data-termto="<%= (t.termTo ?? 3) %>"
                            data-incdraft="<%= (t.includeDraftResults ? "1" : "0") %>"
                            data-autogen="<%= (t.autoGenerated ? "1" : "0") %>"
                            data-notes="<%= (t.notes || "") %>"
                            data-teachercomment="<%= (t.teacherComment || "") %>"
                            data-headteachercomment="<%= (t.headTeacherComment || "") %>"
                            data-status="<%= st %>"
                          ><i class="fa-solid fa-pen"></i></button>

                          <form method="POST" action="/admin/transcripts/<%= t._id %>/clone" style="display:inline">
                            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                            <button class="btn-xs" type="submit"><i class="fa-solid fa-copy"></i></button>
                          </form>

                          <% if (st !== "issued") { %>
                            <button class="btn-xs" type="button" data-action="issue" data-id="<%= t._id %>"><i class="fa-solid fa-certificate"></i></button>
                          <% } %>

                          <% if (st === "issued") { %>
                            <a class="btn-xs" href="/admin/transcripts/<%= t._id %>/print" target="_blank"><i class="fa-solid fa-print"></i></a>
                          <% } %>

                          <button class="btn-xs" type="button" data-action="revoke" data-id="<%= t._id %>"><i class="fa-solid fa-ban"></i></button>
                          <button class="btn-xs" type="button" data-action="delete" data-id="<%= t._id %>"><i class="fa-solid fa-trash"></i></button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>
            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);
                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.kind) params.set("kind", query.kind);
                  if (query?.status) params.set("status", query.status);
                  if (query?.classGroup) params.set("classGroup", query.classGroup);
                  if (query?.sectionId) params.set("sectionId", query.sectionId);
                  if (query?.streamId) params.set("streamId", query.streamId);
                  params.set("page", String(targetPage));
                  return "/admin/transcripts?" + params.toString();
                }
                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>"><i class="fa-solid fa-angle-left"></i></a>
              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>
              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>"><i class="fa-solid fa-angle-right"></i></a>
            </div>
          </div>

          <form id="bulkForm" method="POST" action="/admin/transcripts/bulk" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
            <input type="hidden" name="action" id="bulkActionVal" value="">
            <input type="hidden" name="ids" id="bulkIdsVal" value="">
          </form>

          <form id="issueForm" method="POST" action="#" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          </form>

          <form id="revokeForm" method="POST" action="#" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          </form>

          <form id="deleteForm" method="POST" action="#" style="display:none;">
            <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          </form>
        </section>

        <aside class="card" style="min-width:0;">
          <% if (!preview) { %>
            <div class="note">Select a transcript to preview.</div>
          <% } else { %>
            <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;">
              <div>
                <div class="section-title">Transcript Preview</div>
                <div class="muted">
                  Type: <strong><%= preview.transcriptMeta.kind || "official" %></strong> •
                  Status: <strong><%= preview.transcriptMeta.status %></strong>
                  <% if (preview.transcriptMeta.issueNumber) { %> • Issue: <strong><%= preview.transcriptMeta.issueNumber %></strong><% } %>
                </div>
              </div>
              <% if (preview.transcriptMeta.status === "issued") { %>
                <a class="btn light" href="/admin/transcripts/<%= preview.transcriptMeta._id %>/print" target="_blank">Print</a>
              <% } %>
            </div>

            <div class="divider"></div>

            <div class="section-title">Learner</div>
            <div class="strong" style="margin-top:6px;"><%= preview.student.name %></div>
            <div class="muted">Reg: <strong><%= preview.student.reg || "—" %></strong></div>
            <div class="muted">Class: <strong><%= preview.student.classGroup || "—" %></strong></div>
            <div class="muted">Section: <strong><%= preview.student.section || "—" %></strong></div>
            <div class="muted">Stream: <strong><%= preview.student.stream || "—" %></strong></div>

            <div class="divider"></div>

            <div class="section-title">Totals</div>
            <div class="strong" style="margin-top:6px;">Average: <%= Number(preview.totals?.average || 0).toFixed(2) %>%</div>
            <div class="muted">Overall Grade: <strong><%= preview.totals?.overallGrade || "—" %></strong></div>
            <div class="muted">Overall Remark: <strong><%= preview.totals?.overallRemark || "—" %></strong></div>

            <div class="divider"></div>

            <div class="section-title">Attendance Summary</div>
            <div class="muted" style="margin-top:6px;">
              Present: <strong><%= preview.totals?.attendanceSummary?.present || 0 %></strong> •
              Absent: <strong><%= preview.totals?.attendanceSummary?.absent || 0 %></strong> •
              Late: <strong><%= preview.totals?.attendanceSummary?.late || 0 %></strong> •
              Excused: <strong><%= preview.totals?.attendanceSummary?.excused || 0 %></strong>
            </div>

            <% (preview.terms || []).forEach(function(s){ %>
              <div class="term-block">
                <div class="term-head">
                  <div class="strong"><%= s.academicYear %> • Term <%= s.term %></div>
                  <div class="muted">Average: <strong><%= Number(s.average || 0).toFixed(2) %>%</strong> • Grade: <strong><%= s.grade || "—" %></strong></div>
                </div>

                <table class="subj-table">
                  <thead>
                    <tr>
                      <th>Subject</th>
                      <th>Exam</th>
                      <th>Score</th>
                      <th>%</th>
                      <th>Grade</th>
                      <th>Remark</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% (s.rows || []).forEach(function(r){ %>
                      <tr>
                        <td><strong><%= r.subjectCode || "" %></strong> <%= r.subjectTitle ? ("— " + r.subjectTitle) : "" %></td>
                        <td><%= r.examTitle || "Exam" %></td>
                        <td><%= r.score %>/<%= r.total %></td>
                        <td><%= Number(r.percentage || 0).toFixed(2) %>%</td>
                        <td><strong><%= r.grade %></strong></td>
                        <td><%= r.remark %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% }) %>

            <div class="divider"></div>

            <div class="section-title">Comments</div>
            <div class="note" style="margin-top:8px;">
              Teacher: <strong><%= preview.transcriptMeta.teacherComment || "—" %></strong><br>
              Head Teacher: <strong><%= preview.transcriptMeta.headTeacherComment || "—" %></strong>
            </div>

            <div class="divider"></div>

            <div class="mini-list">
              <div class="mini-item">
                <div class="left">
                  <div class="strong">Draft previews are live</div>
                  <div class="muted">They reflect the latest results each time</div>
                </div>
              </div>
              <div class="mini-item">
                <div class="left">
                  <div class="strong">Issued transcripts are locked</div>
                  <div class="muted">QR verification uses signed snapshots</div>
                </div>
              </div>
            </div>
          <% } %>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="trModal" aria-hidden="true">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="trModalTitle">Generate Transcript</div>
        <button class="btn-xs" type="button" data-action="closeModal"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="trForm" method="POST" action="/admin/transcripts" data-academic-selector>
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field" style="grid-column:1/-1;">
              <label>Learner</label>
              <select class="select" id="mStudent" name="student" required data-role="student" data-placeholder="Select Learner">
                <option value="">— Select Learner —</option>
                <% (studentsList || []).forEach(function(s){
                  const nm = s.fullName || [s.firstName,s.middleName,s.lastName].filter(Boolean).join(" ") || s.name || "Learner";
                  const rg = s.regNo || s.studentNo || s.indexNumber || "";
                %>
                  <option value="<%= s._id %>"><%= nm %> <%= rg ? ("• " + rg) : "" %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Class</label>
              <select class="select" id="mClassGroup" name="classGroup" data-role="class" data-placeholder="Select Class">
                <option value="">— Select Class —</option>
                <% (classes || []).forEach(function(c){ %>
                  <option value="<%= c._id %>"><%= c.name || c.code || 'Class' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Section</label>
              <select class="select" id="mSectionId" name="sectionId" data-role="section" data-placeholder="Select Section">
                <option value="">— Select Section —</option>
                <% (sections || []).forEach(function(s){ %>
                  <option value="<%= s._id || s.id %>"><%= s.name || s.code || 'Section' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Stream</label>
              <select class="select" id="mStreamId" name="streamId" data-role="stream" data-placeholder="Select Stream">
                <option value="">— Select Stream —</option>
                <% (streams || []).forEach(function(s){ %>
                  <option value="<%= s._id || s.id %>"><%= s.name || s.code || 'Stream' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Transcript Type</label>
              <select class="select" id="mKind" name="kind">
                <option value="official">Official</option>
                <option value="unofficial">Unofficial</option>
              </select>
            </div>

            <div class="field">
              <label>Range Mode</label>
              <select class="select" id="mRangeMode" name="rangeMode">
                <option value="auto">Auto Detect</option>
                <option value="current_term">Current Term</option>
                <option value="all_available">All Available</option>
                <option value="custom">Custom Range</option>
              </select>
            </div>

            <div class="field">
              <label>Academic Year From</label>
              <input class="input" id="mAYFrom" name="academicYearFrom" placeholder="e.g. 2026" />
            </div>

            <div class="field">
              <label>Academic Year To</label>
              <input class="input" id="mAYTo" name="academicYearTo" placeholder="e.g. 2026" />
            </div>

            <div class="field">
              <label>Term From</label>
              <select class="select" id="mTermFrom" name="termFrom">
                <option value="1">Term 1</option>
                <option value="2">Term 2</option>
                <option value="3">Term 3</option>
              </select>
            </div>

            <div class="field">
              <label>Term To</label>
              <select class="select" id="mTermTo" name="termTo">
                <option value="1">Term 1</option>
                <option value="2">Term 2</option>
                <option value="3">Term 3</option>
              </select>
            </div>

            <div class="field">
              <label>Include Draft Results</label>
              <label class="view-input" style="justify-content:flex-start;gap:10px;">
                <input type="checkbox" id="mIncludeDraft" name="includeDraftResults" value="1" />
                Include Draft Results
              </label>
            </div>

            <div class="field">
              <label>Auto Generated</label>
              <label class="view-input" style="justify-content:flex-start;gap:10px;">
                <input type="checkbox" id="mAutoGenerated" checked disabled />
                Built automatically from results
              </label>
            </div>

            <div class="field" style="grid-column:1/-1;">
              <label>Internal Notes</label>
              <textarea class="textarea" id="mNotes" name="notes" placeholder="Optional internal notes"></textarea>
            </div>

            <div class="field">
              <label>Teacher Comment</label>
              <textarea class="textarea" id="mTeacherComment" name="teacherComment" placeholder="Optional teacher comment"></textarea>
            </div>

            <div class="field">
              <label>Head Teacher Comment</label>
              <textarea class="textarea" id="mHeadTeacherComment" name="headTeacherComment" placeholder="Optional head teacher comment"></textarea>
            </div>
          </div>

          <input type="hidden" id="mId" value="" />
          <input type="hidden" id="mStatus" value="draft" />
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-action="closeModal">Cancel</button>
          <button class="btn primary" type="button" data-action="saveTranscript">Generate / Save Transcript</button>
        </div>
      </form>
    </div>
  </div>

  <textarea id="classesData" style="display:none" aria-hidden="true"><%- JSON.stringify(classes || []) %></textarea>
  <textarea id="sectionsData" style="display:none" aria-hidden="true"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="streamsData" style="display:none" aria-hidden="true"><%- JSON.stringify(streams || []) %></textarea>
  <textarea id="studentsData" style="display:none" aria-hidden="true"><%- JSON.stringify(studentsData || studentsList || []) %></textarea>
  <script src="/js/navbar.js" defer></script>
  <script src="/js/academic-selector.js" defer></script>
  <script src="/js/transcripts.js" defer></script>
</body>
</html>
