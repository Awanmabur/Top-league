<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Timetable</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.65fr) minmax(300px,.35fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1720px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-course{width:280px}
    .col-class{width:180px}
    .col-lecturer{width:180px}
    .col-day{width:100px}
    .col-time{width:150px}
    .col-room{width:150px}
    .col-campus{width:150px}
    .col-academic{width:160px}
    .col-week{width:110px}
    .col-status{width:120px}
    .col-actions{width:240px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .entry-main{min-width:0}
    .entry-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .entry-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1080px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(560px,100%)}
    .modal.md{width:min(920px,100%)}
    .modal.lg{width:min(1080px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:6px 10px;
      border-radius:999px;
      background:#eef2ff;
      color:#3730a3;
      font-size:12px;
      font-weight:800;
    }

    .tabs{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      margin-bottom:10px;
    }

    .tabbtn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:38px;
      padding:0 14px;
      border-radius:999px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-weight:800;
    }

    .tabbtn.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .ttwrap{display:none}
    .ttwrap.active{display:block}

    .ttgrid{
      display:grid;
      grid-template-columns:100px repeat(6,minmax(140px,1fr));
      gap:8px;
      overflow-x:auto;
    }

    .tthead{
      font-size:12px;
      color:#6b7280;
      font-weight:900;
      padding:8px 10px;
      background:rgba(13,64,96,.03);
      border-radius:10px;
      text-align:center;
    }

    .tthour{
      border:1px dashed rgba(13,64,96,.18);
      border-radius:10px;
      min-height:82px;
      padding:8px;
      background:#fbfdff;
      color:#64748b;
      font-weight:900;
      font-size:12px;
    }

    .ttcell{
      border:1px solid rgba(13,64,96,.10);
      border-radius:10px;
      min-height:82px;
      padding:8px;
      background:#fff;
    }

    .block{
      border:1px solid #cfe0ff;
      background:#eef4ff;
      border-radius:10px;
      padding:8px;
      margin-bottom:6px;
    }

    .block .b1{font-weight:900;font-size:12px;color:#0a6fbf}
    .block .b2{font-size:11px;color:#475569;margin-top:2px}

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1720px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Timetable</div>
          <div class="subtitle">Create, edit, import, export, print and manage timetable slots.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Slot</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Live timetable slots</div>
        </div>
        <div class="card">
          <div class="section-title">Inactive</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.inactive || 0 %></div>
          <div class="muted">Disabled but saved</div>
        </div>
        <div class="card">
          <div class="section-title">Archived</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div>
          <div class="muted">Ignored in conflicts</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/timetable">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search room, campus, term..." />

            <select class="select" name="academicYear">
              <option value="">Any Year</option>
              <% (academicYears || []).forEach(function(y){ %>
                <option value="<%= y %>" <%= query?.academicYear === y ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>

            <select class="select" name="semester">
              <option value="">Any Semester</option>
              <% for (let s = 1; s <= 4; s++) { %>
                <option value="<%= s %>" <%= String(query?.semester || '') === String(s) ? 'selected' : '' %>>Sem <%= s %></option>
              <% } %>
            </select>

            <select class="select" name="classGroup">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= String(c._id) %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
              <% }) %>
            </select>

            <select class="select" name="lecturer">
              <option value="">All Lecturers</option>
              <% (staffList || []).forEach(function(s){ %>
                <option value="<%= String(s._id) %>" <%= String(query?.lecturer || '') === String(s._id) ? 'selected' : '' %>>
                  <%= s.fullName || s.name || 'Staff' %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="dayOfWeek">
              <option value="">All Days</option>
              <% (days || []).forEach(function(d){ %>
                <option value="<%= d %>" <%= query?.dayOfWeek === d ? 'selected' : '' %>><%= d %></option>
              <% }) %>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= query?.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/timetable"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">slot(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <button class="btn-xs" id="bulkDeactivate" type="button"><i class="fa-solid fa-circle-pause"></i> Inactivate</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div class="tabs">
            <button class="tabbtn active" id="tabList" type="button">List View</button>
            <button class="tabbtn" id="tabGrid" type="button">Grid View</button>
          </div>

          <div id="listWrap" class="ttwrap active">
            <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
              <div>
                <div class="section-title">Timetable Table</div>
                <div class="section-sub">Showing <%= entries.length %> of <%= query?.total || 0 %> records.</div>
              </div>
              <div class="muted">
                Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
              </div>
            </div>

            <div style="margin-top:10px;">
              <div class="table-wrap" id="printArea">
                <table>
                  <thead>
                    <tr>
                      <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                      <th class="col-course">Course</th>
                      <th class="col-class">Class</th>
                      <th class="col-lecturer">Lecturer</th>
                      <th class="col-day">Day</th>
                      <th class="col-time">Time</th>
                      <th class="col-room">Room</th>
                      <th class="col-campus">Campus</th>
                      <th class="col-academic">Academic</th>
                      <th class="col-week">Week</th>
                      <th class="col-status">Status</th>
                      <th class="col-actions" style="text-align:right;">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="tbodyEntries"></tbody>
                </table>
              </div>
            </div>

            <div class="pagination">
              <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>

              <div class="pagination-links">
                <%
                  const currentPage = Number(query?.page || 1);
                  const totalPages = Number(query?.totalPages || 1);

                  function buildPageUrl(targetPage) {
                    const params = new URLSearchParams();
                    if (query?.q) params.set("q", query.q);
                    if (query?.academicYear) params.set("academicYear", query.academicYear);
                    if (query?.semester) params.set("semester", query.semester);
                    if (query?.classGroup) params.set("classGroup", query.classGroup);
                    if (query?.lecturer) params.set("lecturer", query.lecturer);
                    if (query?.dayOfWeek) params.set("dayOfWeek", query.dayOfWeek);
                    if (query?.status) params.set("status", query.status);
                    params.set("page", String(targetPage));
                    return "/admin/timetable?" + params.toString();
                  }

                  const startPage = Math.max(1, currentPage - 2);
                  const endPage = Math.min(totalPages, currentPage + 2);
                %>

                <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                  <i class="fa-solid fa-angle-left"></i>
                </a>

                <% for (let p = startPage; p <= endPage; p++) { %>
                  <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
                <% } %>

                <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                  <i class="fa-solid fa-angle-right"></i>
                </a>
              </div>
            </div>
          </div>

          <div id="gridWrap" class="ttwrap">
            <div class="note" style="margin-bottom:10px;">
              Grid view uses the currently loaded page. Filter by one class or semester for the cleanest layout.
            </div>
            <div id="ttMeta" class="muted" style="margin-bottom:10px;"></div>
            <div class="ttgrid" id="ttGrid"></div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Morning Slot</div>
                <div class="muted">Starts 08:00 by default</div>
              </div>
              <button class="btn-xs" id="quickMorning" type="button"><i class="fa-solid fa-sun"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Afternoon Slot</div>
                <div class="muted">Starts 14:00 by default</div>
              </div>
              <button class="btn-xs" id="quickAfternoon" type="button"><i class="fa-solid fa-clock"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Import From CSV</div>
                <div class="muted">Bulk create timetable slots</div>
              </div>
              <button class="btn-xs" id="quickImport" type="button"><i class="fa-solid fa-file-import"></i></button>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section-title">CSV Import Format</div>
          <div class="note" style="margin-top:10px;">
            Required columns:<br>
            <strong>classCode,courseCode,dayOfWeek,startTime,endTime</strong><br><br>
            Optional:<br>
            academicYear, semester, term, lecturerEmail, room, campus, weekPattern, status, note
          </div>
        </aside>
      </div>
    </main>
  </div>

  <!-- Add/Edit Modal -->
  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Timetable Slot</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="entryForm" method="POST" action="/admin/timetable">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Class</label>
              <select class="select" id="mClass" name="classGroup" required>
                <option value="">— Select Class —</option>
                <% (classes || []).forEach(function(c){ %>
                  <option value="<%= String(c._id) %>"><%= c.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Course</label>
              <select class="select" id="mCourse" name="course" required>
                <option value="">— Select Course —</option>
                <% (courses || []).forEach(function(c){ %>
                  <option value="<%= String(c._id) %>"><%= c.code %> — <%= c.title %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Lecturer</label>
              <select class="select" id="mLect" name="lecturer">
                <option value="">— Not Assigned —</option>
                <% (staffList || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' — ' + s.role) : '' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Day</label>
              <select class="select" id="mDay" name="dayOfWeek" required>
                <% (days || []).forEach(function(d){ %>
                  <option value="<%= d %>"><%= d %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Start Time</label>
              <input class="input" id="mStart" name="startTime" placeholder="08:00" required />
            </div>

            <div class="field">
              <label>End Time</label>
              <input class="input" id="mEnd" name="endTime" placeholder="10:00" required />
            </div>

            <div class="field">
              <label>Academic Year</label>
              <input class="input" id="mAY" name="academicYear" placeholder="2025/2026" />
            </div>

            <div class="field">
              <label>Semester</label>
              <input class="input" id="mSem" name="semester" type="number" min="0" max="6" value="1" />
            </div>

            <div class="field">
              <label>Term</label>
              <input class="input" id="mTerm" name="term" placeholder="Optional: Term 1" />
            </div>

            <div class="field">
              <label>Room</label>
              <input class="input" id="mRoom" name="room" />
            </div>

            <div class="field">
              <label>Campus</label>
              <input class="input" id="mCampus" name="campus" />
            </div>

            <div class="field">
              <label>Week Pattern</label>
              <select class="select" id="mWeek" name="weekPattern">
                <option value="all">All Weeks</option>
                <option value="odd">Odd Weeks</option>
                <option value="even">Even Weeks</option>
              </select>
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field">
              <label>Duration</label>
              <div class="view-input" id="mDurationPreview">—</div>
            </div>

            <div class="field">
              <label>Conflict Rules</label>
              <div class="note">Class, lecturer and room conflicts are blocked within the same academic year and semester unless archived.</div>
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Note</label>
            <textarea class="textarea" id="mNote" name="note" maxlength="500"></textarea>
            <div class="muted" id="noteCount">0 / 500</div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Slot</button>
        </div>
      </form>
    </div>
  </div>

  <!-- View Modal -->
  <div class="modal-backdrop" id="mView">
    <div class="modal md">
      <div class="modal-header">
        <div class="modal-title">Timetable Slot Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Course</label>
            <div class="view-input" id="vCourse">—</div>
          </div>

          <div class="field">
            <label>Class</label>
            <div class="view-input" id="vClass">—</div>
          </div>

          <div class="field">
            <label>Lecturer</label>
            <div class="view-input" id="vLecturer">—</div>
          </div>

          <div class="field">
            <label>Day</label>
            <div class="view-input" id="vDay">—</div>
          </div>

          <div class="field">
            <label>Time</label>
            <div class="view-input" id="vTime">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Room</label>
            <div class="view-input" id="vRoom">—</div>
          </div>

          <div class="field">
            <label>Campus</label>
            <div class="view-input" id="vCampus">—</div>
          </div>

          <div class="field">
            <label>Academic</label>
            <div class="view-input" id="vAcademic">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Note</label>
          <div class="view-input multiline" id="vNote">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <!-- Import Modal -->
  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Timetable CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="importForm" method="POST" action="/admin/timetable/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="field">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>

          <div class="note" style="margin-top:12px;">
            Required columns:<br>
            <strong>classCode,courseCode,dayOfWeek,startTime,endTime</strong>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusValue">
  </form>

  <form id="bulkForm" method="POST" action="/admin/timetable/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionValue">
    <input type="hidden" name="ids" id="bulkIdsValue">
  </form>

  <textarea id="entriesData" class="json-data" aria-hidden="true"><%- JSON.stringify((entries || []).map(function(e){
    return {
      id: String(e._id || ''),
      academicYear: e.academicYear || '',
      semester: Number(e.semester ?? 1),
      term: e.term || '',
      classId: e.classGroup?._id ? String(e.classGroup._id) : '',
      className: e.classGroup?.name || '',
      courseId: e.course?._id ? String(e.course._id) : '',
      courseCode: e.course?.code || '',
      courseTitle: e.course?.title || '',
      lecturerId: e.lecturer?._id ? String(e.lecturer._id) : '',
      lecturerName: e.lecturer?.fullName || e.lecturer?.name || '',
      dayOfWeek: e.dayOfWeek || '',
      startTime: e.startTime || '',
      endTime: e.endTime || '',
      startMinutes: Number(e.startMinutes || 0),
      endMinutes: Number(e.endMinutes || 0),
      room: e.room || '',
      campus: e.campus || '',
      weekPattern: e.weekPattern || 'all',
      status: e.status || 'active',
      note: e.note || ''
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/timetable.js"></script>
</body>
</html>