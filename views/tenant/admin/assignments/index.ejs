<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> - Assignments</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" href="data:," />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}.textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}.strong{font-weight:900}.json-data{display:none!important}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}.warn{background:#fef9c3;color:#92400e}.bad{background:#fee2e2;color:#b91c1c}.info{background:#eef2ff;color:#3730a3}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1580px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)} tr.row-clickable{cursor:pointer}
    .col-check{width:48px}.col-assignment{width:290px}.col-subject{width:220px}.col-class{width:180px}.col-section{width:150px}.col-stream{width:150px}.col-due{width:170px}.col-points{width:110px}.col-status{width:130px}.col-actions{width:230px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .item-main{min-width:0}.item-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.item-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}.badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}.flash{padding:12px 14px;border-radius:12px;font-weight:700}.flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}.flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}.topbar>div:first-child{min-width:0;flex:1 1 auto}.top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}.modal{width:min(1080px,100%);max-height:calc(100dvh - 40px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(760px,100%)}.modal.lg{width:min(1080px,100%)}.modal>form{display:flex;flex-direction:column;min-height:0;flex:1 1 auto}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px;color:#0f172a}.modal-body{padding:18px 20px;overflow-y:auto;flex:1 1 auto}.modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.field{display:flex;flex-direction:column;gap:6px}.field.full{grid-column:1 / -1}.field label{font-size:12px;font-weight:800;color:#475569}
    .mini-list{display:grid;gap:10px;margin-top:10px}.mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}.mini-item .left{display:grid;gap:2px}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}.pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}.page-link.disabled{pointer-events:none;opacity:.45}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width:520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left>*,.toolbar .right>*{max-width:100%}table{min-width:1580px}}
    @media print{body *{visibility:hidden!important}#printArea,#printArea *{visibility:visible!important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>
<body>
  <%
    const items = Array.isArray(assignments) ? assignments : [];
    const kpiData = (typeof kpis !== "undefined" && kpis) ? kpis : { total: items.length, published: 0, draft: 0, archived: 0, closed: 0 };
  %>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %>
          <% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Assignments</div>
          <div class="subtitle">Create and manage coursework by class, section, stream and subject.</div>
        </div>
        <div class="top-actions">
          <a class="btn light" href="/admin/assignments/export?<%= new URLSearchParams({q:query?.q||'',course:query?.course||'',classGroup:query?.classGroup||'',sectionId:query?.sectionId||'',streamId:query?.streamId||'',status:query?.status||''}).toString() %>"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</a>
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Assignment</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpiData.total || 0 %></div><div class="muted">All assignments</div></div>
        <div class="card"><div class="section-title">Published</div><div class="kpi-value" style="color:#15803d"><%= kpiData.published || 0 %></div><div class="muted">Visible to learners</div></div>
        <div class="card"><div class="section-title">Draft</div><div class="kpi-value" style="color:#92400e"><%= kpiData.draft || 0 %></div><div class="muted">Still preparing</div></div>
        <div class="card"><div class="section-title">Archived</div><div class="kpi-value" style="color:#b91c1c"><%= kpiData.archived || 0 %></div><div class="muted">Hidden history</div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" action="/admin/assignments" method="GET" data-academic-selector>
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search assignment, subject..." />
            <select name="classGroup" class="select" data-role="class" data-placeholder="All Classes">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %><option value="<%= c._id || c.id %>" <%= String(query?.classGroup||"")===String(c._id || c.id)?"selected":"" %>><%= c.name || c.label || c.code || "Class" %></option><% }) %>
            </select>
            <select name="sectionId" class="select" data-role="section" data-placeholder="All Sections" data-selected="<%= query?.sectionId || '' %>"><option value="">All Sections</option></select>
            <select name="streamId" class="select" data-role="stream" data-placeholder="All Streams" data-selected="<%= query?.streamId || '' %>"><option value="">All Streams</option></select>
            <select name="course" class="select" data-role="subject" data-placeholder="All Subjects">
              <option value="">All Subjects</option>
              <% (courses || []).forEach(function(c){ %><option value="<%= c._id || c.id %>" <%= String(query?.course||"")===String(c._id || c.id)?"selected":"" %>><%= c.title || c.code || c.name || "Subject" %></option><% }) %>
            </select>
            <select name="status" class="select">
              <option value="">All Status</option>
              <option value="published" <%= query?.status==="published"?"selected":"" %>>Published</option>
              <option value="draft" <%= query?.status==="draft"?"selected":"" %>>Draft</option>
              <option value="closed" <%= query?.status==="closed"?"selected":"" %>>Closed</option>
              <option value="archived" <%= query?.status==="archived"?"selected":"" %>>Archived</option>
            </select>
          </div>
          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/assignments"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>
        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap"><strong>Selected</strong><span class="badge-count" id="selCount">0</span><span class="muted">assignment(s)</span></div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkPublish" type="button">Publish</button>
            <button class="btn-xs" id="bulkUnpublish" type="button">Draft</button>
            <button class="btn-xs" id="bulkClose" type="button">Close</button>
            <button class="btn-xs" id="bulkArchive" type="button">Archive</button>
            <button class="btn-xs" id="bulkClear" type="button">Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div><div class="section-title">Assignments Table</div><div class="section-sub">Showing <%= items.length %> of <%= query?.total || 0 %> records.</div></div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>
          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-assignment">Assignment</th>
                    <th class="col-subject">Subject</th>
                    <th class="col-class">Class</th>
                    <th class="col-section">Section</th>
                    <th class="col-stream">Stream</th>
                    <th class="col-due">Due Date</th>
                    <th class="col-points">Points</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyAssignments"></tbody>
              </table>
            </div>
          </div>

          <% const currentPage = Number(query?.page || 1); const totalPages = Number(query?.totalPages || 1); function pageUrl(p){ const params = new URLSearchParams(); if (query?.q) params.set("q", query.q); if (query?.course) params.set("course", query.course); if (query?.classGroup) params.set("classGroup", query.classGroup); if (query?.sectionId) params.set("sectionId", query.sectionId); if (query?.streamId) params.set("streamId", query.streamId); if (query?.status) params.set("status", query.status); params.set("page", String(p)); return "/admin/assignments?" + params.toString(); } %>
          <div class="pagination">
            <div class="muted">Total records: <%= query?.total || 0 %></div>
            <div class="pagination-links">
              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= currentPage <= 1 ? '#' : pageUrl(currentPage - 1) %>">Prev</a>
              <% for (let p = 1; p <= totalPages; p++) { if (p === 1 || p === totalPages || Math.abs(p - currentPage) <= 1) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= pageUrl(p) %>"><%= p %></a>
              <% } else if (Math.abs(p - currentPage) === 2) { %>
                <span class="muted">...</span>
              <% } } %>
              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= currentPage >= totalPages ? '#' : pageUrl(currentPage + 1) %>">Next</a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast assignment workflow.</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Add Draft</div><div class="muted">Prepare before publishing</div></div><button class="btn-xs" id="quickDraft" type="button"><i class="fa-solid fa-pen-to-square"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add Published</div><div class="muted">Visible immediately</div></div><button class="btn-xs" id="quickPublished" type="button"><i class="fa-solid fa-eye"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Import CSV</div><div class="muted">Bulk upload assignments</div></div><button class="btn-xs" type="button" onclick="document.getElementById('btnImport').click()"><i class="fa-solid fa-file-import"></i></button></div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitleBar">Add Assignment</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="assignForm" method="POST" action="/admin/assignments" data-academic-selector>
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="form-grid">
            <div class="field full"><label>Title</label><input class="input" id="mTitle" name="title" required /></div>
            <div class="field"><label>Class</label><select class="select" id="mClassGroup" name="classGroup" data-role="class" data-placeholder="Select Class"><option value="">Select Class</option></select></div>
            <div class="field"><label>Section</label><select class="select" id="mSection" name="sectionId" data-role="section" data-placeholder="Whole Class"><option value="">Whole Class</option></select></div>
            <div class="field"><label>Stream</label><select class="select" id="mStream" name="streamId" data-role="stream" data-placeholder="All Streams"><option value="">All Streams</option></select></div>
            <div class="field"><label>Subject</label><select class="select" id="mCourse" name="course" data-role="subject" data-placeholder="Select Subject" required><option value="">Select Subject</option></select></div>
            <div class="field"><label>Due Date</label><input class="input" id="mDue" name="dueDate" type="datetime-local" /></div>
            <div class="field"><label>Total Points</label><input class="input" id="mPoints" name="totalPoints" type="number" min="0" max="1000" value="100" /></div>
            <div class="field"><label>Status</label><select class="select" id="mStatus" name="status"><option value="draft">Draft</option><option value="published">Published</option><option value="closed">Closed</option><option value="archived">Archived</option></select></div>
            <div class="field full"><label>Instructions</label><textarea class="textarea" id="mInstr" name="instructions"></textarea></div>
            <div class="field full"><label>Rubric</label><textarea class="textarea" id="mRubric" name="rubric"></textarea></div>
            <div class="field full"><label>Attachments (one URL per line)</label><textarea class="textarea" id="mAttach" placeholder="https://..."></textarea><div id="mAttachWrap"></div></div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button">Save Assignment</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Assignment Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field full"><label>Assignment</label><div class="view-input" id="vTitle">-</div></div>
          <div class="field"><label>Subject</label><div class="view-input" id="vCourse">-</div></div>
          <div class="field"><label>Class</label><div class="view-input" id="vClass">-</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vSection">-</div></div>
          <div class="field"><label>Stream</label><div class="view-input" id="vStream">-</div></div>
          <div class="field"><label>Due Date</label><div class="view-input" id="vDue">-</div></div>
          <div class="field"><label>Points</label><div class="view-input" id="vPoints">-</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">-</div></div>
        </div>
        <div class="field" style="margin-top:12px;"><label>Instructions</label><div class="view-input multiline" id="vInstr">-</div></div>
        <div class="field" style="margin-top:12px;"><label>Rubric</label><div class="view-input multiline" id="vRubric">-</div></div>
        <div class="field" style="margin-top:12px;"><label>Attachments</label><div class="view-input multiline" id="vAttach">-</div></div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" id="viewPublishBtn">Publish</button>
        <button class="btn light" type="button" id="viewArchiveBtn">Archive</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn">Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Assignments CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form method="POST" action="/admin/assignments/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="field"><label>CSV File</label><input class="input" type="file" name="file" accept=".csv,text/csv" required /></div>
          <div class="muted">Supported headers: title, subjectCode, dueDate, totalPoints, status, instructions, rubric, attachments.</div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit">Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;"><% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %></form>
  <form id="bulkForm" method="POST" action="/admin/assignments/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionField">
    <input type="hidden" name="ids" id="bulkIdsField">
  </form>

  <textarea id="assignmentsData" class="json-data" aria-hidden="true"><%- JSON.stringify(items.map(function(a){
    return {
      id: String(a._id || ""),
      title: a.title || "",
      classId: a.classGroup?._id ? String(a.classGroup._id) : String(a.classGroup || ""),
      className: a.classGroup?.name || a.className || "",
      sectionId: a.sectionId?._id ? String(a.sectionId._id) : String(a.sectionId || ""),
      sectionName: a.sectionName || a.sectionId?.name || "",
      streamId: a.streamId?._id ? String(a.streamId._id) : String(a.streamId || ""),
      streamName: a.streamName || a.streamId?.name || "",
      courseId: a.course?._id ? String(a.course._id) : String(a.course || ""),
      courseName: a.course?.title || a.course?.code || a.courseName || "",
      dueDate: a.dueDate ? new Date(a.dueDate).toISOString().slice(0,16) : "",
      dueDisplay: a.dueDate ? new Date(a.dueDate).toLocaleString() : "",
      totalPoints: Number(a.totalPoints ?? 100),
      status: a.status || "draft",
      instructions: a.instructions || "",
      rubric: a.rubric || "",
      attachments: Array.isArray(a.attachments) ? a.attachments : []
    };
  })) %></textarea>
  <textarea id="classesData" class="json-data" aria-hidden="true"><%- JSON.stringify(classes || []) %></textarea>
  <textarea id="sectionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="streamsData" class="json-data" aria-hidden="true"><%- JSON.stringify(streams || []) %></textarea>
  <textarea id="subjectOptionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(subjectOptions || subjects || courses || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/academic-selector.js"></script>
  <script src="/js/assignments.js"></script>
</body>
</html>
