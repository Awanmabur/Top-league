<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title><%= (tenant?.name || "Classic Academy") %> — Assignments</title>
<link rel="icon" href="data:," />
<link rel="stylesheet" href="/css/navbar.css" />
<%-include("../.././partials/header") %>
<style>
  
  .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap}
  .title{font-size:20px;font-weight:900;color:var(--blue-2)}
  .subtitle{font-size:13px;color:var(--muted);max-width:720px}
  .top-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}

  .search-box{display:flex;align-items:center;gap:8px;background:var(--card);border-radius:10px;border:1px solid #e1e9f7;padding:7px 10px}
  .search-box input{border:none;outline:none;font-size:14px;background:transparent;min-width:220px}
  .select{padding:8px 10px;border-radius:8px;border:1px solid #dbe3f6;background:#fff;font-size:14px}
  .btn{padding:9px 12px;border-radius:8px;border:none;cursor:pointer;font-weight:900;font-size:14px}
  .btn.primary{background:var(--blue);color:#fff}
  .btn.light{background:#eef4ff;color:var(--blue);border:1px solid #dbe3f6}
  .btn.ghost{background:transparent;color:#111827;border:1px solid #e5e7eb}
  .btn.danger{background:#fff1f2;color:var(--danger);border:1px solid #fecdd3}

  .summary{display:grid;grid-template-columns:repeat(4,minmax(140px,1fr));gap:12px}
  @media(max-width:860px){.summary{grid-template-columns:repeat(2,minmax(140px,1fr))}}
  .stat{border:1px solid #e7efff;border-radius:12px;padding:12px;background:linear-gradient(180deg,#fff,#fbfdff)}
  .stat .k{font-size:12px;color:var(--muted);font-weight:900}
  .stat .v{margin-top:6px;font-size:18px;font-weight:1000}
  .stat .s{margin-top:4px;font-size:12px;color:#64748b}

  .content{display:grid;grid-template-columns:2fr 1fr;gap:18px;align-items:flex-start}
  @media(max-width:1024px){ .content{grid-template-columns:1fr}}

  .card{background:var(--card);border-radius:var(--radius);padding:14px;border:1px solid #e4ecfb;box-shadow:var(--shadow)}
  .bulk-row{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap}
  .bulk-left{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .bulk-left label{font-size:13px;color:#4b5563}
  .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900}
  .ok{background:#ecfdf3;color:#15803d}
  .warn{background:#fff7ed;color:#92400e}
  .bad{background:#fee2e2;color:#b91c1c}
  .info{background:#eef2ff;color:#3730a3}
  .muted{font-size:12px;color:#6b7280}
  .strong{font-weight:900}

  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(360px,1fr));gap:12px}
  .acard{border:1px solid #e6eefc;border-radius:14px;background:#fff;padding:12px;cursor:pointer}
  .acard:hover{border-color:rgba(10,111,191,.35);box-shadow:0 10px 22px rgba(12,38,73,.10)}
  .acard.selected{outline:3px solid rgba(10,111,191,.18);border-color:rgba(10,111,191,.55)}
  .row{display:flex;justify-content:space-between;gap:10px}
  .aname{font-weight:1000;color:var(--blue-2);line-height:1.1}
  .mini{font-size:12px;color:#64748b;margin-top:3px}
  .tag{display:inline-block;padding:6px 9px;border-radius:10px;background:#eef4ff;font-size:12px;color:var(--blue-2);margin-right:6px;margin-top:6px;font-weight:900}
  .badge{padding:4px 8px;border-radius:999px;font-size:11px;font-weight:1000;white-space:nowrap}
  .b-pub{background:#e6f9ee;color:var(--success)}
  .b-draft{background:#eef2ff;color:var(--accent)}
  .b-arch{background:#fff7ed;color:var(--warning)}
  .b-closed{background:#f1f5f9;color:#334155}
  .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;font-weight:900}
  .btn-xs:hover{background:rgba(10,111,191,.06)}
  .btn-xs.danger{background:#fff1f2;border-color:#fecdd3;color:var(--danger)}
  .actions{display:flex;gap:6px;justify-content:flex-end;margin-top:10px;flex-wrap:wrap}

  .preview-title{font-size:15px;font-weight:1000;color:var(--blue-2)}
  .preview-label{font-size:12px;color:#6b7280;font-weight:900}
  .preview-value{font-size:14px;color:#111827;margin-top:3px}
  .preview-row{margin-top:10px}
  .small-muted{font-size:12px;color:#6b7280;margin-top:4px}
  .preview-actions{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}

  .menu{position:relative;display:inline-block}
  .menu-panel{position:absolute;right:0;top:38px;min-width:200px;background:#fff;border:1px solid #e6eefc;border-radius:12px;box-shadow:0 18px 40px rgba(15,23,42,.18);padding:6px;display:none;z-index:8}
  .menu-panel.show{display:block}
  .menu-panel button{width:100%;text-align:left;padding:9px 10px;border:none;background:transparent;border-radius:10px;cursor:pointer;font-weight:900}
  .menu-panel button:hover{background:#f1f6ff}
  .menu-panel .danger:hover{background:#fff1f2}

  .backdrop{position:fixed;inset:0;background:rgba(15,23,42,.55);display:none;align-items:center;justify-content:center;padding:20px;z-index:50}
  .modal{width:1080px;max-width:100%;max-height:90vh;overflow:auto;border-radius:14px;background:#fff;box-shadow:0 30px 60px rgba(15,23,42,.35);padding:16px 16px 18px}
  .modal-header{display:flex;justify-content:space-between;align-items:center;gap:10px}
  .modal-title{font-size:18px;font-weight:1100;color:var(--blue-2)}
  .modal-grid{display:grid;grid-template-columns:1.35fr 1fr;gap:14px;margin-top:12px}
  @media(max-width:860px){.modal-grid{grid-template-columns:1fr}}
  .field{display:flex;flex-direction:column;margin-bottom:10px}
  .field label{font-size:12px;font-weight:1000;margin-bottom:5px;color:#374151}
  .field input,.field select,.field textarea{border-radius:10px;border:1px solid #dbe3f6;padding:10px 10px;font-size:14px;outline:none;background:#fff}
  .field textarea{min-height:120px;resize:vertical}
  .divider{height:1px;background:#eef2ff;margin:10px 0}
  .hint{background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:10px;font-size:12px;color:#475569}
  .tabs{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0 12px}
  .tab{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:1000;font-size:12px}
  .tab.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
</style>
</head>

<body>
  <%
    const items = Array.isArray(assignments) ? assignments : [];
    const kpiData =
      (typeof kpis !== "undefined" && kpis)
        ? kpis
        : { total: items.length, published: 0, draft: 0, archived: 0, closed: 0 };
  %>


<div class="app">
<%-include("../.././partials/navbar") %>
  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Assignments</div>
        <div class="subtitle">Create, publish, collect, grade and track coursework. Use bulk actions for faster management.</div>
      </div>

      <div class="top-actions">
        <form action="/admin/assignments" method="GET" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <div class="search-box">
            <svg width="16" height="16" viewBox="0 0 24 24" stroke="#94a3b8" fill="none" stroke-width="1.7">
              <circle cx="11" cy="11" r="6"></circle>
              <path d="M16 16L21 21" stroke-linecap="round"></path>
            </svg>
            <input name="q" value="<%= (query?.q || "") %>" placeholder="Search assignment, course, lecturer..." />
          </div>

          <select name="course" class="select">
            <option value="">All Courses</option>
            <% (courses || []).forEach(c => { %>
              <option value="<%= c._id %>" <%= (String(query?.course||"")===String(c._id)?"selected":"") %>><%= c.title || c.code || "Course" %></option>
            <% }) %>
          </select>

          <select name="status" class="select">
            <option value="">Any Status</option>
            <option value="published" <%= (query?.status==="published"?"selected":"") %>>Published</option>
            <option value="draft" <%= (query?.status==="draft"?"selected":"") %>>Draft</option>
            <option value="closed" <%= (query?.status==="closed"?"selected":"") %>>Closed</option>
            <option value="archived" <%= (query?.status==="archived"?"selected":"") %>>Archived</option>
          </select>

          <button class="btn light" type="submit">Filter</button>
        </form>

        <button class="btn primary" type="button" data-action="openAssign">+ New Assignment</button>

        <div class="menu">
          <button class="btn light" type="button" data-action="toggleTools">Tools ▾</button>
          <div class="menu-panel" id="toolsMenu">
            <button type="button" data-action="openImport">Import CSV</button>
            <a href="/admin/assignments/export?<%= new URLSearchParams({q:query?.q||'',course:query?.course||'',status:query?.status||''}).toString() %>" style="text-decoration:none;display:block;">
              <button type="button">Export CSV</button>
            </a>
            <button type="button" data-action="bulkPublish">Bulk Publish</button>
            <button type="button" data-action="bulkArchive">Bulk Archive</button>
          </div>
        </div>
      </div>
    </div>

    <div class="summary">
      <div class="stat"><div class="k">Total</div><div class="v"><%= kpiData.total ?? 0 %></div><div class="s">All assignments</div></div>
      <div class="stat"><div class="k">Published</div><div class="v"><%= kpis.published ?? 0 %></div><div class="s">Visible to students</div></div>
      <div class="stat"><div class="k">Draft</div><div class="v"><%= kpiData.draft ?? 0 %></div><div class="s">Still preparing</div></div>
      <div class="stat"><div class="k">Archived</div><div class="v"><%= kpiData.archived ?? 0 %></div><div class="s">Hidden history</div></div>
    </div>

    <div class="content">
      <!-- LEFT -->
      <section class="card">
        <div class="bulk-row">
          <div class="bulk-left">
            <input id="selectAll" type="checkbox" />
            <label for="selectAll">Select all on this page</label>
            <span class="pill info"><span id="selCount">0</span> selected</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button class="btn light" type="button" data-action="clearPreview">Clear preview</button>
          </div>
        </div>

        <div class="grid" id="assignmentGrid">
          <% if (items.length) { %>
            <% items.forEach(a => { %>
              <div class="acard"
                data-id="<%= a._id %>"
                data-title="<%= a.title || '' %>"
                data-courseid="<%= a.course ? (a.course._id || a.course) : '' %>"
                data-coursename="<%= a.course?.title || a.course?.code || a.courseName || '' %>"
                data-duedate="<%= a.dueDate ? new Date(a.dueDate).toISOString().slice(0,16) : '' %>"
                data-points="<%= (a.totalPoints ?? 100) %>"
                data-status="<%= a.status || 'draft' %>"
                data-instructions="<%= a.instructions || '' %>"
                data-rubric="<%= (a.rubric || '').replace(/\n/g,'\\n') %>"
                data-attachments="<%= (Array.isArray(a.attachments)?a.attachments.join('||'):'') %>"
              >
                <div class="row">
                  <div style="min-width:0">
                    <div class="aname"><%= a.title %></div>
                    <div class="mini">
                      <span class="tag"><%= a.course?.title || a.course?.code || a.courseName || "Course" %></span>
                      <span class="tag">Points: <%= (a.totalPoints ?? 100) %></span>
                      <% if (a.dueDate) { %><span class="tag">Due: <%= new Date(a.dueDate).toLocaleString() %></span><% } %>
                    </div>
                    <div class="mini" style="margin-top:6px;">
                      <%= (a.instructions || "").slice(0,110) %><%= (a.instructions || "").length>110 ? "..." : "" %>
                    </div>
                  </div>

                  <div>
                    <% if (a.status === "published") { %>
                      <span class="badge b-pub">Published</span>
                    <% } else if (a.status === "archived") { %>
                      <span class="badge b-arch">Archived</span>
                    <% } else if (a.status === "closed") { %>
                      <span class="badge b-closed">Closed</span>
                    <% } else { %>
                      <span class="badge b-draft">Draft</span>
                    <% } %>

                    <div class="actions">
                      <button class="btn-xs" type="button" data-action="viewAssign" data-id="<%= a._id %>">View</button>
                      <button class="btn-xs" type="button" data-action="editAssign" data-id="<%= a._id %>">Edit</button>
                      <div class="menu">
                        <button class="btn-xs" type="button" data-action="toggleRowMenu" data-id="<%= a._id %>">⋮</button>
                        <div class="menu-panel" id="rowMenu-<%= a._id %>">
                          <% if (a.status !== "published") { %>
                            <button type="button" data-action="publishAssign" data-id="<%= a._id %>">Publish</button>
                          <% } else { %>
                            <button type="button" data-action="unpublishAssign" data-id="<%= a._id %>">Unpublish</button>
                          <% } %>
                          <button type="button" data-action="archiveAssign" data-id="<%= a._id %>">Archive</button>
                          <button class="danger" type="button" data-action="deleteAssign" data-id="<%= a._id %>">Delete</button>
                        </div>
                      </div>
                    </div>

                    <div style="margin-top:8px;display:flex;justify-content:flex-end">
                      <input class="selChk" type="checkbox" data-id="<%= a._id %>"/>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="hint">
              <div class="strong">No assignments found</div>
              <div class="muted" style="margin-top:6px;">Create your first assignment or adjust filters.</div>
            </div>
          <% } %>
        </div>

        <div style="margin-top:12px;display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
          <div class="muted">
            Page <b><%= query?.page || 1 %></b> / <b><%= query?.totalPages || 1 %></b> • Total <b><%= query?.total || 0 %></b>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <% const p = Number(query?.page||1); %>
            <% if (p > 1) { %>
              <a class="btn light" href="/admin/assignments?<%= new URLSearchParams({...query, page: p-1}).toString() %>" style="text-decoration:none;display:inline-flex;align-items:center;">← Prev</a>
            <% } %>
            <% if (p < (query?.totalPages||1)) { %>
              <a class="btn light" href="/admin/assignments?<%= new URLSearchParams({...query, page: p+1}).toString() %>" style="text-decoration:none;display:inline-flex;align-items:center;">Next →</a>
            <% } %>
          </div>
        </div>
      </section>

      <!-- RIGHT -->
      <aside class="card">
        <div class="preview-title">Assignment Preview</div>
        <div class="small-muted">Click an assignment card to preview details.</div>
        <div class="divider"></div>

        <div class="preview-row">
          <div class="preview-label">Title</div>
          <div class="preview-value" id="pvTitle">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Course</div>
          <div class="preview-value" id="pvCourse">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Due Date</div>
          <div class="preview-value" id="pvDue">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Points</div>
          <div class="preview-value" id="pvPoints">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Status</div>
          <div class="preview-value" id="pvStatus">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Instructions</div>
          <div class="preview-value" id="pvInstr">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Rubric</div>
          <div class="preview-value" id="pvRubric">—</div>
        </div>
        <div class="preview-row">
          <div class="preview-label">Attachments</div>
          <div class="preview-value" id="pvAttach">—</div>
        </div>

        <div class="preview-actions">
          <button class="btn light" type="button" data-action="editCurrent">Edit</button>
          <button class="btn light" type="button" data-action="publishCurrent">Publish</button>
          <button class="btn light" type="button" data-action="archiveCurrent">Archive</button>
          <button class="btn danger" type="button" data-action="deleteCurrent">Delete</button>
        </div>

        <!-- Hidden forms -->
        <form id="publishForm" method="POST" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        </form>
        <form id="archiveForm" method="POST" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        </form>
        <form id="deleteForm" method="POST" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        </form>
        <form id="bulkForm" method="POST" action="/admin/assignments/bulk" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <input type="hidden" name="action" id="bulkActionVal" value="">
          <input type="hidden" name="ids" id="bulkIdsVal" value="">
        </form>
      </aside>
    </div>
  </main>
</div>

<!-- Modal: Add/Edit Assignment -->
<div class="backdrop" id="assignModal" aria-hidden="true">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="assignModalTitle">New Assignment</div>
      <button class="btn light" type="button" data-action="closeAssign">Close</button>
    </div>

    <form id="assignForm" method="POST" action="/admin/assignments">
      <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

      <div class="tabs" id="mTabs">
        <button class="tab active" type="button" data-tab="basic">Basic</button>
        <button class="tab" type="button" data-tab="rubric">Rubric</button>
        <button class="tab" type="button" data-tab="attach">Attachments</button>
      </div>

      <div class="modal-grid">
        <div>
          <!-- BASIC TAB -->
          <div id="tab-basic">
            <div class="field">
              <label>Title</label>
              <input id="mTitle" name="title" placeholder="e.g., Data Structures — Assignment 1" required />
            </div>

            <div class="field">
              <label>Course</label>
              <select id="mCourse" name="course" required>
                <option value="">— select course —</option>
                <% (courses || []).forEach(c => { %>
                  <option value="<%= c._id %>"><%= c.title || c.code || "Course" %></option>
                <% }) %>
              </select>
            </div>

            <div style="display:flex;gap:10px;flex-wrap:wrap;">
              <div class="field" style="flex:1">
                <label>Due Date</label>
                <input id="mDue" name="dueDate" type="datetime-local" />
              </div>
              <div class="field" style="flex:1">
                <label>Total Points</label>
                <input id="mPoints" name="totalPoints" type="number" min="0" max="1000" value="100" />
              </div>
            </div>

            <div class="field">
              <label>Status</label>
              <select id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
                <option value="closed">Closed</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field">
              <label>Instructions</label>
              <textarea id="mInstr" name="instructions" placeholder="Describe what students must do, rules, submission format, etc."></textarea>
            </div>
          </div>

          <!-- RUBRIC TAB -->
          <div id="tab-rubric" style="display:none;">
            <div class="hint">
              Add rubric items (one per line). Example: <b>Correctness (40)</b>, <b>Documentation (20)</b>, <b>Presentation (10)</b>.
            </div>
            <div class="divider"></div>
            <div class="field">
              <label>Rubric</label>
              <textarea id="mRubric" name="rubric" placeholder="Correctness (40)&#10;Code quality (30)&#10;Documentation (20)&#10;Presentation (10)"></textarea>
            </div>
          </div>

          <!-- ATTACH TAB -->
          <div id="tab-attach" style="display:none;">
            <div class="hint">
              For now, use URLs (one per line). Later you can wire real file uploads.
            </div>
            <div class="divider"></div>
            <div class="field">
              <label>Attachments (URLs)</label>
              <textarea id="mAttach" placeholder="https://...&#10;https://..."></textarea>
            </div>
            <div id="mAttachWrap"></div>
          </div>
        </div>

        <div>
          <div class="hint">
            <b>Workflow:</b><br/>
            • Draft → prepare content.<br/>
            • Publish → visible to students.<br/>
            • Closed → no more submissions.<br/>
            • Archive → hidden but retained.<br/><br/>
            <b>Tip:</b> Use bulk publish for weekly assignments.
          </div>

          <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
            <button class="btn primary" type="button" data-action="saveAssign">Save</button>
            <button class="btn ghost" type="button" data-action="closeAssign">Cancel</button>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Import CSV -->
<div class="backdrop" id="importModal" aria-hidden="true">
  <div class="modal" style="width:760px">
    <div class="modal-header">
      <div class="modal-title">Import Assignments (CSV)</div>
      <button class="btn light" type="button" data-action="closeImport">Close</button>
    </div>

    <form method="POST" action="/admin/assignments/import" enctype="multipart/form-data">
      <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

      <div class="hint" style="margin-top:10px">
        CSV headers: <b>title,courseCode,dueDate,totalPoints,status,instructions,rubric,attachments</b><br/>
        attachments = URLs separated by <b>||</b><br/>
        dueDate format: <b>YYYY-MM-DD HH:mm</b> or <b>YYYY-MM-DDTHH:mm</b>
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Select CSV File</label>
        <input type="file" name="file" accept=".csv,text/csv" required />
      </div>

      <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn primary" type="submit">Import</button>
        <button class="btn ghost" type="button" data-action="closeImport">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/navbar.js" defer></script>
