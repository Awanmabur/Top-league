<%- include("../.././partials/header") %>
<%- include("../.././partials/navbar") %>

<main class="main">
  <section class="tab active" id="dashboard">
    <div class="topbar">
      <div class="topbar-left">
        <div class="page-title">
          <h2>Dashboard Overview</h2>
          <p>Welcome back, <%= user?.name || user?.fullName || "Admin" %> — here's what's happening across your campus</p>
        </div>

        <div class="topbar-right">
          <form class="search" role="search" method="GET" action="/admin/search">
            <i class="fa fa-magnifying-glass"></i>
            <input id="searchInput" name="q" placeholder="Search students, staff, programs..." />
          </form>

          <a class="notif-pill" href="/admin/notifications">
            <span>Notifications</span>
            <span class="chip" id="notifCount"><%= dashboardData?.notificationsCount || 0 %></span>
          </a>

          <div class="avatar">
            <div class="avatar-circle">
              <%= ((user?.name || user?.fullName || "A").charAt(0)).toUpperCase() %>
            </div>
            <div class="avatar-meta">
              <strong><%= user?.name || user?.fullName || "Admin User" %></strong>
              <span><%= user?.role || "Admin" %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- KPIs -->
    <section class="grid grid-4">
      <article class="card stat">
        <div class="stat-head">
          <div>
            <div class="label">Total Students</div>
            <div class="value" id="totalStudents"><%= (stats?.totalStudents || 0).toLocaleString() %></div>
          </div>
          <div class="stat-meta">
            <span>New this month</span>
            <strong class="accent">+<%= (stats?.newStudentsThisMonth || 0).toLocaleString() %></strong>
          </div>
        </div>
        <div class="spark-wrap"><canvas id="studentsTrend"></canvas></div>
      </article>

      <article class="card stat">
        <div class="stat-head">
          <div>
            <div class="label">Pending Applications</div>
            <div class="value" id="pendingApps"><%= (stats?.pendingApps || 0).toLocaleString() %></div>
          </div>
          <div class="stat-meta">
            <span>Avg. review time</span>
            <strong class="warn"><%= stats?.avgReviewTime || "48 hrs" %></strong>
          </div>
        </div>
        <div class="spark-wrap"><canvas id="appsTrend"></canvas></div>
      </article>

      <article class="card stat">
        <div class="stat-head">
          <div>
            <div class="label">Outstanding Fees</div>
            <div class="value" id="outstandingFees">
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.outstandingFees || 0) %>
            </div>
          </div>
          <div class="stat-meta">
            <span>Students owing</span>
            <strong class="danger"><%= (stats?.studentsOwing || 0).toLocaleString() %></strong>
          </div>
        </div>
        <div class="spark-wrap"><canvas id="feesTrend"></canvas></div>
      </article>

      <article class="card stat">
        <div class="stat-head">
          <div>
            <div class="label">Portal Health</div>
            <div class="value" id="portalUptime"><%= stats?.portalUptime || 98 %>%</div>
          </div>
          <div class="stat-meta">
            <span>Active users</span>
            <strong class="accent"><%= (stats?.activeUsers || 0).toLocaleString() %></strong>
          </div>
        </div>
        <div class="spark-wrap"><canvas id="uptimeTrend"></canvas></div>
      </article>
    </section>

    <!-- Snapshot -->
    <section class="card">
      <div class="card-head">
        <div>
          <h3>Admissions Snapshot</h3>
          <p>Intake: Live • Current Month</p>
        </div>
        <div class="card-actions">
          <a class="btn" href="/admin/applications">View Applications</a>
          <a class="btn secondary" href="/admin/applications/export/csv">Export CSV</a>
        </div>
      </div>

      <div class="grid grid-3 snap-grid">
        <div class="softbox">
          <div class="kpi"><span>Submitted</span><strong><%= dashboardData?.admissions?.submitted || 0 %></strong></div>
          <div class="bar"><div class="barfill" style="width:<%= dashboardData?.admissions?.submittedPct || 0 %>%"></div></div>

          <div class="kpi"><span>Verified</span><strong><%= dashboardData?.admissions?.verified || 0 %></strong></div>
          <div class="bar"><div class="barfill" style="width:<%= dashboardData?.admissions?.verifiedPct || 0 %>%"></div></div>

          <div class="kpi"><span>Accepted</span><strong><%= dashboardData?.admissions?.accepted || 0 %></strong></div>
          <div class="bar"><div class="barfill" style="width:<%= dashboardData?.admissions?.acceptedPct || 0 %>%"></div></div>
        </div>

        <div class="softbox">
          <div class="softhead">
            <h4>Top Countries</h4>
            <span>last 30 days</span>
          </div>

          <div class="donut-row">
            <svg class="donut" viewBox="0 0 42 42" id="donutCountries"></svg>
            <div class="legend" id="countriesLegend"></div>
          </div>
        </div>

        <div class="softbox">
          <div class="softhead">
            <h4>Students by Department</h4>
            <span>updated live</span>
          </div>

          <svg class="dept" id="deptChart"></svg>

          <div class="soft-actions">
            <a class="btn secondary" href="/admin/students">Students</a>
            <a class="btn secondary" href="/admin/programs">Programs</a>
            <a class="btn" href="/admin/departments">Departments</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 3 columns -->
    <section class="grid grid-3">
      <section class="card">
        <div class="card-head">
          <div>
            <h3>Recent Activity</h3>
            <p>Last 10 actions</p>
          </div>
          <div class="card-actions">
            <a class="btn secondary" href="/admin/helpdesk">Helpdesk</a>
            <a class="btn" href="/admin/audit-log">Audit Log</a>
          </div>
        </div>

        <div class="list">
          <% if (dashboardData?.recentActivity?.length) { %>
            <% dashboardData.recentActivity.forEach(item => { %>
              <div class="list-item">
                <%= item.text %>
                <span class="muted"><%= item.time %></span>
              </div>
            <% }) %>
          <% } else { %>
            <div class="list-item">No recent activity <span class="muted">Live</span></div>
          <% } %>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div>
            <h3>Announcements</h3>
            <p>Internal updates</p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/announcements/new">New</a>
            <a class="btn secondary" href="/admin/announcements">Manage</a>
          </div>
        </div>

        <div class="list">
          <% if (dashboardData?.announcements?.length) { %>
            <% dashboardData.announcements.forEach(item => { %>
              <div class="list-item">
                📣 <%= item.title %>
                <span class="muted"><%= item.status %></span>
              </div>
            <% }) %>
          <% } else { %>
            <div class="list-item">No announcements yet <span class="muted">Empty</span></div>
          <% } %>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div>
            <h3>System Status</h3>
            <p>Last 24 hours</p>
          </div>
          <div class="card-actions">
            <a class="btn secondary" href="/admin/system/monitoring">Monitoring</a>
            <a class="btn" href="/admin/system/diagnostics">Diagnostics</a>
          </div>
        </div>

        <div class="sys">
          <div class="sys-row">
            <div class="kpi"><span>Uptime</span><strong class="ok"><%= dashboardData?.systemStatus?.uptime || 99.2 %>%</strong></div>
            <div class="bar"><div class="barfill" style="width:<%= dashboardData?.systemStatus?.uptime || 99.2 %>%"></div></div>
          </div>

          <div class="sys-row">
            <div class="kpi"><span>Errors (24h)</span><strong class="danger"><%= dashboardData?.systemStatus?.errors24h || 13 %></strong></div>
            <div class="bar dangerbar"><div class="barfill" style="width:<%= Math.min((dashboardData?.systemStatus?.errors24h || 13) * 2, 100) %>%"></div></div>
          </div>

          <div class="sys-row">
            <div class="kpi"><span>DB lag</span><strong><%= dashboardData?.systemStatus?.dbLag || "0s" %></strong></div>
            <div class="bar okbar"><div class="barfill" style="width:2%"></div></div>
          </div>

          <div class="sys-row">
            <div class="kpi"><span>Storage</span><strong><%= dashboardData?.systemStatus?.storage || 64 %>%</strong></div>
            <div class="bar"><div class="barfill" style="width:<%= dashboardData?.systemStatus?.storage || 64 %>%"></div></div>
          </div>
        </div>
      </section>
    </section>

    <!-- Tables row -->
    <section class="grid grid-3">
      <section class="card">
        <div class="card-head">
          <div>
            <h3>Recent Students</h3>
            <p>Enrolled this month</p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/students">View All</a>
            <a class="btn secondary" href="/admin/students/import">Import</a>
          </div>
        </div>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Student</th>
                <th>Program</th>
                <th>Status</th>
                <th class="right">Balance</th>
              </tr>
            </thead>
            <tbody id="recentStudents"></tbody>
          </table>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div>
            <h3>Pending Applications</h3>
            <p>Action required</p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/applications">View All</a>
            <a class="btn secondary" href="/admin/intakes">Intakes</a>
          </div>
        </div>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Applicant</th>
                <th>Program</th>
                <th>Country</th>
                <th class="right">Action</th>
              </tr>
            </thead>
            <tbody id="pendingAppsTable"></tbody>
          </table>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div>
            <h3>Finance Snapshot</h3>
            <p>Month-to-date</p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/finance">Open</a>
            <a class="btn secondary" href="/admin/finance/export">Export</a>
          </div>
        </div>

        <div class="fin">
          <div class="kpi">
            <span>Collected</span>
            <strong>
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.collected || 0) %>
            </strong>
          </div>

          <div class="kpi">
            <span>Pending</span>
            <strong class="danger">
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.pending || 0) %>
            </strong>
          </div>

          <div class="kpi">
            <span>Refunds</span>
            <strong>
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.refunds || 0) %>
            </strong>
          </div>

          <div class="kpi">
            <span>Offline payments</span>
            <strong>
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.offlinePayments || 0) %>
            </strong>
          </div>
        </div>

        <div class="canvas-wrap">
          <canvas id="revenueChart"></canvas>
        </div>
      </section>
    </section>

    <!-- Shortcuts -->
    <section class="card">
      <div class="card-head">
        <div>
          <h3>Administration Shortcuts</h3>
          <p>Quick admin actions</p>
        </div>
      </div>

      <div class="shortcuts">
        <a class="btn" href="/admin/students/new">➕ Add Student</a>
        <a class="btn" href="/admin/staff/new">➕ Add Staff</a>
        <a class="btn" href="/admin/programs/new">➕ Add Program</a>
        <a class="btn" href="/admin/courses/new">➕ Add Course</a>
        <a class="btn secondary" href="/admin/settings">⚙️ Settings</a>
        <a class="btn secondary" href="/admin/billing">🧾 Billing</a>
        <a class="btn secondary" href="/admin/storage">📁 Storage</a>
        <a class="btn" href="/admin/announcements/new">📣 New Announcement</a>
      </div>
    </section>
  </section>
</main>

<script id="dashboard-json" type="application/json"><%- JSON.stringify(dashboardData || {}) %></script>
  

<%- include("../.././partials/footer") %>