<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Inquiries — CampusSaaS</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:240px}
    .textarea{width:100%;min-height:120px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);gap:12px}

    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1080px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:wrap;
      max-width:100%;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
      overflow-x:hidden;
    }

    .modal-backdrop.show{
      display:flex;
    }

    .modal{
      width:min(1020px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      margin:auto;
    }

    .modal.sm{
      width:min(760px,100%);
    }

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      flex:0 0 auto;
      background:#fff;
    }

    .modal-title{
      font-weight:900;
      font-size:18px;
    }

    .modal-body{
      padding:16px 18px;
      flex:1 1 auto;
      min-height:0;
      overflow-y:auto;
      overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      flex:0 0 auto;
      background:#fff;
      flex-wrap:wrap;
      position:relative;
      z-index:2;
      box-shadow:0 -8px 18px rgba(0,0,0,.04);
    }

    .json-data{display:none !important}

    .view-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
      margin-bottom:14px;
    }

    .view-card{
      padding:14px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:16px;
      background:#fff;
      min-width:0;
    }

    .view-label{
      font-size:12px;
      color:#6b7280;
      margin-bottom:6px;
    }

    .view-value{
      font-weight:800;
      word-break:break-word;
    }

    .view-message{
      padding:14px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:16px;
      background:#fff;
      white-space:pre-wrap;
      line-height:1.65;
    }

    .view-section-title{
      font-weight:900;
      margin-bottom:8px;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
      .top-actions .btn{padding-inline:12px}
      .view-grid{grid-template-columns:1fr}
    }

    @media (max-width: 520px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      .top-actions{gap:6px}
      .top-actions .btn{font-size:12px}
      .actions{justify-content:flex-start}
      table{min-width:980px}

      .modal-backdrop{
        padding:30px 12px;
      }

      .modal{
        max-height:calc(100dvh - 60px);
        border-radius:20px;
      }

      .modal-header,
      .modal-body,
      .modal-footer{
        padding-left:14px;
        padding-right:14px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <% if (success) { %>
        <div class="flash-wrap">
          <div class="flash flash-success"><%= success %></div>
        </div>
      <% } %>

      <% if (error) { %>
        <div class="flash-wrap">
          <div class="flash flash-error"><%= error %></div>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Inquiries</div>
          <div class="subtitle">Review messages submitted from the public school profile contact form.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
          <button class="btn light" id="btnRefresh" type="button"><i class="fa-solid fa-rotate"></i> Refresh</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">All inquiries</div>
        </div>
        <div class="card">
          <div class="section-title">New</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= kpis?.newCount || 0 %></div>
          <div class="muted">Need attention</div>
        </div>
        <div class="card">
          <div class="section-title">Read</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.readCount || 0 %></div>
          <div class="muted">Reviewed</div>
        </div>
        <div class="card">
          <div class="section-title">Resolved</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.resolvedCount || 0 %></div>
          <div class="muted">Closed</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/inquiries">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, contact, message, school code..." />
            <select class="select" name="status">
              <option value="all" <%= query?.status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="new" <%= query?.status === 'new' ? 'selected' : '' %>>New</option>
              <option value="read" <%= query?.status === 'read' ? 'selected' : '' %>>Read</option>
              <option value="resolved" <%= query?.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip active" data-view="list" type="button"><i class="fa-solid fa-list"></i> List</button>
              <button class="chip" data-view="summary" type="button"><i class="fa-solid fa-chart-column"></i> Summary</button>
            </div>
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/inquiries"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">inquiries</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkRead" type="button"><i class="fa-solid fa-envelope-open"></i> Mark Read</button>
            <button class="btn-xs" id="bulkResolve" type="button"><i class="fa-solid fa-circle-check"></i> Resolve</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title" id="panelTitle">Inquiries</div>
              <div class="section-sub" id="panelSub">Manage incoming contact messages.</div>
            </div>
            <div class="muted" id="resultMeta">—</div>
          </div>

          <div id="view-list" style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                    <th>Name</th>
                    <th>Contact</th>
                    <th>Message</th>
                    <th>School Code</th>
                    <th>Created</th>
                    <th>Status</th>
                    <th style="text-align:right;width:260px;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbody"></tbody>
              </table>
            </div>
          </div>

          <div id="view-summary" style="display:none;margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Status</th>
                    <th>Count</th>
                    <th>Description</th>
                  </tr>
                </thead>
                <tbody id="tbodySummary"></tbody>
              </table>
            </div>
          </div>

          <div class="note" style="margin-top:12px;">
            <strong>Admin controls included:</strong> view inquiry, mark as read, resolve, delete, bulk actions, and quick filtering.
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast operations for common workflow.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Review New Messages</div>
                <div class="muted">Focus on unread inquiries</div>
              </div>
              <button class="btn-xs" id="quickNew" type="button"><i class="fa-solid fa-envelope"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Resolved Messages</div>
                <div class="muted">See completed inquiries</div>
              </div>
              <button class="btn-xs" id="quickResolved" type="button"><i class="fa-solid fa-circle-check"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Refresh Page</div>
                <div class="muted">Reload latest messages</div>
              </div>
              <button class="btn-xs" id="quickRefresh" type="button"><i class="fa-solid fa-rotate"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Inquiry Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card">
            <div class="view-label">Name</div>
            <div class="view-value" id="vName">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Contact</div>
            <div class="view-value" id="vContact">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">School Code</div>
            <div class="view-value" id="vSchoolCode">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Status</div>
            <div class="view-value" id="vStatus">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Created</div>
            <div class="view-value" id="vCreated">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Updated</div>
            <div class="view-value" id="vUpdated">—</div>
          </div>
        </div>

        <div class="view-section-title">Message</div>
        <div class="view-message" id="vMessage">—</div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <textarea id="inquiriesData" class="json-data" aria-hidden="true"><%- JSON.stringify(inquiries || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/admin-inquiries.js"></script>
</body>
</html>