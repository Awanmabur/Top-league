<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Departments</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(280px,.45fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1560px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-name{width:300px}
    .col-code{width:140px}
    .col-faculty{width:220px}
    .col-hod{width:220px}
    .col-email{width:230px}
    .col-phone{width:150px}
    .col-programs{width:110px}
    .col-courses{width:110px}
    .col-status{width:130px}
    .col-actions{width:250px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .dept-main{min-width:0}

    .dept-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .dept-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1080px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(900px,100%)}
    .modal.md{width:min(980px,100%)}
    .modal.lg{width:min(1080px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:6px 10px;
      border-radius:999px;
      background:#eef2ff;
      color:#3730a3;
      font-size:12px;
      font-weight:800;
    }

    .multi-select{
      min-height:170px;
      padding:8px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      width:100%;
    }

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1560px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Departments</div>
          <div class="subtitle">Create, edit, import, export, print and manage departments.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Department</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Operational departments</div>
        </div>
        <div class="card">
          <div class="section-title">Inactive</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.inactive || 0 %></div>
          <div class="muted">Currently disabled</div>
        </div>
        <div class="card">
          <div class="section-title">Without HOD</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.withoutHod || 0 %></div>
          <div class="muted">Needs assignment</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/departments">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, code, email, phone..." />

            <select class="select" name="faculty">
              <option value="">All Faculties</option>
              <% (faculties || []).forEach(function(f){ %>
                <option value="<%= String(f._id) %>" <%= String(query?.faculty || '') === String(f._id) ? 'selected' : '' %>>
                  <%= f.name %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= query?.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/departments"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">department(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <button class="btn-xs" id="bulkDeactivate" type="button"><i class="fa-solid fa-circle-pause"></i> Inactivate</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Departments Table</div>
              <div class="section-sub">Showing <%= departments.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-name">Department</th>
                    <th class="col-code">Code</th>
                    <th class="col-faculty">Faculty</th>
                    <th class="col-hod">HOD</th>
                    <th class="col-email">Email</th>
                    <th class="col-phone">Phone</th>
                    <th class="col-programs">Programs</th>
                    <th class="col-courses">Courses</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyDepartments"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>

            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.faculty) params.set("faculty", query.faculty);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/admin/departments?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Active Department</div>
                <div class="muted">Pre-fill status as active</div>
              </div>
              <button class="btn-xs" id="quickActive" type="button"><i class="fa-solid fa-building"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Inactive Department</div>
                <div class="muted">Pre-fill status as inactive</div>
              </div>
              <button class="btn-xs" id="quickInactive" type="button"><i class="fa-solid fa-pause"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Import From CSV</div>
                <div class="muted">Bulk create departments safely</div>
              </div>
              <button class="btn-xs" id="quickImport" type="button"><i class="fa-solid fa-file-import"></i></button>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section-title">CSV Import Format</div>
          <div class="note" style="margin-top:10px;">
            Required columns: <strong>name</strong><br>
            Optional columns: code, facultyCode, status, officeLocation, publicEmail, phone, notes
          </div>
        </aside>
      </div>
    </main>
  </div>

  <!-- Add/Edit Modal -->
  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Department</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="deptForm" method="POST" action="/admin/departments">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Department Name</label>
              <input class="input" id="mName" name="name" required />
            </div>

            <div class="field">
              <label>Department Code</label>
              <input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" />
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
              </select>
            </div>

            <div class="field">
              <label>Faculty</label>
              <select class="select" id="mFaculty" name="faculty">
                <option value="">— Select Faculty —</option>
                <% (faculties || []).forEach(function(f){ %>
                  <option value="<%= String(f._id) %>" data-code="<%= f.code || '' %>"><%= f.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Head of Department</label>
              <select class="select" id="mHod" name="headOfDepartment">
                <option value="">— Not Assigned —</option>
                <% (staffList || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' — ' + s.role) : '' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Office Location</label>
              <input class="input" id="mOffice" name="officeLocation" />
            </div>

            <div class="field">
              <label>Public Email</label>
              <input class="input" id="mEmail" name="publicEmail" type="email" />
            </div>

            <div class="field">
              <label>Phone</label>
              <input class="input" id="mPhone" name="phone" />
            </div>

            <div class="field">
              <label>Description</label>
              <input class="input" id="mDescription" name="description" />
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes</label>
            <textarea class="textarea" id="mNotes" name="notes" maxlength="2000"></textarea>
            <div class="muted" id="notesCount">0 / 2000</div>
          </div>

          <div class="divider"></div>

          <div class="form-grid">
            <div class="field">
              <label>Programs</label>
              <input class="input" id="mProgramsSearch" placeholder="Search programs..." />
              <select class="multi-select" id="mProgramsSel" multiple>
                <% (programs || []).forEach(function(p){ %>
                  <option value="<%= String(p._id) %>"><%= p.code ? (p.code + ' — ') : '' %><%= p.name %></option>
                <% }) %>
              </select>
              <div class="muted">Hold Ctrl / Cmd to select multiple</div>
              <div id="mProgramsWrap"></div>
            </div>

            <div class="field">
              <label>Courses</label>
              <input class="input" id="mCoursesSearch" placeholder="Search courses..." />
              <select class="multi-select" id="mCoursesSel" multiple>
                <% (courses || []).forEach(function(c){ %>
                  <option value="<%= String(c._id) %>"><%= c.code %> — <%= c.title %></option>
                <% }) %>
              </select>
              <div class="muted">Hold Ctrl / Cmd to select multiple</div>
              <div id="mCoursesWrap"></div>
            </div>

            <div class="field">
              <label>Help</label>
              <div class="note">
                Department code auto-generates from faculty code + name initials when left blank.
              </div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Department</button>
        </div>
      </form>
    </div>
  </div>

  <!-- View Modal -->
  <div class="modal-backdrop" id="mView">
    <div class="modal md">
      <div class="modal-header">
        <div class="modal-title">Department Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Department</label>
            <div class="view-input" id="vName">—</div>
          </div>

          <div class="field">
            <label>Code</label>
            <div class="view-input" id="vCode">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Faculty</label>
            <div class="view-input" id="vFaculty">—</div>
          </div>

          <div class="field">
            <label>Head of Department</label>
            <div class="view-input" id="vHod">—</div>
          </div>

          <div class="field">
            <label>Office</label>
            <div class="view-input" id="vOffice">—</div>
          </div>

          <div class="field">
            <label>Email</label>
            <div class="view-input" id="vEmail">—</div>
          </div>

          <div class="field">
            <label>Phone</label>
            <div class="view-input" id="vPhone">—</div>
          </div>

          <div class="field">
            <label>Description</label>
            <div class="view-input" id="vDescription">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Notes</label>
          <div class="view-input multiline" id="vNotes">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Programs</label>
          <div class="view-input multiline">
            <div class="tag-list" id="vPrograms"></div>
          </div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Courses</label>
          <div class="view-input multiline">
            <div class="tag-list" id="vCourses"></div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <!-- Import Modal -->
  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Departments CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="importForm" method="POST" action="/admin/departments/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="field">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>

          <div class="note" style="margin-top:12px;">
            Example columns:<br>
            <strong>name,code,facultyCode,status,officeLocation,publicEmail,phone,notes</strong>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkStatusForm" method="POST" action="/admin/departments/bulk-status" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="status" id="bulkStatus">
  </form>

  <form id="bulkDeleteForm" method="POST" action="/admin/departments/bulk-delete" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkDeleteIds">
  </form>

  <textarea id="departmentsData" class="json-data" aria-hidden="true"><%- JSON.stringify((departments || []).map(function(d){
    return {
      id: String(d._id || ''),
      name: d.name || '',
      code: d.code || '',
      facultyId: d.faculty?._id ? String(d.faculty._id) : (d.faculty ? String(d.faculty) : ''),
      facultyName: d.faculty?.name || '',
      facultyCode: d.faculty?.code || '',
      status: d.status || 'active',
      officeLocation: d.officeLocation || '',
      publicEmail: d.publicEmail || '',
      phone: d.phone || '',
      description: d.description || '',
      notes: d.notes || '',
      hodId: d.headOfDepartment?._id ? String(d.headOfDepartment._id) : '',
      hodName: d.headOfDepartment?.fullName || d.headOfDepartment?.name || '',
      programs: Array.isArray(d.programs) ? d.programs.map(function(x){ return String(x?._id || x); }) : [],
      courses: Array.isArray(d.courses) ? d.courses.map(function(x){ return String(x?._id || x); }) : [],
      programLabels: Array.isArray(d.programLabels) ? d.programLabels : [],
      courseCodes: Array.isArray(d.courseCodes) ? d.courseCodes : []
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/departments.js"></script>
</body>
</html>