<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title><%= (tenant?.name || "Classic Academy") %> — Academic Calendar</title>
<link rel="icon" href="data:," />
<link rel="stylesheet" href="/css/navbar.css" />
<%-include("../.././partials/header") %>
<style>
  
  .topbar{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
  .title{font-size:20px;font-weight:900;color:var(--blue-2)}
  .subtitle{font-size:13px;color:var(--muted)}
  .top-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}

  .search-box{display:flex;align-items:center;gap:8px;background:var(--card);border-radius:10px;border:1px solid #e1e9f7;padding:7px 10px}
  .search-box input{border:none;outline:none;font-size:14px;background:transparent;min-width:220px}
  .select{padding:8px 10px;border-radius:8px;border:1px solid #dbe3f6;background:#fff;font-size:14px}
  .btn{padding:9px 12px;border-radius:8px;border:none;cursor:pointer;font-weight:900;font-size:14px}
  .btn.primary{background:var(--blue);color:#fff}
  .btn.light{background:#eef4ff;color:var(--blue);border:1px solid #dbe3f6}
  .btn.ghost{background:transparent;color:#111827;border:1px solid #e5e7eb}
  .btn.danger{background:#fff1f2;color:var(--danger);border:1px solid #fecdd3}

  .content{display:grid;grid-template-columns:2fr 1fr;gap:18px;align-items:flex-start}
  @media(max-width:1024px){.sidebar{display:none}.content{grid-template-columns:1fr}}

  .card{background:var(--card);border-radius:var(--radius);padding:14px;border:1px solid #e4ecfb;box-shadow:var(--shadow)}
  .summary{display:grid;grid-template-columns:repeat(4,minmax(140px,1fr));gap:12px}
  @media(max-width:860px){.summary{grid-template-columns:repeat(2,minmax(140px,1fr))}}
  .stat{border:1px solid #e7efff;border-radius:12px;padding:12px;background:linear-gradient(180deg,#fff,#fbfdff)}
  .stat .k{font-size:12px;color:var(--muted);font-weight:900}
  .stat .v{margin-top:6px;font-size:18px;font-weight:1000}
  .stat .s{margin-top:4px;font-size:12px;color:#64748b}

  .bulk-row{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap}
  .bulk-left{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
  .bulk-left label{font-size:13px;color:#4b5563}
  .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900}
  .ok{background:#ecfdf3;color:#15803d}
  .warn{background:#fef9c3;color:#92400e}
  .bad{background:#fee2e2;color:#b91c1c}
  .info{background:#eef2ff;color:#3730a3}
  .muted{font-size:12px;color:#6b7280}
  .strong{font-weight:900}

  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:12px}
  .ec{border:1px solid #e6eefc;border-radius:14px;background:#fff;padding:12px;cursor:pointer}
  .ec:hover{border-color:rgba(10,111,191,.35);box-shadow:0 10px 22px rgba(12,38,73,.10)}
  .ec.selected{outline:3px solid rgba(10,111,191,.18);border-color:rgba(10,111,191,.55)}
  .row{display:flex;justify-content:space-between;gap:10px}
  .ename{font-weight:1000;color:var(--blue-2);line-height:1.1}
  .mini{font-size:12px;color:#64748b;margin-top:3px}
  .badge{padding:4px 8px;border-radius:999px;font-size:11px;font-weight:1000;white-space:nowrap}
  .b-active{background:#e6f9ee;color:var(--success)}
  .b-draft{background:#eef2ff;color:var(--accent)}
  .b-arch{background:#fff7ed;color:var(--warning)}

  .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;font-weight:900}
  .btn-xs:hover{background:rgba(10,111,191,.06)}
  .btn-xs.danger{background:#fff1f2;border-color:#fecdd3;color:var(--danger)}
  .actions{display:flex;gap:6px;justify-content:flex-end;margin-top:10px;flex-wrap:wrap}

  .preview-title{font-size:15px;font-weight:1000;color:var(--blue-2)}
  .preview-label{font-size:12px;color:#6b7280;font-weight:900}
  .preview-value{font-size:14px;color:#111827;margin-top:3px}
  .preview-row{margin-top:10px}
  .tag{display:inline-block;padding:6px 9px;border-radius:10px;background:#eef4ff;font-size:12px;color:var(--blue-2);margin-right:6px;margin-top:6px;font-weight:900}
  .small-muted{font-size:12px;color:#6b7280;margin-top:4px}
  .preview-actions{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}

  .backdrop{position:fixed;inset:0;background:rgba(15,23,42,.55);display:none;align-items:center;justify-content:center;padding:20px;z-index:50}
  .modal{width:1020px;max-width:100%;max-height:90vh;overflow:auto;border-radius:14px;background:#fff;box-shadow:0 30px 60px rgba(15,23,42,.35);padding:16px 16px 18px}
  .modal-header{display:flex;justify-content:space-between;align-items:center;gap:10px}
  .modal-title{font-size:18px;font-weight:1100;color:var(--blue-2)}
  .modal-grid{display:grid;grid-template-columns:1.25fr 1fr;gap:14px;margin-top:12px}
  @media(max-width:860px){.modal-grid{grid-template-columns:1fr}}
  .field{display:flex;flex-direction:column;margin-bottom:10px}
  .field label{font-size:12px;font-weight:1000;margin-bottom:5px;color:#374151}
  .field input,.field select,.field textarea{border-radius:10px;border:1px solid #dbe3f6;padding:10px 10px;font-size:14px;outline:none;background:#fff}
  .field textarea{min-height:110px;resize:vertical}
  .divider{height:1px;background:#eef2ff;margin:10px 0}
  .hint{background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:10px;font-size:12px;color:#475569}

  .tabs{display:flex;gap:8px;flex-wrap:wrap;margin:10px 0}
  .tab{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:1000;font-size:12px}
  .tab.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
  .menu{position:relative;display:inline-block}
  .menu-panel{position:absolute;right:0;top:38px;min-width:190px;background:#fff;border:1px solid #e6eefc;border-radius:12px;box-shadow:0 18px 40px rgba(15,23,42,.18);padding:6px;display:none;z-index:5}
  .menu-panel.show{display:block}
  .menu-panel button{width:100%;text-align:left;padding:9px 10px;border:none;background:transparent;border-radius:10px;cursor:pointer;font-weight:900}
  .menu-panel button:hover{background:#f1f6ff}
  .menu-panel .danger:hover{background:#fff1f2}
  .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
</style>
</head>

<body>
<div class="app">
<%-include("../.././partials/navbar") %>
  <main class="main">
    <div class="topbar">
      <div>
        <div class="title">Academic Calendar</div>
        <div class="subtitle">Plan semesters, exams, holidays, registration deadlines and all key academic events.</div>
      </div>

      <div class="top-actions">
        <form action="/admin/academic-calendar" method="GET" style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
          <div class="search-box">
            <svg width="16" height="16" viewBox="0 0 24 24" stroke="#94a3b8" fill="none" stroke-width="1.7">
              <circle cx="11" cy="11" r="6"></circle>
              <path d="M16 16L21 21" stroke-linecap="round"></path>
            </svg>
            <input name="q" value="<%= (query?.q || "") %>" placeholder="Search title, type, term, year." />
          </div>

          <select name="academicYear" class="select">
            <option value="">All Years</option>
            <% (years || []).forEach(y => { %>
              <option value="<%= y %>" <%= (query?.academicYear === y ? "selected" : "") %>><%= y %></option>
            <% }) %>
          </select>

          <select name="term" class="select">
            <option value="">All Terms</option>
            <% (terms || []).forEach(t => { %>
              <option value="<%= t %>" <%= (query?.term === t ? "selected" : "") %>><%= t %></option>
            <% }) %>
          </select>

          <select name="type" class="select">
            <option value="">All Types</option>
            <% (types || []).forEach(t => { %>
              <option value="<%= t %>" <%= (query?.type === t ? "selected" : "") %>><%= t %></option>
            <% }) %>
          </select>

          <select name="status" class="select">
            <option value="">Any Status</option>
            <option value="active" <%= (query?.status === "active" ? "selected" : "") %>>Active</option>
            <option value="draft" <%= (query?.status === "draft" ? "selected" : "") %>>Draft</option>
            <option value="archived" <%= (query?.status === "archived" ? "selected" : "") %>>Archived</option>
          </select>

          <button class="btn light" type="submit">Filter</button>
        </form>

        <button class="btn primary" type="button" data-action="openEvent">+ Add Event</button>

        <div class="menu">
          <button class="btn light" type="button" data-action="toggleTools">Tools ▾</button>
          <div class="menu-panel" id="toolsMenu">
            <button type="button" data-action="openImport">Import CSV</button>
            <a class="btnlink" href="/admin/academic-calendar/export?<%= new URLSearchParams({q:query?.q||'',academicYear:query?.academicYear||'',term:query?.term||'',type:query?.type||'',status:query?.status||''}).toString() %>" style="display:block;text-decoration:none;">
              <button type="button">Export CSV</button>
            </a>
            <button type="button" data-action="bulkApply">Bulk Archive</button>
          </div>
        </div>
      </div>
    </div>

    <div class="summary">
      <div class="stat"><div class="k">Total Events</div><div class="v"><%= (kpis?.total ?? 0) %></div><div class="s">All visible filters</div></div>
      <div class="stat"><div class="k">Active</div><div class="v"><%= (kpis?.active ?? 0) %></div><div class="s">Published events</div></div>
      <div class="stat"><div class="k">Draft</div><div class="v"><%= (kpis?.draft ?? 0) %></div><div class="s">Still preparing</div></div>
      <div class="stat"><div class="k">Archived</div><div class="v"><%= (kpis?.archived ?? 0) %></div><div class="s">Hidden by admin</div></div>
    </div>

    <div class="content">
      <!-- LEFT -->
      <section class="card">
        <div class="bulk-row">
          <div class="bulk-left">
            <input id="selectAll" type="checkbox" />
            <label for="selectAll">Select all on this page</label>
            <span class="pill info"><span id="selCount">0</span> selected</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button class="btn light" type="button" data-action="clearPreview">Clear preview</button>
          </div>
        </div>

        <div class="grid" id="eventGrid">
          <% if ((events||[]).length) { %>
            <% events.forEach(ev => { %>
              <div class="ec"
                data-id="<%= ev._id %>"
                data-title="<%= ev.title || '' %>"
                data-type="<%= ev.type || '' %>"
                data-academicyear="<%= ev.academicYear || '' %>"
                data-term="<%= ev.term || '' %>"
                data-start="<%= ev.startDate ? new Date(ev.startDate).toISOString().slice(0,10) : '' %>"
                data-end="<%= ev.endDate ? new Date(ev.endDate).toISOString().slice(0,10) : '' %>"
                data-status="<%= ev.status || 'draft' %>"
                data-location="<%= ev.location || '' %>"
                data-notes="<%= ev.notes || '' %>"
              >
                <div class="row">
                  <div style="min-width:0">
                    <div class="ename"><%= ev.title %></div>
                    <div class="mini">
                      <span class="tag"><%= ev.type %></span>
                      <span class="tag"><%= ev.academicYear || "—" %></span>
                      <span class="tag"><%= ev.term || "—" %></span>
                    </div>
                    <div class="mini" style="margin-top:6px;">
                      📅 <%= ev.startDate ? new Date(ev.startDate).toDateString() : "—" %>
                      <% if (ev.endDate) { %> → <%= new Date(ev.endDate).toDateString() %> <% } %>
                    </div>
                  </div>
                  <div>
                    <% if (ev.status === "active") { %>
                      <span class="badge b-active">Active</span>
                    <% } else if (ev.status === "archived") { %>
                      <span class="badge b-arch">Archived</span>
                    <% } else { %>
                      <span class="badge b-draft">Draft</span>
                    <% } %>

                    <div class="actions">
                      <button class="btn-xs" type="button" data-action="viewEvent" data-id="<%= ev._id %>">View</button>
                      <button class="btn-xs" type="button" data-action="editEvent" data-id="<%= ev._id %>">Edit</button>
                      <div class="menu">
                        <button class="btn-xs" type="button" data-action="toggleRowMenu" data-id="<%= ev._id %>">⋮</button>
                        <div class="menu-panel" id="rowMenu-<%= ev._id %>">
                          <button type="button" data-action="archiveEvent" data-id="<%= ev._id %>">Archive</button>
                          <button class="danger" type="button" data-action="deleteEvent" data-id="<%= ev._id %>">Delete</button>
                        </div>
                      </div>
                    </div>

                    <div style="margin-top:8px;display:flex;justify-content:flex-end">
                      <input class="selChk" type="checkbox" data-id="<%= ev._id %>"/>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="note">
              <div class="strong">No events found</div>
              <div class="muted" style="margin-top:6px;">Try adjusting filters or add your first academic event.</div>
            </div>
          <% } %>
        </div>

        <div style="margin-top:12px;display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap;">
          <div class="muted">
            Page <b><%= query?.page || 1 %></b> / <b><%= query?.totalPages || 1 %></b> • Total <b><%= query?.total || 0 %></b>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <% const p = Number(query?.page||1); %>
            <% if (p > 1) { %>
              <a class="btn light" href="/admin/academic-calendar?<%= new URLSearchParams({...query, page: p-1}).toString() %>" style="text-decoration:none;display:inline-flex;align-items:center;">← Prev</a>
            <% } %>
            <% if (p < (query?.totalPages||1)) { %>
              <a class="btn light" href="/admin/academic-calendar?<%= new URLSearchParams({...query, page: p+1}).toString() %>" style="text-decoration:none;display:inline-flex;align-items:center;">Next →</a>
            <% } %>
          </div>
        </div>
      </section>

      <!-- RIGHT -->
      <aside class="card">
        <div class="preview-title">Event Preview</div>
        <div class="small-muted">Click an event card to preview details.</div>

        <div class="divider"></div>

        <div class="preview-row">
          <div class="preview-label">Title</div>
          <div class="preview-value" id="pvTitle">—</div>
        </div>

        <div class="preview-row">
          <div class="preview-label">Type</div>
          <div class="preview-value" id="pvType">—</div>
        </div>

        <div class="preview-row">
          <div class="preview-label">Academic Year / Term</div>
          <div class="preview-value" id="pvYT">—</div>
        </div>

        <div class="preview-row">
          <div class="preview-label">Dates</div>
          <div class="preview-value" id="pvDates">—</div>
        </div>

        <div class="preview-row">
          <div class="preview-label">Status</div>
          <div class="preview-value" id="pvStatus">—</div>
        </div>

        <div class="preview-row">
          <div class="preview-label">Location</div>
          <div class="preview-value" id="pvLocation">—</div>
        </div>

        <div class="preview-row">
          <div class="preview-label">Notes</div>
          <div class="preview-value" id="pvNotes">—</div>
        </div>

        <div class="preview-actions">
          <button class="btn light" type="button" data-action="editCurrent">Edit</button>
          <button class="btn light" type="button" data-action="archiveCurrent">Archive</button>
          <button class="btn danger" type="button" data-action="deleteCurrent">Delete</button>
        </div>

        <!-- Hidden forms for actions -->
        <form id="archiveForm" method="POST" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        </form>
        <form id="deleteForm" method="POST" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        </form>
        <form id="bulkForm" method="POST" action="/admin/academic-calendar/bulk-archive" style="display:none;">
          <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
          <input type="hidden" name="ids" id="bulkIdsVal" value="">
        </form>
      </aside>
    </div>
  </main>
</div>

<!-- Modal: Add/Edit Event -->
<div class="backdrop" id="eventModal" aria-hidden="true">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title" id="eventModalTitle">Add Event</div>
      <button class="btn light" type="button" data-action="closeEvent">Close</button>
    </div>

    <form id="eventForm" method="POST" action="/admin/academic-calendar">
      <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

      <div class="modal-grid">
        <div>
          <div class="field">
            <label>Title</label>
            <input id="mTitle" name="title" placeholder="e.g. Semester 1 Opens" required />
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <div class="field" style="flex:1">
              <label>Type</label>
              <select id="mType" name="type" required>
                <option value="">— choose —</option>
                <% (types || ["Semester","Registration","Exam","Holiday","Deadline","Meeting","Other"]).forEach(t=>{ %>
                  <option value="<%= t %>"><%= t %></option>
                <% }) %>
              </select>
            </div>

            <div class="field" style="flex:1">
              <label>Status</label>
              <select id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="active">Active</option>
                <option value="archived">Archived</option>
              </select>
            </div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <div class="field" style="flex:1">
              <label>Academic Year</label>
              <input id="mYear" name="academicYear" placeholder="e.g. 2025/2026" />
            </div>
            <div class="field" style="flex:1">
              <label>Term</label>
              <input id="mTerm" name="term" placeholder="e.g. Semester 1" />
            </div>
          </div>

          <div style="display:flex;gap:10px;flex-wrap:wrap;">
            <div class="field" style="flex:1">
              <label>Start Date</label>
              <input id="mStart" name="startDate" type="date" required />
            </div>
            <div class="field" style="flex:1">
              <label>End Date (optional)</label>
              <input id="mEnd" name="endDate" type="date" />
            </div>
          </div>
        </div>

        <div>
          <div class="hint">
            Use Academic Calendar events for registration, exams, holidays and major milestones. Active events can be shown to students; drafts stay internal.
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Location (optional)</label>
            <input id="mLocation" name="location" placeholder="e.g. Main Hall / Online" />
          </div>

          <div class="field">
            <label>Notes / Description</label>
            <textarea id="mNotes" name="notes" placeholder="Internal or public notes (max 1200 chars)."></textarea>
          </div>

          <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
            <button class="btn primary" type="button" data-action="saveEvent">Save</button>
            <button class="btn ghost" type="button" data-action="closeEvent">Cancel</button>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Modal: Import CSV -->
<div class="backdrop" id="importModal" aria-hidden="true">
  <div class="modal" style="width:720px">
    <div class="modal-header">
      <div class="modal-title">Import Academic Calendar (CSV)</div>
      <button class="btn light" type="button" data-action="closeImport">Close</button>
    </div>

    <form id="importForm" method="POST" action="/admin/academic-calendar/import" enctype="multipart/form-data">
      <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

      <div class="hint" style="margin-top:10px">
        CSV headers supported: <b>title,type,academicYear,term,startDate,endDate,status,location,notes</b>.<br/>
        Dates must be <b>YYYY-MM-DD</b>. Status: active/draft/archived.
      </div>

      <div class="divider"></div>

      <div class="field">
        <label>Select CSV File</label>
        <input type="file" name="file" accept=".csv,text/csv" required />
      </div>

      <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap;">
        <button class="btn primary" type="submit">Import</button>
        <button class="btn ghost" type="button" data-action="closeImport">Cancel</button>
      </div>
    </form>
  </div>
</div>
<script src="/js/navbar.js" defer></script>
<script src="/js/academic-calendar.js" defer></script>
</body>
</html>
