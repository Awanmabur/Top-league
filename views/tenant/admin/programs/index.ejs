<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Programs</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1320px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-program{width:360px}
    .col-department{width:240px}
    .col-faculty{width:200px}
    .col-level{width:140px}
    .col-duration{width:110px}
    .col-seats{width:110px}
    .col-fee{width:150px}
    .col-status{width:140px}
    .col-actions{width:220px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .program-main{min-width:0}

    .program-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .program-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1020px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(980px,100%)}
    .modal.lg{width:min(1020px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:6px 10px;
      border-radius:999px;
      background:#eef2ff;
      color:#3730a3;
      font-size:12px;
      font-weight:800;
    }

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1320px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Programs</div>
          <div class="subtitle">Create, edit, export, print and manage academic programs.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Program</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Live programs</div>
        </div>
        <div class="card">
          <div class="section-title">Draft</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div>
          <div class="muted">Still being prepared</div>
        </div>
        <div class="card">
          <div class="section-title">Archived</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div>
          <div class="muted">Hidden / inactive</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/programs">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, code, faculty, level..." />

            <select class="select" name="department">
              <option value="">All Departments</option>
              <% (departmentsList || []).forEach(function(d){ 
                const label = (d.name || d.title || d.code || "").trim();
                if (!label) return;
                const id = String(d._id);
              %>
                <option value="<%= id %>" <%= String(query?.department || '') === id ? 'selected' : '' %>><%= label %></option>
              <% }) %>
            </select>

            <select class="select" name="faculty">
              <option value="">All Faculties</option>
              <% (facultiesList || []).forEach(function(f){ 
                const label = (f.name || f.code || "").trim();
                if (!label) return;
              %>
                <option value="<%= label %>" <%= query?.faculty === label ? 'selected' : '' %>><%= label %></option>
              <% }) %>
            </select>

            <select class="select" name="level">
              <option value="">All Levels</option>
              <% (levels || []).forEach(function(l){ %>
                <option value="<%= l %>" <%= query?.level === l ? 'selected' : '' %>><%= l %></option>
              <% }) %>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/programs"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">program(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Programs Table</div>
              <div class="section-sub">Showing <%= programs.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-program">Program</th>
                    <th class="col-department">Department</th>
                    <th class="col-faculty">Faculty</th>
                    <th class="col-level">Level</th>
                    <th class="col-duration">Duration</th>
                    <th class="col-seats">Seats</th>
                    <th class="col-fee">Fee</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyPrograms"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong>10</strong>
            </div>

            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.department) params.set("department", query.department);
                  if (query?.faculty) params.set("faculty", query.faculty);
                  if (query?.level) params.set("level", query.level);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/admin/programs?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Bachelor Program</div>
                <div class="muted">Pre-fill level as Bachelor</div>
              </div>
              <button class="btn-xs" id="quickBachelor" type="button"><i class="fa-solid fa-graduation-cap"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Diploma Program</div>
                <div class="muted">Pre-fill level as Diploma</div>
              </div>
              <button class="btn-xs" id="quickDiploma" type="button"><i class="fa-solid fa-certificate"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Master Program</div>
                <div class="muted">Pre-fill level as Master</div>
              </div>
              <button class="btn-xs" id="quickMaster" type="button"><i class="fa-solid fa-user-graduate"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Program</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="programForm" method="POST" action="/admin/programs">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Program Name</label>
              <input class="input" id="mName" name="name" required />
            </div>

            <div class="field">
              <label>Program Code</label>
              <input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" />
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="active">Active</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field">
              <label>Department</label>
              <select class="select" id="mDepartment" name="department" required>
                <option value="">— Select Department —</option>
                <% (departmentsList || []).forEach(function(d){ 
                  const label = (d.name || d.title || d.code || "").trim();
                  if (!label) return;
                %>
                  <option value="<%= d._id %>"><%= label %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Faculty</label>
              <select class="select" id="mFaculty" name="faculty" required>
                <option value="">— Select Faculty —</option>
                <% (facultiesList || []).forEach(function(f){ 
                  const label = (f.name || f.code || "").trim();
                  if (!label) return;
                %>
                  <option value="<%= label %>"><%= label %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Level</label>
              <input class="input" id="mLevel" name="level" required />
            </div>

            <div class="field">
              <label>Duration (Years)</label>
              <input class="input" id="mDurationYears" name="durationYears" type="number" min="0" max="20" />
            </div>

            <div class="field">
              <label>Seats</label>
              <input class="input" id="mSeats" name="seats" type="number" min="0" max="100000" />
            </div>

            <div class="field">
              <label>Fee</label>
              <input class="input" id="mFee" name="fee" type="number" min="0" max="100000000" />
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Short Summary</label>
            <textarea class="textarea" id="mShort" name="short" maxlength="500"></textarea>
            <div class="muted" id="shortCount">0 / 500</div>
          </div>

          <div class="field" style="margin-top:12px;">
            <label>Requirements</label>
            <textarea class="textarea" id="mReqs" name="reqs" maxlength="1200"></textarea>
            <div class="muted" id="reqsCount">0 / 1200</div>
          </div>

          <div class="field" style="margin-top:12px;">
            <label>Modules (comma-separated)</label>
            <input class="input" id="mModules" />
            <div id="mModulesWrap" style="display:none;"></div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Program</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Program Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Program</label>
            <div class="view-input" id="vName">—</div>
          </div>

          <div class="field">
            <label>Code</label>
            <div class="view-input" id="vCode">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Department</label>
            <div class="view-input" id="vDepartment">—</div>
          </div>

          <div class="field">
            <label>Faculty</label>
            <div class="view-input" id="vFaculty">—</div>
          </div>

          <div class="field">
            <label>Level</label>
            <div class="view-input" id="vLevel">—</div>
          </div>

          <div class="field">
            <label>Duration</label>
            <div class="view-input" id="vDuration">—</div>
          </div>

          <div class="field">
            <label>Seats</label>
            <div class="view-input" id="vSeats">—</div>
          </div>

          <div class="field">
            <label>Fee</label>
            <div class="view-input" id="vFee">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Short Summary</label>
          <div class="view-input multiline" id="vShort">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Requirements</label>
          <div class="view-input multiline" id="vReqs">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Modules</label>
          <div class="view-input multiline">
            <div class="tag-list" id="vModules"></div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/programs/bulk-archive" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
  </form>

  <textarea id="programsData" class="json-data" aria-hidden="true"><%- JSON.stringify((programs || []).map(function(p){
    return {
      id: String(p._id || ''),
      name: p.name || '',
      code: p.code || '',
      departmentId: p.department?._id ? String(p.department._id) : (p.department ? String(p.department) : ''),
      departmentName: p.department?.name || p.department?.title || p.department?.code || '',
      faculty: p.faculty || '',
      level: p.level || '',
      durationYears: Number(p.durationYears ?? p.duration ?? 0),
      seats: Number(p.seats || 0),
      fee: Number(p.fee || 0),
      status: p.status || 'draft',
      short: p.short || '',
      reqs: p.reqs || '',
      modules: Array.isArray(p.modules) ? p.modules : []
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/program.js"></script>
</body>
</html>

 