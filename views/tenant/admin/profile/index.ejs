<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • School Profile — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />

  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center;min-width:0}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none;max-width:100%;min-width:0}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);gap:12px}
    .grid-2-even{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .pin{background:rgba(10,111,191,.12);color:#0a6fbf}
    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:980px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:top}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;max-width:100%}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px;min-width:0;flex:1}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .hero{display:grid;grid-template-columns:110px minmax(0,1fr) 280px;gap:14px;align-items:center}
    .hero-logo{width:110px;height:110px;border-radius:22px;overflow:hidden;background:rgba(10,111,191,.08);border:1px solid rgba(13,64,96,.10);display:grid;place-items:center;font-size:36px;font-weight:900;color:#0a6fbf}
    .hero-logo img{width:100%;height:100%;object-fit:cover;display:block}
    .hero-main{min-width:0;display:grid;gap:8px}
    .hero-title{font-size:28px;font-weight:900;line-height:1.1}
    .hero-side{display:grid;gap:10px}
    .mini-kpi{padding:12px;border:1px solid rgba(13,64,96,.10);border-radius:14px;background:#fff}
    .mini-kpi b{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .mini-kpi span{display:block;font-weight:900}
    .avatar-thumb{width:100%;height:140px;border-radius:16px;overflow:hidden;border:1px solid rgba(13,64,96,.10);background:#fff}
    .avatar-thumb img{width:100%;height:100%;object-fit:cover;display:block}
    .dropzone{position:relative;padding:14px;border-radius:14px;border:1px dashed rgba(13,64,96,.22);background:rgba(13,64,96,.03)}
    .dropzone input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer}
    .dropzone-inner{display:flex;align-items:center;gap:12px}
    .dropzone-inner i{font-size:20px;color:#0a6fbf}
    .thumb-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px;margin-top:12px}
    .thumb{position:relative;overflow:hidden;border-radius:12px;border:1px solid rgba(13,64,96,.10);background:#fff}
    .thumb img{width:100%;height:95px;object-fit:cover;display:block}
    .thumb .x{position:absolute;top:6px;right:6px;width:28px;height:28px;border-radius:10px;border:1px solid rgba(255,255,255,.28);background:rgba(2,8,23,.45);color:#fff;cursor:pointer}
    .section-head{display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap;margin-bottom:10px}
    .savebar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .savebar.show{display:flex}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1020px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto}
    .modal.sm{width:min(760px,100%)}
    .modal > form,.modal > div{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field{min-width:0}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%;min-width:0;max-width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .review-card,.faq-card{padding:12px;border:1px solid rgba(13,64,96,.10);border-radius:14px;background:#fff}
    .list-col{display:grid;gap:10px;min-width:0}
    @media (max-width:1100px){.grid-2,.grid-2-even,.grid-3{grid-template-columns:1fr}.hero{grid-template-columns:1fr}.hero-side{grid-template-columns:repeat(3,minmax(0,1fr))}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}.thumb-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.hero-side{grid-template-columns:1fr}}
    @media (max-width:520px){.grid-4{grid-template-columns:1fr}.toolbar .left,.toolbar .right{width:100%}.toolbar .left > *,.toolbar .right > *{max-width:100%}.modal-backdrop{padding:30px 12px}.modal{max-height:calc(100dvh - 60px);border-radius:20px}.modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}}
  </style>
</head>
<body>
<%
  var tenantObj = tenant || {};
  var settings = tenantObj.settings || {};
  var p = settings.profile || {};
  var b = settings.branding || {};
  var contact = p.contact || {};
  var socials = p.socials || {};
  var seo = p.seo || {};
  var admissions = p.admissions || {};
  var locationObj = p.location || {};
  var stats = profileStats || {};
  var schoolUnitsList = Array.isArray(typeof schoolUnits !== "undefined" ? schoolUnits : null) ? schoolUnits : [];
  var activeSchoolUnitIdValue = typeof activeSchoolUnitId !== "undefined" ? String(activeSchoolUnitId || "") : "";
  var gallery = Array.isArray(p.gallery) ? p.gallery : [];
  var faqs = Array.isArray(p.faqs) ? p.faqs : [];
  var pendingReviews = Array.isArray(pending) ? pending : [];
  var approvedReviews = Array.isArray(approved) ? approved : [];

  function safeStr(x){ return String(x == null ? "" : x); }

  var valuesText = Array.isArray(p.values) ? p.values.join(", ") : safeStr(p.values);
  var facilitiesText = Array.isArray(p.facilities) ? p.facilities.join(", ") : safeStr(p.facilities);
  var accreditationsText = Array.isArray(p.accreditations) ? p.accreditations.join(", ") : "";
  var clubsText = Array.isArray(p.clubs) ? p.clubs.join(", ") : "";
  var scholarshipsText = Array.isArray(p.scholarships) ? p.scholarships.join(", ") : "";
  var policiesText = Array.isArray(p.policies) ? p.policies.join(", ") : "";
  var keywordsText = Array.isArray(seo.keywords) ? seo.keywords.join(", ") : "";

  var whyText = "";
  if (Array.isArray(p.highlights) && p.highlights.length) whyText = p.highlights.join("\n");
  else if (Array.isArray(p.whyChooseUs)) whyText = p.whyChooseUs.join("\n");
  else whyText = safeStr(p.whyChooseUs);

  var awardsText = "";
  if (Array.isArray(p.awards)) {
    var alines = [];
    for (var a1 = 0; a1 < p.awards.length; a1++) {
      var aw = p.awards[a1] || {};
      alines.push(
        safeStr(aw.title) + " | " +
        safeStr(aw.organization) + " | " +
        safeStr(aw.year) + " | " +
        safeStr(aw.description)
      );
    }
    awardsText = alines.join("\n");
  }

  var newsText = "";
  if (Array.isArray(p.announcements)) {
    var nlines = [];
    for (var n = 0; n < p.announcements.length; n++) {
      var nn = p.announcements[n] || {};
      var d = "";
      try {
        if (nn.date) d = new Date(nn.date).toISOString().slice(0,10);
      } catch(e) {}
      nlines.push(safeStr(nn.title) + " | " + d + " | " + safeStr(nn.body));
    }
    newsText = nlines.join("\n");
  }

  var admissionStepsText = Array.isArray(admissions.steps) ? admissions.steps.join("\n") : "";
  var requiredDocsText = Array.isArray(admissions.requiredDocs) ? admissions.requiredDocs.join("\n") : "";
%>

<div class="app">
  <%- include("../../partials/navbar") %>

  <main class="main">
    <% if (typeof success !== "undefined" && success) { %>
      <div class="flash-wrap">
        <div class="flash flash-success"><%= success %></div>
      </div>
    <% } %>

    <% if (typeof error !== "undefined" && error) { %>
      <div class="flash-wrap">
        <div class="flash flash-error"><%= error %></div>
      </div>
    <% } %>

    <div class="topbar">
      <div>
        <div class="title">School Unit Profile</div>
        <div class="subtitle">Manage the selected school unit profile, branding, media, admissions, SEO, reviews and FAQ. Tenant stays global; profile editing happens per school unit.</div>
      </div>

      <div class="top-actions">
        <% if (schoolUnitsList.length) { %>
          <select id="schoolUnitId" class="select">
            <% schoolUnitsList.forEach(function(unit){ %>
              <option value="<%= unit._id %>" <%= String(activeSchoolUnitIdValue) === String(unit._id) ? "selected" : "" %>><%= unit.name %><%= unit.category ? " · " + unit.category : "" %></option>
            <% }) %>
          </select>
        <% } %>
        <a class="btn light" id="previewBtn" data-tenant-code="<%= tenantObj.code || '' %>"
          href="/schools/<%= tenantObj.code %><%= activeSchoolUnitIdValue ? ('?schoolUnitId=' + encodeURIComponent(activeSchoolUnitIdValue)) : '' %>">
          <i class="fa-solid fa-arrow-up-right-from-square"></i>
          Preview
        </a>

        <button class="btn light" id="btnReset" type="button">
          <i class="fa-solid fa-rotate-left"></i> Reset
        </button>

        <button class="btn primary" id="btnSave" type="button">
          <i class="fa-solid fa-floppy-disk"></i> Save Profile
        </button>
      </div>
    </div>

    <div class="savebar" id="savebar">
      <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
        <strong>Unsaved changes</strong>
        <span class="muted">Your profile has changes that are not yet saved.</span>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <button class="btn primary" id="btnSave2" type="button">
          <i class="fa-solid fa-floppy-disk"></i> Save now
        </button>
      </div>
    </div>

    <section class="card" style="margin-top:12px;">
      <div class="hero">
        <div class="hero-logo">
          <% if (b.logoUrl) { %>
            <img src="<%= b.logoUrl %>" alt="School logo" />
          <% } else { %>
            <span><%= (tenantObj.name || "S").charAt(0).toUpperCase() %></span>
          <% } %>
        </div>

        <div class="hero-main">
          <div class="hero-title"><%= p.shortName || tenantObj.name || "School Name" %></div>
          <div class="muted"><%= p.tagline || "Update your public school presence, admissions info, trust content and search metadata." %></div>

          <div class="chips">
            <span class="pill info"><i class="fa-solid fa-school"></i> <%= p.type || "Not set" %></span>
            <span class="pill info"><i class="fa-solid fa-globe"></i> <%= tenantObj.subdomain || tenantObj.code || "tenant" %></span>
            <span class="pill <%= tenantObj.status === 'active' ? 'ok' : 'warn' %>">
              <i class="fa-solid fa-shield"></i> <%= tenantObj.status || "trial" %>
            </span>
            <span class="pill <%= p.verified ? 'ok' : 'warn' %>">
              <i class="fa-solid fa-badge-check"></i> <%= p.verified ? "Verified" : "Not verified" %>
            </span>
            <span class="pill <%= p.enabled !== false ? 'ok' : 'bad' %>">
              <i class="fa-solid fa-eye"></i> <%= p.enabled !== false ? "Public enabled" : "Public disabled" %>
            </span>
          </div>
        </div>

        <div class="hero-side">
          <div class="mini-kpi">
            <b>Created</b>
            <span><%= stats.createdAtLabel || "—" %></span>
          </div>
          <div class="mini-kpi">
            <b>Staff</b>
            <span><%= stats.staff || 0 %></span>
          </div>
          <div class="mini-kpi">
            <b>Campuses</b>
            <span><%= stats.campuses || 0 %></span>
          </div>
        </div>
      </div>
    </section>

    <div class="grid-4" style="margin-top:12px;">
      <div class="card">
        <div class="section-title">Completion</div>
        <div class="kpi-value"><%= stats.completion || 0 %>%</div>
        <div class="muted">Profile quality score</div>
      </div>
      <div class="card">
        <div class="section-title">Students</div>
        <div class="kpi-value" style="color:#0a6fbf"><%= stats.students || 0 %></div>
        <div class="muted">Live student count</div>
      </div>
      <div class="card">
        <div class="section-title">Subjects</div>
        <div class="kpi-value" style="color:#92400e"><%= stats.subjects || 0 %></div>
        <div class="muted">Subjects published</div>
      </div>
      <div class="card">
        <div class="section-title">Approved Reviews</div>
        <div class="kpi-value" style="color:#15803d"><%= stats.reviews || 0 %></div>
        <div class="muted"><%= stats.rating || 0 %> average rating</div>
      </div>
    </div>

    <section class="card" style="margin-top:12px;">
      <div class="toolbar">
        <div class="left">
          <div class="chips" id="viewChips">
            <button class="chip active" data-view="general" type="button"><i class="fa-solid fa-building"></i> General</button>
            <button class="chip" data-view="branding" type="button"><i class="fa-solid fa-palette"></i> Branding & Media</button>
            <button class="chip" data-view="public" type="button"><i class="fa-solid fa-globe"></i> Public Content</button>
            <button class="chip" data-view="trust" type="button"><i class="fa-solid fa-star"></i> Reviews & FAQ</button>
            <button class="chip" data-view="seo" type="button"><i class="fa-solid fa-magnifying-glass"></i> SEO & Admissions</button>
          </div>
        </div>

        <div class="right">
          <button class="btn light" id="btnOpenFaqModal" type="button">
            <i class="fa-solid fa-circle-question"></i> New FAQ
          </button>
          <button class="btn primary" id="btnSaveTop2" type="button">
            <i class="fa-solid fa-floppy-disk"></i> Save
          </button>
        </div>
      </div>
    </section>

    <form id="schoolForm" method="POST" action="/admin/profile">
      <input type="hidden" name="schoolUnitId" value="<%= activeSchoolUnitIdValue || "" %>">
      <% if (csrfToken) { %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>

      <div id="view-general" style="margin-top:12px;">
        <div class="grid-2">
          <section class="card">
            <div class="section-head">
              <div>
                <div class="section-title">School Identity</div>
                <div class="section-sub">Core public identity and narrative.</div>
              </div>
              <span class="pill info"><i class="fa-solid fa-id-card"></i> Core Info</span>
            </div>

            <div class="form-grid">
              <div class="field">
                <label>School Name</label>
                <input class="input" name="name" value="<%= tenantObj.name || "" %>" required>
              </div>
              <div class="field">
                <label>School Type</label>
                <select class="select" name="type">
                  <option value="">Select type</option>
                  <option value="Secondary School" <%= p.type==="Secondary School" ? "selected" : "" %>>Secondary School</option>
                  <option value="Primary School" <%= p.type==="Primary School" ? "selected" : "" %>>Primary School</option>
                  <option value="Nursery School" <%= p.type==="Nursery School" ? "selected" : "" %>>Nursery School</option>
                </select>
              </div>

              <div class="field">
                <label>Tagline</label>
                <input class="input" name="tagline" value="<%= p.tagline || "" %>" placeholder="Short school selling statement">
              </div>
              <div class="field">
                <label>Founded Year</label>
                <input class="input" name="foundedYear" value="<%= p.foundedYear || "" %>" placeholder="e.g. 2008">
              </div>

              <div class="field">
                <label>School System</label>
                <input class="input" name="system" value="<%= p.system || "" %>" placeholder="Day / Boarding / Mixed">
              </div>
              <div class="field">
                <label>City</label>
                <input class="input" name="city" value="<%= locationObj.city || p.city || "" %>" placeholder="Kampala">
              </div>

              <div class="field" style="grid-column:1 / -1;">
                <label>Google Map URL</label>
                <input class="input" name="googleMapUrl" value="<%= locationObj.googleMapUrl || "" %>" placeholder="https://maps.google.com/...">
              </div>
            </div>

            <div class="divider"></div>

            <div class="field">
              <label>About School</label>
              <textarea class="textarea" name="about" rows="6"><%= p.about || "" %></textarea>
            </div>

            <div class="form-grid">
              <div class="field">
                <label>Mission</label>
                <textarea class="textarea" name="mission" rows="4"><%= p.mission || "" %></textarea>
              </div>
              <div class="field">
                <label>Vision</label>
                <textarea class="textarea" name="vision" rows="4"><%= p.vision || "" %></textarea>
              </div>
            </div>

            <div class="field">
              <label>Values (comma separated)</label>
              <input class="input" name="values" value="<%= valuesText %>" placeholder="Integrity, Excellence, Respect">
            </div>

            <div class="field">
              <label>Why Choose Us (one per line)</label>
              <textarea class="textarea" name="whyChooseUs" rows="6"><%= whyText %></textarea>
            </div>
          </section>

          <aside class="card">
            <div class="section-title">Contacts & Socials</div>
            <div class="section-sub">Public contact points and social identity.</div>

            <div class="mini-list">
              <div class="mini-item">
                <div class="left">
                  <div class="strong">Public Profile</div>
                  <div class="muted">Enable or disable public visibility</div>
                </div>
                <label class="muted" style="display:flex;align-items:center;gap:8px;flex:0 0 auto;">
                  <input type="checkbox" name="enabled" <%= p.enabled !== false ? "checked" : "" %>> Enabled
                </label>
              </div>

              <div class="mini-item">
                <div class="left">
                  <div class="strong">Verified Badge</div>
                  <div class="muted">Display verification trust marker</div>
                </div>
                <label class="muted" style="display:flex;align-items:center;gap:8px;flex:0 0 auto;">
                  <input type="checkbox" name="verified" <%= p.verified ? "checked" : "" %>> Verified
                </label>
              </div>
            </div>

            <div class="divider"></div>

            <div class="form-grid">
              <div class="field">
                <label>Phone</label>
                <input class="input" name="phone" value="<%= contact.phone || "" %>" placeholder="+256...">
              </div>
              <div class="field">
                <label>Email</label>
                <input class="input" name="email" value="<%= contact.email || "" %>" placeholder="info@school.com">
              </div>

              <div class="field">
                <label>Website</label>
                <input class="input" name="website" value="<%= contact.website || "" %>" placeholder="https://...">
              </div>
              <div class="field">
                <label>Address (full)</label>
                <input class="input" name="addressFull" value="<%= contact.addressFull || "" %>" placeholder="Street, City, Country">
              </div>

              <div class="field">
                <label>Facebook</label>
                <input class="input" name="facebook" value="<%= socials.facebook || "" %>">
              </div>
              <div class="field">
                <label>Instagram</label>
                <input class="input" name="instagram" value="<%= socials.instagram || "" %>">
              </div>

              <div class="field">
                <label>X / Twitter</label>
                <input class="input" name="x" value="<%= socials.x || "" %>">
              </div>
              <div class="field">
                <label>YouTube</label>
                <input class="input" name="youtube" value="<%= socials.youtube || "" %>">
              </div>

              <div class="field">
                <label>TikTok</label>
                <input class="input" name="tiktok" value="<%= socials.tiktok || "" %>">
              </div>
              <div class="field">
                <label>LinkedIn</label>
                <input class="input" name="linkedin" value="<%= socials.linkedin || "" %>">
              </div>
            </div>
          </aside>
        </div>
      </div>

      <div id="view-branding" style="display:none;margin-top:12px;">
        <div class="grid-2">
          <section class="card">
            <div class="section-head">
              <div>
                <div class="section-title">Branding</div>
                <div class="section-sub">Logo, cover image and school color system.</div>
              </div>
              <span class="pill info"><i class="fa-solid fa-palette"></i> Visual Identity</span>
            </div>

            <div class="grid-2-even">
              <div>
                <div class="strong" style="margin-bottom:8px;">School Logo</div>
                <div class="dropzone">
                  <input type="file" accept="image/*" id="logoFile">
                  <div class="dropzone-inner">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <div>
                      <div class="strong">Upload logo</div>
                      <div class="muted">Square image recommended</div>
                    </div>
                  </div>
                </div>
                <div class="avatar-thumb" style="margin-top:12px;">
                  <img id="logoPreview" src="<%= b.logoUrl || "" %>" alt="Logo preview">
                </div>
              </div>

              <div>
                <div class="strong" style="margin-bottom:8px;">Cover Image</div>
                <div class="dropzone">
                  <input type="file" accept="image/*" id="coverFile">
                  <div class="dropzone-inner">
                    <i class="fa-solid fa-image"></i>
                    <div>
                      <div class="strong">Upload cover</div>
                      <div class="muted">Wide banner recommended</div>
                    </div>
                  </div>
                </div>
                <div class="avatar-thumb" style="margin-top:12px;">
                  <img id="coverPreview" src="<%= b.coverUrl || "" %>" alt="Cover preview">
                </div>
              </div>
            </div>

            <div class="divider"></div>

            <div class="form-grid">
              <div class="field">
                <label>Primary Color</label>
                <input class="input" name="primaryColor" value="<%= b.primaryColor || "#0a3d62" %>">
              </div>
              <div class="field">
                <label>Accent Color</label>
                <input class="input" name="accentColor" value="<%= b.accentColor || "#0a6fbf" %>">
              </div>
            </div>
          </section>

          <aside class="card">
            <div class="section-title">Lists & School Extras</div>
            <div class="section-sub">Facilities, clubs, scholarships and policy entries.</div>

            <div class="field">
              <label>Facilities (comma separated)</label>
              <input class="input" name="facilities" value="<%= facilitiesText %>" placeholder="Library, Computer Lab, Science Lab">
            </div>

            <div class="field">
              <label>Accreditations (comma separated)</label>
              <input class="input" name="accreditations" value="<%= accreditationsText %>" placeholder="UNEB, NCHE">
            </div>

            <div class="field">
              <label>Clubs (comma separated)</label>
              <input class="input" name="clubs" value="<%= clubsText %>" placeholder="Debate Club, Robotics Club">
            </div>

            <div class="field">
              <label>Scholarships (comma separated)</label>
              <input class="input" name="scholarships" value="<%= scholarshipsText %>" placeholder="Merit Scholarship, Need-based Aid">
            </div>

            <div class="field">
              <label>Policies (comma separated)</label>
              <input class="input" name="policies" value="<%= policiesText %>" placeholder="Child Protection, Anti-Bullying">
            </div>
          </aside>
        </div>

        <section class="card" style="margin-top:12px;">
          <div class="section-head">
            <div>
              <div class="section-title">Gallery, Awards & News</div>
              <div class="section-sub">Media and trust-building public content.</div>
            </div>
            <span class="pill info"><i class="fa-solid fa-stars"></i> Public Assets</span>
          </div>

          <div class="grid-3">
            <div>
              <div class="strong" style="margin-bottom:8px;">Gallery Images</div>

              <div class="dropzone">
                <input type="file" accept="image/*" id="galleryFiles" multiple>
                <div class="dropzone-inner">
                  <i class="fa-solid fa-images"></i>
                  <div>
                    <div class="strong">Upload multiple images</div>
                    <div class="muted">Click or drag school photos here</div>
                  </div>
                </div>
              </div>

              <div class="thumb-grid" id="galleryThumbs">
                <% for (var gi = 0; gi < Math.min(24, gallery.length); gi++) { var img = gallery[gi]; %>
                  <div class="thumb">
                    <img src="<%= img.url %>" alt="gallery">
                    <button type="button" class="x" data-del="<%= img._id %>">
                      <i class="fa-solid fa-xmark"></i>
                    </button>
                  </div>
                <% } %>
              </div>
            </div>

            <div>
              <div class="strong" style="margin-bottom:8px;">Awards</div>
              <textarea class="textarea" name="awardsText" rows="14"><%= awardsText %></textarea>
              <div class="muted" style="margin-top:6px;">Format: Title | Organization | Year | Description</div>
            </div>

            <div>
              <div class="strong" style="margin-bottom:8px;">News / Announcements</div>
              <textarea class="textarea" name="newsText" rows="14"><%= newsText %></textarea>
              <div class="muted" style="margin-top:6px;">Format: Title | Date | Description</div>
            </div>
          </div>
        </section>
      </div>

      <div id="view-public" style="display:none;margin-top:12px;">
        <div class="grid-2">
          <section class="card">
            <div class="section-head">
              <div>
                <div class="section-title">Public Admissions Info</div>
                <div class="section-sub">What students and parents see before applying.</div>
              </div>
              <span class="pill info"><i class="fa-solid fa-graduation-cap"></i> Admissions</span>
            </div>

            <div class="field">
              <label>Apply URL</label>
              <input class="input" name="applyUrl" value="<%= admissions.applyUrl || p.applyUrl || "" %>" placeholder="/apply or full URL">
            </div>

            <div class="form-grid">
              <div class="field">
                <label>Intake Label</label>
                <input class="input" name="intakeLabel" value="<%= admissions.intakeLabel || "" %>" placeholder="2026 Intake / Term 2 Intake">
              </div>
              <div class="field">
                <label>Admissions Phone</label>
                <input class="input" name="admissionPhone" value="<%= admissions.admissionPhone || "" %>" placeholder="+256...">
              </div>
            </div>

            <div class="field">
              <label>Requirements</label>
              <textarea class="textarea" name="requirements" rows="6"><%= admissions.requirements || p.requirements || "" %></textarea>
            </div>

            <div class="field">
              <label>Admission Steps (one per line)</label>
              <textarea class="textarea" name="admissionSteps" rows="6"><%= admissionStepsText %></textarea>
            </div>

            <div class="field">
              <label>Required Documents (one per line)</label>
              <textarea class="textarea" name="requiredDocs" rows="5"><%= requiredDocsText %></textarea>
            </div>

            <div class="form-grid">
              <div class="field">
                <label>Fees Range</label>
                <input class="input" name="feesRange" value="<%= admissions.feesRange || p.feesRange || "" %>" placeholder="UGX 350,000 – 650,000 per term">
              </div>
              <div class="field">
                <label>Payment Options</label>
                <input class="input" name="paymentOptions" value="<%= admissions.paymentOptions || p.paymentOptions || "" %>" placeholder="Per term, installment plan, bank transfer">
              </div>
            </div>

            <div class="form-grid">
              <div class="field">
                <label>Application Fee Text</label>
                <input class="input" name="applicationFeeText" value="<%= admissions.applicationFeeText || "" %>" placeholder="UGX 50,000">
              </div>
              <div class="field">
                <label>Office Hours</label>
                <textarea class="textarea" name="officeHours" rows="3"><%= admissions.officeHours || p.officeHours || "" %></textarea>
              </div>
            </div>

            <div class="mini-item" style="margin-top:12px;">
              <div class="left">
                <div class="strong">Admissions Open</div>
                <div class="muted">Controls the open/closed status shown publicly</div>
              </div>
              <label class="muted" style="display:flex;align-items:center;gap:8px;flex:0 0 auto;">
                <input type="checkbox" name="admissionsOpen" <%= admissions.isOpen !== false ? "checked" : "" %>> Open
              </label>
            </div>
          </section>

          <aside class="card">
            <div class="section-title">Public Summary Check</div>
            <div class="section-sub">Quick visual check of major public data points.</div>

            <div class="mini-list">
              <div class="mini-item"><div class="left"><div class="strong">School Name</div><div class="muted"><%= tenantObj.name || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">School Type</div><div class="muted"><%= p.type || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Phone / Email</div><div class="muted"><%= contact.phone || "—" %> / <%= contact.email || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Address</div><div class="muted"><%= contact.addressFull || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Apply Link</div><div class="muted"><%= admissions.applyUrl || p.applyUrl || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Fees</div><div class="muted"><%= admissions.feesRange || p.feesRange || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Documents</div><div class="muted"><%= Array.isArray(admissions.requiredDocs) && admissions.requiredDocs.length ? admissions.requiredDocs.join(", ") : "—" %></div></div></div>
            </div>
          </aside>
        </div>
      </div>

      <div id="view-trust" style="display:none;margin-top:12px;">
        <div class="grid-2">
          <section class="card" style="min-width:0;">
            <div class="section-head">
              <div>
                <div class="section-title">Reviews Moderation</div>
                <div class="section-sub">Approve, reject, feature and delete reviews.</div>
              </div>
              <div class="chips">
                <span class="pill warn"><i class="fa-solid fa-clock"></i> Pending <%= pendingReviews.length %></span>
                <span class="pill ok"><i class="fa-solid fa-check"></i> Approved <%= approvedReviews.length %></span>
              </div>
            </div>

            <div class="grid-2-even">
              <div class="list-col">
                <div class="strong">Pending Reviews</div>
                <% if (!pendingReviews.length) { %>
                  <div class="note">No pending reviews.</div>
                <% } %>

                <% for (var pi = 0; pi < pendingReviews.length; pi++) { var r = pendingReviews[pi]; %>
                  <div class="review-card">
                    <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap">
                      <div class="strong"><%= r.name %></div>
                      <span class="pill info"><i class="fa-solid fa-star"></i> <%= r.rating %>/5</span>
                    </div>
                    <% if (r.title) { %><div style="margin-top:6px;font-weight:800"><%= r.title %></div><% } %>
                    <% if (r.message) { %><div class="muted" style="margin-top:6px"><%= r.message %></div><% } %>

                    <div class="actions" style="margin-top:10px;justify-content:flex-start">
                      <button type="button" class="btn-xs" data-approve="<%= r._id %>"><i class="fa-solid fa-check"></i> Approve</button>
                      <button type="button" class="btn-xs" data-reject="<%= r._id %>"><i class="fa-solid fa-ban"></i> Reject</button>
                      <button type="button" class="btn-xs" data-delreview="<%= r._id %>"><i class="fa-solid fa-trash"></i> Delete</button>
                    </div>
                  </div>
                <% } %>
              </div>

              <div class="list-col">
                <div class="strong">Approved Reviews</div>
                <% if (!approvedReviews.length) { %>
                  <div class="note">No approved reviews.</div>
                <% } %>

                <% for (var ai = 0; ai < approvedReviews.length; ai++) { var r2 = approvedReviews[ai]; %>
                  <div class="review-card">
                    <div style="display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap">
                      <div class="strong"><%= r2.name %></div>
                      <span class="pill ok"><i class="fa-solid fa-star"></i> <%= r2.rating %>/5</span>
                    </div>
                    <% if (r2.title) { %><div style="margin-top:6px;font-weight:800"><%= r2.title %></div><% } %>
                    <% if (r2.message) { %><div class="muted" style="margin-top:6px"><%= r2.message %></div><% } %>

                    <div class="actions" style="margin-top:10px;justify-content:flex-start">
                      <button type="button" class="btn-xs" data-feature="<%= r2._id %>">
                        <i class="fa-solid fa-star"></i> <%= r2.featured ? "Unfeature" : "Feature" %>
                      </button>
                      <button type="button" class="btn-xs" data-delreview="<%= r2._id %>">
                        <i class="fa-solid fa-trash"></i> Delete
                      </button>
                    </div>
                  </div>
                <% } %>
              </div>
            </div>
          </section>

          <aside class="card" style="min-width:0;">
            <div class="section-head">
              <div>
                <div class="section-title">Public FAQ</div>
                <div class="section-sub">Frequently asked questions shown on the public page.</div>
              </div>
              <button class="btn light" id="faqAdd" type="button">
                <i class="fa-solid fa-plus"></i> Add FAQ
              </button>
            </div>

            <div class="list-col" id="faqList">
              <% for (var fi = 0; fi < faqs.length; fi++) { var f = faqs[fi]; %>
                <div class="faq-card">
                  <div class="strong"><%= f.q %></div>
                  <div class="muted" style="margin-top:6px"><%= f.a %></div>
                  <div class="actions" style="margin-top:10px;justify-content:flex-start">
                    <button type="button" class="btn-xs"
                      data-faqedit="<%= f._id %>"
                      data-q="<%- safeStr(f.q).replace(/"/g,'&quot;') %>"
                      data-a="<%- safeStr(f.a).replace(/"/g,'&quot;') %>">
                      <i class="fa-solid fa-pen"></i> Edit
                    </button>
                    <button type="button" class="btn-xs" data-faqdel="<%= f._id %>">
                      <i class="fa-solid fa-trash"></i> Delete
                    </button>
                  </div>
                </div>
              <% } %>

              <% if (!faqs.length) { %>
                <div class="note">No FAQs yet.</div>
              <% } %>
            </div>
          </aside>
        </div>
      </div>

      <div id="view-seo" style="display:none;margin-top:12px;">
        <div class="grid-2">
          <section class="card">
            <div class="section-head">
              <div>
                <div class="section-title">SEO Settings</div>
                <div class="section-sub">Search visibility and metadata configuration.</div>
              </div>
              <span class="pill info"><i class="fa-solid fa-magnifying-glass"></i> Search</span>
            </div>

            <div class="field">
              <label>Meta Title</label>
              <input class="input" name="metaTitle" value="<%= seo.metaTitle || "" %>" placeholder="School name | Admissions | Location">
            </div>

            <div class="field">
              <label>Meta Description</label>
              <textarea class="textarea" name="metaDescription" rows="5"><%= seo.metaDescription || "" %></textarea>
            </div>

            <div class="field">
              <label>Keywords (comma separated)</label>
              <input class="input" name="keywords" value="<%= keywordsText %>" placeholder="school in Kampala, boarding school Uganda">
            </div>

            <div class="divider"></div>

            <div class="section-title">Admissions Preview</div>
            <div class="section-sub">Read-only preview of the admissions content entered in the Public Content tab.</div>

            <div class="field" style="margin-top:10px;">
              <label>Apply URL</label>
              <input class="input" value="<%= admissions.applyUrl || p.applyUrl || "" %>" readonly>
            </div>

            <div class="field">
              <label>Requirements</label>
              <textarea class="textarea" rows="6" readonly><%= admissions.requirements || p.requirements || "" %></textarea>
            </div>

            <div class="field">
              <label>Admission Steps</label>
              <textarea class="textarea" rows="6" readonly><%= admissionStepsText %></textarea>
            </div>

            <div class="field">
              <label>Required Documents</label>
              <textarea class="textarea" rows="5" readonly><%= requiredDocsText %></textarea>
            </div>

            <div class="field">
              <label>Fees / Payment</label>
              <textarea class="textarea" rows="4" readonly><%= (admissions.feesRange || p.feesRange || "") + ((admissions.paymentOptions || p.paymentOptions) ? "\n" + (admissions.paymentOptions || p.paymentOptions) : "") %></textarea>
            </div>
          </section>

          <aside class="card">
            <div class="section-title">Tenant Snapshot</div>
            <div class="section-sub">Tenant infrastructure details for this school.</div>

            <div class="mini-list">
              <div class="mini-item"><div class="left"><div class="strong">Tenant Code</div><div class="muted"><%= tenantObj.code || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Subdomain</div><div class="muted"><%= tenantObj.subdomain || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">DB Name</div><div class="muted"><%= tenantObj.dbName || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Custom Domain</div><div class="muted"><%= tenantObj.customDomain || "—" %></div></div></div>
              <div class="mini-item"><div class="left"><div class="strong">Status</div><div class="muted"><%= tenantObj.status || "—" %></div></div></div>
            </div>
          </aside>
        </div>
      </div>
    </form>
  </main>
</div>

<div class="modal-backdrop" id="faqModal">
  <div class="modal sm">
    <form id="faqFormModal">
      <div class="modal-header">
        <div class="modal-title" id="faqModalTitle">Add FAQ</div>
        <button class="btn-xs" type="button" data-close-modal="faqModal">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="modal-body">
        <input type="hidden" id="faqId">

        <div class="field">
          <label>Question</label>
          <input class="input" id="faqQ" placeholder="e.g. Do you offer boarding?">
        </div>

        <div class="field">
          <label>Answer</label>
          <textarea class="textarea" id="faqA" rows="5" placeholder="Short clear answer..."></textarea>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="faqModal">Cancel</button>
        <button class="btn primary" id="faqSaveBtn" type="submit">
          <i class="fa-solid fa-floppy-disk"></i> Save FAQ
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  window.__TENANT_CODE__ = "<%= tenantObj.code || '' %>";
</script>
<script src="/js/navbar.js"></script>
<script src="/js/admin-school-profile.js"></script>
</body>
</html>