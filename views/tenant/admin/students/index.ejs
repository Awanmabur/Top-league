<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>
    <%= (tenant?.name || "Classic Campus" ) %> • Students
  </title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center
    }

    .toolbar .left,
    .toolbar .right {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center
    }

    .input,
    .select,
    .textarea,
    .view-input {
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(13, 64, 96, .16);
      background: #fff;
      outline: none;
    }

    .input {
      min-width: 220px
    }

    .textarea {
      width: 100%;
      min-height: 110px;
      resize: vertical
    }

    .input:focus,
    .select:focus,
    .textarea:focus {
      border-color: rgba(10, 111, 191, .45);
      box-shadow: 0 0 0 3px rgba(10, 111, 191, .12);
    }

    .view-input {
      min-height: 44px;
      display: flex;
      align-items: center;
      font-weight: 800;
      color: #0f172a;
      background: #fbfdff;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .view-input.multiline {
      min-height: 96px;
      align-items: flex-start;
      white-space: pre-wrap;
      overflow: auto;
      text-overflow: unset;
      line-height: 1.55;
    }

    .muted {
      font-size: 12px;
      color: #6b7280
    }

    .strong {
      font-weight: 900
    }

    .grid-5 {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 12px
    }

    .grid-2 {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(320px, .5fr);
      gap: 12px
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap
    }

    .ok {
      background: #ecfdf3;
      color: #15803d
    }

    .warn {
      background: #fef9c3;
      color: #92400e
    }

    .bad {
      background: #fee2e2;
      color: #b91c1c
    }

    .info {
      background: #eef2ff;
      color: #3730a3
    }

    .arch {
      background: #f1f5f9;
      color: #334155
    }

    .table-wrap {
      overflow-x: auto;
      overflow-y: hidden;
      border: 1px solid rgba(13, 64, 96, .10);
      border-radius: 12px;
      max-width: 100%;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      min-width: 1500px;
      border-collapse: separate;
      border-spacing: 0;
      background: #fff;
      table-layout: fixed;
    }

    th,
    td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(13, 64, 96, .08);
      vertical-align: middle;
    }

    th {
      font-size: 12px;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: .04em;
      text-align: left;
      background: rgba(13, 64, 96, .03);
      position: sticky;
      top: 0;
      z-index: 1;
      white-space: nowrap;
    }

    tr:hover td {
      background: rgba(10, 111, 191, .04)
    }

    tr.row-clickable {
      cursor: pointer
    }

    .col-check {
      width: 48px
    }

    .col-student {
      width: 280px
    }

    .col-program {
      width: 220px
    }

    .col-class {
      width: 220px
    }

    .col-year {
      width: 120px
    }

    .col-academic {
      width: 150px
    }

    .col-contacts {
      width: 220px
    }

    .col-status {
      width: 140px
    }

    .col-hold {
      width: 220px
    }

    .col-actions {
      width: 220px
    }

    .cell-ellipsis {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 100%;
    }

    .student-main {
      min-width: 0
    }

    .student-title {
      font-weight: 900;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap
    }

    .student-sub {
      font-size: 12px;
      color: #6b7280;
      margin-top: 2px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap
    }

    .actions {
      display: flex;
      gap: 6px;
      justify-content: flex-end;
      flex-wrap: nowrap;
      overflow: hidden
    }

    .btn-xs {
      padding: 6px 8px;
      border-radius: 10px;
      border: 1px solid rgba(13, 64, 96, .14);
      background: #fff;
      cursor: pointer;
      font-size: 12px;
      position: relative;
      z-index: 2;
      flex: 0 0 auto
    }

    .btn-xs:hover {
      background: rgba(10, 111, 191, .06)
    }

    .bulkbar {
      display: none;
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 12px;
      background: rgba(10, 111, 191, .08);
      border: 1px solid rgba(10, 111, 191, .18);
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .bulkbar.show {
      display: flex
    }

    .badge-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 26px;
      height: 22px;
      padding: 0 8px;
      border-radius: 999px;
      background: #0a6fbf;
      color: #fff;
      font-size: 12px;
      font-weight: 900;
    }

    .note {
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px dashed rgba(13, 64, 96, .18);
      background: rgba(13, 64, 96, .03)
    }

    .mini-list {
      display: grid;
      gap: 10px;
      margin-top: 10px
    }

    .mini-item {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border: 1px solid rgba(13, 64, 96, .10);
      border-radius: 12px;
      background: #fff
    }

    .mini-item .left {
      display: grid;
      gap: 2px
    }

    .flash-wrap {
      display: grid;
      gap: 10px;
      margin-bottom: 12px
    }

    .flash {
      padding: 12px 14px;
      border-radius: 12px;
      font-weight: 700
    }

    .flash-success {
      background: #ecfdf3;
      color: #166534;
      border: 1px solid #bbf7d0
    }

    .flash-error {
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: nowrap
    }

    .topbar>div:first-child {
      min-width: 0;
      flex: 1 1 auto
    }

    .top-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
      align-items: center;
      flex: 0 0 auto;
      margin-left: auto
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 30px 18px;
      z-index: 9999;
      overflow-y: auto;
    }

    .modal-backdrop.show {
      display: flex
    }

    .modal {
      width: min(1100px, 100%);
      max-height: calc(100dvh - 60px);
      background: #fff;
      border-radius: 22px;
      box-shadow: 0 24px 70px rgba(0, 0, 0, .25);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .modal.sm {
      width: min(720px, 100%)
    }

    .modal.lg {
      width: min(1100px, 100%)
    }

    .modal>form {
      display: flex;
      flex-direction: column;
      flex: 1 1 auto;
      min-height: 0;
      overflow: hidden
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(13, 64, 96, .10);
      background: #fff
    }

    .modal-title {
      font-weight: 900;
      font-size: 18px
    }

    .modal-body {
      padding: 16px 18px;
      overflow-y: auto;
      min-height: 0;
      flex: 1 1 auto
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      padding: 14px 18px;
      border-top: 1px solid rgba(13, 64, 96, .10);
      background: #fff;
      flex-wrap: wrap
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px
    }

    .field label {
      display: block;
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 6px
    }

    .field input,
    .field select,
    .field textarea {
      width: 100%
    }

    .divider {
      height: 1px;
      background: rgba(13, 64, 96, .10);
      margin: 12px 0
    }

    .json-data {
      display: none !important
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      background: #eef2ff;
      color: #3730a3;
      font-size: 12px;
      font-weight: 800
    }

    .tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 12px
    }

    .tab {
      border: 1px solid rgba(13, 64, 96, .14);
      background: #fff;
      border-radius: 999px;
      padding: 8px 12px;
      cursor: pointer;
      font-weight: 900;
      font-size: 12px
    }

    .tab.active {
      background: rgba(10, 111, 191, .12);
      border-color: rgba(10, 111, 191, .35)
    }

    .tab-pane {
      display: none
    }

    .tab-pane.active {
      display: block
    }

    .pagination {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-top: 14px;
      flex-wrap: wrap
    }

    .pagination-links {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center
    }

    .page-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 38px;
      height: 38px;
      padding: 0 12px;
      border-radius: 10px;
      border: 1px solid rgba(13, 64, 96, .14);
      background: #fff;
      color: #0f172a;
      text-decoration: none;
      font-weight: 800
    }

    .page-link.active {
      background: #0a6fbf;
      color: #fff;
      border-color: #0a6fbf
    }

    .page-link.disabled {
      pointer-events: none;
      opacity: .45
    }

    @media (max-width: 1100px) {
      .grid-2 {
        grid-template-columns: 1fr
      }
    }

    @media (max-width: 900px) {
      .form-grid {
        grid-template-columns: 1fr
      }

      .topbar {
        flex-wrap: wrap
      }

      .top-actions{width:100%;justify-content:flex-start}

      .grid-5 {
        grid-template-columns: repeat(2, minmax(0, 1fr))
      }
    }

    @media (max-width: 680px) {
      .input {
        min-width: 160px
      }
    }

    @media (max-width: 520px) {

      .toolbar .left,
      .toolbar .right {
        width: 100%
      }

      .toolbar .left>*,
      .toolbar .right>* {
        max-width: 100%
      }

      table {
        min-width: 1500px
      }

      .grid-5 {
        grid-template-columns: 1fr
      }
    }

    @media print {
      body * {
        visibility: hidden !important
      }

      #printArea,
      #printArea * {
        visibility: visible !important
      }

      #printArea {
        position: absolute;
        inset: 0;
        background: #fff;
        padding: 20px
      }
    }
  </style>
</head>

<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

      <main class="main">
        <% if (typeof messages !=="undefined" && (messages.success?.length || messages.error?.length)) { %>
          <div class="flash-wrap">
            <% (messages.success || []).forEach(function(msg){ %>
              <div class="flash flash-success">
                <%= msg %>
              </div>
              <% }) %>
                <% (messages.error || []).forEach(function(msg){ %>
                  <div class="flash flash-error">
                    <%= msg %>
                  </div>
                  <% }) %>
          </div>
          <% } %>

            <div class="topbar">
              <div>
                <div class="title">Students</div>
                <div class="subtitle">Create, edit, import, export, print and manage student records.</div>
              </div>

              <div class="top-actions">
                <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import
                  CSV</button>
                <a class="btn light" id="btnExport" href="/admin/students/export?<%= exportQuery %>"><i
                    class="fa-solid fa-file-arrow-down"></i> Export CSV</a>
                <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
                <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add
                  Student</button>
              </div>
            </div>

            <div class="grid-5">
              <div class="card">
                <div class="section-title">Total</div>
                <div class="kpi-value">
                  <%= kpis?.total || 0 %>
                </div>
                <div class="muted">Matching filter</div>
              </div>
              <div class="card">
                <div class="section-title">Active</div>
                <div class="kpi-value" style="color:#15803d">
                  <%= kpis?.active || 0 %>
                </div>
                <div class="muted">Active students</div>
              </div>
              <div class="card">
                <div class="section-title">On Hold</div>
                <div class="kpi-value" style="color:#92400e">
                  <%= kpis?.on_hold || 0 %>
                </div>
                <div class="muted">Blocked temporarily</div>
              </div>
              <div class="card">
                <div class="section-title">Suspended</div>
                <div class="kpi-value" style="color:#b91c1c">
                  <%= kpis?.suspended || 0 %>
                </div>
                <div class="muted">Disciplinary / restricted</div>
              </div>
              <div class="card">
                <div class="section-title">Graduated</div>
                <div class="kpi-value" style="color:#3730a3">
                  <%= kpis?.graduated || 0 %>
                </div>
                <div class="muted">Completed students</div>
              </div>
            </div>

            <section class="card" style="margin-top:12px;">
              <form class="toolbar" method="GET" action="/admin/students">
                <div class="left">
                  <input class="input" name="q" value="<%= query?.q || '' %>"
                    placeholder="Search name, reg no, email, phone..." />

                  <select class="select" name="program">
                    <option value="">All Programs</option>
                    <% (programs || []).forEach(function(p){ const label=((p.code ? p.code + ' — ' : '' ) + (p.name ||
                      p.title || 'Program' )).trim(); %>
                      <option value="<%= p._id %>" <%=String(query?.program || '' )===String(p._id) ? 'selected' : '' %>
                        ><%= label %>
                      </option>
                      <% }) %>
                  </select>

                  <select class="select" name="classGroup">
                    <option value="">All Classes</option>
                    <% (classes || []).forEach(function(c){ const label=((c.code ? c.code + ' — ' : '' ) + (c.name ||
                      c.title || 'Class' )).trim(); %>
                      <option value="<%= c._id %>" <%=String(query?.classGroup || '' )===String(c._id) ? 'selected' : ''
                        %>><%= label %>
                      </option>
                      <% }) %>
                  </select>

                  <select class="select" name="yearLevel">
                    <option value="">All Years</option>
                    <% (years || []).forEach(function(y){ %>
                      <option value="<%= y %>" <%=query?.yearLevel===y ? 'selected' : '' %>><%= y %>
                      </option>
                      <% }) %>
                  </select>

                  <select class="select" name="status">
                    <option value="">All Status</option>
                    <option value="active" <%=query?.status==='active' ? 'selected' : '' %>>Active</option>
                    <option value="on_hold" <%=query?.status==='on_hold' ? 'selected' : '' %>>On Hold</option>
                    <option value="suspended" <%=query?.status==='suspended' ? 'selected' : '' %>>Suspended</option>
                    <option value="graduated" <%=query?.status==='graduated' ? 'selected' : '' %>>Graduated</option>
                    <option value="archived" <%=query?.status==='archived' ? 'selected' : '' %>>Archived</option>
                  </select>
                </div>

                <div class="right">
                  <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i>
                    Bulk</button>
                  <a class="btn light" href="/admin/students"><i class="fa-solid fa-rotate-left"></i> Reset</a>
                  <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
                </div>
              </form>

              <div class="bulkbar" id="bulkbar">
                <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                  <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
                  <span class="muted">student(s)</span>
                </div>
                <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
                  <button class="btn-xs" id="bulkSetStatus" type="button"><i class="fa-solid fa-rotate"></i> Set
                    Status</button>
                  <button class="btn-xs" id="bulkApplyHold" type="button"><i class="fa-solid fa-ban"></i> Apply
                    Hold</button>
                  <button class="btn-xs" id="bulkClearHold" type="button"><i class="fa-solid fa-circle-check"></i> Clear
                    Hold</button>
                  <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i>
                    Archive</button>
                  <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
                  <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
                </div>
              </div>
            </section>

            <div class="grid-2" style="margin-top:12px;">
              <section class="card" style="min-width:0;">
                <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
                  <div>
                    <div class="section-title">Students Table</div>
                    <div class="section-sub">Showing <%= students.length %> of <%= query?.total || 0 %> records.</div>
                  </div>
                  <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
                  </div>
                </div>

                <div style="margin-top:10px;">
                  <div class="table-wrap" id="printArea">
                    <table>
                      <thead>
                        <tr>
                          <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                          <th class="col-student">Student</th>
                          <th class="col-program">Program</th>
                          <th class="col-class">Class</th>
                          <th class="col-year">Year</th>
                          <th class="col-academic">Academic</th>
                          <th class="col-contacts">Contacts</th>
                          <th class="col-status">Status</th>
                          <th class="col-hold">Hold</th>
                          <th class="col-actions" style="text-align:right;">Actions</th>
                        </tr>
                      </thead>
                      <tbody id="tbodyStudents"></tbody>
                    </table>
                  </div>
                </div>

                <div class="pagination">
                  <div class="muted">Rows per page: <strong>
                      <%= query?.perPage || 20 %>
                    </strong></div>
                  <div class="pagination-links">
                    <% const currentPage=Number(query?.page || 1); const totalPages=Number(query?.totalPages || 1);
                      function buildPageUrl(targetPage) { const params=new URLSearchParams(); if (query?.q)
                      params.set('q', query.q); if (query?.program) params.set('program', query.program); if
                      (query?.classGroup) params.set('classGroup', query.classGroup); if (query?.yearLevel)
                      params.set('yearLevel', query.yearLevel); if (query?.status) params.set('status', query.status);
                      params.set('page', String(targetPage)); return '/admin/students?' + params.toString(); } const
                      startPage=Math.max(1, currentPage - 2); const endPage=Math.min(totalPages, currentPage + 2); %>

                      <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>"
                        href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>"><i
                          class="fa-solid fa-angle-left"></i></a>
                      <% for (let p=startPage; p <=endPage; p++) { %>
                        <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>">
                          <%= p %>
                        </a>
                        <% } %>
                          <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>"
                            href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>"><i
                              class="fa-solid fa-angle-right"></i></a>
                  </div>
                </div>
              </section>

              <aside class="card" style="min-width:0;">
                <div class="section-title">Quick Actions</div>
                <div class="section-sub">Fast create helpers and imports.</div>

                <div class="mini-list">
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Add Active Student</div>
                      <div class="muted">Pre-fill active status</div>
                    </div>
                    <button class="btn-xs" id="quickActive" type="button"><i class="fa-solid fa-user-plus"></i></button>
                  </div>
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Add On Hold Student</div>
                      <div class="muted">Pre-fill status as On Hold</div>
                    </div>
                    <button class="btn-xs" id="quickHold" type="button"><i class="fa-solid fa-ban"></i></button>
                  </div>
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Import Students</div>
                      <div class="muted">Upload CSV for bulk create/update</div>
                    </div>
                    <button class="btn-xs" id="quickImport" type="button"><i
                        class="fa-solid fa-file-import"></i></button>
                  </div>
                </div>
              </aside>
            </div>
      </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Student</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="studentForm" method="POST" action="/admin/students" novalidate>
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% } %>

            <div class="modal-body">
              <div class="tabs">
                <button class="tab active" type="button" data-tab="basic">Basic</button>
                <button class="tab" type="button" data-tab="academic">Academic</button>
                <button class="tab" type="button" data-tab="contacts">Contacts</button>
                <button class="tab" type="button" data-tab="holds">Holds</button>
              </div>

              <div class="tab-pane active" id="tab-basic">
                <div class="form-grid">
                  <div class="field"><label>Registration No *</label><input class="input" id="mRegNo" name="regNo"
                      maxlength="60" required /></div>
                  <div class="field"><label>Full Name</label><input class="input" id="mFullName" name="fullName"
                      maxlength="120" /></div>
                  <div class="field"><label>Status</label><select class="select" id="mStatus" name="status">
                      <option value="active">Active</option>
                      <option value="on_hold">On Hold</option>
                      <option value="suspended">Suspended</option>
                      <option value="graduated">Graduated</option>
                      <option value="archived">Archived</option>
                    </select></div>
                  <div class="field"><label>First Name</label><input class="input" id="mFirstName" name="firstName"
                      maxlength="60" /></div>
                  <div class="field"><label>Middle Name</label><input class="input" id="mMiddleName" name="middleName"
                      maxlength="60" /></div>
                  <div class="field"><label>Last Name</label><input class="input" id="mLastName" name="lastName"
                      maxlength="60" /></div>
                  <div class="field"><label>Gender</label><input class="input" id="mGender" name="gender"
                      maxlength="30" /></div>
                  <div class="field"><label>Nationality</label><input class="input" id="mNationality" name="nationality"
                      maxlength="60" /></div>
                  <div class="field"><label>Address</label><input class="input" id="mAddress" name="address"
                      maxlength="200" /></div>
                </div>
              </div>

              <div class="tab-pane" id="tab-academic">
                <div class="form-grid">
                  <div class="field"><label>Program *</label><select class="select" id="mProgram" name="program"
                      required>
                      <option value="">— Select Program —</option>
                      <% (programs || []).forEach(function(p){ const label=((p.code ? p.code + ' — ' : '' ) + (p.name ||
                        p.title || 'Program' )).trim(); %>
                        <option value="<%= p._id %>">
                          <%= label %>
                        </option>
                        <% }) %>
                    </select></div>
                  <div class="field"><label>Class *</label><select class="select" id="mClassGroup" name="classGroup"
                      required>
                      <option value="">— Select Class —</option>
                      <% (classes || []).forEach(function(c){ const label=((c.code ? c.code + ' — ' : '' ) + (c.name ||
                        c.title || 'Class' )).trim(); %>
                        <option value="<%= c._id %>">
                          <%= label %>
                        </option>
                        <% }) %>
                    </select></div>
                  <div class="field"><label>Year Level</label><input class="input" id="mYearLevel" name="yearLevel"
                      maxlength="30" /></div>
                  <div class="field"><label>Academic Year</label><input class="input" id="mAcademicYear"
                      name="academicYear" maxlength="20" /></div>
                  <div class="field"><label>Semester</label><input class="input" id="mSemester" name="semester"
                      type="number" min="0" max="6" value="1" /></div>
                </div>
              </div>

              <div class="tab-pane" id="tab-contacts">
                <div class="form-grid">
                  <div class="field"><label>Email</label><input class="input" id="mEmail" name="email" maxlength="120"
                      type="email" /></div>
                  <div class="field"><label>Phone</label><input class="input" id="mPhone" name="phone" maxlength="40" />
                  </div>
                  <div class="field"><label>Guardian Name</label><input class="input" id="mGuardianName"
                      name="guardianName" maxlength="120" /></div>
                  <div class="field"><label>Guardian Phone</label><input class="input" id="mGuardianPhone"
                      name="guardianPhone" maxlength="40" /></div>
                  <div class="field"><label>Guardian Email</label><input class="input" id="mGuardianEmail"
                      name="guardianEmail" maxlength="120" type="email" /></div>
                </div>
              </div>

              <div class="tab-pane" id="tab-holds">
                <div class="form-grid">
                  <div class="field"><label>Hold Type</label><input class="input" id="mHoldType" name="holdType"
                      maxlength="60" /></div>
                  <div class="field" style="grid-column:1 / -1"><label>Hold Reason</label><textarea class="textarea"
                      id="mHoldReason" name="holdReason" maxlength="200"></textarea>
                    <div class="muted" id="holdReasonCount">0 / 200</div>
                  </div>
                </div>
              </div>
            </div>

            <div class="modal-footer">
              <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
              <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save
                Student</button>
            </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Student Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Full Name</label>
            <div class="view-input" id="vFullName">—</div>
          </div>
          <div class="field"><label>Registration No</label>
            <div class="view-input" id="vRegNo">—</div>
          </div>
          <div class="field"><label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>
          <div class="field"><label>Program</label>
            <div class="view-input" id="vProgram">—</div>
          </div>
          <div class="field"><label>Class</label>
            <div class="view-input" id="vClass">—</div>
          </div>
          <div class="field"><label>Year</label>
            <div class="view-input" id="vYear">—</div>
          </div>
          <div class="field"><label>Academic Year</label>
            <div class="view-input" id="vAcademicYear">—</div>
          </div>
          <div class="field"><label>Semester</label>
            <div class="view-input" id="vSemester">—</div>
          </div>
          <div class="field"><label>Email</label>
            <div class="view-input" id="vEmail">—</div>
          </div>
          <div class="field"><label>Phone</label>
            <div class="view-input" id="vPhone">—</div>
          </div>
          <div class="field"><label>Guardian</label>
            <div class="view-input" id="vGuardian">—</div>
          </div>
          <div class="field"><label>Guardian Email</label>
            <div class="view-input" id="vGuardianEmail">—</div>
          </div>
        </div>
        <div class="divider"></div>
        <div class="field"><label>Hold</label>
          <div class="view-input multiline" id="vHold">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Students (CSV)</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form method="POST" action="/admin/students/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <% } %>
            <div class="modal-body">
              <div class="field"><label>CSV File</label><input class="input" type="file" name="file"
                  accept=".csv,text/csv" required /></div>
              <div class="note">Required header: <strong>regNo</strong>. For new inserts, include
                <strong>programCode</strong> and <strong>classCode</strong>. Optional: fullName, email, phone,
                yearLevel, academicYear, semester, status, holdType, holdReason.</div>
            </div>
            <div class="modal-footer">
              <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
              <button class="btn primary" type="submit"><i class="fa-solid fa-file-import"></i> Import</button>
            </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/students/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>
        <input type="hidden" name="action" id="bulkActionVal">
        <input type="hidden" name="status" id="bulkStatusVal">
        <input type="hidden" name="holdType" id="bulkHoldTypeVal">
        <input type="hidden" name="holdReason" id="bulkHoldReasonVal">
        <input type="hidden" name="ids" id="bulkIdsVal">
  </form>

  <textarea id="studentsData" class="json-data" aria-hidden="true"><%- JSON.stringify((students || []).map(function(s){
    const progCode = String(s?.program?.code || '').trim();
    const progName = String(s?.program?.name || s?.program?.title || '').trim();
    const programLabel = (progCode && progName && progCode.toLowerCase() !== progName.toLowerCase()) ? (progCode + ' — ' + progName) : (progCode || progName || '');
    const classCode = String(s?.classGroup?.code || '').trim();
    const className = String(s?.classGroup?.name || s?.classGroup?.title || '').trim();
    const classLabel = (classCode && className && classCode.toLowerCase() !== className.toLowerCase()) ? (classCode + ' — ' + className) : (classCode || className || '');
    return {
      id: String(s._id || ''),
      regNo: s.regNo || '',
      fullName: s.fullName || '',
      firstName: s.firstName || '',
      middleName: s.middleName || '',
      lastName: s.lastName || '',
      email: s.email || '',
      phone: s.phone || '',
      programId: s.program?._id ? String(s.program._id) : (s.program ? String(s.program) : ''),
      programName: programLabel,
      classId: s.classGroup?._id ? String(s.classGroup._id) : (s.classGroup ? String(s.classGroup) : ''),
      className: classLabel,
      yearLevel: s.yearLevel || '',
      academicYear: s.academicYear || '',
      semester: Number(s.semester ?? 1),
      status: s.status || 'active',
      holdType: s.holdType || '',
      holdReason: s.holdReason || '',
      gender: s.gender || '',
      nationality: s.nationality || '',
      address: s.address || '',
      guardianName: s.guardianName || '',
      guardianPhone: s.guardianPhone || '',
      guardianEmail: s.guardianEmail || ''
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/students.js"></script>
</body>

</html>
