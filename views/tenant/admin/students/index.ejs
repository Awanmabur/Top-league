<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Students</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-5{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(320px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .arch{background:#f1f5f9;color:#334155}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1700px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}
    .col-check{width:48px}
    .col-student{width:280px}
    .col-level{width:120px}
    .col-class{width:120px}
    .col-subjects{width:300px}
    .col-term{width:100px}
    .col-academic{width:140px}
    .col-contacts{width:220px}
    .col-status{width:140px}
    .col-hold{width:220px}
    .col-actions{width:260px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .student-main{min-width:0}
    .student-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .student-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar>div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1100px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(760px,100%)}
    .modal.lg{width:min(1100px,100%)}
    .modal>form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px;font-weight:800}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}
    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:#eef2ff;color:#3730a3;font-size:12px;font-weight:800}
    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
    .tab{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .tab.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .tab-pane{display:none}
    .tab-pane.active{display:block}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}
    .multi-select{width:100%;min-height:190px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;padding:8px;outline:none;font-size:14px}
    .multi-select:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .help{font-size:12px;color:#6b7280}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}.grid-5{grid-template-columns:repeat(2,minmax(0,1fr))}}
    @media (max-width:680px){.input{min-width:160px}}
    @media (max-width:520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left>*,.toolbar .right>*{max-width:100%}table{min-width:1700px}.grid-5{grid-template-columns:1fr}}
    @media print{body *{visibility:hidden !important}#printArea,#printArea *{visibility:visible !important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>

<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Students</div>
          <div class="subtitle">Create, edit, import, export, print and manage academy student records.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <a class="btn light" id="btnExport" href="/tenant/students/export?<%= exportQuery %>"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</a>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Student</button>
        </div>
      </div>

      <div class="grid-5">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Active students</div>
        </div>
        <div class="card">
          <div class="section-title">On Hold</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.on_hold || 0 %></div>
          <div class="muted">Blocked temporarily</div>
        </div>
        <div class="card">
          <div class="section-title">Suspended</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.suspended || 0 %></div>
          <div class="muted">Restricted students</div>
        </div>
        <div class="card">
          <div class="section-title">Graduated</div>
          <div class="kpi-value" style="color:#3730a3"><%= kpis?.graduated || 0 %></div>
          <div class="muted">Completed students</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/tenant/students">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, reg no, email, phone..." />

            <select class="select" name="schoolLevel">
              <option value="">All Levels</option>
              <option value="nursery" <%= query?.schoolLevel === 'nursery' ? 'selected' : '' %>>Nursery</option>
              <option value="primary" <%= query?.schoolLevel === 'primary' ? 'selected' : '' %>>Primary</option>
              <option value="secondary" <%= query?.schoolLevel === 'secondary' ? 'selected' : '' %>>Secondary</option>
            </select>

            <select class="select" name="classLevel">
              <option value="">All Classes</option>
              <% (classLevels || []).forEach(function(level){ %>
                <option value="<%= level %>" <%= query?.classLevel === level ? 'selected' : '' %>><%= level %></option>
              <% }) %>
            </select>

            <select class="select" name="term">
              <option value="">All Terms</option>
              <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
              <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
              <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="on_hold" <%= query?.status === 'on_hold' ? 'selected' : '' %>>On Hold</option>
              <option value="suspended" <%= query?.status === 'suspended' ? 'selected' : '' %>>Suspended</option>
              <option value="graduated" <%= query?.status === 'graduated' ? 'selected' : '' %>>Graduated</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/tenant/students"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">student(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkSetStatus" type="button"><i class="fa-solid fa-rotate"></i> Set Status</button>
            <button class="btn-xs" id="bulkApplyHold" type="button"><i class="fa-solid fa-ban"></i> Apply Hold</button>
            <button class="btn-xs" id="bulkClearHold" type="button"><i class="fa-solid fa-circle-check"></i> Clear Hold</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Students Table</div>
              <div class="section-sub">Showing <%= students.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-student">Student</th>
                    <th class="col-level">Level</th>
                    <th class="col-class">Class</th>
                    <th class="col-subjects">Subjects</th>
                    <th class="col-term">Term</th>
                    <th class="col-academic">Academic Year</th>
                    <th class="col-contacts">Contacts</th>
                    <th class="col-status">Status</th>
                    <th class="col-hold">Hold</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyStudents"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>
            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.schoolLevel) params.set("schoolLevel", query.schoolLevel);
                  if (query?.classLevel) params.set("classLevel", query.classLevel);
                  if (query?.term) params.set("term", query.term);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/tenant/students?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers and imports.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Active Student</div>
                <div class="muted">Pre-fill active status</div>
              </div>
              <button class="btn-xs" id="quickActive" type="button"><i class="fa-solid fa-user-plus"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add On Hold Student</div>
                <div class="muted">Pre-fill status as On Hold</div>
              </div>
              <button class="btn-xs" id="quickHold" type="button"><i class="fa-solid fa-ban"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Import Students</div>
                <div class="muted">Upload CSV for bulk create/update</div>
              </div>
              <button class="btn-xs" id="quickImport" type="button"><i class="fa-solid fa-file-import"></i></button>
            </div>
          </div>

          <div class="note" style="margin-top:12px;">
            CSV headers: <strong>regNo, fullName, email, phone, schoolLevel, classLevel, term, academicYear, status, subjectCodes, holdType, holdReason</strong><br>
            Use pipe-separated subject codes in <strong>subjectCodes</strong>, for example: <strong>MAT-PRI-T1|ENG-PRI-T1</strong>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitleBar">Add Student</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="studentForm" method="POST" action="/tenant/students" novalidate>
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="tabs">
            <button class="tab active" type="button" data-tab="basic">Basic</button>
            <button class="tab" type="button" data-tab="academic">Academic</button>
            <button class="tab" type="button" data-tab="contacts">Contacts</button>
            <button class="tab" type="button" data-tab="holds">Holds</button>
          </div>

          <div class="tab-pane active" id="tab-basic">
            <div class="form-grid">
              <div class="field"><label>Registration No *</label><input class="input" id="mRegNo" name="regNo" maxlength="60" required /></div>
              <div class="field"><label>Full Name</label><input class="input" id="mFullName" name="fullName" maxlength="120" /></div>
              <div class="field"><label>Status</label>
                <select class="select" id="mStatus" name="status">
                  <option value="active">Active</option>
                  <option value="on_hold">On Hold</option>
                  <option value="suspended">Suspended</option>
                  <option value="graduated">Graduated</option>
                  <option value="archived">Archived</option>
                </select>
              </div>
              <div class="field"><label>First Name</label><input class="input" id="mFirstName" name="firstName" maxlength="60" /></div>
              <div class="field"><label>Middle Name</label><input class="input" id="mMiddleName" name="middleName" maxlength="60" /></div>
              <div class="field"><label>Last Name</label><input class="input" id="mLastName" name="lastName" maxlength="60" /></div>
              <div class="field"><label>Gender</label><input class="input" id="mGender" name="gender" maxlength="30" /></div>
              <div class="field"><label>Nationality</label><input class="input" id="mNationality" name="nationality" maxlength="60" /></div>
              <div class="field"><label>Address</label><input class="input" id="mAddress" name="address" maxlength="200" /></div>
            </div>
          </div>

          <div class="tab-pane" id="tab-academic">
            <div class="form-grid">
              <div class="field">
                <label>School Level *</label>
                <select class="select" id="mSchoolLevel" name="schoolLevel" required>
                  <option value="">— Select Level —</option>
                  <option value="nursery">Nursery</option>
                  <option value="primary">Primary</option>
                  <option value="secondary">Secondary</option>
                </select>
              </div>

              <div class="field">
                <label>Class Level *</label>
                <select class="select" id="mClassLevel" name="classLevel" required>
                  <option value="">— Select Class —</option>
                  <% (classLevels || []).forEach(function(level){ %>
                    <option value="<%= level %>"><%= level %></option>
                  <% }) %>
                </select>
              </div>

              <div class="field">
                <label>Term</label>
                <select class="select" id="mTerm" name="term">
                  <option value="1">Term 1</option>
                  <option value="2">Term 2</option>
                  <option value="3">Term 3</option>
                </select>
              </div>

              <div class="field">
                <label>Academic Year</label>
                <input class="input" id="mAcademicYear" name="academicYear" maxlength="20" />
              </div>

              <div class="field" style="grid-column:1 / -1">
                <label>Subjects</label>
                <select class="multi-select" id="mSubjects" name="subjects" multiple>
                  <% (subjects || []).forEach(function(s){ %>
                    <option value="<%= String(s._id) %>"><%= (s.code ? s.code + ' — ' : '') + (s.title || 'Subject') %></option>
                  <% }) %>
                </select>
                <div class="help">Use Ctrl/Cmd to select multiple subjects.</div>
              </div>
            </div>
          </div>

          <div class="tab-pane" id="tab-contacts">
            <div class="form-grid">
              <div class="field"><label>Email</label><input class="input" id="mEmail" name="email" maxlength="120" type="email" /></div>
              <div class="field"><label>Phone</label><input class="input" id="mPhone" name="phone" maxlength="40" /></div>
              <div class="field"><label>Guardian Name</label><input class="input" id="mGuardianName" name="guardianName" maxlength="120" /></div>
              <div class="field"><label>Guardian Phone</label><input class="input" id="mGuardianPhone" name="guardianPhone" maxlength="40" /></div>
              <div class="field"><label>Guardian Email</label><input class="input" id="mGuardianEmail" name="guardianEmail" maxlength="120" type="email" /></div>
            </div>
          </div>

          <div class="tab-pane" id="tab-holds">
            <div class="form-grid">
              <div class="field"><label>Hold Type</label><input class="input" id="mHoldType" name="holdType" maxlength="60" /></div>
              <div class="field" style="grid-column:1 / -1">
                <label>Hold Reason</label>
                <textarea class="textarea" id="mHoldReason" name="holdReason" maxlength="200"></textarea>
                <div class="muted" id="holdReasonCount">0 / 200</div>
              </div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Student</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Student Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Full Name</label><div class="view-input" id="vFullName">—</div></div>
          <div class="field"><label>Registration No</label><div class="view-input" id="vRegNo">—</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div>
          <div class="field"><label>School Level</label><div class="view-input" id="vSchoolLevel">—</div></div>
          <div class="field"><label>Class Level</label><div class="view-input" id="vClassLevel">—</div></div>
          <div class="field"><label>Term</label><div class="view-input" id="vTerm">—</div></div>
          <div class="field"><label>Academic Year</label><div class="view-input" id="vAcademicYear">—</div></div>
          <div class="field"><label>Email</label><div class="view-input" id="vEmail">—</div></div>
          <div class="field"><label>Phone</label><div class="view-input" id="vPhone">—</div></div>
          <div class="field"><label>Guardian</label><div class="view-input" id="vGuardian">—</div></div>
          <div class="field" style="grid-column:1 / -1">
            <label>Subjects</label>
            <div class="view-input multiline" id="vSubjects">—</div>
          </div>
          <div class="field" style="grid-column:1 / -1">
            <label>Hold Details</label>
            <div class="view-input multiline" id="vHold">—</div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" id="viewResendBtn"><i class="fa-solid fa-envelope"></i> Resend Setup</button>
        <button class="btn light" type="button" id="viewArchiveBtn"><i class="fa-solid fa-box-archive"></i> Archive</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Students CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form method="POST" action="/tenant/students/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="field">
            <label>Select CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>
          <div class="note" style="margin-top:12px;">
            Required header: <strong>regNo</strong><br>
            Recommended headers: <strong>fullName, email, phone, schoolLevel, classLevel, term, academicYear, status, subjectCodes, holdType, holdReason</strong>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-file-import"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusField">
  </form>

  <form id="bulkForm" method="POST" action="/tenant/students/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionVal">
    <input type="hidden" name="status" id="bulkStatusVal">
    <input type="hidden" name="holdType" id="bulkHoldTypeVal">
    <input type="hidden" name="holdReason" id="bulkHoldReasonVal">
    <input type="hidden" name="ids" id="bulkIdsVal">
  </form>

  <textarea id="studentsData" class="json-data" aria-hidden="true"><%- JSON.stringify((students || []).map(function(s){
    return {
      id: String(s._id || ''),
      regNo: s.regNo || '',
      fullName: s.fullName || '',
      firstName: s.firstName || '',
      middleName: s.middleName || '',
      lastName: s.lastName || '',
      email: s.email || '',
      phone: s.phone || '',
      schoolLevel: s.schoolLevel || '',
      classLevel: s.classLevel || '',
      term: Number(s.term ?? 1),
      academicYear: s.academicYear || '',
      status: s.status || 'active',
      holdType: s.holdType || '',
      holdReason: s.holdReason || '',
      gender: s.gender || '',
      nationality: s.nationality || '',
      address: s.address || '',
      guardianName: s.guardianName || '',
      guardianPhone: s.guardianPhone || '',
      guardianEmail: s.guardianEmail || '',
      subjects: Array.isArray(s.subjects) ? s.subjects.map(function(x){
        return {
          id: String(x?._id || x || ''),
          title: x?.title || '',
          code: x?.code || '',
          shortTitle: x?.shortTitle || ''
        };
      }) : []
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);

      function readStudentsData() {
        const el = $("studentsData");
        if (!el) return [];
        try {
          return JSON.parse(el.value || "[]");
        } catch (err) {
          console.error("Failed to parse students data:", err);
          return [];
        }
      }

      const STUDENTS = readStudentsData();
      if (!$("tbodyStudents")) return;

      const state = {
        selected: new Set(),
        currentViewId: null,
      };

      function escapeHtml(v) {
        return String(v ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function openModal(id) {
        const el = $(id);
        if (!el) return;
        el.classList.add("show");
        document.body.style.overflow = "hidden";
      }

      function closeModal(id) {
        const el = $(id);
        if (!el) return;
        el.classList.remove("show");
        document.body.style.overflow = "";
      }

      function submitRowAction(actionUrl, status) {
        const form = $("rowActionForm");
        if (!form) return;
        form.action = actionUrl;
        if ($("rowStatusField")) $("rowStatusField").value = status || "";
        form.submit();
      }

      function syncBulkbar() {
        $("selCount").textContent = String(state.selected.size);
        $("bulkbar").classList.toggle("show", state.selected.size > 0);
      }

      function titleCase(v) {
        const s = String(v || "");
        if (!s) return "—";
        return s.charAt(0).toUpperCase() + s.slice(1);
      }

      function schoolLevelLabel(v) {
        const map = { nursery: "Nursery", primary: "Primary", secondary: "Secondary" };
        return map[v] || v || "—";
      }

      function statusPill(status) {
        if (status === "active") return '<span class="pill ok"><i class="fa-solid fa-circle-check"></i> Active</span>';
        if (status === "on_hold") return '<span class="pill warn"><i class="fa-solid fa-ban"></i> On Hold</span>';
        if (status === "suspended") return '<span class="pill bad"><i class="fa-solid fa-triangle-exclamation"></i> Suspended</span>';
        if (status === "graduated") return '<span class="pill info"><i class="fa-solid fa-graduation-cap"></i> Graduated</span>';
        return '<span class="pill arch"><i class="fa-solid fa-box-archive"></i> Archived</span>';
      }

      function subjectLabelList(subjects) {
        if (!Array.isArray(subjects) || !subjects.length) return "—";
        return subjects.map((s) => {
          const code = String(s?.code || "").trim();
          const title = String(s?.title || s?.shortTitle || "").trim();
          return code && title ? `${code} — ${title}` : (code || title || "");
        }).filter(Boolean).join(", ") || "—";
      }

      function renderTable() {
        $("tbodyStudents").innerHTML =
          STUDENTS.map((s) => {
            const checked = state.selected.has(s.id) ? "checked" : "";
            const holdText = s.holdType ? `${s.holdType}${s.holdReason ? " • " + s.holdReason : ""}` : "—";

            return `
              <tr class="row-clickable" data-id="${escapeHtml(s.id)}">
                <td class="col-check">
                  <input type="checkbox" class="rowCheck" data-id="${escapeHtml(s.id)}" ${checked}>
                </td>

                <td class="col-student">
                  <div class="student-main">
                    <div class="student-title" title="${escapeHtml(s.fullName || [s.firstName, s.middleName, s.lastName].filter(Boolean).join(" "))}">
                      ${escapeHtml(s.fullName || [s.firstName, s.middleName, s.lastName].filter(Boolean).join(" ") || "—")}
                    </div>
                    <div class="student-sub" title="${escapeHtml(s.regNo || "—")}">${escapeHtml(s.regNo || "—")}</div>
                  </div>
                </td>

                <td class="col-level"><span class="cell-ellipsis">${escapeHtml(schoolLevelLabel(s.schoolLevel))}</span></td>
                <td class="col-class"><span class="cell-ellipsis">${escapeHtml(s.classLevel || "—")}</span></td>
                <td class="col-subjects"><span class="cell-ellipsis" title="${escapeHtml(subjectLabelList(s.subjects))}">${escapeHtml(subjectLabelList(s.subjects))}</span></td>
                <td class="col-term"><span class="cell-ellipsis">${escapeHtml("Term " + Number(s.term || 1))}</span></td>
                <td class="col-academic"><span class="cell-ellipsis">${escapeHtml(s.academicYear || "—")}</span></td>
                <td class="col-contacts">
                  <span class="cell-ellipsis" title="${escapeHtml([s.email, s.phone].filter(Boolean).join(" • ") || "—")}">
                    ${escapeHtml([s.email, s.phone].filter(Boolean).join(" • ") || "—")}
                  </span>
                </td>
                <td class="col-status">${statusPill(s.status)}</td>
                <td class="col-hold"><span class="cell-ellipsis" title="${escapeHtml(holdText)}">${escapeHtml(holdText)}</span></td>

                <td class="col-actions">
                  <div class="actions">
                    <button class="btn-xs actView" type="button" title="View"><i class="fa-solid fa-eye"></i></button>
                    <button class="btn-xs actEdit" type="button" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    <button class="btn-xs actResend" type="button" title="Resend Setup"><i class="fa-solid fa-envelope"></i></button>
                    <button class="btn-xs actArchive" type="button" title="Archive"><i class="fa-solid fa-box-archive"></i></button>
                    <button class="btn-xs actDelete" type="button" title="Delete"><i class="fa-solid fa-trash"></i></button>
                  </div>
                </td>
              </tr>
            `;
          }).join("") ||
          `
            <tr>
              <td colspan="11" style="padding:18px;">
                <div class="muted">No students found.</div>
              </td>
            </tr>
          `;

        $("checkAll").checked = STUDENTS.length > 0 && STUDENTS.every((s) => state.selected.has(s.id));
        syncBulkbar();
      }

      function openEditor(prefill) {
        const s = prefill || null;

        $("mTitleBar").textContent = s ? "Edit Student" : "Add Student";
        $("studentForm").action = s ? `/tenant/students/${encodeURIComponent(s.id)}` : "/tenant/students";

        $("mRegNo").value = s ? s.regNo || "" : "";
        $("mFullName").value = s ? s.fullName || "" : "";
        $("mStatus").value = s ? s.status || "active" : "active";
        $("mFirstName").value = s ? s.firstName || "" : "";
        $("mMiddleName").value = s ? s.middleName || "" : "";
        $("mLastName").value = s ? s.lastName || "" : "";
        $("mGender").value = s ? s.gender || "" : "";
        $("mNationality").value = s ? s.nationality || "" : "";
        $("mAddress").value = s ? s.address || "" : "";
        $("mSchoolLevel").value = s ? s.schoolLevel || "primary" : "primary";
        $("mClassLevel").value = s ? s.classLevel || "" : "";
        $("mTerm").value = s ? String(s.term || 1) : "1";
        $("mAcademicYear").value = s ? s.academicYear || "" : "";
        $("mEmail").value = s ? s.email || "" : "";
        $("mPhone").value = s ? s.phone || "" : "";
        $("mGuardianName").value = s ? s.guardianName || "" : "";
        $("mGuardianPhone").value = s ? s.guardianPhone || "" : "";
        $("mGuardianEmail").value = s ? s.guardianEmail || "" : "";
        $("mHoldType").value = s ? s.holdType || "" : "";
        $("mHoldReason").value = s ? s.holdReason || "" : "";

        const subjectSel = $("mSubjects");
        if (subjectSel) {
          const ids = s && Array.isArray(s.subjects) ? s.subjects.map((x) => String(x.id || "")) : [];
          Array.from(subjectSel.options).forEach((o) => {
            o.selected = ids.includes(o.value);
          });
        }

        $("holdReasonCount").textContent = `${$("mHoldReason").value.length} / 200`;
        openModal("mEdit");
      }

      function openViewModal(s) {
        if (!s) return;

        state.currentViewId = s.id;
        $("vFullName").textContent = s.fullName || [s.firstName, s.middleName, s.lastName].filter(Boolean).join(" ") || "—";
        $("vRegNo").textContent = s.regNo || "—";
        $("vStatus").innerHTML = statusPill(s.status || "active");
        $("vSchoolLevel").textContent = schoolLevelLabel(s.schoolLevel);
        $("vClassLevel").textContent = s.classLevel || "—";
        $("vTerm").textContent = `Term ${Number(s.term || 1)}`;
        $("vAcademicYear").textContent = s.academicYear || "—";
        $("vEmail").textContent = s.email || "—";
        $("vPhone").textContent = s.phone || "—";
        $("vGuardian").textContent = [s.guardianName, s.guardianPhone, s.guardianEmail].filter(Boolean).join(" • ") || "—";
        $("vSubjects").textContent = subjectLabelList(s.subjects);
        $("vHold").textContent = s.holdType ? `${s.holdType}${s.holdReason ? " • " + s.holdReason : ""}` : "—";

        openModal("mView");
      }

      function saveStudent() {
        const regNo = $("mRegNo").value.trim();
        const schoolLevel = $("mSchoolLevel").value;
        const classLevel = $("mClassLevel").value;

        if (!regNo) return alert("Registration number is required.");
        if (!schoolLevel) return alert("School level is required.");
        if (!classLevel) return alert("Class level is required.");

        $("studentForm").submit();
      }

      function submitBulk(action, extra = {}) {
        const ids = Array.from(state.selected);
        if (!ids.length) return alert("Select at least one student.");

        if (action === "delete" && !window.confirm(`Delete ${ids.length} selected student(s)?`)) return;
        if (action === "archive" && !window.confirm(`Archive ${ids.length} selected student(s)?`)) return;

        $("bulkActionVal").value = action;
        $("bulkStatusVal").value = extra.status || "";
        $("bulkHoldTypeVal").value = extra.holdType || "";
        $("bulkHoldReasonVal").value = extra.holdReason || "";
        $("bulkIdsVal").value = ids.join(",");
        $("bulkForm").submit();
      }

      function updateHoldCounter() {
        $("holdReasonCount").textContent = `${$("mHoldReason").value.length} / 200`;
      }

      $("btnCreate").addEventListener("click", function () {
        openEditor();
      });

      $("quickActive").addEventListener("click", function () {
        openEditor();
        $("mStatus").value = "active";
      });

      $("quickHold").addEventListener("click", function () {
        openEditor();
        $("mStatus").value = "on_hold";
      });

      $("btnImport").addEventListener("click", function () {
        openModal("mImport");
      });

      $("quickImport").addEventListener("click", function () {
        openModal("mImport");
      });

      $("btnPrint").addEventListener("click", function () {
        window.print();
      });

      $("btnBulk").addEventListener("click", function () {
        if (!state.selected.size) return alert("Select at least one student.");
        $("bulkbar").classList.add("show");
      });

      $("bulkSetStatus").addEventListener("click", function () {
        const status = prompt("Enter status: active, on_hold, suspended, graduated, archived");
        if (!status) return;
        submitBulk("set_status", { status });
      });

      $("bulkApplyHold").addEventListener("click", function () {
        const holdType = prompt("Enter hold type:");
        if (!holdType) return;
        const holdReason = prompt("Enter hold reason (optional):") || "";
        submitBulk("set_hold", { holdType, holdReason });
      });

      $("bulkClearHold").addEventListener("click", function () {
        submitBulk("clear_hold");
      });

      $("bulkArchive").addEventListener("click", function () {
        submitBulk("archive");
      });

      $("bulkDelete").addEventListener("click", function () {
        submitBulk("delete");
      });

      $("bulkClear").addEventListener("click", function () {
        state.selected.clear();
        renderTable();
      });

      $("checkAll").addEventListener("change", function (e) {
        if (e.target.checked) STUDENTS.forEach((s) => state.selected.add(s.id));
        else STUDENTS.forEach((s) => state.selected.delete(s.id));
        renderTable();
      });

      $("tbodyStudents").addEventListener("change", function (e) {
        if (!e.target.classList.contains("rowCheck")) return;
        const id = e.target.dataset.id;
        if (e.target.checked) state.selected.add(id);
        else state.selected.delete(id);
        renderTable();
      });

      $("tbodyStudents").addEventListener("click", function (e) {
        const tr = e.target.closest("tr[data-id]");
        if (!tr) return;

        const s = STUDENTS.find((x) => x.id === tr.dataset.id);
        if (!s) return;

        if (e.target.closest(".rowCheck") || e.target.closest(".actions") || e.target.closest(".btn-xs")) {
          if (e.target.closest(".actView")) return openViewModal(s);
          if (e.target.closest(".actEdit")) return openEditor(s);

          if (e.target.closest(".actResend")) {
            if (!window.confirm(`Resend setup link for "${s.fullName || s.regNo}"?`)) return;
            return submitRowAction(`/tenant/students/${encodeURIComponent(s.id)}/resend-setup`);
          }

          if (e.target.closest(".actArchive")) {
            if (!window.confirm(`Archive "${s.fullName || s.regNo}"?`)) return;
            return submitRowAction(`/tenant/students/${encodeURIComponent(s.id)}/archive`);
          }

          if (e.target.closest(".actDelete")) {
            if (!window.confirm(`Delete "${s.fullName || s.regNo}"?`)) return;
            return submitRowAction(`/tenant/students/${encodeURIComponent(s.id)}/delete`);
          }

          return;
        }

        openViewModal(s);
      });

      $("viewEditBtn").addEventListener("click", function () {
        const s = STUDENTS.find((x) => x.id === state.currentViewId);
        if (!s) return;
        closeModal("mView");
        openEditor(s);
      });

      $("viewArchiveBtn").addEventListener("click", function () {
        const s = STUDENTS.find((x) => x.id === state.currentViewId);
        if (!s) return;
        if (!window.confirm(`Archive "${s.fullName || s.regNo}"?`)) return;
        submitRowAction(`/tenant/students/${encodeURIComponent(s.id)}/archive`);
      });

      $("viewResendBtn").addEventListener("click", function () {
        const s = STUDENTS.find((x) => x.id === state.currentViewId);
        if (!s) return;
        if (!window.confirm(`Resend setup link for "${s.fullName || s.regNo}"?`)) return;
        submitRowAction(`/tenant/students/${encodeURIComponent(s.id)}/resend-setup`);
      });

      $("saveBtn").addEventListener("click", saveStudent);
      $("mHoldReason").addEventListener("input", updateHoldCounter);

      document.querySelectorAll("[data-close-modal]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          closeModal(btn.dataset.closeModal);
        });
      });

      ["mEdit", "mView", "mImport"].forEach(function (mid) {
        const el = $(mid);
        if (!el) return;
        el.addEventListener("click", function (e) {
          if (e.target.id === mid) closeModal(mid);
        });
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          document.querySelectorAll(".modal-backdrop.show").forEach(function (el) {
            el.classList.remove("show");
          });
          document.body.style.overflow = "";
        }
      });

      document.querySelectorAll(".tab").forEach(function (tab) {
        tab.addEventListener("click", function () {
          const key = tab.dataset.tab;
          document.querySelectorAll(".tab").forEach((t) => t.classList.remove("active"));
          document.querySelectorAll(".tab-pane").forEach((p) => p.classList.remove("active"));
          tab.classList.add("active");
          const pane = document.getElementById("tab-" + key);
          if (pane) pane.classList.add("active");
        });
      });

      renderTable();
      updateHoldCounter();
    })();
  </script>
</body>
</html>