<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Courses</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1760px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-course{width:320px}
    .col-program{width:220px}
    .col-department{width:190px}
    .col-level{width:130px}
    .col-yos{width:110px}
    .col-sem{width:110px}
    .col-type{width:120px}
    .col-mode{width:120px}
    .col-credits{width:120px}
    .col-staff{width:220px}
    .col-status{width:140px}
    .col-actions{width:250px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .course-main{min-width:0}

    .course-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .course-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1180px,100%);
      max-height:calc(100dvh - 40px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(980px,100%)}
    .modal.lg{width:min(1180px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:18px 20px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{
      font-weight:900;
      font-size:18px;
      color:#0f172a;
    }

    .modal-body{
      padding:18px 20px;
      overflow-y:auto;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 20px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .modal-layout{
      display:grid;
      grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);
      gap:18px;
      align-items:start;
    }

    .modal-panel{
      border:1px solid rgba(13,64,96,.10);
      border-radius:18px;
      padding:16px;
      background:#fcfdff;
    }

    .panel-title{
      font-size:13px;
      font-weight:900;
      color:#0f172a;
      margin-bottom:2px;
    }

    .panel-sub{
      font-size:12px;
      color:#6b7280;
      margin-bottom:14px;
    }

    .form-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:12px;
    }

    .form-grid-3{
      display:grid;
      grid-template-columns:repeat(3,minmax(0,1fr));
      gap:12px;
    }

    .field{
      display:flex;
      flex-direction:column;
      gap:6px;
    }

    .field.full{
      grid-column:1 / -1;
    }

    .field label{
      font-size:12px;
      font-weight:800;
      color:#475569;
    }

    .field input,.field select,.field textarea{width:100%}

    .multi-select{
      width:100%;
      min-height:220px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      padding:8px;
      outline:none;
      font-size:14px;
    }

    .multi-select:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .help{
      font-size:12px;
      color:#6b7280;
    }

    .char-count{
      font-size:12px;
      color:#6b7280;
      text-align:right;
    }

    .note-box{
      padding:12px 14px;
      border-radius:14px;
      border:1px dashed rgba(13,64,96,.18);
      background:rgba(13,64,96,.03);
      font-size:12px;
      color:#475569;
      line-height:1.5;
    }

    .section-divider{
      height:1px;
      background:rgba(13,64,96,.10);
      margin:14px 0;
    }

    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:6px 10px;
      border-radius:999px;
      background:#eef2ff;
      color:#3730a3;
      font-size:12px;
      font-weight:800;
    }

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    .json-data{display:none !important}

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
      .modal-layout{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 720px){
      .form-grid,
      .form-grid-3{
        grid-template-columns:1fr;
      }
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1760px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Courses</div>
          <div class="subtitle">Create, edit, export, print and manage academic courses.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Course</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Published courses</div>
        </div>
        <div class="card">
          <div class="section-title">Draft</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div>
          <div class="muted">Work in progress</div>
        </div>
        <div class="card">
          <div class="section-title">Archived</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div>
          <div class="muted">Hidden / inactive</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/courses">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search title, code, level..." />

            <select class="select" name="program">
              <option value="">All Programs</option>
              <% (programsList || []).forEach(function(p){ %>
                <option value="<%= String(p._id) %>" <%= String(query?.program || '') === String(p._id) ? 'selected' : '' %>><%= p.name || p.code || 'Program' %></option>
              <% }) %>
            </select>

            <select class="select" name="department">
              <option value="">All Departments</option>
              <% (departmentsList || []).forEach(function(d){ %>
                <option value="<%= String(d._id) %>" <%= String(query?.department || '') === String(d._id) ? 'selected' : '' %>><%= d.name || d.code || 'Department' %></option>
              <% }) %>
            </select>

            <select class="select" name="type">
              <option value="">All Types</option>
              <option value="core" <%= query?.type === 'core' ? 'selected' : '' %>>Core</option>
              <option value="elective" <%= query?.type === 'elective' ? 'selected' : '' %>>Elective</option>
              <option value="general" <%= query?.type === 'general' ? 'selected' : '' %>>General</option>
            </select>

            <select class="select" name="studyMode">
              <option value="">All Modes</option>
              <option value="day" <%= query?.studyMode === 'day' ? 'selected' : '' %>>Day</option>
              <option value="evening" <%= query?.studyMode === 'evening' ? 'selected' : '' %>>Evening</option>
              <option value="weekend" <%= query?.studyMode === 'weekend' ? 'selected' : '' %>>Weekend</option>
              <option value="online" <%= query?.studyMode === 'online' ? 'selected' : '' %>>Online</option>
            </select>

            <select class="select" name="yearOfStudy">
              <option value="">All Years</option>
              <% for (let y = 0; y <= 6; y++) { %>
                <option value="<%= y %>" <%= String(query?.yearOfStudy || '') === String(y) ? 'selected' : '' %>><%= y === 0 ? 'Foundation' : ('Year ' + y) %></option>
              <% } %>
            </select>

            <select class="select" name="semester">
              <option value="">All Semesters</option>
              <% for (let s = 0; s <= 6; s++) { %>
                <option value="<%= s %>" <%= String(query?.semester || '') === String(s) ? 'selected' : '' %>><%= s === 0 ? '—' : ('Semester ' + s) %></option>
              <% } %>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/courses"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">course(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <button class="btn-xs" id="bulkDraft" type="button"><i class="fa-solid fa-pen-to-square"></i> Draft</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Courses Table</div>
              <div class="section-sub">Showing <%= courses.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-course">Course</th>
                    <th class="col-program">Program</th>
                    <th class="col-department">Department</th>
                    <th class="col-level">Level</th>
                    <th class="col-yos">Year</th>
                    <th class="col-sem">Semester</th>
                    <th class="col-type">Type</th>
                    <th class="col-mode">Mode</th>
                    <th class="col-credits">Credits / Hours</th>
                    <th class="col-staff">Coordinator / Lecturer</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyCourses"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong><%= query?.perPage || 10 %></strong>
            </div>

            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.program) params.set("program", query.program);
                  if (query?.department) params.set("department", query.department);
                  if (query?.type) params.set("type", query.type);
                  if (query?.studyMode) params.set("studyMode", query.studyMode);
                  if (query?.yearOfStudy) params.set("yearOfStudy", query.yearOfStudy);
                  if (query?.semester) params.set("semester", query.semester);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/admin/courses?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Core Course</div>
                <div class="muted">Pre-fill type as Core</div>
              </div>
              <button class="btn-xs" id="quickCore" type="button"><i class="fa-solid fa-book"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Elective Course</div>
                <div class="muted">Pre-fill type as Elective</div>
              </div>
              <button class="btn-xs" id="quickElective" type="button"><i class="fa-solid fa-layer-group"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Online Course</div>
                <div class="muted">Pre-fill mode as Online</div>
              </div>
              <button class="btn-xs" id="quickOnline" type="button"><i class="fa-solid fa-globe"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitleBar">Add Course</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form id="courseForm" method="POST" action="/admin/courses">
        <% if (csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="modal-body">
          <div class="modal-layout">
            <section class="modal-panel">
              <div class="panel-title">Course Information</div>
              <div class="panel-sub">Main course identity, classification and academic structure.</div>

              <div class="form-grid">
                <div class="field full">
                  <label for="mTitle">Course Title</label>
                  <input class="input" id="mTitle" name="title" placeholder="e.g. Data Structures" required />
                </div>

                <div class="field">
                  <label for="mCode">Course Code</label>
                  <input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" />
                </div>

                <div class="field">
                  <label for="mStatus">Status</label>
                  <select class="select" id="mStatus" name="status">
                    <option value="active">Active</option>
                    <option value="draft">Draft</option>
                    <option value="archived">Archived</option>
                  </select>
                </div>

                <div class="field">
                  <label for="mShortTitle">Short Title</label>
                  <input class="input" id="mShortTitle" name="shortTitle" maxlength="80" placeholder="Optional short title" />
                </div>

                <div class="field">
                  <label for="mLevel">Level</label>
                  <input class="input" id="mLevel" name="level" maxlength="40" placeholder="e.g. Bachelor" />
                </div>

                <div class="field">
                  <label for="mProgram">Program</label>
                  <select class="select" id="mProgram" name="program">
                    <option value="">— Select Program —</option>
                    <% (programsList || []).forEach(function(p){ %>
                      <option value="<%= String(p._id) %>"><%= p.name || p.code || 'Program' %></option>
                    <% }) %>
                  </select>
                </div>

                <div class="field">
                  <label for="mDepartment">Department</label>
                  <select class="select" id="mDepartment" name="department">
                    <option value="">— Select Department —</option>
                    <% (departmentsList || []).forEach(function(d){ %>
                      <option value="<%= String(d._id) %>"><%= d.name || d.code || 'Department' %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="section-divider"></div>

              <div class="panel-title">Academic Setup</div>
              <div class="panel-sub">Year, semester, credits, hours and delivery mode.</div>

              <div class="form-grid-3">
                <div class="field">
                  <label for="mYearOfStudy">Year of Study</label>
                  <input class="input" id="mYearOfStudy" name="yearOfStudy" type="number" min="0" max="20" />
                </div>

                <div class="field">
                  <label for="mSemester">Semester</label>
                  <input class="input" id="mSemester" name="semester" type="number" min="0" max="6" />
                </div>

                <div class="field">
                  <label for="mCredits">Credits</label>
                  <input class="input" id="mCredits" name="credits" type="number" min="0" max="60" />
                </div>

                <div class="field">
                  <label for="mContactHours">Contact Hours</label>
                  <input class="input" id="mContactHours" name="contactHours" type="number" min="0" max="500" />
                </div>

                <div class="field">
                  <label for="mType">Type</label>
                  <select class="select" id="mType" name="type">
                    <option value="core">Core</option>
                    <option value="elective">Elective</option>
                    <option value="general">General</option>
                  </select>
                </div>

                <div class="field">
                  <label for="mStudyMode">Study Mode</label>
                  <select class="select" id="mStudyMode" name="studyMode">
                    <option value="day">Day</option>
                    <option value="evening">Evening</option>
                    <option value="weekend">Weekend</option>
                    <option value="online">Online</option>
                  </select>
                </div>
              </div>

              <div class="section-divider"></div>

              <div class="field">
                <label for="mDescription">Description</label>
                <textarea class="textarea" id="mDescription" name="description" maxlength="1200" placeholder="Write a clear summary of the course..."></textarea>
                <div class="char-count" id="descCount">0 / 1200</div>
              </div>
            </section>

            <section class="modal-panel">
              <div class="panel-title">Staff & Dependencies</div>
              <div class="panel-sub">Assign teaching staff and configure prerequisites.</div>

              <div class="note-box">
                You can save the course without prerequisites and update them later when your catalog is complete.
              </div>

              <div class="form-grid" style="margin-top:12px;">
                <div class="field full">
                  <label for="mCoordinator">Coordinator</label>
                  <select class="select" id="mCoordinator" name="coordinator">
                    <option value="">— Select Coordinator —</option>
                    <% (staffList || []).forEach(function(s){ %>
                      <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' — ' + s.role) : '' %></option>
                    <% }) %>
                  </select>
                </div>

                <div class="field full">
                  <label for="mLecturer">Lecturer</label>
                  <select class="select" id="mLecturer" name="lecturer">
                    <option value="">— Select Lecturer —</option>
                    <% (staffList || []).forEach(function(s){ %>
                      <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' — ' + s.role) : '' %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="section-divider"></div>

              <div class="field">
                <label for="mPrerequisites">Prerequisites</label>
                <select id="mPrerequisites" class="multi-select" multiple>
                  <% (allCoursesList || []).forEach(function(c){ %>
                    <option value="<%= String(c._id) %>"><%= c.code || '—' %> — <%= c.title || 'Course' %></option>
                  <% }) %>
                </select>
                <div class="help">Use Ctrl/Cmd to select multiple courses.</div>
                <div id="mPrereqWrap" style="display:none;"></div>
              </div>

              <div class="section-divider"></div>

              <div class="field">
                <label for="mObjectives">Objectives</label>
                <textarea class="textarea" id="mObjectives" name="objectives" maxlength="1200" placeholder="Course learning objectives..."></textarea>
                <div class="char-count" id="objCount">0 / 1200</div>
              </div>

              <div class="field" style="margin-top:12px;">
                <label for="mOutline">Outline</label>
                <textarea class="textarea" id="mOutline" name="outline" maxlength="5000" placeholder="Course outline, topics or weekly breakdown..."></textarea>
                <div class="char-count" id="outlineCount">0 / 5000</div>
              </div>
            </section>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button">
            <i class="fa-solid fa-floppy-disk"></i> Save Course
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Course Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Course</label>
            <div class="view-input" id="vTitle">—</div>
          </div>

          <div class="field">
            <label>Code</label>
            <div class="view-input" id="vCode">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Short Title</label>
            <div class="view-input" id="vShortTitle">—</div>
          </div>

          <div class="field">
            <label>Level</label>
            <div class="view-input" id="vLevel">—</div>
          </div>

          <div class="field">
            <label>Program</label>
            <div class="view-input" id="vProgram">—</div>
          </div>

          <div class="field">
            <label>Department</label>
            <div class="view-input" id="vDepartment">—</div>
          </div>

          <div class="field">
            <label>Year / Semester</label>
            <div class="view-input" id="vYearSemester">—</div>
          </div>

          <div class="field">
            <label>Credits / Hours</label>
            <div class="view-input" id="vCreditsHours">—</div>
          </div>

          <div class="field">
            <label>Type / Mode</label>
            <div class="view-input" id="vTypeMode">—</div>
          </div>

          <div class="field">
            <label>Coordinator</label>
            <div class="view-input" id="vCoordinator">—</div>
          </div>

          <div class="field">
            <label>Lecturer</label>
            <div class="view-input" id="vLecturer">—</div>
          </div>
        </div>

        <div class="section-divider"></div>

        <div class="field">
          <label>Description</label>
          <div class="view-input multiline" id="vDescription">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Objectives</label>
          <div class="view-input multiline" id="vObjectives">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Outline</label>
          <div class="view-input multiline" id="vOutline">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Prerequisites</label>
          <div class="view-input multiline">
            <div class="tag-list" id="vPrerequisites"></div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" id="viewActivateBtn"><i class="fa-solid fa-circle-check"></i> Activate</button>
        <button class="btn light" type="button" id="viewDraftBtn"><i class="fa-solid fa-pen-to-square"></i> Draft</button>
        <button class="btn light" type="button" id="viewArchiveBtn"><i class="fa-solid fa-box-archive"></i> Archive</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusField">
  </form>

  <form id="bulkForm" method="POST" action="/admin/courses/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionField">
    <input type="hidden" name="ids" id="bulkIdsField">
  </form>

  <textarea id="coursesData" class="json-data" aria-hidden="true"><%- JSON.stringify((courses || []).map(function(c){
    return {
      id: String(c._id || ''),
      title: c.title || '',
      code: c.code || '',
      shortTitle: c.shortTitle || '',
      departmentId: c.department?._id ? String(c.department._id) : (c.department ? String(c.department) : ''),
      departmentName: c.department?.name || c.department?.code || '',
      programId: c.program?._id ? String(c.program._id) : (c.program ? String(c.program) : ''),
      programName: c.program?.name || c.program?.code || '',
      level: c.level || '',
      yearOfStudy: Number(c.yearOfStudy ?? 1),
      semester: Number(c.semester ?? 1),
      credits: Number(c.credits || 0),
      contactHours: Number(c.contactHours || 0),
      type: c.type || 'core',
      studyMode: c.studyMode || 'day',
      status: c.status || 'active',
      description: c.description || '',
      objectives: c.objectives || '',
      outline: c.outline || '',
      prerequisites: Array.isArray(c.prerequisites) ? c.prerequisites.map(function(x){ return String(x); }) : [],
      prerequisiteLabels: Array.isArray(c.prerequisitesResolved) ? c.prerequisitesResolved.map(function(x){
        return {
          id: String(x._id || ''),
          label: ((x.code || '—') + ' — ' + (x.title || 'Course')).trim()
        };
      }) : [],
      coordinatorId: c.coordinator?._id ? String(c.coordinator._id) : (c.coordinator ? String(c.coordinator) : ''),
      coordinatorName: c.coordinator?.fullName || c.coordinator?.name || '',
      lecturerId: c.lecturer?._id ? String(c.lecturer._id) : (c.lecturer ? String(c.lecturer) : ''),
      lecturerName: c.lecturer?.fullName || c.lecturer?.name || ''
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/courses.js"></script>
</body>
</html>