<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Campus") %> • Exams</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(320px,.45fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1620px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-exam{width:330px}
    .col-course{width:220px}
    .col-class{width:180px}
    .col-program{width:180px}
    .col-date{width:140px}
    .col-time{width:140px}
    .col-room{width:140px}
    .col-invigilator{width:180px}
    .col-status{width:130px}
    .col-actions{width:260px}

    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .exam-main{min-width:0}
    .exam-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .exam-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}

    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}

    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1080px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(980px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:#eef2ff;color:#3730a3;font-size:12px;font-weight:800}

    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}

    .calendar-wrap{display:grid;gap:10px}
    .calbar{display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .calgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:8px}
    .calhead{font-size:12px;font-weight:900;color:#6b7280;padding:6px}
    .daycell{min-height:120px;border:1px solid rgba(13,64,96,.10);border-radius:14px;padding:8px;background:#fff;display:flex;flex-direction:column;gap:6px}
    .daycell.muted{background:#fbfdff;color:#94a3b8}
    .daytop{display:flex;justify-content:space-between;align-items:center;font-size:12px;font-weight:900}
    .cal-pill{display:block;padding:5px 8px;border-radius:999px;background:#eef2ff;color:#3730a3;font-size:11px;font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:pointer}

    .paperbox{border:1px solid rgba(13,64,96,.10);border-radius:14px;background:#fbfdff;padding:10px}
    .paperrow{display:grid;grid-template-columns:minmax(0,1.3fr) minmax(110px,.5fr) minmax(110px,.5fr) auto;gap:8px;align-items:end;margin-top:8px}

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }
    @media (max-width: 900px){
      .form-grid,.paperrow{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
      .calgrid{grid-template-columns:repeat(2,1fr)}
    }
    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }
    @media (max-width: 520px){
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
    }
    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{position:absolute;inset:0;background:#fff;padding:20px}
      .no-print{display:none !important}
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap no-print">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar no-print">
        <div>
          <div class="title">Exams</div>
          <div class="subtitle">Schedule, edit, export, import, print and manage exams with conflict checks.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnCalendar" type="button"><i class="fa-solid fa-calendar-days"></i> Calendar</button>
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Schedule Exam</button>
        </div>
      </div>

      <div class="grid-4" style="margin-top:12px;">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div><div class="muted">Matching filter</div></div>
        <div class="card"><div class="section-title">Scheduled</div><div class="kpi-value" style="color:#3730a3"><%= kpis?.scheduled || 0 %></div><div class="muted">Upcoming exams</div></div>
        <div class="card"><div class="section-title">Ongoing</div><div class="kpi-value" style="color:#92400e"><%= kpis?.ongoing || 0 %></div><div class="muted">Currently in progress</div></div>
        <div class="card"><div class="section-title">Completed</div><div class="kpi-value" style="color:#15803d"><%= kpis?.completed || 0 %></div><div class="muted">Finished exams</div></div>
      </div>

      <section class="card no-print" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/exams">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search title, room, campus..." />

            <select class="select" name="academicYear">
              <option value="">Any Year</option>
              <% (academicYears || []).forEach(function(y){ %>
                <option value="<%= y %>" <%= query?.academicYear === y ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>

            <select class="select" name="semester">
              <option value="">Any Semester</option>
              <% for (let s = 1; s <= 6; s++) { %>
                <option value="<%= s %>" <%= String(query?.semester || '') === String(s) ? 'selected' : '' %>><%= 'Sem ' + s %></option>
              <% } %>
            </select>

            <select class="select" name="classGroup">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= c._id %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
              <% }) %>
            </select>

            <select class="select" name="course">
              <option value="">All Courses</option>
              <% (courses || []).forEach(function(c){ %>
                <option value="<%= c._id %>" <%= String(query?.course || '') === String(c._id) ? 'selected' : '' %>><%= c.code %></option>
              <% }) %>
            </select>

            <select class="select" name="examType">
              <option value="">All Types</option>
              <% ['midterm','final','quiz','test','mock','practical','other'].forEach(function(t){ %>
                <option value="<%= t %>" <%= query?.examType === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
              <% }) %>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <% ['scheduled','ongoing','completed','archived'].forEach(function(t){ %>
                <option value="<%= t %>" <%= query?.status === t ? 'selected' : '' %>><%= t.charAt(0).toUpperCase() + t.slice(1) %></option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/exams"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">exam(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Exams Table</div>
              <div class="section-sub">Showing <%= exams.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check no-print"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-exam">Exam</th>
                    <th class="col-course">Course</th>
                    <th class="col-class">Class</th>
                    <th class="col-program">Program</th>
                    <th class="col-date">Date</th>
                    <th class="col-time">Time</th>
                    <th class="col-room">Room/Campus</th>
                    <th class="col-invigilator">Invigilator</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions no-print" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyExams"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination no-print">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>
            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);
                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set('q', query.q);
                  if (query?.academicYear) params.set('academicYear', query.academicYear);
                  if (query?.semester) params.set('semester', query.semester);
                  if (query?.classGroup) params.set('classGroup', query.classGroup);
                  if (query?.course) params.set('course', query.course);
                  if (query?.examType) params.set('examType', query.examType);
                  if (query?.status) params.set('status', query.status);
                  params.set('page', String(targetPage));
                  return '/admin/exams?' + params.toString();
                }
                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>
              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>"><i class="fa-solid fa-angle-left"></i></a>
              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>
              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>"><i class="fa-solid fa-angle-right"></i></a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast schedule helpers and calendar preview.</div>

          <div class="mini-list no-print">
            <div class="mini-item">
              <div class="left"><div class="strong">Schedule Final Exam</div><div class="muted">Pre-fill type as Final</div></div>
              <button class="btn-xs" id="quickFinal" type="button"><i class="fa-solid fa-graduation-cap"></i></button>
            </div>
            <div class="mini-item">
              <div class="left"><div class="strong">Schedule Midterm</div><div class="muted">Pre-fill type as Midterm</div></div>
              <button class="btn-xs" id="quickMidterm" type="button"><i class="fa-solid fa-pen-ruler"></i></button>
            </div>
            <div class="mini-item">
              <div class="left"><div class="strong">Schedule Practical</div><div class="muted">Pre-fill type as Practical</div></div>
              <button class="btn-xs" id="quickPractical" type="button"><i class="fa-solid fa-flask"></i></button>
            </div>
          </div>

          <div class="divider"></div>

          <div class="calendar-wrap">
            <div class="calbar">
              <div>
                <div class="section-title" id="calTitle">Calendar</div>
                <div class="muted">Local preview from loaded page records</div>
              </div>
              <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center" class="no-print">
                <button class="btn-xs" type="button" id="calPrev"><i class="fa-solid fa-angle-left"></i></button>
                <button class="btn-xs" type="button" id="calToday">Today</button>
                <button class="btn-xs" type="button" id="calNext"><i class="fa-solid fa-angle-right"></i></button>
              </div>
            </div>
            <div class="calgrid" id="calendarGrid"></div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitleLabel">Schedule Exam</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="examForm" method="POST" action="/admin/exams">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="form-grid">
            <div class="field"><label>Exam Title</label><input class="input" id="mExamTitle" name="title" required /></div>
            <div class="field"><label>Exam Type</label><select class="select" id="mExamType" name="examType"><% ['final','midterm','quiz','test','mock','practical','other'].forEach(function(t){ %><option value="<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></option><% }) %></select></div>
            <div class="field"><label>Status</label><select class="select" id="mStatus" name="status"><% ['scheduled','ongoing','completed','archived'].forEach(function(t){ %><option value="<%= t %>"><%= t.charAt(0).toUpperCase() + t.slice(1) %></option><% }) %></select></div>

            <div class="field"><label>Class</label><select class="select" id="mClass" name="classGroup" required><option value="">— Select Class —</option><% (classes || []).forEach(function(c){ %><option value="<%= c._id %>"><%= c.name %></option><% }) %></select></div>
            <div class="field"><label>Course</label><select class="select" id="mCourse" name="course" required><option value="">— Select Course —</option><% (courses || []).forEach(function(c){ %><option value="<%= c._id %>"><%= c.code %> — <%= c.title %></option><% }) %></select></div>
            <div class="field"><label>Program (optional)</label><select class="select" id="mProgram" name="program"><option value="">— None —</option><% (programs || []).forEach(function(p){ %><option value="<%= p._id %>"><%= p.name %></option><% }) %></select></div>

            <div class="field"><label>Date</label><input class="input" id="mDate" name="date" type="date" required /></div>
            <div class="field"><label>Start Time</label><input class="input" id="mStart" name="startTime" type="time" required /></div>
            <div class="field"><label>End Time</label><input class="input" id="mEnd" name="endTime" type="time" required /></div>

            <div class="field"><label>Room</label><input class="input" id="mRoom" name="room" maxlength="60" /></div>
            <div class="field"><label>Campus</label><input class="input" id="mCampus" name="campus" maxlength="80" /></div>
            <div class="field"><label>Invigilator</label><select class="select" id="mInvigilator" name="invigilator"><option value="">— Not Assigned —</option><% (staffList || []).forEach(function(s){ %><option value="<%= s._id %>"><%= (s.fullName || s.name || 'Staff') %><%= s.role ? (' — ' + s.role) : '' %></option><% }) %></select></div>

            <div class="field"><label>Academic Year</label><input class="input" id="mAcademicYear" name="academicYear" placeholder="2025/2026" maxlength="20" /></div>
            <div class="field"><label>Semester</label><input class="input" id="mSemester" name="semester" type="number" min="1" max="6" value="1" /></div>
            <div class="field"><label>Duration Minutes</label><input class="input" id="mDurationMinutes" name="durationMinutes" type="number" min="1" max="1440" value="120" /></div>

            <div class="field"><label>Total Marks</label><input class="input" id="mTotalMarks" name="totalMarks" type="number" min="0" max="100000" value="100" /></div>
            <div class="field"><label>Pass Mark</label><input class="input" id="mPassMark" name="passMark" type="number" min="0" max="100000" value="50" /></div>
            <div class="field"><label>Instructions</label><textarea class="textarea" id="mInstructions" name="instructions" maxlength="2000"></textarea></div>
          </div>

          <div class="divider"></div>

          <div style="display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap">
            <div>
              <div class="section-title">Papers</div>
              <div class="muted">Optional paper breakdown</div>
            </div>
            <button class="btn-xs" id="addPaperRow" type="button"><i class="fa-solid fa-plus"></i> Add Paper</button>
          </div>

          <div class="paperbox" id="papersWrap">
            <div class="paperrow" style="margin-top:0;">
              <div class="muted strong">Paper Name</div>
              <div class="muted strong">Marks</div>
              <div class="muted strong">Duration</div>
              <div></div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Exam</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Exam Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Exam</label><div class="view-input" id="vTitle">—</div></div>
          <div class="field"><label>Type</label><div class="view-input" id="vType">—</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div>
          <div class="field"><label>Course</label><div class="view-input" id="vCourse">—</div></div>
          <div class="field"><label>Class</label><div class="view-input" id="vClass">—</div></div>
          <div class="field"><label>Program</label><div class="view-input" id="vProgram">—</div></div>
          <div class="field"><label>Date</label><div class="view-input" id="vDate">—</div></div>
          <div class="field"><label>Time</label><div class="view-input" id="vTime">—</div></div>
          <div class="field"><label>Room / Campus</label><div class="view-input" id="vRoom">—</div></div>
          <div class="field"><label>Invigilator</label><div class="view-input" id="vInvigilator">—</div></div>
          <div class="field"><label>Academic Year</label><div class="view-input" id="vAcademicYear">—</div></div>
          <div class="field"><label>Semester</label><div class="view-input" id="vSemester">—</div></div>
          <div class="field"><label>Marks</label><div class="view-input" id="vMarks">—</div></div>
          <div class="field"><label>Duration</label><div class="view-input" id="vDuration">—</div></div>
        </div>
        <div class="divider"></div>
        <div class="field"><label>Instructions</label><div class="view-input multiline" id="vInstructions">—</div></div>
        <div class="field" style="margin-top:12px;"><label>Papers</label><div class="view-input multiline"><div class="tag-list" id="vPapers"></div></div></div>
      </div>
      <div class="modal-footer no-print">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Exams CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form method="POST" action="/admin/exams/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="note">Expected headers: title, examType, academicYear, semester, classGroupId, courseId, programId, date, startTime, endTime, room, campus, invigilatorId, totalMarks, passMark, status, instructions.</div>
          <div class="field" style="margin-top:12px;"><label>CSV File</label><input class="input" type="file" name="file" accept=".csv,text/csv" required /></div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit">Upload CSV</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusValue" />
  </form>

  <form id="bulkForm" method="POST" action="/admin/exams/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionValue">
    <input type="hidden" name="ids" id="bulkIds">
  </form>

  <script id="examsData" type="application/json"><%- JSON.stringify((exams || []).map(function(x){
    return {
      id: String(x._id || ''),
      title: x.title || '',
      examType: x.examType || 'final',
      academicYear: x.academicYear || '',
      semester: Number(x.semester || 1),
      classId: x.classGroup?._id ? String(x.classGroup._id) : '',
      className: x.classGroup?.name || '',
      programId: x.program?._id ? String(x.program._id) : '',
      programName: x.program?.name || '',
      courseId: x.course?._id ? String(x.course._id) : '',
      courseCode: x.course?.code || '',
      courseTitle: x.course?.title || '',
      date: x.dateKey || (x.date ? new Date(x.date).toISOString().slice(0,10) : ''),
      startTime: x.startTime || '',
      endTime: x.endTime || '',
      room: x.room || '',
      campus: x.campus || '',
      invigilatorId: x.invigilator?._id ? String(x.invigilator._id) : '',
      invigilatorName: x.invigilator?.fullName || x.invigilator?.name || '',
      totalMarks: Number(x.totalMarks || 100),
      passMark: Number(x.passMark || 50),
      durationMinutes: Number(x.durationMinutes || 0),
      status: x.status || 'scheduled',
      instructions: x.instructions || '',
      papers: Array.isArray(x.papers) ? x.papers : []
    };
  })) %></script>

  <script src="/js/navbar.js" defer></script>
  <script src="/js/exams.js" defer></script>
</body>
</html>