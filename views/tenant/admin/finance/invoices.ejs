<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Invoices — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.24fr) minmax(320px,.76fr);gap:12px}
    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .draft{background:rgba(13,64,96,.08);color:#0f172a}
    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1220px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;max-width:100%}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1120px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto}
    .modal.sm{width:min(760px,100%)}
    .modal.lg{width:min(1140px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap;position:relative;z-index:2;box-shadow:0 -8px 18px rgba(0,0,0,.04)}
    .form-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}
    .view-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-bottom:14px}
    .view-card{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;min-width:0}
    .view-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .view-value{font-weight:800;word-break:break-word}
    .view-message{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;white-space:pre-wrap;line-height:1.65}
    .view-section-title{font-weight:900;margin-bottom:8px}
    .items-table{width:100%;min-width:960px;border-collapse:separate;border-spacing:0;background:#fff}
    .items-table th,.items-table td{padding:10px;border-bottom:1px solid rgba(13,64,96,.08)}
    .items-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:14px}
    .icon-btn{width:40px;height:40px;border-radius:12px;border:1px solid rgba(13,64,96,.12);background:#fff;display:inline-flex;align-items:center;justify-content:center;cursor:pointer}
    .amount-lg{font-size:24px;font-weight:900}
    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 980px){.form-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width: 680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}.view-grid{grid-template-columns:1fr}.form-grid{grid-template-columns:1fr}}
    @media (max-width: 520px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
      .actions{justify-content:flex-start}
      table{min-width:1100px}
      .modal-backdrop{padding:30px 12px}
      .modal{max-height:calc(100dvh - 60px);border-radius:20px}
      .modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}
    }
  </style>
</head>
<body>
  <%
    const safe = (v)=> (v===null||v===undefined) ? "" : String(v);
    const q = query || {};
    const formatMoney = (v) => Number(v || 0).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:2});
  %>

  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Invoices</div>
          <div class="subtitle">Create, track and manage student invoices, balances, payments and invoice summaries.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/finance"><i class="fa-solid fa-arrow-left"></i> Finance</a>
          <a class="btn light" href="/admin/payments"><i class="fa-solid fa-money-bill-wave"></i> Payments</a>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Create Invoice</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Invoices</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">All active invoices</div>
        </div>
        <div class="card">
          <div class="section-title">Total Billed</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= formatMoney(kpis?.billed || 0) %></div>
          <div class="muted">Gross billed amount</div>
        </div>
        <div class="card">
          <div class="section-title">Collected</div>
          <div class="kpi-value" style="color:#15803d"><%= formatMoney(kpis?.paidValue || 0) %></div>
          <div class="muted">Settled value</div>
        </div>
        <div class="card">
          <div class="section-title">Outstanding</div>
          <div class="kpi-value" style="color:#b91c1c"><%= formatMoney(kpis?.balanceValue || 0) %></div>
          <div class="muted">Remaining balance</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/invoices">
          <div class="left">
            <input class="input" name="q" value="<%= q.q || '' %>" placeholder="Search invoice no, reference, term, academic year..." />

            <select class="select" name="status">
              <option value="all" <%= q.status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="Draft" <%= q.status === 'Draft' ? 'selected' : '' %>>Draft</option>
              <option value="Unpaid" <%= q.status === 'Unpaid' ? 'selected' : '' %>>Unpaid</option>
              <option value="Partially Paid" <%= q.status === 'Partially Paid' ? 'selected' : '' %>>Partially Paid</option>
              <option value="Paid" <%= q.status === 'Paid' ? 'selected' : '' %>>Paid</option>
              <option value="Overdue" <%= q.status === 'Overdue' ? 'selected' : '' %>>Overdue</option>
              <option value="Cancelled" <%= q.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
            </select>

            <select class="select" name="student">
              <option value="all" <%= q.student === 'all' ? 'selected' : '' %>>All Students</option>
              <% (students || []).forEach(function(s){ %>
                <option value="<%= s.id %>" <%= q.student === s.id ? 'selected' : '' %>><%= s.name %></option>
              <% }) %>
            </select>

            <select class="select" name="program">
              <option value="all" <%= q.program === 'all' ? 'selected' : '' %>>All Programs</option>
              <% (programs || []).forEach(function(p){ %>
                <option value="<%= p.id %>" <%= q.program === p.id ? 'selected' : '' %>><%= p.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip active" data-view="list" type="button"><i class="fa-solid fa-list"></i> List</button>
              <button class="chip" data-view="payments" type="button"><i class="fa-solid fa-money-bill-wave"></i> Payments</button>
              <button class="chip" data-view="summary" type="button"><i class="fa-solid fa-chart-pie"></i> Summary</button>
            </div>
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/invoices"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">invoice(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkMarkPaid" type="button"><i class="fa-solid fa-circle-check"></i> Mark Paid</button>
            <button class="btn-xs" id="bulkDraft" type="button"><i class="fa-solid fa-file"></i> Draft</button>
            <button class="btn-xs" id="bulkCancel" type="button"><i class="fa-solid fa-ban"></i> Cancel</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title" id="panelTitle">Invoices</div>
              <div class="section-sub" id="panelSub">Manage invoice records, balances and billing details.</div>
            </div>
            <div class="muted" id="resultMeta">—</div>
          </div>

          <div id="view-list" style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                    <th>Invoice</th>
                    <th>Student</th>
                    <th>Program</th>
                    <th>Issue / Due</th>
                    <th>Total</th>
                    <th>Paid</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th style="text-align:right;width:260px;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbody"></tbody>
              </table>
            </div>
          </div>

          <div id="view-payments" style="display:none;margin-top:10px;">
            <div class="note">Recent payments linked to finance/invoice activity.</div>
            <div class="table-wrap" style="margin-top:10px;">
              <table>
                <thead>
                  <tr>
                    <th>Receipt No</th>
                    <th>Student</th>
                    <th>Amount</th>
                    <th>Method</th>
                    <th>Status</th>
                    <th>Payment Date</th>
                  </tr>
                </thead>
                <tbody id="tbodyPayments"></tbody>
              </table>
            </div>
          </div>

          <div id="view-summary" style="display:none;margin-top:10px;">
            <div class="grid-4">
              <div class="view-card">
                <div class="view-label">Paid</div>
                <div class="amount-lg" style="color:#15803d"><%= kpis?.paid || 0 %></div>
              </div>
              <div class="view-card">
                <div class="view-label">Partial</div>
                <div class="amount-lg" style="color:#92400e"><%= kpis?.partial || 0 %></div>
              </div>
              <div class="view-card">
                <div class="view-label">Unpaid</div>
                <div class="amount-lg" style="color:#b91c1c"><%= kpis?.unpaid || 0 %></div>
              </div>
              <div class="view-card">
                <div class="view-label">Overdue</div>
                <div class="amount-lg" style="color:#7c2d12"><%= kpis?.overdue || 0 %></div>
              </div>
            </div>

            <div class="note" style="margin-top:12px;">
              <strong>Snapshot:</strong>
              <span>Billed: <%= formatMoney(kpis?.billed || 0) %></span> ·
              <span>Collected: <%= formatMoney(kpis?.paidValue || 0) %></span> ·
              <span>Outstanding: <%= formatMoney(kpis?.balanceValue || 0) %></span>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Common invoice workflows.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">New Invoice</div>
                <div class="muted">Create invoice for a student</div>
              </div>
              <button class="btn-xs" id="quickNewInvoice" type="button"><i class="fa-solid fa-plus"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Unpaid Review</div>
                <div class="muted">Focus on outstanding invoices</div>
              </div>
              <a class="btn-xs" href="/admin/invoices?status=Unpaid"><i class="fa-solid fa-filter"></i></a>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Overdue Review</div>
                <div class="muted">Focus on overdue invoices</div>
              </div>
              <a class="btn-xs" href="/admin/invoices?status=Overdue"><i class="fa-solid fa-clock"></i></a>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Go to Payments</div>
                <div class="muted">Track receipts and allocations</div>
              </div>
              <a class="btn-xs" href="/admin/payments"><i class="fa-solid fa-money-bill-wave"></i></a>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Create Invoice</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="invoiceForm" method="POST" action="/admin/invoices">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Student</label>
              <select class="select" id="iStudent" name="studentId" required>
                <option value="">Select student</option>
                <% (students || []).forEach(function(s){ %>
                  <option value="<%= s.id %>"><%= s.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Program</label>
              <select class="select" id="iProgram" name="programId">
                <option value="">Select program</option>
                <% (programs || []).forEach(function(p){ %>
                  <option value="<%= p.id %>"><%= p.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Reference</label>
              <input class="input" id="iReference" name="reference" placeholder="Optional internal reference">
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="iStatus" name="status">
                <option value="Unpaid">Unpaid</option>
                <option value="Draft">Draft</option>
              </select>
            </div>

            <div class="field">
              <label>Academic Year</label>
              <input class="input" id="iAcademicYear" name="academicYear" placeholder="e.g. 2025/2026">
            </div>

            <div class="field">
              <label>Term / Semester</label>
              <input class="input" id="iTerm" name="term" placeholder="e.g. Term 1">
            </div>

            <div class="field">
              <label>Issue Date</label>
              <input class="input" id="iIssueDate" name="issueDate" type="date">
            </div>

            <div class="field">
              <label>Due Date</label>
              <input class="input" id="iDueDate" name="dueDate" type="date">
            </div>

            <div class="field">
              <label>Currency</label>
              <select class="select" id="iCurrency" name="currency">
                <option value="UGX">UGX</option>
                <option value="USD">USD</option>
                <option value="SSP">SSP</option>
                <option value="KES">KES</option>
              </select>
            </div>

            <div class="field">
              <label>Discount Amount</label>
              <input class="input calc-input" id="iDiscount" name="discountAmount" type="number" min="0" step="0.01" value="0">
            </div>

            <div class="field">
              <label>Tax Amount</label>
              <input class="input calc-input" id="iTax" name="taxAmount" type="number" min="0" step="0.01" value="0">
            </div>
          </div>

          <div class="divider"></div>

          <div style="display:flex;justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap;">
            <div>
              <div class="strong">Invoice Items</div>
              <div class="muted">Add all billable lines for this invoice.</div>
            </div>
            <button class="btn light" id="addItemBtn" type="button"><i class="fa-solid fa-plus"></i> Add Item</button>
          </div>

          <div class="items-wrap" style="margin-top:10px;">
            <table class="items-table">
              <thead>
                <tr>
                  <th style="min-width:220px;">Title</th>
                  <th style="min-width:160px;">Category</th>
                  <th style="min-width:100px;">Qty</th>
                  <th style="min-width:140px;">Unit Amount</th>
                  <th style="min-width:140px;">Amount</th>
                  <th style="min-width:180px;">Note</th>
                  <th style="width:70px;">Remove</th>
                </tr>
              </thead>
              <tbody id="itemsTbody"></tbody>
            </table>
          </div>

          <div class="divider"></div>

          <div class="grid-4">
            <div class="view-card">
              <div class="view-label">Subtotal</div>
              <div class="view-value" id="subTotalPreview">0</div>
            </div>
            <div class="view-card">
              <div class="view-label">Discount</div>
              <div class="view-value" id="discountPreview">0</div>
            </div>
            <div class="view-card">
              <div class="view-label">Tax</div>
              <div class="view-value" id="taxPreview">0</div>
            </div>
            <div class="view-card">
              <div class="view-label">Total</div>
              <div class="view-value" id="totalPreview">0</div>
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes</label>
            <textarea class="textarea" id="iNotes" name="notes" placeholder="Optional notes shown on invoice..."></textarea>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Invoice</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Invoice Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card">
            <div class="view-label">Invoice No</div>
            <div class="view-value" id="vInvoiceNo">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Student</div>
            <div class="view-value" id="vStudent">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Program</div>
            <div class="view-value" id="vProgram">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Status</div>
            <div class="view-value" id="vStatus">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Issue Date</div>
            <div class="view-value" id="vIssueDate">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Due Date</div>
            <div class="view-value" id="vDueDate">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Total Amount</div>
            <div class="view-value" id="vTotal">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Balance</div>
            <div class="view-value" id="vBalance">—</div>
          </div>
        </div>

        <div class="view-section-title">Items</div>
        <div class="view-message" id="vItems">—</div>

        <div class="view-section-title" style="margin-top:14px;">Notes</div>
        <div class="view-message" id="vNotes">—</div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/invoices/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkActionInput">
  </form>

  <textarea id="invoicesData" class="json-data" aria-hidden="true"><%- JSON.stringify(invoices || []) %></textarea>
  <textarea id="paymentsData" class="json-data" aria-hidden="true"><%- JSON.stringify(payments || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/invoices.js"></script>
</body>
</html>