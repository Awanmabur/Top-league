<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Finance Reports — CampusSaaS</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .input:focus,.select:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-3{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.28fr) minmax(340px,.72fr);gap:12px}
    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .soft{background:rgba(13,64,96,.08);color:#0f172a}
    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1080px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .legend-list{display:grid;gap:8px}
    .legend-row{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .json-data{display:none !important}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1000px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow:auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .view-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-bottom:14px}
    .view-card{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff}
    .view-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .view-value{font-weight:800;word-break:break-word}
    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 980px){.grid-4,.grid-3{grid-template-columns:repeat(2,minmax(0,1fr))}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width: 680px){.grid-4,.grid-3{grid-template-columns:1fr}.input{min-width:160px}.view-grid{grid-template-columns:1fr}}
    @media (max-width: 520px){
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
      table{min-width:980px}
      .modal-backdrop{padding:30px 12px}
      .modal{max-height:calc(100dvh - 60px);border-radius:20px}
      .modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}
    }
  </style>
</head>
<body>
  <%
    const q = query || {};
    const r = reports || {};
    const overview = r.overview || {};
    const invoiceSummary = r.invoiceSummary || {};
    const paymentSummary = r.paymentSummary || {};
    const expenseSummary = r.expenseSummary || {};
    const scholarshipSummary = r.scholarshipSummary || {};
    const collectionByMethod = r.collectionByMethod || [];
    const balancesByStudent = r.balancesByStudent || [];
    const recentActivity = r.recentActivity || [];
    const formatMoney = (v) => Number(v || 0).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:2});
  %>

  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <div class="topbar">
        <div>
          <div class="title">Finance Reports</div>
          <div class="subtitle">Analyze billed revenue, collections, balances, expenses, scholarships and recent finance activity.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/finance"><i class="fa-solid fa-arrow-left"></i> Finance</a>
          <a class="btn light" href="/admin/invoices"><i class="fa-solid fa-file-invoice-dollar"></i> Invoices</a>
          <a class="btn light" href="/admin/payments"><i class="fa-solid fa-money-bill-wave"></i> Payments</a>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Billed</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= formatMoney(overview.billed || 0) %></div>
          <div class="muted">Invoice value in range</div>
        </div>
        <div class="card">
          <div class="section-title">Collected</div>
          <div class="kpi-value" style="color:#15803d"><%= formatMoney(overview.collected || 0) %></div>
          <div class="muted">Payments in range</div>
        </div>
        <div class="card">
          <div class="section-title">Outstanding</div>
          <div class="kpi-value" style="color:#b91c1c"><%= formatMoney(overview.outstanding || 0) %></div>
          <div class="muted">Remaining balances</div>
        </div>
        <div class="card">
          <div class="section-title">Net Position</div>
          <div class="kpi-value" style="color:<%= (overview.net || 0) >= 0 ? '#15803d' : '#b91c1c' %>"><%= formatMoney(overview.net || 0) %></div>
          <div class="muted">Collections minus expenses</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/finance-reports">
          <div class="left">
            <input class="input" name="q" value="<%= q.q || '' %>" placeholder="Search invoice, receipt, expense, student..." />

            <select class="select" name="period">
              <option value="this_month" <%= q.period === 'this_month' ? 'selected' : '' %>>This Month</option>
              <option value="today" <%= q.period === 'today' ? 'selected' : '' %>>Today</option>
              <option value="last_30_days" <%= q.period === 'last_30_days' ? 'selected' : '' %>>Last 30 Days</option>
              <option value="this_year" <%= q.period === 'this_year' ? 'selected' : '' %>>This Year</option>
              <option value="all_time" <%= q.period === 'all_time' ? 'selected' : '' %>>All Time</option>
            </select>

            <select class="select" name="program">
              <option value="all" <%= q.program === 'all' ? 'selected' : '' %>>All Programs</option>
              <% (programs || []).forEach(function(p){ %>
                <option value="<%= p.id %>" <%= q.program === p.id ? 'selected' : '' %>><%= p.name %></option>
              <% }) %>
            </select>

            <select class="select" name="student">
              <option value="all" <%= q.student === 'all' ? 'selected' : '' %>>All Students</option>
              <% (students || []).forEach(function(s){ %>
                <option value="<%= s.id %>" <%= q.student === s.id ? 'selected' : '' %>><%= s.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip active" data-view="overview" type="button"><i class="fa-solid fa-table-columns"></i> Overview</button>
              <button class="chip" data-view="collections" type="button"><i class="fa-solid fa-sack-dollar"></i> Collections</button>
              <button class="chip" data-view="balances" type="button"><i class="fa-solid fa-scale-balanced"></i> Balances</button>
              <button class="chip" data-view="expenses" type="button"><i class="fa-solid fa-money-check-dollar"></i> Expenses</button>
            </div>
            <a class="btn light" href="/admin/finance-reports"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>
      </section>

      <div class="grid-3" style="margin-top:12px;">
        <div class="card">
          <div class="section-title">Invoice Summary</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Total</div><div class="muted">Invoices in range</div></div><div class="pill info"><%= invoiceSummary.total || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Paid</div><div class="muted">Fully settled</div></div><div class="pill ok"><%= invoiceSummary.paid || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Partial</div><div class="muted">Partially paid</div></div><div class="pill warn"><%= invoiceSummary.partial || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Unpaid</div><div class="muted">No payment yet</div></div><div class="pill bad"><%= invoiceSummary.unpaid || 0 %></div></div>
          </div>
        </div>

        <div class="card">
          <div class="section-title">Payment Summary</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Total</div><div class="muted">Payments in range</div></div><div class="pill info"><%= paymentSummary.total || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Completed</div><div class="muted">Counted in collections</div></div><div class="pill ok"><%= paymentSummary.completed || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Pending</div><div class="muted">Awaiting completion</div></div><div class="pill warn"><%= paymentSummary.pending || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Voided/Refunded</div><div class="muted">Excluded from totals</div></div><div class="pill bad"><%= (paymentSummary.voided || 0) + (paymentSummary.refunded || 0) %></div></div>
          </div>
        </div>

        <div class="card">
          <div class="section-title">Scholarships</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Total</div><div class="muted">Scholarship records</div></div><div class="pill info"><%= scholarshipSummary.total || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Active</div><div class="muted">Currently effective</div></div><div class="pill ok"><%= scholarshipSummary.active || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Percentage</div><div class="muted">Percentage-based awards</div></div><div class="pill warn"><%= scholarshipSummary.percentage || 0 %></div></div>
            <div class="mini-item"><div class="left"><div class="strong">Full</div><div class="muted">100% awards</div></div><div class="pill soft"><%= scholarshipSummary.full || 0 %></div></div>
          </div>
        </div>
      </div>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title" id="panelTitle">Overview Report</div>
              <div class="section-sub" id="panelSub">Recent finance activity and high-level results for the selected filter range.</div>
            </div>
            <div class="muted" id="resultMeta">Live report</div>
          </div>

          <div id="view-overview" style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Reference</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th style="text-align:right;width:120px;">Action</th>
                  </tr>
                </thead>
                <tbody id="tbodyOverview"></tbody>
              </table>
            </div>
          </div>

          <div id="view-collections" style="display:none;margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Method</th>
                    <th>Collected Amount</th>
                    <th>Share</th>
                  </tr>
                </thead>
                <tbody id="tbodyCollections"></tbody>
              </table>
            </div>
          </div>

          <div id="view-balances" style="display:none;margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Student</th>
                    <th>Admission No</th>
                    <th>Program</th>
                    <th>Total Invoiced</th>
                    <th>Total Paid</th>
                    <th>Balance</th>
                    <th style="text-align:right;width:120px;">Action</th>
                  </tr>
                </thead>
                <tbody id="tbodyBalances"></tbody>
              </table>
            </div>
          </div>

          <div id="view-expenses" style="display:none;margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th>Category</th>
                    <th>Total Expense</th>
                  </tr>
                </thead>
                <tbody id="tbodyExpenses"></tbody>
              </table>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Collections by Method</div>
          <% if (collectionByMethod.length) { %>
            <div class="legend-list" style="margin-top:10px;">
              <% collectionByMethod.forEach(function(row){ %>
                <div class="legend-row">
                  <div>
                    <div class="strong"><%= row.label %></div>
                    <div class="muted">Collection method</div>
                  </div>
                  <div class="pill ok"><i class="fa-solid fa-sack-dollar"></i> <%= formatMoney(row.amount) %></div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="note" style="margin-top:10px;">No collection method summary found.</div>
          <% } %>

          <div class="section-title" style="margin-top:16px;">Expense Categories</div>
          <% if ((expenseSummary.categories || []).length) { %>
            <div class="legend-list" style="margin-top:10px;">
              <% expenseSummary.categories.forEach(function(row){ %>
                <div class="legend-row">
                  <div>
                    <div class="strong"><%= row.label %></div>
                    <div class="muted">Expense category</div>
                  </div>
                  <div class="pill warn"><i class="fa-solid fa-money-check-dollar"></i> <%= formatMoney(row.amount) %></div>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <div class="note" style="margin-top:10px;">No expense summary found.</div>
          <% } %>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Report Detail</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card">
            <div class="view-label">Type</div>
            <div class="view-value" id="vType">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Reference</div>
            <div class="view-value" id="vRef">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Date</div>
            <div class="view-value" id="vDate">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Amount</div>
            <div class="view-value" id="vAmount">—</div>
          </div>
          <div class="view-card" style="grid-column:1 / -1;">
            <div class="view-label">Description</div>
            <div class="view-value" id="vDescription">—</div>
          </div>
          <div class="view-card" style="grid-column:1 / -1;">
            <div class="view-label">Status</div>
            <div class="view-value" id="vStatus">—</div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <textarea id="reportsData" class="json-data" aria-hidden="true"><%- JSON.stringify(reports || {}) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/finance-reports.js"></script>
</body>
</html>