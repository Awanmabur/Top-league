<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Terms</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <% if (csrfToken) { %>
    <meta name="csrf-token" content="<%= csrfToken %>">
  <% } %>

  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    crossorigin="anonymous"
    referrerpolicy="no-referrer"
  />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.45fr) minmax(300px,.55fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .draft{background:#f3f4f6;color:#111827}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1520px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-intake{width:280px}
    .col-code{width:130px}
    .col-apply{width:180px}
    .col-study{width:180px}
    .col-programs{width:240px}
    .col-capacity{width:110px}
    .col-applicants{width:110px}
    .col-status{width:120px}
    .col-active{width:100px}
    .col-actions{width:260px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .program-main,.intake-main{min-width:0}
    .intake-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .intake-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1060px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(900px,100%)}
    .modal.md{width:min(980px,100%)}
    .modal.lg{width:min(1060px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}
    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:6px 10px;
      border-radius:999px;
      background:#eef2ff;
      color:#3730a3;
      font-size:12px;
      font-weight:800;
    }

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    .prog-row{
      display:grid;
      grid-template-columns:minmax(0,1.4fr) minmax(130px,.6fr) auto;
      gap:10px;
      align-items:end;
      margin-bottom:10px;
    }

    .sticky-tools{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
      .prog-row{grid-template-columns:1fr}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1520px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
<%
  const safe = (v, d = "") => (v === null || v === undefined ? d : String(v));
  const itemsArr = Array.isArray(items) ? items : [];
  const programsArr = Array.isArray(programs) ? programs : [];
  const q = safe(query?.q);
  const st = safe(query?.status);
  const currentPage = Number(query?.page || 1);
  const totalPages = Number(query?.totalPages || 1);
  const applicantCountsSafe = applicantCounts || {};

  function fmtInputDate(d){
    if (!d) return "";
    const x = new Date(d);
    if (isNaN(x.getTime())) return "";
    const yyyy = x.getFullYear();
    const mm = String(x.getMonth() + 1).padStart(2, "0");
    const dd = String(x.getDate()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd}`;
  }

  function fmtDate(d){
    if (!d) return "—";
    const x = new Date(d);
    if (isNaN(x.getTime())) return "—";
    return x.toLocaleDateString();
  }

  function intakeApplicants(it){
    const k1 = safe(it?.code);
    const k2 = safe(it?.name);
    return Number(applicantCountsSafe[k1] || applicantCountsSafe[k2] || 0);
  }

  const counts = {
    total: Number(query?.total || itemsArr.length || 0),
    draft: 0,
    open: 0,
    closed: 0,
    archived: 0,
    applicants: 0,
    activeName: "—"
  };

  itemsArr.forEach((it) => {
    const s = safe(it?.status, "draft");
    if (counts[s] !== undefined) counts[s] += 1;
    counts.applicants += intakeApplicants(it);
    if (it?.isActive) counts.activeName = safe(it?.name, safe(it?.code, "Active"));
  });

  function buildPageUrl(targetPage) {
    const params = new URLSearchParams();
    if (q) params.set("q", q);
    if (st) params.set("status", st);
    params.set("page", String(targetPage));
    return "/admin/admissions/intakes?" + params.toString();
  }

  const startPage = Math.max(1, currentPage - 2);
  const endPage = Math.min(totalPages, currentPage + 2);

  const intakesJson = itemsArr.map((it) => {
    const arr = Array.isArray(it?.programs) ? it.programs : [];
    const totalCapacity = arr.reduce((sum, x) => sum + (parseInt(x?.capacity || 0, 10) || 0), 0);

    return {
      id: String(it?._id || ""),
      name: safe(it?.name),
      code: safe(it?.code),
      year: it?.year || "",
      term: safe(it?.term || it?.name),
      status: safe(it?.status, "draft"),
      isActive: !!it?.isActive,
      applicationOpenDate: fmtInputDate(it?.applicationOpenDate),
      applicationCloseDate: fmtInputDate(it?.applicationCloseDate),
      startDate: fmtInputDate(it?.startDate),
      endDate: fmtInputDate(it?.endDate),
      applicants: intakeApplicants(it),
      allowAllPrograms: !(Array.isArray(it?.programs) && it.programs.length > 0),
      totalCapacity,
      programs: arr.map((x) => {
        const pid =
          x?.program && typeof x.program === "object"
            ? String(x.program?._id || "")
            : String(x?.program || "");

        const pobj =
          x?.program && typeof x.program === "object"
            ? x.program
            : (programsArr.find((p) => String(p?._id) === pid) || null);

        return {
          program: pid,
          capacity: Number(x?.capacity || 0),
          name: safe(pobj?.name || pobj?.className || "Section"),
          code: safe(pobj?.code)
        };
      })
    };
  });

  const programsJson = programsArr.map((p) => ({
    _id: String(p?._id || ""),
    name: safe(p?.name || p?.className || "Section"),
    code: safe(p?.code)
  }));
%>

  <div class="app">
    <%- include("../../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Intake Management</div>
          <div class="subtitle">Create, edit, import, export, print and manage admissions intakes.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Intake</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= counts.total %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Open</div>
          <div class="kpi-value" style="color:#15803d"><%= counts.open %></div>
          <div class="muted">Accepting applications</div>
        </div>
        <div class="card">
          <div class="section-title">Draft</div>
          <div class="kpi-value" style="color:#92400e"><%= counts.draft %></div>
          <div class="muted">Still being prepared</div>
        </div>
        <div class="card">
          <div class="section-title">Applicants</div>
          <div class="kpi-value" style="color:#3730a3"><%= counts.applicants %></div>
          <div class="muted">Across this page</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/admissions/intakes">
          <div class="left">
            <input class="input" name="q" value="<%= q %>" placeholder="Search name, code, term..." />

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="draft" <%= st === "draft" ? "selected" : "" %>>Draft</option>
              <option value="open" <%= st === "open" ? "selected" : "" %>>Open</option>
              <option value="closed" <%= st === "closed" ? "selected" : "" %>>Closed</option>
              <option value="archived" <%= st === "archived" ? "selected" : "" %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/admissions/intakes"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">intake(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkOpen" type="button"><i class="fa-solid fa-door-open"></i> Open</button>
            <button class="btn-xs" id="bulkClose" type="button"><i class="fa-solid fa-lock"></i> Close</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Intakes Table</div>
              <div class="section-sub">Showing <%= itemsArr.length %> of <%= Number(query?.total || itemsArr.length || 0) %> records.</div>
            </div>
            <div class="muted" id="resultMeta">
              Page <%= currentPage %> of <%= totalPages %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-intake">Term</th>
                    <th class="col-code">Code</th>
                    <th class="col-apply">Application Window</th>
                    <th class="col-study">Study Period</th>
                    <th class="col-programs">Sections</th>
                    <th class="col-capacity">Capacity</th>
                    <th class="col-applicants">Applicants</th>
                    <th class="col-status">Status</th>
                    <th class="col-active">Active</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyIntakes"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong><%= Number(query?.perPage || 10) %></strong>
            </div>

            <div class="pagination-links">
              <a class="page-link <%= currentPage <= 1 ? "disabled" : "" %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? "active" : "" %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? "disabled" : "" %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Create Draft Term</div>
                <div class="muted">Pre-fill status as draft</div>
              </div>
              <button class="btn-xs" id="quickDraft" type="button"><i class="fa-solid fa-pen"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Create Open Term</div>
                <div class="muted">Pre-fill status as open</div>
              </div>
              <button class="btn-xs" id="quickOpen" type="button"><i class="fa-solid fa-door-open"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Current Active Term</div>
                <div class="muted"><%= counts.activeName %></div>
              </div>
              <span class="pill info"><i class="fa-solid fa-bolt"></i> Active</span>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <!-- CREATE / EDIT MODAL -->
  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Term</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="intakeForm" method="POST" action="/admin/admissions/intakes/new">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Term Name</label>
              <input class="input" id="mName" name="name" required maxlength="160" placeholder="e.g. Term 1" />
            </div>

            <div class="field">
              <label>Academic Year</label>
              <input class="input" id="mYear" name="year" type="number" min="2000" max="2100" required />
            </div>

            <div class="field">
              <label>Term Label</label>
              <input class="input" id="mTerm" name="term" maxlength="120" placeholder="e.g. Term 1" />
            </div>

            <div class="field">
              <label>Term Code</label>
              <input class="input" id="mCode" name="code" maxlength="40" readonly placeholder="Auto-generated" />
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="open">Open</option>
                <option value="closed">Closed</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field">
              <label>Application Open Date</label>
              <input class="input" id="mApplicationOpenDate" name="applicationOpenDate" type="date" />
            </div>

            <div class="field">
              <label>Application Close Date</label>
              <input class="input" id="mApplicationCloseDate" name="applicationCloseDate" type="date" />
            </div>

            <div class="field">
              <label>Set Active</label>
              <select class="select" id="mIsActive" name="isActive">
                <option value="0">No</option>
                <option value="1">Yes</option>
              </select>
            </div>

            <div class="field">
              <label>Study Start Date</label>
              <input class="input" id="mStartDate" name="startDate" type="date" />
            </div>

            <div class="field">
              <label>Study End Date</label>
              <input class="input" id="mEndDate" name="endDate" type="date" />
            </div>

            <div class="field">
              <label>Allow All Sections</label>
              <select class="select" id="mAllowAllPrograms">
                <option value="1">Yes</option>
                <option value="0">No</option>
              </select>
            </div>
          </div>

          <div class="divider"></div>

          <div class="sticky-tools" style="margin-bottom:10px;">
            <button class="btn-xs" type="button" id="btnAddProgramRow"><i class="fa-solid fa-plus"></i> Add Section Row</button>
            <span class="muted">Total capacity: <strong id="mCapTotal">0</strong></span>
          </div>

          <div id="programRows"></div>
          <input type="hidden" name="programsJson" id="mProgramsJson" value="[]">

          <div class="divider"></div>

          <div class="note">
            Keep this page fast by rendering rows from the embedded JSON and only opening modals when needed.
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Term</button>
        </div>
      </form>
    </div>
  </div>

  <!-- VIEW MODAL -->
  <div class="modal-backdrop" id="mView">
    <div class="modal md">
      <div class="modal-header">
        <div class="modal-title">Term Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Name</label>
            <div class="view-input" id="vName">—</div>
          </div>

          <div class="field">
            <label>Code</label>
            <div class="view-input" id="vCode">—</div>
          </div>

          <div class="field">
            <label>Academic Year</label>
            <div class="view-input" id="vYear">—</div>
          </div>

          <div class="field">
            <label>Term Label</label>
            <div class="view-input" id="vTerm">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Application Open</label>
            <div class="view-input" id="vApplicationOpenDate">—</div>
          </div>

          <div class="field">
            <label>Application Close</label>
            <div class="view-input" id="vApplicationCloseDate">—</div>
          </div>

          <div class="field">
            <label>Active</label>
            <div class="view-input" id="vIsActive">—</div>
          </div>

          <div class="field">
            <label>Study Start</label>
            <div class="view-input" id="vStartDate">—</div>
          </div>

          <div class="field">
            <label>Study End</label>
            <div class="view-input" id="vEndDate">—</div>
          </div>

          <div class="field">
            <label>Applicants</label>
            <div class="view-input" id="vApplicants">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Sections</label>
          <div class="view-input multiline">
            <div class="tag-list" id="vPrograms"></div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <!-- IMPORT MODAL -->
  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Intakes CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="importForm" method="POST" action="/admin/admissions/intakes/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="field">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>

          <div class="note">
            Expected columns: name, code, status, applicationOpenDate, applicationCloseDate, startDate, endDate, isActive
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-file-import"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowActionStatus" value="">
  </form>

  <form id="bulkForm" method="POST" action="/admin/admissions/intakes/bulk-status" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="status" id="bulkStatus">
  </form>

  <textarea id="intakesData" class="json-data" aria-hidden="true"><%- JSON.stringify(intakesJson).replace(/</g, "\\u003c") %></textarea>
  <textarea id="programsData" class="json-data" aria-hidden="true"><%- JSON.stringify(programsJson).replace(/</g, "\\u003c") %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/intakes-index.js"></script>
</body>
</html>
