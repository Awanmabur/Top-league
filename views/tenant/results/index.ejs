<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Results</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:120px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:110px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .json-data{display:none !important}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.45fr) minmax(320px,.55fr);gap:12px}

    .pill{
      display:inline-flex;
      align-items:center;
      gap:6px;
      padding:4px 10px;
      border-radius:999px;
      font-size:12px;
      font-weight:900;
      white-space:nowrap;
    }

    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1880px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-student{width:260px}
    .col-reg{width:140px}
    .col-exam{width:220px}
    .col-class{width:180px}
    .col-section{width:150px}
    .col-stream{width:150px}
    .col-subject{width:220px}
    .col-score{width:120px}
    .col-grade{width:100px}
    .col-status{width:130px}
    .col-actions{width:220px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .student-main{min-width:0}
    .student-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .student-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .preview-card{
      display:grid;
      gap:12px;
    }

    .preview-hero{
      padding:16px;
      border-radius:18px;
      border:1px solid rgba(13,64,96,.10);
      background:linear-gradient(180deg,#ffffff 0%,#f8fbff 100%);
    }

    .preview-name{
      font-size:20px;
      font-weight:900;
      color:#0f172a;
      line-height:1.2;
    }

    .preview-sub{
      margin-top:4px;
      color:#475569;
      font-weight:700;
    }

    .preview-score{
      margin-top:12px;
      font-size:28px;
      font-weight:900;
      color:#0a6fbf;
    }

    .preview-grid{
      display:grid;
      grid-template-columns:repeat(2,minmax(0,1fr));
      gap:10px;
    }

    .preview-box{
      padding:12px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:14px;
      background:#fff;
    }

    .preview-label{
      font-size:11px;
      text-transform:uppercase;
      letter-spacing:.05em;
      color:#6b7280;
      font-weight:900;
      margin-bottom:6px;
    }

    .preview-value{
      font-weight:800;
      color:#0f172a;
      line-height:1.45;
      white-space:pre-wrap;
      word-break:break-word;
    }

    .preview-actions{
      display:grid;
      gap:8px;
    }

    .note{
      padding:10px 12px;
      border-radius:12px;
      border:1px dashed rgba(13,64,96,.18);
      background:rgba(13,64,96,.03);
    }

    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{
      display:flex;
      justify-content:space-between;
      gap:10px;
      align-items:center;
      padding:10px 12px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      background:#fff;
    }

    .mini-item .left{display:grid;gap:2px}

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1080px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(760px,100%)}
    .modal.lg{width:min(1080px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}

    .dropzone{
      border:2px dashed rgba(13,64,96,.18);
      border-radius:18px;
      padding:26px 18px;
      text-align:center;
      background:#fbfdff;
      transition:.18s ease;
    }

    .dropzone.drag{
      border-color:#0a6fbf;
      background:#f0f7ff;
    }

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
      .preview-grid{grid-template-columns:1fr}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1880px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (messages?.success?.length || messages?.error?.length) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Results</div>
          <div class="subtitle">Enter, review, publish and export exam results.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/results/export.csv<%= exportQueryString ? ('?' + exportQueryString) : '' %>">
            <i class="fa-solid fa-file-arrow-down"></i> Export CSV
          </a>
          <button class="btn light" id="btnImport" type="button">
            <i class="fa-solid fa-file-import"></i> Import CSV
          </button>
          <button class="btn light" id="btnPrint" type="button">
            <i class="fa-solid fa-print"></i> Print
          </button>
          <button class="btn primary" id="btnCreate" type="button">
            <i class="fa-solid fa-plus"></i> Add Result
          </button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Published</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.published || 0 %></div>
          <div class="muted">Visible results</div>
        </div>
        <div class="card">
          <div class="section-title">Draft</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div>
          <div class="muted">Unpublished</div>
        </div>
        <div class="card">
          <div class="section-title">Avg Score</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= kpis?.avgScore || 0 %></div>
          <div class="muted">Current page average</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/results" data-academic-selector>
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search student, exam..." />

            <select class="select" name="exam">
              <option value="">All Exams</option>
              <% (exams || []).forEach(function(exam){ %>
                <option value="<%= String(exam._id) %>" <%= String(query?.exam || '') === String(exam._id) ? 'selected' : '' %>>
                  <%= exam.title || 'Exam' %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="classGroup" data-role="class" data-placeholder="All Classes">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= String(c._id) %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>>
                  <%= c.name || c.title || c.code || 'Class' %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="sectionId" data-role="section" data-placeholder="All Sections" data-selected="<%= query?.sectionId || '' %>">
              <option value="">All Sections</option>
            </select>

            <select class="select" name="streamId" data-role="stream" data-placeholder="All Streams" data-selected="<%= query?.streamId || '' %>">
              <option value="">All Streams</option>
            </select>

            <select class="select" name="subject" data-role="subject" data-placeholder="All Subjects">
              <option value="">All Subjects</option>
              <% (subjects || []).forEach(function(s){ %>
                <option value="<%= String(s._id) %>" <%= String(query?.subject || '') === String(s._id) ? 'selected' : '' %>>
                  <%= s.title || s.code || 'Subject' %>
                </option>
              <% }) %>
            </select>

            <input class="input" name="academicYear" value="<%= query?.academicYear || '' %>" placeholder="Academic Year" />

            <select class="select" name="term">
              <option value="">All Terms</option>
              <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
              <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
              <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
            </select>

            <input class="input" name="grade" value="<%= query?.grade || '' %>" placeholder="Grade" />
            <input class="input" name="minScore" value="<%= query?.minScore || '' %>" placeholder="Min score" />
            <input class="input" name="maxScore" value="<%= query?.maxScore || '' %>" placeholder="Max score" />

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="published" <%= query?.status === 'published' ? 'selected' : '' %>>Published</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button">
              <i class="fa-solid fa-layer-group"></i> Bulk
            </button>
            <a class="btn light" href="/admin/results">
              <i class="fa-solid fa-rotate-left"></i> Reset
            </a>
            <button class="btn primary" type="submit">
              <i class="fa-solid fa-magnifying-glass"></i> Filter
            </button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">result(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <select class="select" id="bulkAction" style="min-width:180px">
              <option value="">Choose action</option>
              <option value="publish">Publish</option>
              <option value="draft">Set Draft</option>
              <option value="delete">Delete</option>
            </select>
            <button class="btn-xs" id="bulkApply" type="button">
              <i class="fa-solid fa-check"></i> Apply
            </button>
            <button class="btn-xs" id="bulkClear" type="button">
              <i class="fa-solid fa-xmark"></i> Clear
            </button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Results Table</div>
              <div class="section-sub">Showing <%= resultsData.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">
              Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-student">Student</th>
                    <th class="col-reg">Reg No</th>
                    <th class="col-exam">Exam</th>
                    <th class="col-class">Class</th>
                    <th class="col-section">Section</th>
                    <th class="col-stream">Stream</th>
                    <th class="col-subject">Subject</th>
                    <th class="col-score">Score</th>
                    <th class="col-grade">Grade</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyResults"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">
              Rows per page: <strong><%= query?.perPage || 10 %></strong>
            </div>

            <div class="pagination-links">
              <a class="page-link <%= query.page <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, query.page - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = pagination.startPage; p <= pagination.endPage; p++) { %>
                <a class="page-link <%= p === query.page ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= query.page >= query.totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(query.totalPages, query.page + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Preview</div>
          <div class="section-sub">Selected result snapshot.</div>

          <div class="preview-card" style="margin-top:12px;">
            <div class="preview-hero">
              <div class="preview-name" id="pvStudent">—</div>
              <div class="preview-sub" id="pvRegNo">—</div>
              <div class="preview-sub" id="pvExam">—</div>
              <div class="preview-sub" id="pvMeta">—</div>
              <div class="preview-score" id="pvScore">—</div>
            </div>

            <div class="preview-grid">
              <div class="preview-box">
                <div class="preview-label">Class</div>
                <div class="preview-value" id="pvClass">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Section</div>
                <div class="preview-value" id="pvSection">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Stream</div>
                <div class="preview-value" id="pvStream">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Subject</div>
                <div class="preview-value" id="pvSubject">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Grade</div>
                <div class="preview-value" id="pvGrade">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Remark</div>
                <div class="preview-value" id="pvRemark">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Status</div>
                <div class="preview-value" id="pvStatus">—</div>
              </div>
              <div class="preview-box">
                <div class="preview-label">Published</div>
                <div class="preview-value" id="pvPub">—</div>
              </div>
            </div>

            <div class="preview-box">
              <div class="preview-label">Last Update</div>
              <div class="preview-value" id="pvUpdated">—</div>
            </div>

            <div class="preview-actions">
              <button class="btn primary" id="previewEditBtn" type="button">
                <i class="fa-solid fa-pen"></i> Edit
              </button>
              <button class="btn light" id="previewViewBtn" type="button">
                <i class="fa-solid fa-eye"></i> View
              </button>
              <button class="btn light" id="previewStatusBtn" type="button">
                <i class="fa-solid fa-arrows-rotate"></i> Change Status
              </button>
              <button class="btn danger" id="previewDeleteBtn" type="button" style="background:#b91c1c;color:#fff;border:none;">
                <i class="fa-solid fa-trash"></i> Delete
              </button>
            </div>

            <div class="divider"></div>

            <div class="section-title">Quick Actions</div>
            <div class="mini-list">
              <div class="mini-item">
                <div class="left">
                  <div class="strong">Add Result</div>
                  <div class="muted">Open manual result entry</div>
                </div>
                <button class="btn-xs" type="button" onclick="document.getElementById('btnCreate').click()">
                  <i class="fa-solid fa-plus"></i>
                </button>
              </div>

              <div class="mini-item">
                <div class="left">
                  <div class="strong">Import CSV</div>
                  <div class="muted">Bulk upload student scores</div>
                </div>
                <button class="btn-xs" type="button" onclick="document.getElementById('btnImport').click()">
                  <i class="fa-solid fa-file-import"></i>
                </button>
              </div>
            </div>

            <div class="note">
              CSV import requires columns: <strong>examId, studentId, score</strong>.<br>
              Optional: <strong>grade, remark, status</strong>.
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Enter Result</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form id="resultForm" method="POST" action="/admin/results">
        <% if (csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Exam</label>
              <select class="select" id="mExam" name="exam" required>
                <option value="">— Select Exam —</option>
                <% (exams || []).forEach(function(exam){ %>
                  <option value="<%= String(exam._id) %>"><%= exam.title || 'Exam' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Student</label>
              <select class="select" id="mStudent" name="student" required>
                <option value="">— Select student —</option>
              </select>
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="published">Published</option>
              </select>
            </div>

            <div class="field">
              <label>Class</label>
              <div class="view-input" id="mClassScope">—</div>
            </div>

            <div class="field">
              <label>Section</label>
              <div class="view-input" id="mSectionScope">—</div>
            </div>

            <div class="field">
              <label>Stream</label>
              <div class="view-input" id="mStreamScope">—</div>
            </div>

            <div class="field">
              <label>Score</label>
              <input class="input" id="mScore" name="score" type="number" min="0" max="100000" step="0.01" />
            </div>

            <div class="field">
              <label>Total Marks</label>
              <input class="input" id="mTotal" type="number" min="0" max="100000" step="0.01" readonly />
            </div>

            <div class="field">
              <label>Percentage</label>
              <input class="input" id="mPercentage" type="text" readonly />
            </div>

            <div class="field">
              <label>Grade</label>
              <input class="input" id="mGrade" name="grade" maxlength="10" />
            </div>

            <div class="field">
              <label>Remark</label>
              <input class="input" id="mRemark" name="remark" maxlength="300" />
            </div>

            <div class="field" style="grid-column:1 / -1;">
              <label>Exam Details</label>
              <div class="view-input multiline" id="mExamMeta">Select an exam to load class, subject, year and term.</div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button">
            <i class="fa-solid fa-floppy-disk"></i> Save Result
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Result Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Student</label>
            <div class="view-input" id="vStudent">—</div>
          </div>

          <div class="field">
            <label>Reg No</label>
            <div class="view-input" id="vRegNo">—</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">—</div>
          </div>

          <div class="field">
            <label>Exam</label>
            <div class="view-input" id="vExam">—</div>
          </div>

          <div class="field">
            <label>Class</label>
            <div class="view-input" id="vClass">—</div>
          </div>

          <div class="field">
            <label>Section</label>
            <div class="view-input" id="vSection">—</div>
          </div>

          <div class="field">
            <label>Stream</label>
            <div class="view-input" id="vStream">—</div>
          </div>

          <div class="field">
            <label>Subject</label>
            <div class="view-input" id="vSubject">—</div>
          </div>

          <div class="field">
            <label>Academic Year</label>
            <div class="view-input" id="vYear">—</div>
          </div>

          <div class="field">
            <label>Term</label>
            <div class="view-input" id="vTerm">—</div>
          </div>

          <div class="field">
            <label>Score</label>
            <div class="view-input" id="vScore">—</div>
          </div>

          <div class="field">
            <label>Percentage</label>
            <div class="view-input" id="vPercentage">—</div>
          </div>

          <div class="field">
            <label>Grade</label>
            <div class="view-input" id="vGrade">—</div>
          </div>

          <div class="field">
            <label>Remark</label>
            <div class="view-input" id="vRemark">—</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Audit</label>
          <div class="view-input multiline" id="vAudit">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn">
          <i class="fa-solid fa-pen"></i> Edit
        </button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mStatus">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Change Result Status</div>
        <button class="btn-xs" type="button" data-close-modal="mStatus">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <div class="modal-body">
        <div class="note">
          Choose whether the selected result should stay as draft or be published.
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mStatus">Cancel</button>
        <button class="btn light" type="button" id="statusDraftBtn">
          <i class="fa-solid fa-pen-to-square"></i> Draft
        </button>
        <button class="btn primary" type="button" id="statusPublishBtn">
          <i class="fa-solid fa-eye"></i> Publish
        </button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Results CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form method="POST" action="/admin/results/import" enctype="multipart/form-data">
        <% if (csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="modal-body">
          <div class="dropzone" id="importDropzone">
            <div style="font-size:28px;color:#0a6fbf;margin-bottom:8px;">
              <i class="fa-solid fa-file-csv"></i>
            </div>
            <div class="strong">Drag and drop CSV here</div>
            <div class="muted" style="margin-top:4px;">or click below to choose a file</div>

            <div style="margin-top:14px;">
              <input id="importFile" type="file" name="file" accept=".csv,text/csv" />
            </div>

            <div class="muted" id="importFileName" style="margin-top:10px;">No file selected</div>
          </div>

          <div class="divider"></div>

          <div class="note">
            Required columns: <strong>examId, studentId, score</strong><br>
            Optional columns: <strong>grade, remark, status</strong>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit">
            <i class="fa-solid fa-upload"></i> Import
          </button>
        </div>
      </form>
    </div>
  </div>

  <form id="statusForm" method="POST" style="display:none;">
    <% if (csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>
    <input type="hidden" name="status" id="statusVal">
  </form>

  <form id="deleteForm" method="POST" style="display:none;">
    <% if (csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/results/bulk" style="display:none;">
    <% if (csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>
    <input type="hidden" name="action" id="bulkActionVal">
    <input type="hidden" name="ids" id="bulkIdsVal">
  </form>

  <textarea id="resultsData" class="json-data" aria-hidden="true"><%- JSON.stringify(resultsData || []) %></textarea>
  <textarea id="classesData" class="json-data" aria-hidden="true"><%- JSON.stringify(classes || []) %></textarea>
  <textarea id="sectionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="streamsData" class="json-data" aria-hidden="true"><%- JSON.stringify(streams || []) %></textarea>
  <textarea id="subjectOptionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(subjectOptions || subjects || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/academic-selector.js"></script>
  <script src="/js/results.js"></script>
</body>
</html>

