<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Transcript — <%= data.student.name %></title>
<link rel="icon" href="data:," />
<style>
  body{font-family:system-ui,Segoe UI,Arial;margin:24px;color:#0b1020}
  .page{position:relative}
  .watermark{
    position:fixed; inset:0; display:flex; align-items:center; justify-content:center;
    pointer-events:none; opacity:.08; font-size:72px; font-weight:900; transform:rotate(-25deg);
  }
  .hdr{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}
  .brand{font-weight:900;font-size:18px}
  .small{font-size:12px;color:#334155}
  .box{border:1px solid #e2e8f0;border-radius:10px;padding:12px;margin-top:12px}
  table{width:100%;border-collapse:collapse;margin-top:10px}
  th,td{border-bottom:1px solid #e2e8f0;padding:8px;text-align:left;font-size:12px}
  th{color:#334155}
  .right{text-align:right}
  .row{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap}
  .sig{margin-top:30px;display:flex;justify-content:space-between}
  .qr{display:flex;gap:12px;align-items:center;flex-wrap:wrap}
  .qr img{width:130px;height:130px;border:1px solid #e2e8f0;border-radius:8px;padding:6px}
  @media print{ #printBtn{display:none} body{margin:10mm} }
</style>
</head>
<body data-portal="tenant">
<div class="page">
  <% const st = data.transcriptMeta?.status || "draft"; %>
  <% if (st === "draft" || st === "revoked") { %>
    <div class="watermark"><%= st.toUpperCase() %></div>
  <% } %>

  <button id="printBtn" type="button">Print</button>

  <div class="hdr">
    <div>
      <div class="brand"><%= (tenant?.name || "Classic Academy") %></div>
      <div class="small">ACADEMIC TRANSCRIPT (<%= (data.transcriptMeta.kind || "official").toUpperCase() %>)</div>
    </div>

    <div class="small">
      Status: <b><%= st %></b><br/>
      Issue No: <b><%= data.transcriptMeta.issueNumber || "—" %></b><br/>
      Issued: <b><%= data.transcriptMeta.issuedAt ? new Date(data.transcriptMeta.issuedAt).toISOString().slice(0,10) : "—" %></b><br/>
      Hash: <b><%= data.snapshotHash || "—" %></b>
    </div>
  </div>

  <div class="box">
    <div class="row">
      <div>
        <div><b>Learner:</b> <%= data.student.name %></div>
        <div><b>Reg No:</b> <%= data.student.reg || "—" %></div>
        <div><b>Class:</b> <%= data.student.classGroup || "—" %></div>
      </div>
      <div>
        <div><b>Average:</b> <%= Number(data.totals.average || 0).toFixed(2) %>%</div>
        <div><b>Overall Grade:</b> <%= data.totals.overallGrade || "—" %></div>
        <div><b>Overall Remark:</b> <%= data.totals.overallRemark || "—" %></div>
      </div>
    </div>
  </div>

  <div class="box">
    <div><b>Attendance Summary</b></div>
    <div class="small" style="margin-top:6px;">
      Present: <b><%= data.totals.attendanceSummary?.present || 0 %></b> •
      Absent: <b><%= data.totals.attendanceSummary?.absent || 0 %></b> •
      Late: <b><%= data.totals.attendanceSummary?.late || 0 %></b> •
      Excused: <b><%= data.totals.attendanceSummary?.excused || 0 %></b>
    </div>
  </div>

  <% if (qrDataUrl && data.transcriptMeta.issueNumber) { %>
    <div class="box">
      <div class="qr">
        <img src="<%= qrDataUrl %>" alt="QR Verify" />
        <div class="small">
          <div><b>Verify this transcript</b></div>
          <div>Scan QR or open:</div>
          <div><b><%= verifyUrl %></b></div>
        </div>
      </div>
    </div>
  <% } %>

  <% (data.terms || []).forEach(function(t){ %>
    <div class="box">
      <div class="row">
        <div><b><%= t.academicYear %></b> • Term <b><%= t.term %></b></div>
        <div>
          Average: <b><%= Number(t.average || 0).toFixed(2) %>%</b> •
          Grade: <b><%= t.grade || "—" %></b> •
          Remark: <b><%= t.remark || "—" %></b>
        </div>
      </div>

      <table>
        <thead>
          <tr>
            <th>Subject</th>
            <th>Exam</th>
            <th class="right">Score</th>
            <th class="right">%</th>
            <th class="right">Grade</th>
            <th class="right">Remark</th>
          </tr>
        </thead>
        <tbody>
          <% (t.rows || []).forEach(function(r){ %>
            <tr>
              <td><b><%= r.subjectCode %></b> <%= r.subjectTitle ? ("— " + r.subjectTitle) : "" %></td>
              <td><%= r.examTitle || "Exam" %></td>
              <td class="right"><%= r.score %>/<%= r.total %></td>
              <td class="right"><%= Number(r.percentage || 0).toFixed(2) %>%</td>
              <td class="right"><b><%= r.grade %></b></td>
              <td class="right"><%= r.remark %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% }) %>

  <div class="box">
    <div><b>Teacher Comment:</b> <%= data.transcriptMeta.teacherComment || "—" %></div>
    <div style="margin-top:8px;"><b>Head Teacher Comment:</b> <%= data.transcriptMeta.headTeacherComment || "—" %></div>
  </div>

  <div class="sig">
    <div>
      <div class="small">Academic Office</div>
      <div style="margin-top:40px;border-top:1px solid #0b1020;width:240px"></div>
      <div class="small">Signature & Stamp</div>
    </div>

    <div>
      <div class="small">Date</div>
      <div style="margin-top:40px;border-top:1px solid #0b1020;width:180px"></div>
      <div class="small"><%= new Date().toISOString().slice(0,10) %></div>
    </div>
  </div>
</div>

<script src="/js/transcript-print.js" defer></script>
</body>
</html>
