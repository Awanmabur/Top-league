<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Admin • Hostels — <%= (tenant && tenant.name) ? tenant.name : "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>

  <link rel="stylesheet" href="/css/student-portal.css"/>
  <link rel="stylesheet" href="/css/navbar.css"/>

  <style>
    *{box-sizing:border-box}
    html,body{max-width:100%;overflow-x:hidden}
    body{overflow-x:hidden}
    .main{min-width:0}
    .card{min-width:0}
    .grid-2 > *{min-width:0}

    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center;min-width:0}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none;max-width:100%}
    .textarea{min-height:110px;resize:vertical;width:100%}
    .input{min-width:230px;max-width:100%}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr);gap:12px}

    .chips{display:flex;gap:8px;flex-wrap:wrap;max-width:100%}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px;max-width:100%}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;max-width:100%}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      width:100%;
      max-width:100%;
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      -webkit-overflow-scrolling:touch;
    }

    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1120px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}

    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap}

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .alloc-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:10px}
    .alloc-card{border:1px solid rgba(13,64,96,.12);border-radius:14px;background:#fff;padding:12px;display:grid;gap:8px;min-width:0}
    .alloc-top{display:flex;justify-content:space-between;align-items:center;gap:10px}
    .bar{height:10px;border-radius:999px;background:rgba(13,64,96,.08);overflow:hidden}
    .bar > div{height:100%}
    .alloc-meta{display:flex;justify-content:space-between;gap:10px;flex-wrap:wrap}
    .alloc-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}

    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px;min-width:0}

    /* MODALS */
    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:20px;
      z-index:9999;
      overflow-y:auto;
      overflow-x:hidden;
      -webkit-overflow-scrolling:touch;
    }
    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1000px,100%);
      max-width:100%;
      max-height:min(88vh,900px);
      margin:auto;
      background:#fff;
      border-radius:20px;
      box-shadow:0 24px 70px rgba(0,0,0,.24);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      flex:0 0 auto;
      background:#fff;
    }

    .modal-title{font-weight:900}

    .modal-body{
      padding:16px 18px;
      max-width:100%;
      overflow-y:auto;
      overflow-x:hidden;
      flex:1 1 auto;
      min-height:0;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex:0 0 auto;
    }

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field{min-width:0}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%;min-width:0}

    .detail-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .detail-card{
      border:1px solid rgba(13,64,96,.10);
      border-radius:16px;
      padding:14px;
      background:#fff;
      min-width:0;
    }
    .detail-card .label{font-size:12px;color:#6b7280;margin-bottom:4px}
    .detail-card .value{font-weight:800;color:#0f172a;word-break:break-word}
    .detail-list{display:grid;gap:10px}
    .detail-list .item{
      padding:12px 14px;
      border:1px solid rgba(13,64,96,.10);
      border-radius:16px;
      background:#fff;
      word-break:break-word;
    }

    @media (max-width: 980px){
      .grid-2{grid-template-columns:1fr}
      .form-grid,.detail-grid{grid-template-columns:1fr}
      .alloc-grid{grid-template-columns:1fr}
      .input{min-width:180px}
    }

    @media (max-width: 768px){
      .topbar{gap:12px}
      .top-actions{display:flex;gap:8px;flex-wrap:wrap}
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *, .toolbar .right > *{flex:1 1 160px}
      .input,.select{width:100%;min-width:0}
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .modal-backdrop{
        align-items:flex-start;
        padding:12px;
      }
      .modal{
        width:100%;
        max-height:calc(100vh - 24px);
        border-radius:18px;
      }
      .modal-header,
      .modal-body,
      .modal-footer{
        padding-left:14px;
        padding-right:14px;
      }
    }

    @media (max-width: 560px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .card{overflow:hidden}
      .section-title,.section-sub,.muted,.strong{word-break:break-word}
      .top-actions .btn{flex:1 1 calc(50% - 8px)}
      .actions{justify-content:flex-start}
      .modal{
        border-radius:16px;
      }
      .modal-footer{
        flex-wrap:wrap;
      }
      .modal-footer .btn{
        flex:1 1 140px;
      }
    }
  </style>
</head>
<body data-portal="tenant">
  <%- include("../partials/flash") %>
<%- include("../partials/navbar") %>
  <main class="main">
    

    <div class="topbar">
      <div>
        <div class="title">Hostels</div>
        <div class="subtitle">Manage hostel blocks, rooms, applications, allocations, check-ins, maintenance, discipline and fees.</div>
      </div>
      <div class="top-actions">
        <button class="btn light" type="button" id="btnExport"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
        <button class="btn light" type="button" id="btnReports"><i class="fa-solid fa-chart-column"></i> Reports</button>
        <button class="btn light" type="button" id="btnPolicies"><i class="fa-solid fa-scale-balanced"></i> Policies</button>
        <button class="btn primary" type="button" id="btnAddRoom"><i class="fa-solid fa-plus"></i> Add Room</button>
      </div>
    </div>

    <div class="grid-4">
      <div class="card"><div class="section-title">Rooms</div><div class="kpi-value"><%= kpis.rooms || 0 %></div><div class="muted">In system</div></div>
      <div class="card"><div class="section-title">Beds</div><div class="kpi-value"><%= kpis.beds || 0 %></div><div class="muted">Total capacity</div></div>
      <div class="card"><div class="section-title">Occupied</div><div class="kpi-value" style="color:#92400e"><%= kpis.occupied || 0 %></div><div class="muted">Allocated beds</div></div>
      <div class="card"><div class="section-title">Applications</div><div class="kpi-value" style="color:#0a6fbf"><%= kpis.applications || 0 %></div><div class="muted">Pending approvals</div></div>
    </div>

    <section class="card" style="margin-top:12px;">
      <form method="GET" action="/admin/hostels">
        <div class="toolbar">
          <div class="left">
            <input class="input" name="q" value="<%= query.q || '' %>" placeholder="Search room / block / status / warden..." />
            <select class="select" name="block">
              <option value="all">All Blocks</option>
              <% blocks.forEach(function(b){ %>
                <option value="<%= b %>" <%= query.block === b ? "selected" : "" %>><%= b %></option>
              <% }) %>
            </select>
            <select class="select" name="gender">
              <option value="all" <%= query.gender === "all" ? "selected" : "" %>>All Genders</option>
              <option value="Male" <%= query.gender === "Male" ? "selected" : "" %>>Male</option>
              <option value="Female" <%= query.gender === "Female" ? "selected" : "" %>>Female</option>
              <option value="Mixed" <%= query.gender === "Mixed" ? "selected" : "" %>>Mixed</option>
            </select>
            <select class="select" name="status">
              <option value="all" <%= query.status === "all" ? "selected" : "" %>>All Status</option>
              <option value="Available" <%= query.status === "Available" ? "selected" : "" %>>Available</option>
              <option value="Full" <%= query.status === "Full" ? "selected" : "" %>>Full</option>
              <option value="Maintenance" <%= query.status === "Maintenance" ? "selected" : "" %>>Maintenance</option>
              <option value="Closed" <%= query.status === "Closed" ? "selected" : "" %>>Closed</option>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip <%= (query.view || 'rooms') === 'rooms' ? 'active' : '' %>" type="button" data-view="rooms"><i class="fa-solid fa-building"></i> Rooms</button>
              <button class="chip <%= query.view === 'applications' ? 'active' : '' %>" type="button" data-view="applications"><i class="fa-solid fa-inbox"></i> Applications</button>
              <button class="chip <%= query.view === 'allocations' ? 'active' : '' %>" type="button" data-view="allocations"><i class="fa-solid fa-people-roof"></i> Allocation</button>
              <button class="chip <%= query.view === 'checkin' ? 'active' : '' %>" type="button" data-view="checkin"><i class="fa-solid fa-clipboard-check"></i> Check-in/out</button>
              <button class="chip <%= query.view === 'maintenance' ? 'active' : '' %>" type="button" data-view="maintenance"><i class="fa-solid fa-screwdriver-wrench"></i> Maintenance</button>
              <button class="chip <%= query.view === 'discipline' ? 'active' : '' %>" type="button" data-view="discipline"><i class="fa-solid fa-gavel"></i> Discipline</button>
              <button class="chip <%= query.view === 'fees' ? 'active' : '' %>" type="button" data-view="fees"><i class="fa-solid fa-receipt"></i> Fees</button>
            </div>
            <input type="hidden" name="view" id="viewInput" value="<%= query.view || 'rooms' %>"/>
            <button class="btn light" type="submit"><i class="fa-solid fa-filter"></i> Apply</button>
            <a class="btn light" href="/admin/hostels"><i class="fa-solid fa-rotate-left"></i> Reset</a>
          </div>
        </div>
      </form>
    </section>

    <% const currentView = query.view || "rooms"; %>

    <div class="grid-2" style="margin-top:12px;">
      <section class="card">
        <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
          <div>
            <div class="section-title">
              <%= currentView === "applications" ? "Applications"
                : currentView === "allocations" ? "Allocation"
                : currentView === "checkin" ? "Check-in/out"
                : currentView === "maintenance" ? "Maintenance"
                : currentView === "discipline" ? "Discipline"
                : currentView === "fees" ? "Fees"
                : "Rooms" %>
            </div>
            <div class="section-sub">
              <%= currentView === "applications" ? "Approve, deny, or waitlist requests."
                : currentView === "allocations" ? "Assign students to hostel rooms."
                : currentView === "checkin" ? "Track room occupancy movement."
                : currentView === "maintenance" ? "Manage repair tickets."
                : currentView === "discipline" ? "Monitor discipline cases."
                : currentView === "fees" ? "Track hostel payments and receipts."
                : "Manage hostel rooms and capacity." %>
            </div>
          </div>
        </div>

        <% if (currentView === "rooms") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Room</th>
                  <th>Block</th>
                  <th>Gender</th>
                  <th>Type</th>
                  <th>Beds</th>
                  <th>Occupied</th>
                  <th>Price / Sem</th>
                  <th>Status</th>
                  <th style="text-align:right;width:260px;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!rooms.length) { %>
                  <tr><td colspan="9"><div class="muted">No rooms found.</div></td></tr>
                <% } %>
                <% rooms.forEach(function(room){ %>
                  <tr>
                    <td>
                      <div class="strong"><%= room.code %></div>
                      <div class="muted">Warden: <%= room.warden || "—" %></div>
                    </td>
                    <td><%= room.block %></td>
                    <td><span class="pill info"><i class="fa-solid fa-user"></i> <%= room.gender %></span></td>
                    <td><%= room.type %></td>
                    <td><span class="pill info"><i class="fa-solid fa-layer-group"></i> <%= room.beds %></span></td>
                    <td><span class="pill <%= room.occupied >= room.beds ? 'warn' : 'ok' %>"><i class="fa-solid fa-person-shelter"></i> <%= room.occupied %></span></td>
                    <td><span class="pill info"><i class="fa-solid fa-coins"></i> UGX <%= Number(room.pricePerSemester || 0).toLocaleString() %></span></td>
                    <td>
                      <% if (room.status === "Available") { %>
                        <span class="pill ok"><i class="fa-solid fa-check"></i> Available</span>
                      <% } else if (room.status === "Full") { %>
                        <span class="pill warn"><i class="fa-solid fa-bed"></i> Full</span>
                      <% } else if (room.status === "Maintenance") { %>
                        <span class="pill bad"><i class="fa-solid fa-screwdriver-wrench"></i> Maintenance</span>
                      <% } else { %>
                        <span class="pill bad"><i class="fa-solid fa-lock"></i> Closed</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="actions">
                        <button class="btn-xs js-view-room" type="button" title="View" data-room='<%- JSON.stringify(room) %>'><i class="fa-solid fa-eye"></i></button>
                        <button class="btn-xs js-edit-room" type="button" title="Edit" data-room='<%- JSON.stringify(room) %>'><i class="fa-solid fa-pen"></i></button>
                        <button class="btn-xs js-assign-room" type="button" title="Assign Student" data-id="<%= room._id %>" data-code="<%= room.code %>"><i class="fa-solid fa-user-plus"></i></button>
                        <button class="btn-xs js-maint-room" type="button" title="Create Ticket" data-id="<%= room._id %>" data-code="<%= room.code %>"><i class="fa-solid fa-screwdriver-wrench"></i></button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "applications") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Application</th>
                  <th>Student</th>
                  <th>Preference</th>
                  <th>Submitted</th>
                  <th>Status</th>
                  <th style="text-align:right;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!applications.length) { %>
                  <tr><td colspan="6"><div class="muted">No applications found.</div></td></tr>
                <% } %>
                <% applications.forEach(function(a){ %>
                  <tr>
                    <td>
                      <div class="strong"><%= a.applicationId || a._id %></div>
                      <div class="muted"><%= a.roomBlock %> • <%= a.roomCode %></div>
                    </td>
                    <td><%= a.studentName %><% if (a.regNo) { %> — <%= a.regNo %><% } %></td>
                    <td class="muted"><%= a.preference || "—" %></td>
                    <td class="muted"><%= helpers.formatDate(a.submittedAt) %></td>
                    <td>
                      <% if (a.status === "Pending") { %>
                        <span class="pill warn"><i class="fa-solid fa-hourglass"></i> Pending</span>
                      <% } else if (a.status === "Waitlist") { %>
                        <span class="pill info"><i class="fa-solid fa-clock"></i> Waitlist</span>
                      <% } else if (a.status === "Approved") { %>
                        <span class="pill ok"><i class="fa-solid fa-check"></i> Approved</span>
                      <% } else { %>
                        <span class="pill bad"><i class="fa-solid fa-xmark"></i> Denied</span>
                      <% } %>
                    </td>
                    <td style="text-align:right;">
                      <form action="/admin/hostels/rooms/<%= a.roomMongoId %>/applications/<%= a._id %>/status" method="POST" style="display:inline;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="status" value="Approved">
                        <button class="btn-xs" type="submit"><i class="fa-solid fa-check"></i> Approve</button>
                      </form>
                      <form action="/admin/hostels/rooms/<%= a.roomMongoId %>/applications/<%= a._id %>/status" method="POST" style="display:inline;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="status" value="Denied">
                        <button class="btn-xs" type="submit"><i class="fa-solid fa-xmark"></i> Deny</button>
                      </form>
                      <form action="/admin/hostels/rooms/<%= a.roomMongoId %>/applications/<%= a._id %>/status" method="POST" style="display:inline;">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="status" value="Waitlist">
                        <button class="btn-xs" type="submit"><i class="fa-solid fa-clock"></i> Waitlist</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "allocations") { %>
          <div class="note" style="margin-top:10px;">Allocation dashboard. Backend prevents over-allocation and invalid room assignment.</div>
          <div class="alloc-grid">
            <% rooms.forEach(function(room){ const pct = room.beds ? Math.min(100, Math.round((room.occupied / room.beds) * 100)) : 0; %>
              <div class="alloc-card">
                <div class="alloc-top">
                  <div>
                    <div class="strong"><%= room.block %> • <%= room.code %></div>
                    <div class="muted"><%= room.gender %> • <%= room.type %></div>
                  </div>
                  <% if (room.status === "Available") { %>
                    <span class="pill ok"><i class="fa-solid fa-check"></i> Available</span>
                  <% } else if (room.status === "Full") { %>
                    <span class="pill warn"><i class="fa-solid fa-bed"></i> Full</span>
                  <% } else if (room.status === "Maintenance") { %>
                    <span class="pill bad"><i class="fa-solid fa-screwdriver-wrench"></i> Maintenance</span>
                  <% } else { %>
                    <span class="pill bad"><i class="fa-solid fa-lock"></i> Closed</span>
                  <% } %>
                </div>
                <div class="bar"><div style="width:<%= pct %>%;background:<%= pct >= 100 ? '#f59e0b' : (pct >= 70 ? '#0a6fbf' : '#16a34a') %>;"></div></div>
                <div class="alloc-meta">
                  <div class="muted"><i class="fa-solid fa-bed"></i> Beds: <b><%= room.beds %></b></div>
                  <div class="muted"><i class="fa-solid fa-person"></i> Occupied: <b><%= room.occupied %></b></div>
                  <div class="muted"><i class="fa-solid fa-coins"></i> UGX <%= Number(room.pricePerSemester || 0).toLocaleString() %></div>
                </div>
                <div class="alloc-actions">
                  <button class="btn-xs js-view-room" type="button" data-room='<%- JSON.stringify(room) %>'><i class="fa-solid fa-eye"></i> View</button>
                  <button class="btn-xs js-assign-room" type="button" data-id="<%= room._id %>" data-code="<%= room.code %>"><i class="fa-solid fa-user-plus"></i> Assign</button>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>

        <% if (currentView === "checkin") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Student</th>
                  <th>Room</th>
                  <th>Check-in</th>
                  <th>Check-out</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (!checkins.length) { %>
                  <tr><td colspan="5"><div class="muted">No check-in records found.</div></td></tr>
                <% } %>
                <% checkins.forEach(function(c){ %>
                  <tr>
                    <td><div class="strong"><%= c.studentName %></div><div class="muted"><%= c.regNo || c.checkinId || "—" %></div></td>
                    <td><span class="pill info"><i class="fa-solid fa-bed"></i> <%= c.roomCode %></span></td>
                    <td class="muted"><%= helpers.formatDate(c.checkInDate) %></td>
                    <td class="muted"><%= helpers.formatDate(c.checkOutDate) %></td>
                    <td>
                      <% if (c.status === "Checked-in") { %>
                        <span class="pill ok"><i class="fa-solid fa-clipboard-check"></i> Checked-in</span>
                      <% } else { %>
                        <span class="pill info"><i class="fa-solid fa-clipboard"></i> Checked-out</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "maintenance") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Ticket</th>
                  <th>Room</th>
                  <th>Issue</th>
                  <th>Priority</th>
                  <th>Status</th>
                  <th>Created</th>
                </tr>
              </thead>
              <tbody>
                <% if (!maintenance.length) { %>
                  <tr><td colspan="6"><div class="muted">No maintenance tickets found.</div></td></tr>
                <% } %>
                <% maintenance.forEach(function(m){ %>
                  <tr>
                    <td><div class="strong"><%= m.ticketId || m._id %></div><div class="muted">Maintenance</div></td>
                    <td><span class="pill info"><i class="fa-solid fa-bed"></i> <%= m.roomCode %></span></td>
                    <td class="muted"><%= m.issue %></td>
                    <td><span class="pill <%= m.priority === 'High' || m.priority === 'Urgent' ? 'bad' : 'info' %>"><i class="fa-solid fa-flag"></i> <%= m.priority %></span></td>
                    <td><span class="pill <%= m.status === 'Resolved' ? 'ok' : (m.status === 'In Progress' ? 'warn' : 'info') %>"><i class="fa-solid fa-circle"></i> <%= m.status %></span></td>
                    <td class="muted"><%= helpers.formatDate(m.createdAt) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "discipline") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Case</th>
                  <th>Student</th>
                  <th>Violation</th>
                  <th>Action</th>
                  <th>Status</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (!discipline.length) { %>
                  <tr><td colspan="6"><div class="muted">No discipline cases found.</div></td></tr>
                <% } %>
                <% discipline.forEach(function(d){ %>
                  <tr>
                    <td><div class="strong"><%= d.caseId || d._id %></div><div class="muted">Discipline case</div></td>
                    <td><%= d.studentName %><% if (d.regNo) { %> — <%= d.regNo %><% } %></td>
                    <td class="muted"><%= d.violation %></td>
                    <td><span class="pill info"><i class="fa-solid fa-gavel"></i> <%= d.action || "—" %></span></td>
                    <td><span class="pill <%= d.status === 'Closed' ? 'ok' : 'warn' %>"><i class="fa-solid fa-circle"></i> <%= d.status %></span></td>
                    <td class="muted"><%= helpers.formatDate(d.date) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "fees") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Receipt</th>
                  <th>Student</th>
                  <th>Room</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (!fees.length) { %>
                  <tr><td colspan="6"><div class="muted">No hostel fee records found.</div></td></tr>
                <% } %>
                <% fees.forEach(function(f){ %>
                  <tr>
                    <td><div class="strong"><%= f.receiptNo || f._id %></div><div class="muted">Receipt</div></td>
                    <td><%= f.studentName %><% if (f.regNo) { %> — <%= f.regNo %><% } %></td>
                    <td><span class="pill info"><i class="fa-solid fa-bed"></i> <%= f.roomCode %></span></td>
                    <td><span class="pill info"><i class="fa-solid fa-coins"></i> UGX <%= Number(f.amount || 0).toLocaleString() %></span></td>
                    <td><% if (f.status === "Paid") { %><span class="pill ok"><i class="fa-solid fa-check"></i> Paid</span><% } else { %><span class="pill bad"><i class="fa-solid fa-triangle-exclamation"></i> Pending</span><% } %></td>
                    <td class="muted"><%= helpers.formatDate(f.date) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>

      <aside class="card">
        <div class="section-title">Hostel Operations</div>
        <div class="section-sub">Quick admin actions.</div>

        <div class="mini-list">
          <div class="mini-item">
            <div class="left"><div class="strong">Approve Applications</div><div class="muted">Process hostel requests</div></div>
            <a class="btn-xs" href="/admin/hostels?view=applications"><i class="fa-solid fa-inbox"></i></a>
          </div>
          <div class="mini-item">
            <div class="left"><div class="strong">Allocate Student</div><div class="muted">Assign to a room</div></div>
            <a class="btn-xs" href="/admin/hostels?view=allocations"><i class="fa-solid fa-people-roof"></i></a>
          </div>
          <div class="mini-item">
            <div class="left"><div class="strong">Create Maintenance</div><div class="muted">Log a repair ticket</div></div>
            <a class="btn-xs" href="/admin/hostels?view=maintenance"><i class="fa-solid fa-screwdriver-wrench"></i></a>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <!-- Add/Edit Room Modal -->
  <div class="modal-backdrop" id="mRoom">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="mRoomTitle">Add Room</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mRoom"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="roomForm" method="POST" action="/admin/hostels/rooms">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-grid">
            <div class="field"><label>Block</label><input class="input" name="block" id="rBlock" placeholder="Block A"></div>
            <div class="field"><label>Room Code</label><input class="input" name="code" id="rCode" placeholder="A-101"></div>
            <div class="field">
              <label>Gender</label>
              <select class="select" name="gender" id="rGender">
                <option>Male</option>
                <option>Female</option>
                <option>Mixed</option>
              </select>
            </div>
            <div class="field">
              <label>Room Type</label>
              <select class="select" name="type" id="rType">
                <option>Standard</option>
                <option>Premium</option>
                <option>VIP</option>
              </select>
            </div>
            <div class="field"><label>Beds</label><input class="input" name="beds" id="rBeds" type="number" min="1" value="4"></div>
            <div class="field"><label>Price (UGX/Sem)</label><input class="input" name="pricePerSemester" id="rPrice" type="number" min="0" value="250000"></div>
            <div class="field">
              <label>Status</label>
              <select class="select" name="status" id="rStatus">
                <option>Available</option>
                <option>Full</option>
                <option>Maintenance</option>
                <option>Closed</option>
              </select>
            </div>
            <div class="field"><label>Warden</label><input class="input" name="warden" id="rWarden" placeholder="Mr/Ms..."></div>
            <div class="field"><label>Notes</label><input class="input" name="notes" id="rNotes" placeholder="Any notes"></div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light js-close-modal" type="button" data-modal="mRoom">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- View Room Modal -->
  <div class="modal-backdrop" id="mViewRoom">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Room Details</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mViewRoom"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="detail-grid">
          <div class="detail-card"><div class="label">Room Code</div><div class="value" id="vCode">—</div></div>
          <div class="detail-card"><div class="label">Block</div><div class="value" id="vBlock">—</div></div>
          <div class="detail-card"><div class="label">Gender</div><div class="value" id="vGender">—</div></div>
          <div class="detail-card"><div class="label">Type</div><div class="value" id="vType">—</div></div>
          <div class="detail-card"><div class="label">Beds</div><div class="value" id="vBeds">—</div></div>
          <div class="detail-card"><div class="label">Occupied</div><div class="value" id="vOccupied">—</div></div>
          <div class="detail-card"><div class="label">Price / Semester</div><div class="value" id="vPrice">—</div></div>
          <div class="detail-card"><div class="label">Status</div><div class="value" id="vStatus">—</div></div>
          <div class="detail-card"><div class="label">Warden</div><div class="value" id="vWarden">—</div></div>
          <div class="detail-card"><div class="label">Last Updated</div><div class="value" id="vUpdated">—</div></div>
        </div>

        <div class="section-title" style="margin-top:16px;">Notes</div>
        <div class="detail-card"><div class="value" id="vNotes">—</div></div>

        <div class="section-title" style="margin-top:16px;">Quick Summary</div>
        <div class="detail-list">
          <div class="item"><strong>Applications:</strong> <span id="vApplications">0</span></div>
          <div class="item"><strong>Check-ins:</strong> <span id="vCheckins">0</span></div>
          <div class="item"><strong>Maintenance Tickets:</strong> <span id="vMaintenance">0</span></div>
          <div class="item"><strong>Discipline Cases:</strong> <span id="vDiscipline">0</span></div>
          <div class="item"><strong>Fee Receipts:</strong> <span id="vFees">0</span></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn light js-close-modal" type="button" data-modal="mViewRoom">Close</button>
      </div>
    </div>
  </div>

  <!-- Assign Student Modal -->
  <div class="modal-backdrop" id="mAssign">
    <div class="modal" style="width:min(760px,100%);">
      <div class="modal-header">
        <div class="modal-title">Assign Student to Room</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mAssign"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form method="POST" id="assignForm" action="">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-grid" style="grid-template-columns:repeat(2,minmax(0,1fr));">
            <div class="field"><label>Student Name</label><input class="input" name="studentName" placeholder="Student full name"></div>
            <div class="field"><label>Registration No</label><input class="input" name="regNo" placeholder="REG/2024/..."></div>
          </div>
          <div class="field" style="margin-top:12px;">
            <label>Note</label>
            <textarea class="textarea" name="note" placeholder="Optional note"></textarea>
          </div>
          <div class="note" style="margin-top:12px;">Room: <strong id="assignRoomCode">—</strong></div>
        </div>
        <div class="modal-footer">
          <button class="btn light js-close-modal" type="button" data-modal="mAssign">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Assign</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Maintenance Ticket Modal -->
  <div class="modal-backdrop" id="mMaint">
    <div class="modal" style="width:min(760px,100%);">
      <div class="modal-header">
        <div class="modal-title">Create Maintenance Ticket</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mMaint"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form method="POST" id="maintForm" action="">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-grid" style="grid-template-columns:repeat(2,minmax(0,1fr));">
            <div class="field">
              <label>Priority</label>
              <select class="select" name="priority">
                <option>Normal</option>
                <option>High</option>
                <option>Urgent</option>
              </select>
            </div>
            <div class="field">
              <label>Status</label>
              <select class="select" name="status">
                <option>Open</option>
                <option>In Progress</option>
                <option>Resolved</option>
              </select>
            </div>
          </div>
          <div class="field" style="margin-top:12px;">
            <label>Issue</label>
            <input class="input" name="issue" placeholder="Broken door lock / plumbing leak / electrical issue">
          </div>
          <div class="field" style="margin-top:12px;">
            <label>Note</label>
            <textarea class="textarea" name="note" placeholder="Extra internal note"></textarea>
          </div>
          <div class="note" style="margin-top:12px;">Room: <strong id="maintRoomCode">—</strong></div>
        </div>
        <div class="modal-footer">
          <button class="btn light js-close-modal" type="button" data-modal="mMaint">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Save Ticket</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/tenant-admin-hostels.js"></script>
  <script src="/js/navbar.js"></script>
</body>
</html>
