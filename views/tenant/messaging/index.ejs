<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin  -  Messaging - Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:240px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);gap:12px}

    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .pin{background:rgba(10,111,191,.12);color:#0a6fbf}

    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1180px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}

    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;max-width:100%}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}

    .modal-backdrop{
      position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;
      padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden
    }
    .modal-backdrop.show{display:flex}
    .modal{
      width:min(1020px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto
    }
    .modal.sm{width:min(760px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap;position:relative;z-index:2;box-shadow:0 -8px 18px rgba(0,0,0,.04)}

    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .toggle{display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff;min-width:0}
    .switch{position:relative;width:44px;height:26px;border-radius:999px;background:rgba(13,64,96,.16);cursor:pointer;transition:.2s;flex:0 0 auto}
    .switch::after{content:"";position:absolute;top:3px;left:3px;width:20px;height:20px;border-radius:50%;background:#fff;transition:.2s}
    .switch.on{background:rgba(22,163,74,.25)}
    .switch.on::after{left:21px}

    .json-data{display:none !important}

    .view-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-bottom:14px}
    .view-card{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;min-width:0}
    .view-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .view-value{font-weight:800;word-break:break-word}
    .view-message{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;white-space:pre-wrap;line-height:1.65}
    .view-section-title{font-weight:900;margin-bottom:8px}

    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }
    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
      .top-actions .btn{padding-inline:12px}
      .view-grid{grid-template-columns:1fr}
    }
    @media (max-width: 520px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
      .top-actions{gap:6px}
      .top-actions .btn{font-size:12px}
      .actions{justify-content:flex-start}
      table{min-width:1000px}
      .modal-backdrop{padding:30px 12px}
      .modal{max-height:calc(100dvh - 60px);border-radius:20px}
      .modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}
    }
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Messaging</div>
          <div class="subtitle">Compose, schedule and send messages to students, staff, departments and targeted groups.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
          <button class="btn light" id="btnTemplates" type="button"><i class="fa-solid fa-layer-group"></i> Templates</button>
          <button class="btn light" id="btnSettings" type="button"><i class="fa-solid fa-gear"></i> Settings</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> New Message</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Sent</div>
          <div class="kpi-value"><%= kpis?.sent || 0 %></div>
          <div class="muted">Delivered to recipients</div>
        </div>
        <div class="card">
          <div class="section-title">Scheduled</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= kpis?.scheduled || 0 %></div>
          <div class="muted">Queued to send later</div>
        </div>
        <div class="card">
          <div class="section-title">Drafts</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.drafts || 0 %></div>
          <div class="muted">Not sent yet</div>
        </div>
        <div class="card">
          <div class="section-title">Failed</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.failed || 0 %></div>
          <div class="muted">Need attention</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/messaging">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search subject, type, audience, status..." />
            <select class="select" name="status">
              <option value="all" <%= query?.status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="Sent" <%= query?.status === 'Sent' ? 'selected' : '' %>>Sent</option>
              <option value="Scheduled" <%= query?.status === 'Scheduled' ? 'selected' : '' %>>Scheduled</option>
              <option value="Draft" <%= query?.status === 'Draft' ? 'selected' : '' %>>Draft</option>
              <option value="Archived" <%= query?.status === 'Archived' ? 'selected' : '' %>>Archived</option>
              <option value="Failed" <%= query?.status === 'Failed' ? 'selected' : '' %>>Failed</option>
            </select>
            <select class="select" name="type">
              <option value="all" <%= query?.type === 'all' ? 'selected' : '' %>>All Types</option>
              <option value="General" <%= query?.type === 'General' ? 'selected' : '' %>>General</option>
              <option value="Notice" <%= query?.type === 'Notice' ? 'selected' : '' %>>Notice</option>
              <option value="Reminder" <%= query?.type === 'Reminder' ? 'selected' : '' %>>Reminder</option>
              <option value="Alert" <%= query?.type === 'Alert' ? 'selected' : '' %>>Alert</option>
              <option value="Invitation" <%= query?.type === 'Invitation' ? 'selected' : '' %>>Invitation</option>
            </select>
            <select class="select" name="audience">
              <option value="all" <%= query?.audience === 'all' ? 'selected' : '' %>>All Audiences</option>
              <option value="All Students" <%= query?.audience === 'All Students' ? 'selected' : '' %>>All Students</option>
              <option value="All Staff" <%= query?.audience === 'All Staff' ? 'selected' : '' %>>All Staff</option>
              <option value="Specific Department" <%= query?.audience === 'Specific Department' ? 'selected' : '' %>>Specific Department</option>
              <option value="Specific Program" <%= query?.audience === 'Specific Program' ? 'selected' : '' %>>Specific Program</option>
              <option value="Year/Cohort" <%= query?.audience === 'Year/Cohort' ? 'selected' : '' %>>Year/Cohort</option>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip active" data-view="list" type="button"><i class="fa-solid fa-list"></i> List</button>
              <button class="chip" data-view="delivery" type="button"><i class="fa-solid fa-chart-column"></i> Delivery</button>
              <button class="chip" data-view="recipients" type="button"><i class="fa-solid fa-user-check"></i> Recipients</button>
            </div>
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/messaging"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">messages</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkSend" type="button"><i class="fa-solid fa-paper-plane"></i> Send</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDraft" type="button"><i class="fa-solid fa-pen-to-square"></i> Draft</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title" id="panelTitle">Messages</div>
              <div class="section-sub" id="panelSub">Manage messages, schedules and delivery workflow.</div>
            </div>
            <div class="muted" id="resultMeta">-</div>
          </div>

          <div id="view-list" style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                    <th>Message</th>
                    <th>Type</th>
                    <th>Audience</th>
                    <th>Channels</th>
                    <th>Schedule</th>
                    <th>Status</th>
                    <th style="text-align:right;width:280px;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbody"></tbody>
              </table>
            </div>
          </div>

          <div id="view-delivery" style="display:none;margin-top:10px;">
            <div class="note">Delivery data is shown from DB stats fields.</div>
            <div class="table-wrap" style="margin-top:10px;">
              <table>
                <thead>
                  <tr>
                    <th>Message</th>
                    <th>Recipients</th>
                    <th>Delivered</th>
                    <th>Opened</th>
                    <th>Failed</th>
                    <th>Delivery %</th>
                  </tr>
                </thead>
                <tbody id="tbodyEng"></tbody>
              </table>
            </div>
          </div>

          <div id="view-recipients" style="display:none;margin-top:10px;">
            <div class="toolbar">
              <div class="left">
                <input class="input" id="rSearch" placeholder="Search recipient name, email...">
                <select class="select" id="rFilter">
                  <option value="all">All</option>
                  <option value="Delivered">Delivered</option>
                  <option value="Opened">Opened</option>
                  <option value="Failed">Failed</option>
                  <option value="Pending">Pending</option>
                </select>
              </div>
              <div class="right">
                <button class="btn light" id="btnRemind" type="button"><i class="fa-solid fa-bell"></i> Resend / Remind</button>
              </div>
            </div>

            <div class="table-wrap" style="margin-top:10px;">
              <table>
                <thead>
                  <tr>
                    <th>Recipient</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Delivered At</th>
                    <th>Opened At</th>
                  </tr>
                </thead>
                <tbody id="tbodyRec"></tbody>
              </table>
            </div>
          </div>

          <div class="note" style="margin-top:12px;">
            <strong>Admin controls included:</strong> create/edit, schedule, send/archive, audience targeting, channels, delivery and recipient tracking.
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Common message workflows.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">General Notice</div>
                <div class="muted">Portal + email school update</div>
              </div>
              <button class="btn-xs" id="quickNotice" type="button"><i class="fa-solid fa-bullhorn"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Fee Reminder</div>
                <div class="muted">Students payment reminder</div>
              </div>
              <button class="btn-xs" id="quickReminder" type="button"><i class="fa-solid fa-coins"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Urgent Alert</div>
                <div class="muted">Immediate urgent message</div>
              </div>
              <button class="btn-xs" id="quickAlert" type="button"><i class="fa-solid fa-triangle-exclamation"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">New Message</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="messageForm" method="POST" action="/admin/messaging">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Subject</label>
              <input class="input" id="mSubject" name="subject" placeholder="e.g., Fee Payment Reminder">
            </div>
            <div class="field">
              <label>Type</label>
              <select class="select" id="mType" name="type">
                <option>General</option>
                <option>Notice</option>
                <option>Reminder</option>
                <option>Alert</option>
                <option>Invitation</option>
              </select>
            </div>
            <div class="field">
              <label>Priority</label>
              <select class="select" id="mPriority" name="priority">
                <option>Normal</option>
                <option>Important</option>
              </select>
            </div>

            <div class="field">
              <label>Audience Type</label>
              <select class="select" id="mAudienceType" name="audienceType">
                <option>All Students</option>
                <option>All Staff</option>
                <option>Specific Department</option>
                <option>Specific Program</option>
                <option>Year/Cohort</option>
              </select>
            </div>
            <div class="field">
              <label>Audience Value</label>
              <input class="input" id="mAudienceValue" name="audienceValue" placeholder="e.g., Computing, Year 1">
            </div>
            <div class="field">
              <label>Sender Name</label>
              <input class="input" id="mSenderName" name="senderName" placeholder="e.g., Administration">
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Message</label>
            <textarea class="textarea" id="mBody" name="body" placeholder="Write message content here..."></textarea>
            <div class="muted" id="charCount">0 / 5000</div>
          </div>

          <div class="divider"></div>

          <div class="form-grid">
            <div class="field">
              <label>Send Mode</label>
              <select class="select" id="mSendMode" name="sendMode">
                <option>Send Now</option>
                <option>Schedule</option>
                <option>Save as Draft</option>
              </select>
            </div>
            <div class="field">
              <label>Schedule At</label>
              <input class="input" id="mScheduleAt" name="scheduleAt" type="datetime-local">
            </div>
            <div class="field">
              <label>Reply-To Email</label>
              <input class="input" id="mReplyTo" name="replyTo" type="email" placeholder="e.g., info@school.com">
            </div>
          </div>

          <div class="divider"></div>

          <div class="strong">Delivery Channels</div>
          <div class="muted" style="margin-top:4px;">Choose how this message should be sent.</div>

          <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-top:10px;">
            <div class="toggle">
              <div class="switch on" data-ch="portal"></div>
              <div>
                <div class="strong"><i class="fa-solid fa-globe"></i> Portal</div>
                <div class="muted">Internal portal</div>
              </div>
            </div>
            <div class="toggle">
              <div class="switch on" data-ch="email"></div>
              <div>
                <div class="strong"><i class="fa-solid fa-envelope"></i> Email</div>
                <div class="muted">Mail delivery</div>
              </div>
            </div>
            <div class="toggle">
              <div class="switch" data-ch="sms"></div>
              <div>
                <div class="strong"><i class="fa-solid fa-comment-sms"></i> SMS</div>
                <div class="muted">Text message</div>
              </div>
            </div>
            <div class="toggle">
              <div class="switch" data-ch="push"></div>
              <div>
                <div class="strong"><i class="fa-solid fa-bell"></i> Push</div>
                <div class="muted">App notification</div>
              </div>
            </div>
          </div>

          <input type="hidden" name="channelPortal" id="channelPortal" value="true">
          <input type="hidden" name="channelEmail" id="channelEmail" value="true">
          <input type="hidden" name="channelSms" id="channelSms" value="false">
          <input type="hidden" name="channelPush" id="channelPush" value="false">
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Message Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card"><div class="view-label">Subject</div><div class="view-value" id="vSubject">-</div></div>
          <div class="view-card"><div class="view-label">Type</div><div class="view-value" id="vType">-</div></div>
          <div class="view-card"><div class="view-label">Audience</div><div class="view-value" id="vAudience">-</div></div>
          <div class="view-card"><div class="view-label">Audience Value</div><div class="view-value" id="vAudienceValue">-</div></div>
          <div class="view-card"><div class="view-label">Status</div><div class="view-value" id="vStatus">-</div></div>
          <div class="view-card"><div class="view-label">Priority</div><div class="view-value" id="vPriority">-</div></div>
          <div class="view-card"><div class="view-label">Channels</div><div class="view-value" id="vChannels">-</div></div>
          <div class="view-card"><div class="view-label">Schedule</div><div class="view-value" id="vSchedule">-</div></div>
        </div>

        <div class="view-section-title">Message</div>
        <div class="view-message" id="vBody">-</div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/messaging/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkActionInput">
  </form>

  <textarea id="messagesData" class="json-data" aria-hidden="true"><%- JSON.stringify(messages || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/messaging.js"></script>
</body>
</html>
