<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Staff — <%= (tenant?.name || "Classic Academy") %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar { display:flex; gap:10px; flex-wrap:wrap; justify-content:space-between; align-items:center }
    .toolbar .left, .toolbar .right { display:flex; gap:8px; flex-wrap:wrap; align-items:center }
    .input, .select, .textarea { padding:10px 12px; border-radius:12px; border:1px solid rgba(13,64,96,.16); background:#fff; outline:none }
    .input { min-width:220px }
    .textarea { width:100%; min-height:100px; resize:vertical }
    .input:focus, .select:focus, .textarea:focus { border-color:rgba(10,111,191,.45); box-shadow:0 0 0 3px rgba(10,111,191,.12) }
    .muted { font-size:12px; color:#6b7280 }
    .strong { font-weight:900 }
    .grid-4 { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:12px }
    .grid-2 { display:grid; grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr); gap:12px }
    .pill { display:inline-flex; align-items:center; gap:6px; padding:4px 10px; border-radius:999px; font-size:12px; font-weight:900; white-space:nowrap }
    .ok { background:#ecfdf3; color:#15803d }
    .warn { background:#fef9c3; color:#92400e }
    .bad { background:#fee2e2; color:#b91c1c }
    .info { background:#eef2ff; color:#3730a3 }
    .table-wrap { overflow:auto; border:1px solid rgba(13,64,96,.10); border-radius:12px; max-width:100% }
    table { width:100%; border-collapse:separate; border-spacing:0; min-width:1100px; background:#fff }
    th, td { padding:10px 12px; border-bottom:1px solid rgba(13,64,96,.08); vertical-align:middle }
    th { font-size:12px; color:#6b7280; text-transform:uppercase; letter-spacing:.04em; text-align:left; background:rgba(13,64,96,.03); position:sticky; top:0; z-index:1 }
    tr:hover td { background:rgba(10,111,191,.04) }
    .actions { display:flex; gap:6px; justify-content:flex-end; flex-wrap:wrap }
    .btn-xs { padding:6px 8px; border-radius:10px; border:1px solid rgba(13,64,96,.14); background:#fff; cursor:pointer; font-size:12px }
    .btn-xs:hover { background:rgba(10,111,191,.06) }
    .bulkbar { display:none; margin-top:10px; padding:10px 12px; border-radius:12px; background:rgba(10,111,191,.08); border:1px solid rgba(10,111,191,.18); justify-content:space-between; gap:10px; align-items:center; flex-wrap:wrap }
    .bulkbar.show { display:flex }
    .badge-count { display:inline-flex; align-items:center; justify-content:center; min-width:26px; height:22px; padding:0 8px; border-radius:999px; background:#0a6fbf; color:#fff; font-size:12px; font-weight:900 }
    .mini-list { display:grid; gap:10px; margin-top:10px }
    .mini-item { display:flex; justify-content:space-between; gap:10px; align-items:center; padding:10px 12px; border:1px solid rgba(13,64,96,.10); border-radius:12px; background:#fff }
    .flash-wrap { display:grid; gap:10px; margin-bottom:12px }
    .flash { padding:12px 14px; border-radius:12px; font-weight:700 }
    .flash-success { background:#ecfdf3; color:#166534; border:1px solid #bbf7d0 }
    .flash-error { background:#fef2f2; color:#991b1b; border:1px solid #fecaca }
    .topbar { display:flex; justify-content:space-between; align-items:flex-start; gap:14px; flex-wrap:nowrap }
    .topbar > div:first-child { min-width:0; flex:1 1 auto }
    .top-actions { display:flex; gap:8px; flex-wrap:wrap; justify-content:flex-end; align-items:center; flex:0 0 auto; margin-left:auto }
    .modal-backdrop { position:fixed; inset:0; background:rgba(0,0,0,.45); display:none; align-items:center; justify-content:center; padding:30px 18px; z-index:9999; overflow-y:auto; overflow-x:hidden }
    .modal-backdrop.show { display:flex }
    .modal { width:min(1020px,100%); max-height:calc(100dvh - 60px); background:#fff; border-radius:22px; box-shadow:0 24px 70px rgba(0,0,0,.25); overflow:hidden; display:flex; flex-direction:column }
    .modal.sm { width:min(760px,100%) }
    .modal.lg { width:min(1080px,100%) }
    .modal > form { display:flex; flex-direction:column; flex:1 1 auto; min-height:0; overflow:hidden }
    .modal-header { display:flex; justify-content:space-between; align-items:center; gap:12px; padding:16px 18px; border-bottom:1px solid rgba(13,64,96,.10); background:#fff }
    .modal-title { font-weight:900; font-size:18px }
    .modal-body { padding:16px 18px; flex:1 1 auto; min-height:0; overflow-y:auto; overflow-x:hidden }
    .modal-footer { display:flex; justify-content:flex-end; gap:10px; padding:14px 18px; border-top:1px solid rgba(13,64,96,.10); background:#fff; flex-wrap:wrap }
    .form-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:12px }
    .field label { display:block; font-size:12px; color:#6b7280; margin-bottom:6px }
    .field input, .field select, .field textarea { width:100% }
    .divider { height:1px; background:rgba(13,64,96,.10); margin:12px 0 }
    .view-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:12px; margin-bottom:14px }
    .view-card { padding:14px; border:1px solid rgba(13,64,96,.10); border-radius:16px; background:#fff }
    .view-label { font-size:12px; color:#6b7280; margin-bottom:6px }
    .view-value { font-weight:800; word-break:break-word }
    .json-data { display:none !important }

    @media (max-width:1100px) {
      .grid-2 { grid-template-columns:1fr }
    }
    @media (max-width:900px) {
      .form-grid { grid-template-columns:1fr }
      .topbar { flex-wrap:wrap }
      .top-actions { width:100%; justify-content:flex-start }
    }
    @media (max-width:680px) {
      .grid-4 { grid-template-columns:repeat(2,minmax(0,1fr)) }
      .input { min-width:160px }
      .view-grid { grid-template-columns:1fr }
    }
    @media (max-width:520px) {
      .toolbar .left, .toolbar .right { width:100% }
      .toolbar .left > *, .toolbar .right > * { max-width:100% }
      .actions { justify-content:flex-start }
      table { min-width:980px }
    }
  </style>
</head>

<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Staff</div>
          <div class="subtitle">Manage staff records, employment details, banking details, department assignment, and HR status.</div>
        </div>
        <div class="top-actions">
          <a class="btn light" href="/admin/staff-users"><i class="fa-solid fa-users"></i> Users</a>
          <a class="btn light" href="/admin/staff-roles"><i class="fa-solid fa-user-shield"></i> Roles</a>
          <a class="btn light" href="/admin/staff-leave"><i class="fa-solid fa-calendar-check"></i> Leave</a>
          <a class="btn light" href="/admin/staff-payroll"><i class="fa-solid fa-money-check-dollar"></i> Payroll</a>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Staff</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total Staff</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">All records</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Currently active</div>
        </div>
        <div class="card">
          <div class="section-title">On Leave</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.onLeave || 0 %></div>
          <div class="muted">Approved leave</div>
        </div>
        <div class="card">
          <div class="section-title">Exited</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.exited || 0 %></div>
          <div class="muted">Former staff</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/staff">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search staff name, ID, email, phone..." />

            <select class="select" name="status">
              <option value="all" <%= query?.status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="Active" <%= query?.status === 'Active' ? 'selected' : '' %>>Active</option>
              <option value="On Leave" <%= query?.status === 'On Leave' ? 'selected' : '' %>>On Leave</option>
              <option value="Suspended" <%= query?.status === 'Suspended' ? 'selected' : '' %>>Suspended</option>
              <option value="Exited" <%= query?.status === 'Exited' ? 'selected' : '' %>>Exited</option>
            </select>

            <select class="select" name="departmentId">
              <option value="all">All Departments</option>
              <% (departments || []).forEach(function(dep){ %>
                <option value="<%= dep._id %>" <%= String(query?.departmentId || '') === String(dep._id) ? 'selected' : '' %>><%= dep.name %></option>
              <% }) %>
            </select>

            <select class="select" name="employmentType">
              <option value="all" <%= query?.employmentType === 'all' ? 'selected' : '' %>>All Employment Types</option>
              <option value="Full Time" <%= query?.employmentType === 'Full Time' ? 'selected' : '' %>>Full Time</option>
              <option value="Part Time" <%= query?.employmentType === 'Part Time' ? 'selected' : '' %>>Part Time</option>
              <option value="Contract" <%= query?.employmentType === 'Contract' ? 'selected' : '' %>>Contract</option>
              <option value="Temporary" <%= query?.employmentType === 'Temporary' ? 'selected' : '' %>>Temporary</option>
              <option value="Intern" <%= query?.employmentType === 'Intern' ? 'selected' : '' %>>Intern</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/staff"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong>
            <span class="badge-count" id="selCount">0</span>
            <span class="muted">staff record(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-check"></i> Activate</button>
            <button class="btn-xs" id="bulkLeave" type="button"><i class="fa-solid fa-calendar-check"></i> On Leave</button>
            <button class="btn-xs" id="bulkSuspend" type="button"><i class="fa-solid fa-ban"></i> Suspend</button>
            <button class="btn-xs" id="bulkExit" type="button"><i class="fa-solid fa-door-open"></i> Exit</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Staff Directory</div>
              <div class="section-sub">Employee details, departments, roles, payroll and banking data.</div>
            </div>
            <div class="muted" id="resultMeta">—</div>
          </div>

          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                  <th>Staff</th>
                  <th>Employee ID</th>
                  <th>Department</th>
                  <th>Role / Job Title</th>
                  <th>Employment</th>
                  <th>Salary</th>
                  <th>Status</th>
                  <th style="text-align:right;width:240px;">Actions</th>
                </tr>
              </thead>
              <tbody id="tbody"></tbody>
            </table>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Common HR workflows.</div>
          <div class="mini-list">
            <div class="mini-item">
              <div>
                <div class="strong">Create Staff User</div>
                <div class="muted">Invite staff into portal access</div>
              </div>
              <a class="btn-xs" href="/admin/staff-users"><i class="fa-solid fa-user-plus"></i></a>
            </div>
            <div class="mini-item">
              <div>
                <div class="strong">Manage Roles</div>
                <div class="muted">Department roles and access</div>
              </div>
              <a class="btn-xs" href="/admin/staff-roles"><i class="fa-solid fa-user-shield"></i></a>
            </div>
            <div class="mini-item">
              <div>
                <div class="strong">Leave Requests</div>
                <div class="muted">Approve or reject leave</div>
              </div>
              <a class="btn-xs" href="/admin/staff-leave"><i class="fa-solid fa-calendar-check"></i></a>
            </div>
            <div class="mini-item">
              <div>
                <div class="strong">Payroll Runs</div>
                <div class="muted">Process monthly payroll</div>
              </div>
              <a class="btn-xs" href="/admin/staff-payroll"><i class="fa-solid fa-money-check-dollar"></i></a>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Staff</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="staffForm" method="POST" action="/admin/staff">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Linked User</label>
              <select class="select" name="userId" id="fUserId">
                <option value="">Not Linked</option>
                <% (users || []).forEach(function(u){ %>
                  <option value="<%= u._id %>"><%= [u.firstName, u.lastName].filter(Boolean).join(' ') %> — <%= u.email || 'no-email' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Employee ID</label>
              <input class="input" name="employeeId" id="fEmployeeId">
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" name="status" id="fStatus">
                <option>Active</option>
                <option>On Leave</option>
                <option>Suspended</option>
                <option>Exited</option>
              </select>
            </div>

            <div class="field">
              <label>First Name</label>
              <input class="input" name="firstName" id="fFirstName" required>
            </div>

            <div class="field">
              <label>Middle Name</label>
              <input class="input" name="middleName" id="fMiddleName">
            </div>

            <div class="field">
              <label>Last Name</label>
              <input class="input" name="lastName" id="fLastName" required>
            </div>

            <div class="field">
              <label>Email</label>
              <input class="input" name="email" id="fEmail" type="email">
            </div>

            <div class="field">
              <label>Phone</label>
              <input class="input" name="phone" id="fPhone">
            </div>

            <div class="field">
              <label>Gender</label>
              <select class="select" name="gender" id="fGender">
                <option value="">Select</option>
                <option>Male</option>
                <option>Female</option>
                <option>Other</option>
              </select>
            </div>

            <div class="field">
              <label>Department</label>
              <select class="select" name="departmentId" id="fDepartmentId">
                <option value="">Select Department</option>
                <% (departments || []).forEach(function(dep){ %>
                  <option value="<%= dep._id %>"><%= dep.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Role</label>
              <select class="select" name="roleId" id="fRoleId">
                <option value="">Select Role</option>
                <% (roles || []).forEach(function(role){ %>
                  <option value="<%= role._id %>"><%= role.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Job Title</label>
              <input class="input" name="jobTitle" id="fJobTitle">
            </div>

            <div class="field">
              <label>Employment Type</label>
              <select class="select" name="employmentType" id="fEmploymentType">
                <option>Full Time</option>
                <option>Part Time</option>
                <option>Contract</option>
                <option>Temporary</option>
                <option>Intern</option>
              </select>
            </div>

            <div class="field">
              <label>Join Date</label>
              <input class="input" name="joinDate" id="fJoinDate" type="date">
            </div>

            <div class="field">
              <label>Salary</label>
              <input class="input" name="salary" id="fSalary" type="number" min="0" step="0.01">
            </div>

            <div class="field">
              <label>Payroll No.</label>
              <input class="input" name="payrollNumber" id="fPayrollNumber">
            </div>

            <div class="field">
              <label>Bank Name</label>
              <input class="input" name="bankName" id="fBankName">
            </div>

            <div class="field">
              <label>Account Name</label>
              <input class="input" name="bankAccountName" id="fBankAccountName">
            </div>

            <div class="field">
              <label>Account Number</label>
              <input class="input" name="bankAccountNumber" id="fBankAccountNumber">
            </div>

            <div class="field">
              <label>Emergency Contact</label>
              <input class="input" name="emergencyContactName" id="fEmergencyContactName">
            </div>

            <div class="field">
              <label>Emergency Phone</label>
              <input class="input" name="emergencyContactPhone" id="fEmergencyContactPhone">
            </div>

            <div class="field">
              <label>Address</label>
              <input class="input" name="address" id="fAddress">
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes</label>
            <textarea class="textarea" name="notes" id="fNotes"></textarea>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Staff</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Staff Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card">
            <div class="view-label">Name</div>
            <div class="view-value" id="vName">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Employee ID</div>
            <div class="view-value" id="vEmployeeId">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Email</div>
            <div class="view-value" id="vEmail">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Phone</div>
            <div class="view-value" id="vPhone">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Department</div>
            <div class="view-value" id="vDepartment">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Role</div>
            <div class="view-value" id="vRole">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Employment Type</div>
            <div class="view-value" id="vEmploymentType">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Status</div>
            <div class="view-value" id="vStatus">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Join Date</div>
            <div class="view-value" id="vJoinDate">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Salary</div>
            <div class="view-value" id="vSalary">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Payroll Number</div>
            <div class="view-value" id="vPayrollNumber">—</div>
          </div>
          <div class="view-card">
            <div class="view-label">Emergency Contact</div>
            <div class="view-value" id="vEmergency">—</div>
          </div>
        </div>

        <div class="view-card">
          <div class="view-label">Notes</div>
          <div class="view-value" id="vNotes">—</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/staff/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkActionInput">
  </form>

  <textarea id="staffData" class="json-data" aria-hidden="true"><%- JSON.stringify(staff || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/staff.js"></script>
</body>
</html>