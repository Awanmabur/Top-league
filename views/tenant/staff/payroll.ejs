<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Payroll — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.24fr) minmax(320px,.76fr);gap:12px}
    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .soft{background:rgba(13,64,96,.08);color:#0f172a}
    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1180px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;max-width:100%}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1040px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto}
    .modal.sm{width:min(860px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}
    .view-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-bottom:14px}
    .view-card{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff}
    .view-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .view-value{font-weight:800;word-break:break-word}
    .amount-lg{font-size:24px;font-weight:900}
    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 980px){.form-grid{grid-template-columns:repeat(2,minmax(0,1fr))}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width: 680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}.view-grid{grid-template-columns:1fr}.form-grid{grid-template-columns:1fr}}
    @media (max-width: 520px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
      .actions{justify-content:flex-start}
      table{min-width:1080px}
    }
  </style>
</head>
<body>
  <%
    const q = query || {};
    const formatMoney = (v) => Number(v || 0).toLocaleString(undefined,{minimumFractionDigits:0,maximumFractionDigits:2});
  %>

  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Payroll</div>
          <div class="subtitle">Manage payroll runs, process salaries, approve payroll, and review staff pay summaries.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/staff"><i class="fa-solid fa-users"></i> Staff</a>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Create Payroll Run</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Runs</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Payroll runs</div>
        </div>
        <div class="card">
          <div class="section-title">Processed</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= kpis?.processed || 0 %></div>
          <div class="muted">Ready payrolls</div>
        </div>
        <div class="card">
          <div class="section-title">Approved</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.approved || 0 %></div>
          <div class="muted">Approved payrolls</div>
        </div>
        <div class="card">
          <div class="section-title">Net Total</div>
          <div class="kpi-value" style="color:#92400e"><%= formatMoney(kpis?.netTotal || 0) %></div>
          <div class="muted">All run net pay</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/payroll">
          <div class="left">
            <input class="input" name="q" value="<%= q.q || '' %>" placeholder="Search title, month, year, department..." />

            <select class="select" name="status">
              <option value="all" <%= q.status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="Draft" <%= q.status === 'Draft' ? 'selected' : '' %>>Draft</option>
              <option value="Processed" <%= q.status === 'Processed' ? 'selected' : '' %>>Processed</option>
              <option value="Approved" <%= q.status === 'Approved' ? 'selected' : '' %>>Approved</option>
              <option value="Closed" <%= q.status === 'Closed' ? 'selected' : '' %>>Closed</option>
            </select>

            <select class="select" name="department">
              <option value="all" <%= q.department === 'all' ? 'selected' : '' %>>All Departments</option>
              <% (departments || []).forEach(function(d){ %>
                <option value="<%= d.id %>" <%= q.department === d.id ? 'selected' : '' %>><%= d.name %></option>
              <% }) %>
            </select>

            <select class="select" name="year">
              <option value="all" <%= q.year === 'all' ? 'selected' : '' %>>All Years</option>
              <% (years || []).forEach(function(y){ %>
                <option value="<%= y %>" <%= q.year === y ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip active" data-view="list" type="button"><i class="fa-solid fa-list"></i> Runs</button>
              <button class="chip" data-view="items" type="button"><i class="fa-solid fa-money-check-dollar"></i> Payroll Items</button>
              <button class="chip" data-view="summary" type="button"><i class="fa-solid fa-chart-pie"></i> Summary</button>
            </div>
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/payroll"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">run(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkProcess" type="button"><i class="fa-solid fa-gears"></i> Process</button>
            <button class="btn-xs" id="bulkApprove" type="button"><i class="fa-solid fa-circle-check"></i> Approve</button>
            <button class="btn-xs" id="bulkClose" type="button"><i class="fa-solid fa-lock"></i> Close</button>
            <button class="btn-xs" id="bulkDraft" type="button"><i class="fa-solid fa-file"></i> Draft</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title" id="panelTitle">Payroll Runs</div>
              <div class="section-sub" id="panelSub">Manage payroll periods and their status.</div>
            </div>
            <div class="muted" id="resultMeta">—</div>
          </div>

          <div id="view-list" style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                    <th>Run</th>
                    <th>Department</th>
                    <th>Period</th>
                    <th>Pay Date</th>
                    <th>Staff</th>
                    <th>Gross</th>
                    <th>Deductions</th>
                    <th>Net</th>
                    <th>Status</th>
                    <th style="text-align:right;width:280px;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbody"></tbody>
              </table>
            </div>
          </div>

          <div id="view-items" style="display:none;margin-top:10px;">
            <div class="note">Payroll items show staff pay rows generated from the selected or available payroll runs.</div>
            <div class="table-wrap" style="margin-top:10px;">
              <table>
                <thead>
                  <tr>
                    <th>Staff</th>
                    <th>Department</th>
                    <th>Basic</th>
                    <th>Allowances</th>
                    <th>Bonuses</th>
                    <th>Deductions</th>
                    <th>Net Pay</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody id="tbodyItems"></tbody>
              </table>
            </div>
          </div>

          <div id="view-summary" style="display:none;margin-top:10px;">
            <div class="grid-4">
              <div class="view-card">
                <div class="view-label">Draft</div>
                <div class="amount-lg"><%= kpis?.draft || 0 %></div>
              </div>
              <div class="view-card">
                <div class="view-label">Processed</div>
                <div class="amount-lg" style="color:#0a6fbf"><%= kpis?.processed || 0 %></div>
              </div>
              <div class="view-card">
                <div class="view-label">Approved</div>
                <div class="amount-lg" style="color:#15803d"><%= kpis?.approved || 0 %></div>
              </div>
              <div class="view-card">
                <div class="view-label">Closed</div>
                <div class="amount-lg" style="color:#92400e"><%= kpis?.closed || 0 %></div>
              </div>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Common payroll workflows.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">New Payroll Run</div>
                <div class="muted">Create a new payroll period</div>
              </div>
              <button class="btn-xs" id="quickNewPayroll" type="button"><i class="fa-solid fa-plus"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Processed Runs</div>
                <div class="muted">Review ready payrolls</div>
              </div>
              <a class="btn-xs" href="/admin/payroll?status=Processed"><i class="fa-solid fa-filter"></i></a>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Approved Runs</div>
                <div class="muted">Review approved payrolls</div>
              </div>
              <a class="btn-xs" href="/admin/payroll?status=Approved"><i class="fa-solid fa-circle-check"></i></a>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Create Payroll Run</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="payrollForm" method="POST" action="/admin/payroll">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Title</label>
              <input class="input" id="pTitle" name="title" placeholder="e.g. March Payroll" required>
            </div>

            <div class="field">
              <label>Month</label>
              <select class="select" id="pMonth" name="month">
                <option>January</option><option>February</option><option>March</option><option>April</option>
                <option>May</option><option>June</option><option>July</option><option>August</option>
                <option>September</option><option>October</option><option>November</option><option>December</option>
              </select>
            </div>

            <div class="field">
              <label>Year</label>
              <input class="input" id="pYear" name="year" type="number" min="2000" step="1" value="<%= new Date().getFullYear() %>">
            </div>

            <div class="field">
              <label>Period Label</label>
              <input class="input" id="pPeriodLabel" name="periodLabel" placeholder="e.g. March 2026">
            </div>

            <div class="field">
              <label>Department</label>
              <select class="select" id="pDepartment" name="departmentId">
                <option value="">All Departments</option>
                <% (departments || []).forEach(function(d){ %>
                  <option value="<%= d.id %>"><%= d.name %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Pay Date</label>
              <input class="input" id="pPayDate" name="payDate" type="date">
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Notes</label>
            <textarea class="textarea" id="pNotes" name="notes" placeholder="Optional payroll notes..."></textarea>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Payroll Run</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Payroll Run Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card"><div class="view-label">Title</div><div class="view-value" id="vTitle">—</div></div>
          <div class="view-card"><div class="view-label">Department</div><div class="view-value" id="vDepartment">—</div></div>
          <div class="view-card"><div class="view-label">Period</div><div class="view-value" id="vPeriod">—</div></div>
          <div class="view-card"><div class="view-label">Pay Date</div><div class="view-value" id="vPayDate">—</div></div>
          <div class="view-card"><div class="view-label">Staff Count</div><div class="view-value" id="vStaffCount">—</div></div>
          <div class="view-card"><div class="view-label">Status</div><div class="view-value" id="vStatus">—</div></div>
          <div class="view-card"><div class="view-label">Gross</div><div class="view-value" id="vGross">—</div></div>
          <div class="view-card"><div class="view-label">Deductions</div><div class="view-value" id="vDeductions">—</div></div>
          <div class="view-card" style="grid-column:1 / -1;"><div class="view-label">Net</div><div class="view-value" id="vNet">—</div></div>
        </div>

        <div class="section-title">Notes</div>
        <div class="view-card"><div class="view-value" id="vNotes">—</div></div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/payroll/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkActionInput">
  </form>

  <textarea id="payrollRunsData" class="json-data" aria-hidden="true"><%- JSON.stringify(payrollRuns || []) %></textarea>
  <textarea id="payrollItemsData" class="json-data" aria-hidden="true"><%- JSON.stringify(payrollItems || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/payroll.js"></script>
</body>
</html>