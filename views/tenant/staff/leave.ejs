<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Staff Leave — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1120px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;max-width:100%}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1020px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto}
    .modal.sm{width:min(760px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap;position:relative;z-index:2;box-shadow:0 -8px 18px rgba(0,0,0,.04)}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .view-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-bottom:14px}
    .view-card{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;min-width:0}
    .view-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .view-value{font-weight:800;word-break:break-word}
    .json-data{display:none!important}
    .hint{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}

    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}.view-grid{grid-template-columns:1fr}}
    @media (max-width:520px){
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left>*, .toolbar .right>*{max-width:100%}
      .actions{justify-content:flex-start}
      table{min-width:980px}
      .modal-backdrop{padding:30px 12px}
      .modal{max-height:calc(100dvh - 60px);border-radius:20px}
      .modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}
    }
  </style>
</head>
<body data-portal="tenant">
<div class="app">
  <%- include("../partials/navbar") %>

  <main class="main">
    <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
      <div class="flash-wrap">
        <% (messages.success || []).forEach(function(msg){ %>
          <div class="flash flash-success"><%= msg %></div>
        <% }) %>
        <% (messages.error || []).forEach(function(msg){ %>
          <div class="flash flash-error"><%= msg %></div>
        <% }) %>
      </div>
    <% } %>

    <div class="topbar">
      <div>
        <div class="title">Leave</div>
        <div class="subtitle">Manage staff leave requests, approvals, rejections, cancellations and leave periods.</div>
      </div>
      <div class="top-actions">
        <a class="btn light" href="/admin/staff"><i class="fa-solid fa-id-badge"></i> Staff</a>
        <a class="btn light" href="/admin/staff-users"><i class="fa-solid fa-users"></i> Users</a>
        <a class="btn light" href="/admin/staff-roles"><i class="fa-solid fa-user-shield"></i> Roles</a>
        <a class="btn light" href="/admin/staff-payroll"><i class="fa-solid fa-money-check-dollar"></i> Payroll</a>
        <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> New Leave</button>
      </div>
    </div>

    <div class="grid-4">
      <div class="card">
        <div class="section-title">Total Requests</div>
        <div class="kpi-value"><%= kpis?.total || 0 %></div>
        <div class="muted">All leave requests</div>
      </div>
      <div class="card">
        <div class="section-title">Pending</div>
        <div class="kpi-value" style="color:#92400e"><%= kpis?.pending || 0 %></div>
        <div class="muted">Awaiting decision</div>
      </div>
      <div class="card">
        <div class="section-title">Approved</div>
        <div class="kpi-value" style="color:#15803d"><%= kpis?.approved || 0 %></div>
        <div class="muted">Approved requests</div>
      </div>
      <div class="card">
        <div class="section-title">Rejected</div>
        <div class="kpi-value" style="color:#b91c1c"><%= kpis?.rejected || 0 %></div>
        <div class="muted">Rejected requests</div>
      </div>
    </div>

    <section class="card" style="margin-top:12px;">
      <form class="toolbar" method="GET" action="/admin/staff-leave">
        <div class="left">
          <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search staff, department, leave type..." />
          <select class="select" name="status">
            <option value="all" <%= query?.status === 'all' ? 'selected' : '' %>>All Status</option>
            <option value="Pending" <%= query?.status === 'Pending' ? 'selected' : '' %>>Pending</option>
            <option value="Approved" <%= query?.status === 'Approved' ? 'selected' : '' %>>Approved</option>
            <option value="Rejected" <%= query?.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
            <option value="Cancelled" <%= query?.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
          <select class="select" name="leaveType">
            <option value="all" <%= query?.leaveType === 'all' ? 'selected' : '' %>>All Types</option>
            <option value="Annual" <%= query?.leaveType === 'Annual' ? 'selected' : '' %>>Annual</option>
            <option value="Sick" <%= query?.leaveType === 'Sick' ? 'selected' : '' %>>Sick</option>
            <option value="Maternity" <%= query?.leaveType === 'Maternity' ? 'selected' : '' %>>Maternity</option>
            <option value="Paternity" <%= query?.leaveType === 'Paternity' ? 'selected' : '' %>>Paternity</option>
            <option value="Study" <%= query?.leaveType === 'Study' ? 'selected' : '' %>>Study</option>
            <option value="Compassionate" <%= query?.leaveType === 'Compassionate' ? 'selected' : '' %>>Compassionate</option>
            <option value="Unpaid" <%= query?.leaveType === 'Unpaid' ? 'selected' : '' %>>Unpaid</option>
            <option value="Other" <%= query?.leaveType === 'Other' ? 'selected' : '' %>>Other</option>
          </select>
          <select class="select" name="staffId">
            <option value="all">All Staff</option>
            <% (staff || []).forEach(function(s){ %>
              <option value="<%= s._id %>" <%= String(query?.staffId || '') === String(s._id) ? 'selected' : '' %>>
                <%= [s.firstName, s.middleName, s.lastName].filter(Boolean).join(' ') %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="right">
          <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
          <a class="btn light" href="/admin/staff-leave"><i class="fa-solid fa-rotate-left"></i> Reset</a>
          <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
        </div>
      </form>

      <div class="bulkbar" id="bulkbar">
        <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
          <strong>Selected</strong>
          <span class="badge-count" id="selCount">0</span>
          <span class="muted">leave request(s)</span>
        </div>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
          <button class="btn-xs" id="bulkApprove" type="button"><i class="fa-solid fa-check"></i> Approve</button>
          <button class="btn-xs" id="bulkReject" type="button"><i class="fa-solid fa-ban"></i> Reject</button>
          <button class="btn-xs" id="bulkCancel" type="button"><i class="fa-solid fa-xmark"></i> Cancel</button>
          <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
          <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
        </div>
      </div>
    </section>

    <div class="grid-2" style="margin-top:12px;">
      <section class="card" style="min-width:0;">
        <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
          <div>
            <div class="section-title">Leave Requests</div>
            <div class="section-sub">Staff leave applications, dates, decisions and reasons.</div>
          </div>
          <div class="muted" id="resultMeta">—</div>
        </div>

        <div class="table-wrap" style="margin-top:10px;">
          <table>
            <thead>
              <tr>
                <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                <th>Staff</th>
                <th>Type</th>
                <th>Dates</th>
                <th>Days</th>
                <th>Status</th>
                <th>Reason</th>
                <th>Updated</th>
                <th style="text-align:right;width:270px;">Actions</th>
              </tr>
            </thead>
            <tbody id="tbody"></tbody>
          </table>
        </div>
      </section>

      <aside class="card" style="min-width:0;">
        <div class="section-title">Quick Actions</div>
        <div class="section-sub">Common leave workflows.</div>

        <div class="mini-list">
          <div class="mini-item">
            <div>
              <div class="strong">Annual Leave</div>
              <div class="muted">Standard annual leave request</div>
            </div>
            <button class="btn-xs" type="button" id="quickAnnual"><i class="fa-solid fa-sun"></i></button>
          </div>

          <div class="mini-item">
            <div>
              <div class="strong">Sick Leave</div>
              <div class="muted">Medical or sick leave request</div>
            </div>
            <button class="btn-xs" type="button" id="quickSick"><i class="fa-solid fa-notes-medical"></i></button>
          </div>

          <div class="mini-item">
            <div>
              <div class="strong">HR Roles</div>
              <div class="muted">Manage role permissions</div>
            </div>
            <a class="btn-xs" href="/admin/staff-roles"><i class="fa-solid fa-user-shield"></i></a>
          </div>

          <div class="mini-item">
            <div>
              <div class="strong">Staff Directory</div>
              <div class="muted">Open staff records</div>
            </div>
            <a class="btn-xs" href="/admin/staff"><i class="fa-solid fa-id-badge"></i></a>
          </div>
        </div>

        <div class="hint" style="margin-top:12px;">
          <strong>Tip:</strong> approving a leave request can also set the linked staff record to
          <strong>On Leave</strong>. Cancelling can move staff back to <strong>Active</strong>.
        </div>
      </aside>
    </div>
  </main>
</div>

<div class="modal-backdrop" id="mEdit">
  <div class="modal lg">
    <div class="modal-header">
      <div class="modal-title" id="mTitle">New Leave Request</div>
      <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="leaveForm" method="POST" action="/admin/staff-leave">
      <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Staff</label>
            <select class="select" id="lStaffId" name="staffId" required>
              <option value="">Select Staff</option>
              <% (staff || []).forEach(function(s){ %>
                <option value="<%= s._id %>">
                  <%= [s.firstName, s.middleName, s.lastName].filter(Boolean).join(' ') %>
                  <% if (s.employeeId) { %> — <%= s.employeeId %><% } %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="field">
            <label>Leave Type</label>
            <select class="select" id="lLeaveType" name="leaveType">
              <option>Annual</option>
              <option>Sick</option>
              <option>Maternity</option>
              <option>Paternity</option>
              <option>Study</option>
              <option>Compassionate</option>
              <option>Unpaid</option>
              <option>Other</option>
            </select>
          </div>

          <div class="field">
            <label>Status</label>
            <input class="input" value="Pending" disabled />
          </div>

          <div class="field">
            <label>Start Date</label>
            <input class="input" id="lStartDate" name="startDate" type="date" required />
          </div>

          <div class="field">
            <label>End Date</label>
            <input class="input" id="lEndDate" name="endDate" type="date" required />
          </div>

          <div class="field">
            <label>Days</label>
            <input class="input" id="lDays" type="number" value="0" disabled />
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Reason</label>
          <textarea class="textarea" id="lReason" name="reason" placeholder="State the reason for this leave request..."></textarea>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
        <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Leave</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-backdrop" id="mView">
  <div class="modal sm">
    <div class="modal-header">
      <div class="modal-title">Leave Request Details</div>
      <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <div class="modal-body">
      <div class="view-grid">
        <div class="view-card">
          <div class="view-label">Staff</div>
          <div class="view-value" id="vStaff">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">Employee ID</div>
          <div class="view-value" id="vEmployeeId">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">Department</div>
          <div class="view-value" id="vDepartment">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">Leave Type</div>
          <div class="view-value" id="vLeaveType">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">Start Date</div>
          <div class="view-value" id="vStartDate">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">End Date</div>
          <div class="view-value" id="vEndDate">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">Days</div>
          <div class="view-value" id="vDays">—</div>
        </div>
        <div class="view-card">
          <div class="view-label">Status</div>
          <div class="view-value" id="vStatus">—</div>
        </div>
        <div class="view-card" style="grid-column:1 / -1;">
          <div class="view-label">Reason</div>
          <div class="view-value" id="vReason">—</div>
        </div>
        <div class="view-card" style="grid-column:1 / -1;">
          <div class="view-label">Rejection Reason</div>
          <div class="view-value" id="vRejectionReason">—</div>
        </div>
      </div>
    </div>

    <div class="modal-footer">
      <button class="btn light" type="button" data-close-modal="mView">Close</button>
    </div>
  </div>
</div>

<form id="rowActionForm" method="POST" style="display:none;">
  <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
</form>

<form id="bulkForm" method="POST" action="/admin/staff-leave/bulk" style="display:none;">
  <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  <input type="hidden" name="ids" id="bulkIds" />
  <input type="hidden" name="action" id="bulkActionInput" />
</form>

<textarea id="leaveData" class="json-data" aria-hidden="true"><%- JSON.stringify(leave || []) %></textarea>

<script src="/js/navbar.js"></script>
<script src="/js/staff-leave.js"></script>
</body>
</html>
