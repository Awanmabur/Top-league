<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Admissions Requirements</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <% if (csrfToken) { %>
    <meta name="csrf-token" content="<%= csrfToken %>">
  <% } %>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1380px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-check{width:48px}
    .col-title{width:280px}
    .col-category{width:150px}
    .col-programs{width:180px}
    .col-intakes{width:180px}
    .col-mandatory{width:120px}
    .col-active{width:120px}
    .col-sort{width:100px}
    .col-actions{width:220px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .req-main{min-width:0}
    .req-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .req-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{
      display:none;
      margin-top:10px;
      padding:10px 12px;
      border-radius:12px;
      background:rgba(10,111,191,.08);
      border:1px solid rgba(10,111,191,.18);
      justify-content:space-between;
      gap:10px;
      align-items:center;
      flex-wrap:wrap;
    }

    .bulkbar.show{display:flex}

    .badge-count{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:26px;
      height:22px;
      padding:0 8px;
      border-radius:999px;
      background:#0a6fbf;
      color:#fff;
      font-size:12px;
      font-weight:900;
    }

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{min-width:0;flex:1 1 auto}

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(1040px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(680px,100%)}
    .modal.lg{width:min(1040px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .tag-list{display:flex;flex-wrap:wrap;gap:8px}
    .tag{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:999px;background:#eef2ff;color:#3730a3;font-size:12px;font-weight:800}

    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}

    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width: 680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width: 520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left > *,.toolbar .right > *{max-width:100%}table{min-width:1380px}}

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{position:absolute;inset:0;background:#fff;padding:20px}
    }
  </style>
</head>
<body data-portal="tenant">
  <%
    const safe = (v, d = "") => (v === null || v === undefined ? d : String(v));
    const itemsArr = Array.isArray(items) ? items : [];
    const programsArr = Array.isArray(programs) ? programs : [];
    const intakesArr = Array.isArray(intakes) ? intakes : [];
    const qObj = query || {};
    const currentPage = Number(qObj.page || 1);
    const totalPages = Number(qObj.totalPages || 1);

    const kpis = {
      total: Number(counts?.total || 0),
      active: Number(counts?.active || 0),
      mandatory: Number(counts?.mandatory || 0),
      document: Number(counts?.document || 0),
      fee: Number(counts?.fee || 0),
      exam: Number(counts?.exam || 0),
      medical: Number(counts?.medical || 0),
      other: Number(counts?.other || 0)
    };

    function buildPageUrl(targetPage) {
      const params = new URLSearchParams();
      if (qObj?.q) params.set("q", qObj.q);
      if (qObj?.category) params.set("category", qObj.category);
      if (qObj?.isActive) params.set("isActive", qObj.isActive);
      if (qObj?.section || qObj?.program) params.set("section", qObj.section || qObj.program);
      if (qObj?.intake) params.set("intake", qObj.intake);
      params.set("page", String(targetPage));
      return "/admin/admissions/requirements?" + params.toString();
    }

    const startPage = Math.max(1, currentPage - 2);
    const endPage = Math.min(totalPages, currentPage + 2);
  %>

  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Admissions Requirements</div>
          <div class="subtitle">Create, edit, export, print and manage admission requirements by category, section and term.</div>
        </div>

        <div class="top-actions">
          <a class="btn light" href="/admin/admissions"><i class="fa-solid fa-arrow-left"></i> Admissions</a>
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Requirement</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis.total %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis.active %></div>
          <div class="muted">Currently enabled</div>
        </div>
        <div class="card">
          <div class="section-title">Mandatory</div>
          <div class="kpi-value" style="color:#3730a3"><%= kpis.mandatory %></div>
          <div class="muted">Must be submitted</div>
        </div>
        <div class="card">
          <div class="section-title">Non-Document</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis.fee + kpis.exam + kpis.medical + kpis.other %></div>
          <div class="muted">Fee / exam / medical / other</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/admissions/requirements">
          <div class="left">
            <input class="input" name="q" value="<%= qObj?.q || '' %>" placeholder="Search title, code, category..." />

            <select class="select" name="category">
              <option value="">All Categories</option>
              <option value="document" <%= qObj?.category === 'document' ? 'selected' : '' %>>Document</option>
              <option value="fee" <%= qObj?.category === 'fee' ? 'selected' : '' %>>Fee</option>
              <option value="exam" <%= qObj?.category === 'exam' ? 'selected' : '' %>>Exam</option>
              <option value="medical" <%= qObj?.category === 'medical' ? 'selected' : '' %>>Medical</option>
              <option value="other" <%= qObj?.category === 'other' ? 'selected' : '' %>>Other</option>
            </select>

            <select class="select" name="isActive">
              <option value="">All Status</option>
              <option value="true" <%= qObj?.isActive === 'true' ? 'selected' : '' %>>Active</option>
              <option value="false" <%= qObj?.isActive === 'false' ? 'selected' : '' %>>Inactive</option>
            </select>

            <select class="select" name="section">
              <option value="">All Sections</option>
              <% (programsArr || []).forEach(function(p){ %>
                <option value="<%= p._id %>" <%= String(qObj?.section || qObj?.program || '') === String(p._id) ? 'selected' : '' %>><%= p.name || p.className || 'Section' %></option>
              <% }) %>
            </select>

            <select class="select" name="intake">
              <option value="">All Intakes</option>
              <% (intakesArr || []).forEach(function(i){ %>
                <option value="<%= i._id %>" <%= String(qObj?.intake || '') === String(i._id) ? 'selected' : '' %>><%= i.name || i.title || 'Intake' %></option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/admissions/requirements"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">requirement(s)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <button class="btn-xs" id="bulkDeactivate" type="button"><i class="fa-solid fa-circle-xmark"></i> Deactivate</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Requirements Table</div>
              <div class="section-sub">Showing <%= itemsArr.length %> of <%= qObj?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">Page <%= currentPage %> of <%= totalPages %></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-title">Requirement</th>
                    <th class="col-category">Category</th>
                    <th class="col-programs">Sections</th>
                    <th class="col-intakes">Intakes</th>
                    <th class="col-mandatory">Mandatory</th>
                    <th class="col-active">Status</th>
                    <th class="col-sort">Sort</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyRequirements"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= qObj?.perPage || 10 %></strong></div>

            <div class="pagination-links">
              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                <i class="fa-solid fa-angle-left"></i>
              </a>

              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>

              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                <i class="fa-solid fa-angle-right"></i>
              </a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Document Requirement</div>
                <div class="muted">Pre-fill category as document</div>
              </div>
              <button class="btn-xs" id="quickDocument" type="button"><i class="fa-solid fa-file-lines"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Fee Requirement</div>
                <div class="muted">Pre-fill category as fee</div>
              </div>
              <button class="btn-xs" id="quickFee" type="button"><i class="fa-solid fa-money-bill-wave"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Exam Requirement</div>
                <div class="muted">Pre-fill category as exam</div>
              </div>
              <button class="btn-xs" id="quickExam" type="button"><i class="fa-solid fa-pen-ruler"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Requirement</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="requirementForm" method="POST" action="/admin/admissions/requirements">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Title</label>
              <input class="input" id="mReqTitleInput" name="title" required maxlength="160" />
            </div>

            <div class="field">
              <label>Code</label>
              <input class="input" id="mCode" name="code" readonly maxlength="80" placeholder="Auto-normalized" />
            </div>

            <div class="field">
              <label>Category</label>
              <select class="select" id="mCategory" name="category">
                <option value="document">Document</option>
                <option value="fee">Fee</option>
                <option value="exam">Exam</option>
                <option value="medical">Medical</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="field" id="mFeeWrap" style="display:none;">
              <label>Fee Amount</label>
              <input class="input" id="mFeeAmount" name="feeAmount" type="number" min="0" step="0.01" placeholder="0.00" />
            </div>

            <div class="field" id="mCurrencyWrap" style="display:none;">
              <label>Currency</label>
              <input class="input" id="mCurrency" name="currency" type="text" maxlength="10" placeholder="UGX" value="UGX" />
            </div>

            <div class="field">
              <label>Sort Order</label>
              <input class="input" id="mSortOrder" name="sortOrder" type="number" min="0" max="99999" value="0" />
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="isActive">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
              </select>
            </div>

            <div class="field">
              <label>Mandatory</label>
              <select class="select" id="mMandatory" name="isMandatory">
                <option value="true">Yes</option>
                <option value="false">No</option>
              </select>
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Description</label>
            <textarea class="textarea" id="mDescription" name="description" maxlength="1200"></textarea>
            <div class="muted" id="descCount">0 / 1200</div>
          </div>

          <div class="divider"></div>

          <div class="form-grid">
            <div class="field">
              <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" id="mAllPrograms" name="appliesToAllPrograms" value="true" checked />
                Applies to all sections
              </label>
              <select class="select" id="mPrograms" multiple size="8"></select>
              <div id="mProgramsWrap"></div>
            </div>

            <div class="field">
              <label style="display:flex;align-items:center;gap:8px;">
                <input type="checkbox" id="mAllIntakes" name="appliesToAllIntakes" value="true" checked />
                Applies to all intakes
              </label>
              <select class="select" id="mIntakes" multiple size="8"></select>
              <div id="mIntakesWrap"></div>
            </div>

            <div class="field">
              <label>Scope Preview</label>
              <div class="note">
                <div class="muted">Use “all” toggles for global rules, or pick specific sections and intakes for targeted rules.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Requirement</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Requirement Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Title</label><div class="view-input" id="vTitle">—</div></div>
          <div class="field"><label>Code</label><div class="view-input" id="vCode">—</div></div>
          <div class="field"><label>Category</label><div class="view-input" id="vCategory">—</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div>
          <div class="field"><label>Mandatory</label><div class="view-input" id="vMandatory">—</div></div>
          <div class="field"><label>Sort Order</label><div class="view-input" id="vSort">—</div></div>
          <div class="field" id="vFeeWrap" style="display:none;"><label>Fee Amount</label><div class="view-input" id="vFeeAmount">—</div></div>
          <div class="field" id="vCurrencyWrap" style="display:none;"><label>Currency</label><div class="view-input" id="vCurrency">—</div></div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Description</label>
          <div class="view-input multiline" id="vDescription">—</div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Sections</label>
          <div class="view-input multiline"><div class="tag-list" id="vPrograms"></div></div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Intakes</label>
          <div class="view-input multiline"><div class="tag-list" id="vIntakes"></div></div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Requirements CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="importForm" method="POST" action="/admin/admissions/requirements/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="field">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>
          <div class="note" style="margin-top:12px;">
            Expected columns: title, code, category, description, sortOrder, isMandatory, isActive, appliesToAllSections, appliesToAllIntakes, sections, intakes
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-file-import"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/admissions/requirements/bulk-action" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkAction">
  </form>

  <textarea id="requirementsData" class="json-data" aria-hidden="true"><%- JSON.stringify((itemsArr || []).map(function(r){
    return {
      id: String(r._id || ''),
      title: r.title || '',
      code: r.code || '',
      category: r.category || 'document',
      description: r.description || '',
      feeAmount: Number(r.feeAmount || 0),
      currency: r.currency || 'UGX',
      sortOrder: Number(r.sortOrder || 0),
      isMandatory: !!r.isMandatory,
      isActive: !!r.isActive,
      appliesToAllPrograms: !!r.appliesToAllPrograms,
      appliesToAllIntakes: !!r.appliesToAllIntakes,
      programs: Array.isArray(r.programs) ? r.programs.map(function(x){ return String(x._id || x); }) : [],
      intakes: Array.isArray(r.intakes) ? r.intakes.map(function(x){ return String(x._id || x); }) : []
    };
  })) %></textarea>

  <textarea id="lookupData" class="json-data" aria-hidden="true"><%- JSON.stringify({
    programs: (programsArr || []).map(function(p){ return { id: String(p._id || ''), name: p.name || p.className || 'Section' }; }),
    intakes: (intakesArr || []).map(function(i){ return { id: String(i._id || ''), name: i.name || i.term || i.title || 'Term' }; })
  }) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/requirements-index.js"></script>
</body>
</html>

