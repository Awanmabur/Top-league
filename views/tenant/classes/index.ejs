<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %>  -  Classes</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}.textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}.strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}.warn{background:#fef9c3;color:#92400e}.bad{background:#fee2e2;color:#b91c1c}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1680px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)} tr.row-clickable{cursor:pointer}
    .col-check{width:48px}.col-class{width:220px}.col-level{width:140px}.col-classlevel{width:140px}.col-section{width:170px}.col-stream{width:170px}.col-term{width:90px}.col-year{width:130px}.col-shift{width:120px}.col-capacity{width:130px}.col-teacher{width:180px}.col-status{width:140px}.col-actions{width:230px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .class-main{min-width:0}.class-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.class-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}.badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}.flash{padding:12px 14px;border-radius:12px;font-weight:700}.flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}.flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}.topbar>div:first-child{min-width:0;flex:1 1 auto}.top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1120px,100%);max-height:calc(100dvh - 40px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(980px,100%)}.modal.lg{width:min(1120px,100%)}.modal>form{display:flex;flex-direction:column;min-height:0;flex:1 1 auto}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px;color:#0f172a}.modal-body{padding:18px 20px;overflow-y:auto;flex:1 1 auto}.modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.field{display:flex;flex-direction:column;gap:6px}.field.full{grid-column:1 / -1}.field label{font-size:12px;font-weight:800;color:#475569}
    .char-count{font-size:12px;color:#6b7280;text-align:right}.json-data{display:none!important}
    .mini-list{display:grid;gap:10px;margin-top:10px}.mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}.mini-item .left{display:grid;gap:2px}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}.pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}.page-link.disabled{pointer-events:none;opacity:.45}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width:520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left>*,.toolbar .right>*{max-width:100%}table{min-width:1680px}}
    @media print{body *{visibility:hidden !important}#printArea, #printArea *{visibility:visible !important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
       
      <div class="topbar">
        <div>
          <div class="title">Classes</div>
          <div class="subtitle">Classes connect to Sections and Streams as separate fields.</div>
        </div>
        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Class</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div><div class="muted">Matching filter</div></div>
        <div class="card"><div class="section-title">Active</div><div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div><div class="muted">Running classes</div></div>
        <div class="card"><div class="section-title">Inactive</div><div class="kpi-value" style="color:#92400e"><%= kpis?.inactive || 0 %></div><div class="muted">Temporarily paused</div></div>
        <div class="card"><div class="section-title">Archived</div><div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div><div class="muted">Hidden / inactive</div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/classes">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search name, code, section, stream, location." />

            <select class="select" name="schoolUnitId">
              <option value="">All School Units</option>
              <% (structure || []).forEach(function(su){ %>
                <option value="<%= su.id %>" <%= query?.schoolUnitId === su.id ? 'selected' : '' %>><%= su.name %></option>
              <% }) %>
            </select>

            <select class="select" name="campusId">
              <option value="">All Locations</option>
              <% (structure || []).forEach(function(su){ (su.campuses || []).forEach(function(c){ %>
                <option value="<%= c.id %>" <%= query?.campusId === c.id ? 'selected' : '' %>><%= su.name %>  -  <%= c.name %></option>
              <% }) }) %>
            </select>

            <select class="select" name="levelType">
              <option value="">All Levels</option>
              <option value="nursery" <%= query?.levelType === 'nursery' ? 'selected' : '' %>>Nursery</option>
              <option value="primary" <%= query?.levelType === 'primary' ? 'selected' : '' %>>Primary</option>
              <option value="secondary" <%= query?.levelType === 'secondary' ? 'selected' : '' %>>Secondary</option>
            </select>

            <select class="select" name="classLevel">
              <option value="">All Classes</option>
              <% (classLevels || []).forEach(function(level){ %>
                <option value="<%= level %>" <%= query?.classLevel === level ? 'selected' : '' %>><%= level %></option>
              <% }) %>
            </select>

            <select class="select" name="sectionId">
              <option value="">All Sections</option>
              <% (sections || []).forEach(function(section){ const sid = String(section._id || ''); %>
                <option value="<%= sid %>" <%= query?.sectionId === sid ? 'selected' : '' %>><%= section.name %><%= section.className ? ('  -  ' + section.className) : '' %></option>
              <% }) %>
            </select>

            <select class="select" name="streamId">
              <option value="">All Streams</option>
              <% (streams || []).forEach(function(stream){ const sid = String(stream._id || ''); %>
                <option value="<%= sid %>" <%= query?.streamId === sid ? 'selected' : '' %>><%= stream.name %><%= stream.sectionName ? (' Ã¢â‚¬Â¢ ' + stream.sectionName) : '' %><%= stream.className ? (' Ã¢â‚¬Â¢ ' + stream.className) : '' %></option>
              <% }) %>
            </select>

            <select class="select" name="academicYear">
              <option value="">All Academic Years</option>
              <% (academicYears || []).forEach(function(y){ %>
                <option value="<%= y %>" <%= query?.academicYear === y ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>

            <select class="select" name="term">
              <option value="">All Terms</option>
              <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
              <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
              <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= query?.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/classes"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">class(es)</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <button class="btn-xs" id="bulkDeactivate" type="button"><i class="fa-solid fa-circle-pause"></i> Inactivate</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Classes Table</div>
              <div class="section-sub">Showing <%= classes.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted" id="resultMeta">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-class">Class</th>
                    <th class="col-level">School Level</th>
                    <th class="col-classlevel">Class Level</th>
                    <th class="col-section">Section</th>
                    <th class="col-stream">Stream</th>
                    <th class="col-term">Term</th>
                    <th class="col-year">Academic Year</th>
                    <th class="col-shift">Shift</th>
                    <th class="col-capacity">Cap / Enrolled</th>
                    <th class="col-teacher">Class Teacher</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyClasses"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>
            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);
                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.schoolUnitId) params.set("schoolUnitId", query.schoolUnitId);
                  if (query?.campusId) params.set("campusId", query.campusId);
                  if (query?.levelType) params.set("levelType", query.levelType);
                  if (query?.classLevel) params.set("classLevel", query.classLevel);
                  if (query?.sectionId) params.set("sectionId", query.sectionId);
                  if (query?.streamId) params.set("streamId", query.streamId);
                  if (query?.academicYear) params.set("academicYear", query.academicYear);
                  if (query?.term) params.set("term", query.term);
                  if (query?.status) params.set("status", query.status);
                  params.set("page", String(targetPage));
                  return "/admin/classes?" + params.toString();
                }
                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>
              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>"><i class="fa-solid fa-angle-left"></i></a>
              <% for (let p = startPage; p <= endPage; p++) { %><a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a><% } %>
              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>"><i class="fa-solid fa-angle-right"></i></a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Add Nursery Class</div><div class="muted">Pre-fill level as Nursery</div></div><button class="btn-xs" id="quickNursery" type="button"><i class="fa-solid fa-child"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add Primary Class</div><div class="muted">Pre-fill level as Primary</div></div><button class="btn-xs" id="quickPrimary" type="button"><i class="fa-solid fa-school"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add Secondary Class</div><div class="muted">Pre-fill level as Secondary</div></div><button class="btn-xs" id="quickSecondary" type="button"><i class="fa-solid fa-graduation-cap"></i></button></div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Class</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="classForm" method="POST" action="/admin/classes">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field"><label>Class Name</label><input class="input" id="mName" name="name" required /></div>
            <div class="field"><label>Class Code</label><input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" /></div>
            <div class="field"><label>Status</label><select class="select" id="mStatus" name="status"><option value="active">Active</option><option value="inactive">Inactive</option><option value="archived">Archived</option></select></div>
            <div class="field"><label>School Unit</label><select class="select" id="mSchoolUnitId" name="schoolUnitId" required><option value="">- Select School Unit -</option><% (structure || []).forEach(function(su){ %><option value="<%= su.id %>"><%= su.name %></option><% }) %></select></div>
            <div class="field"><label>Location</label><select class="select" id="mCampusId" name="campusId" required><option value="">- Select Location -</option></select></div>
            <div class="field"><label>School Level</label><select class="select" id="mLevelType" name="levelType" required><option value="">- Select Level -</option></select></div>
            <div class="field"><label>Class Level</label><select class="select" id="mClassLevel" name="classLevel" required><option value="">- Select Class Level -</option></select></div>
            <div class="field">
              <label>Section <span class="muted">(optional)</span></label>
              <select class="select" id="mSectionId" name="sectionId"><option value="">- No Section -</option></select>
              <div class="muted" id="sectionHint">Select placement first to load sections, or leave it empty for small schools.</div>
            </div>
            <div class="field">
              <label>Stream <span class="muted">(optional)</span></label>
              <select class="select" id="mStreamId" name="streamId"><option value="">- No Stream -</option></select>
              <div class="muted" id="streamHint">Select a section to narrow streams, or choose a class-level stream.</div>
            </div>
            <div class="field"><label>Term</label><select class="select" id="mTerm" name="term"><option value="1">Term 1</option><option value="2">Term 2</option><option value="3">Term 3</option></select></div>
            <div class="field"><label>Academic Year</label><input class="input" id="mAcademicYear" name="academicYear" placeholder="2026" /></div>
            <div class="field"><label>Class Teacher</label><select class="select" id="mClassTeacher" name="classTeacher"><option value="">- Select Teacher -</option><% (staffList || []).forEach(function(s){ %><option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' - ' + s.role) : '' %></option><% }) %></select></div>
            <div class="field"><label>Shift</label><select class="select" id="mShift" name="shift"><option value="day">Day</option><option value="boarding">Boarding</option><option value="both">Both</option></select></div>
            <div class="field"><label>Capacity</label><input class="input" id="mCapacity" name="capacity" type="number" min="0" /></div>
            <div class="field"><label>Enrolled Count</label><input class="input" id="mEnrolledCount" name="enrolledCount" type="number" min="0" /></div>
            <div class="field"><label>Room</label><input class="input" id="mRoom" name="room" /></div>
            <div class="field full"><label>Description</label><textarea class="textarea" id="mDescription" name="description" maxlength="1200"></textarea><div class="char-count" id="descCount">0 / 1200</div></div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Class</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Class Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Class</label><div class="view-input" id="vName">-</div></div>
          <div class="field"><label>Code</label><div class="view-input" id="vCode">-</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">-</div></div>
          <div class="field"><label>School Level</label><div class="view-input" id="vSchoolLevel">-</div></div>
          <div class="field"><label>Class Level</label><div class="view-input" id="vClassLevel">-</div></div>
          <div class="field"><label>Class Teacher</label><div class="view-input" id="vClassTeacher">-</div></div>
          <div class="field"><label>Academic Year</label><div class="view-input" id="vAcademicYear">-</div></div>
          <div class="field"><label>Term</label><div class="view-input" id="vTerm">-</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vSection">-</div></div>
          <div class="field"><label>Stream</label><div class="view-input" id="vStream">-</div></div>
          <div class="field"><label>Shift</label><div class="view-input" id="vShift">-</div></div>
          <div class="field"><label>Capacity</label><div class="view-input" id="vCapacity">-</div></div>
          <div class="field"><label>Room / Location</label><div class="view-input" id="vRoomCampus">-</div></div>
        </div>

        <div class="field" style="margin-top:12px;">
          <label>Description</label>
          <div class="view-input multiline" id="vDescription">-</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" id="viewActivateBtn"><i class="fa-solid fa-circle-check"></i> Activate</button>
        <button class="btn light" type="button" id="viewInactiveBtn"><i class="fa-solid fa-circle-pause"></i> Inactivate</button>
        <button class="btn light" type="button" id="viewArchiveBtn"><i class="fa-solid fa-box-archive"></i> Archive</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusField">
  </form>

  <form id="bulkForm" method="POST" action="/admin/classes/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionField">
    <input type="hidden" name="ids" id="bulkIdsField">
  </form>

  <textarea id="classesData" class="json-data" aria-hidden="true"><%- JSON.stringify((classes || []).map(function(c){
    const sectionDoc = c.sectionId && typeof c.sectionId === 'object' ? c.sectionId : null;
    const streamDoc = c.streamId && typeof c.streamId === 'object' ? c.streamId : null;
    return {
      id: String(c._id || ''),
      name: c.name || '',
      code: c.code || '',
      schoolUnitId: c.schoolUnitId || '',
      schoolUnitName: c.schoolUnitName || '',
      campusId: c.campusId || '',
      campusName: c.campusName || '',
      levelType: c.levelType || '',
      classLevel: c.classLevel || '',
      sectionId: sectionDoc?._id ? String(sectionDoc._id) : (c.sectionId ? String(c.sectionId) : ''),
      sectionName: c.sectionName || sectionDoc?.name || '',
      sectionCode: c.sectionCode || sectionDoc?.code || '',
      streamId: streamDoc?._id ? String(streamDoc._id) : (c.streamId ? String(c.streamId) : ''),
      streamName: c.streamName || streamDoc?.name || c.stream || '',
      streamCode: c.streamCode || streamDoc?.code || '',
      stream: c.stream || '',
      term: Number(c.term ?? 1),
      academicYear: c.academicYear || '',
      classTeacherId: c.classTeacher?._id ? String(c.classTeacher._id) : '',
      classTeacherName: c.classTeacher?.fullName || c.classTeacher?.name || '',
      capacity: Number(c.capacity || 0),
      enrolledCount: Number(c.enrolledCount || 0),
      room: c.room || '',
      shift: c.shift || 'day',
      status: c.status || 'active',
      description: c.description || ''
    };
  })) %></textarea>

  <textarea id="structureData" class="json-data" aria-hidden="true"><%- JSON.stringify(structure || []) %></textarea>
  <textarea id="classLevelMap" class="json-data" aria-hidden="true"><%- JSON.stringify(classLevelMap || {}) %></textarea>
  <textarea id="sectionsData" class="json-data" aria-hidden="true"><%- JSON.stringify((sections || []).map(function(s){
    return {
      _id: String(s._id || ''),
      id: String(s._id || ''),
      name: s.name || '',
      code: s.code || '',
      schoolUnitId: s.schoolUnitId || '',
      campusId: s.campusId || '',
      levelType: s.levelType || '',
      classId: s.classId?._id ? String(s.classId._id) : String(s.classId || ''),
      className: s.className || s.classId?.name || '',
      classLevel: s.classLevel || '',
      classStream: s.classStream || '',
      streamId: s.streamId?._id ? String(s.streamId._id) : String(s.streamId || ''),
      streamName: s.streamName || s.streamId?.name || '',
      streamCode: s.streamCode || s.streamId?.code || ''
    };
  })) %></textarea>

  <textarea id="streamsData" class="json-data" aria-hidden="true"><%- JSON.stringify((streams || []).map(function(s){
    return {
      _id: String(s._id || ''),
      id: String(s._id || ''),
      name: s.name || '',
      code: s.code || '',
      schoolUnitId: s.schoolUnitId || '',
      campusId: s.campusId || '',
      levelType: s.levelType || '',
      classId: s.classId?._id ? String(s.classId._id) : String(s.classId || ''),
      className: s.className || s.classId?.name || '',
      classLevel: s.classLevel || '',
      classStream: s.classStream || '',
      sectionId: s.sectionId?._id ? String(s.sectionId._id) : String(s.sectionId || ''),
      sectionName: s.sectionName || s.sectionId?.name || '',
      sectionCode: s.sectionCode || s.sectionId?.code || ''
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/classes.js"></script>
</body>
</html>

