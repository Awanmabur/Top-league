<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Admin • Assets — <%= (tenant && tenant.name) ? tenant.name : "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>

  <link rel="stylesheet" href="/css/student-portal.css"/>
  <link rel="stylesheet" href="/css/navbar.css"/>

  <style>
    *{box-sizing:border-box}
    html,body{max-width:100%;overflow-x:hidden}
    .main,.card,.grid-2>*{min-width:0}
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center;min-width:0}
    .input,.select,.textarea{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none;max-width:100%}
    .textarea{min-height:110px;resize:vertical;width:100%}
    .input{min-width:230px;max-width:100%}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr);gap:12px}
    .chips{display:flex;gap:8px;flex-wrap:wrap;max-width:100%}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;max-width:100%}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .table-wrap{width:100%;max-width:100%;overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;-webkit-overflow-scrolling:touch}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1120px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px;min-width:0}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}

    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:20px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1000px,100%);max-width:100%;max-height:min(88vh,900px);margin:auto;background:#fff;border-radius:20px;box-shadow:0 24px 70px rgba(0,0,0,.24);overflow:hidden;display:flex;flex-direction:column}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900}
    .modal-body{padding:16px 18px;overflow-y:auto;overflow-x:hidden;flex:1 1 auto;min-height:0}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex:0 0 auto}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field{min-width:0}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%;min-width:0}
    .detail-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .detail-card{border:1px solid rgba(13,64,96,.10);border-radius:16px;padding:14px;background:#fff;min-width:0}
    .detail-card .label{font-size:12px;color:#6b7280;margin-bottom:4px}
    .detail-card .value{font-weight:800;color:#0f172a;word-break:break-word}
    .detail-list{display:grid;gap:10px}
    .detail-list .item{padding:12px 14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;word-break:break-word}

    @media (max-width:980px){
      .grid-2{grid-template-columns:1fr}
      .form-grid,.detail-grid{grid-template-columns:1fr}
    }
    @media (max-width:768px){
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *, .toolbar .right > *{flex:1 1 160px}
      .input,.select{width:100%;min-width:0}
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .modal-backdrop{align-items:flex-start;padding:12px}
      .modal{width:100%;max-height:calc(100vh - 24px);border-radius:18px}
    }
    @media (max-width:560px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .card{overflow:hidden}
      .actions{justify-content:flex-start}
      .modal-footer{flex-wrap:wrap}
      .modal-footer .btn{flex:1 1 140px}
    }
  </style>
</head>
<body>
  <%- include("../partials/flash") %>
  <%- include("../partials/navbar") %>

  <main class="main">
    
    <div class="topbar">
      <div>
        <div class="title">Assets</div>
        <div class="subtitle">Manage school assets, assignments, maintenance, and movement history.</div>
      </div>
      <div class="top-actions">
        <button class="btn light" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export</button>
        <button class="btn light" type="button"><i class="fa-solid fa-chart-column"></i> Reports</button>
        <button class="btn light" type="button"><i class="fa-solid fa-warehouse"></i> Inventory</button>
        <button class="btn primary" type="button" id="btnAddAsset"><i class="fa-solid fa-plus"></i> Add Asset</button>
      </div>
    </div>

    <div class="grid-4">
      <div class="card"><div class="section-title">Assets</div><div class="kpi-value"><%= kpis.assets || 0 %></div><div class="muted">Total recorded</div></div>
      <div class="card"><div class="section-title">Assigned</div><div class="kpi-value" style="color:#0a6fbf"><%= kpis.assigned || 0 %></div><div class="muted">Currently assigned</div></div>
      <div class="card"><div class="section-title">Maintenance</div><div class="kpi-value" style="color:#92400e"><%= kpis.maintenance || 0 %></div><div class="muted">Needs attention</div></div>
      <div class="card"><div class="section-title">Asset Value</div><div class="kpi-value">UGX <%= Number(kpis.totalValue || 0).toLocaleString() %></div><div class="muted">Estimated total</div></div>
    </div>

    <section class="card" style="margin-top:12px;">
      <form method="GET" action="/admin/assets">
        <div class="toolbar">
          <div class="left">
            <input class="input" name="q" value="<%= query.q || '' %>" placeholder="Search asset tag / name / location / serial..." />
            <select class="select" name="category">
              <option value="all">All Categories</option>
              <% categories.forEach(function(c){ %>
                <option value="<%= c %>" <%= query.category === c ? "selected" : "" %>><%= c %></option>
              <% }) %>
            </select>
            <select class="select" name="status">
              <option value="all" <%= query.status === "all" ? "selected" : "" %>>All Status</option>
              <option value="Available" <%= query.status === "Available" ? "selected" : "" %>>Available</option>
              <option value="Assigned" <%= query.status === "Assigned" ? "selected" : "" %>>Assigned</option>
              <option value="Maintenance" <%= query.status === "Maintenance" ? "selected" : "" %>>Maintenance</option>
              <option value="Disposed" <%= query.status === "Disposed" ? "selected" : "" %>>Disposed</option>
            </select>
            <select class="select" name="condition">
              <option value="all" <%= query.condition === "all" ? "selected" : "" %>>All Condition</option>
              <option value="Excellent" <%= query.condition === "Excellent" ? "selected" : "" %>>Excellent</option>
              <option value="Good" <%= query.condition === "Good" ? "selected" : "" %>>Good</option>
              <option value="Fair" <%= query.condition === "Fair" ? "selected" : "" %>>Fair</option>
              <option value="Damaged" <%= query.condition === "Damaged" ? "selected" : "" %>>Damaged</option>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip <%= (query.view || 'assets') === 'assets' ? 'active' : '' %>" type="button" data-view="assets"><i class="fa-solid fa-boxes-stacked"></i> Assets</button>
              <button class="chip <%= query.view === 'assignments' ? 'active' : '' %>" type="button" data-view="assignments"><i class="fa-solid fa-user-check"></i> Assignments</button>
              <button class="chip <%= query.view === 'maintenance' ? 'active' : '' %>" type="button" data-view="maintenance"><i class="fa-solid fa-screwdriver-wrench"></i> Maintenance</button>
              <button class="chip <%= query.view === 'movements' ? 'active' : '' %>" type="button" data-view="movements"><i class="fa-solid fa-clock-rotate-left"></i> Movements</button>
            </div>
            <input type="hidden" name="view" id="viewInput" value="<%= query.view || 'assets' %>"/>
            <button class="btn light" type="submit"><i class="fa-solid fa-filter"></i> Apply</button>
            <a class="btn light" href="/admin/assets"><i class="fa-solid fa-rotate-left"></i> Reset</a>
          </div>
        </div>
      </form>
    </section>

    <% const currentView = query.view || "assets"; %>

    <div class="grid-2" style="margin-top:12px;">
      <section class="card">
        <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
          <div>
            <div class="section-title">
              <%= currentView === "assignments" ? "Assignments"
                : currentView === "maintenance" ? "Maintenance"
                : currentView === "movements" ? "Movements"
                : "Assets Register" %>
            </div>
            <div class="section-sub">
              <%= currentView === "assignments" ? "Track who has what."
                : currentView === "maintenance" ? "Manage repairs and servicing."
                : currentView === "movements" ? "Audit trail of asset activity."
                : "View and manage asset records." %>
            </div>
          </div>
        </div>

        <% if (currentView === "assets") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Asset</th>
                  <th>Category</th>
                  <th>Qty</th>
                  <th>Unit Cost</th>
                  <th>Location</th>
                  <th>Condition</th>
                  <th>Status</th>
                  <th style="text-align:right;width:260px;">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (!assets.length) { %>
                  <tr><td colspan="8"><div class="muted">No assets found.</div></td></tr>
                <% } %>
                <% assets.forEach(function(asset){ %>
                  <tr>
                    <td>
                      <div class="strong"><%= asset.assetTag %></div>
                      <div class="muted"><%= asset.name %></div>
                    </td>
                    <td><span class="pill info"><%= asset.category %></span></td>
                    <td><%= asset.quantity %></td>
                    <td>UGX <%= Number(asset.unitCost || 0).toLocaleString() %></td>
                    <td><%= asset.location || "—" %></td>
                    <td><span class="pill info"><%= asset.condition %></span></td>
                    <td>
                      <% if (asset.status === "Available") { %>
                        <span class="pill ok">Available</span>
                      <% } else if (asset.status === "Assigned") { %>
                        <span class="pill info">Assigned</span>
                      <% } else if (asset.status === "Maintenance") { %>
                        <span class="pill warn">Maintenance</span>
                      <% } else { %>
                        <span class="pill bad">Disposed</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="actions">
                        <button class="btn-xs js-view-asset" type="button" data-asset='<%- JSON.stringify(asset) %>'><i class="fa-solid fa-eye"></i></button>
                        <button class="btn-xs js-edit-asset" type="button" data-asset='<%- JSON.stringify(asset) %>'><i class="fa-solid fa-pen"></i></button>
                        <button class="btn-xs js-assign-asset" type="button" data-id="<%= asset._id %>" data-tag="<%= asset.assetTag %>"><i class="fa-solid fa-user-check"></i></button>
                        <button class="btn-xs js-maint-asset" type="button" data-id="<%= asset._id %>" data-tag="<%= asset.assetTag %>"><i class="fa-solid fa-screwdriver-wrench"></i></button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "assignments") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Asset</th>
                  <th>Assigned To</th>
                  <th>Type</th>
                  <th>Assigned At</th>
                  <th>Due Back</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (!assignments.length) { %>
                  <tr><td colspan="6"><div class="muted">No assignments found.</div></td></tr>
                <% } %>
                <% assignments.forEach(function(a){ %>
                  <tr>
                    <td><div class="strong"><%= a.assetTag %></div><div class="muted"><%= a.assetName %></div></td>
                    <td><%= a.assignedTo %></td>
                    <td><span class="pill info"><%= a.assigneeType %></span></td>
                    <td><%= helpers.formatDate(a.assignedAt) %></td>
                    <td><%= helpers.formatDate(a.dueBackAt) %></td>
                    <td><span class="pill <%= a.status === 'Assigned' ? 'info' : (a.status === 'Returned' ? 'ok' : 'warn') %>"><%= a.status %></span></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "maintenance") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Asset</th>
                  <th>Issue</th>
                  <th>Priority</th>
                  <th>Status</th>
                  <th>Opened</th>
                </tr>
              </thead>
              <tbody>
                <% if (!maintenance.length) { %>
                  <tr><td colspan="5"><div class="muted">No maintenance records found.</div></td></tr>
                <% } %>
                <% maintenance.forEach(function(m){ %>
                  <tr>
                    <td><div class="strong"><%= m.assetTag %></div><div class="muted"><%= m.assetName %></div></td>
                    <td><%= m.issue %></td>
                    <td><span class="pill <%= m.priority === 'High' || m.priority === 'Urgent' ? 'bad' : 'info' %>"><%= m.priority %></span></td>
                    <td><span class="pill <%= m.status === 'Resolved' ? 'ok' : (m.status === 'In Progress' ? 'warn' : 'info') %>"><%= m.status %></span></td>
                    <td><%= helpers.formatDate(m.openedAt) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <% if (currentView === "movements") { %>
          <div class="table-wrap" style="margin-top:10px;">
            <table>
              <thead>
                <tr>
                  <th>Asset</th>
                  <th>Type</th>
                  <th>Actor</th>
                  <th>Note</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% if (!movements.length) { %>
                  <tr><td colspan="5"><div class="muted">No movements found.</div></td></tr>
                <% } %>
                <% movements.forEach(function(m){ %>
                  <tr>
                    <td><div class="strong"><%= m.assetTag %></div><div class="muted"><%= m.assetName %></div></td>
                    <td><span class="pill info"><%= m.type %></span></td>
                    <td><%= m.actorName || "—" %></td>
                    <td><%= m.note || "—" %></td>
                    <td><%= helpers.formatDate(m.date) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </section>

      <aside class="card">
        <div class="section-title">Asset Operations</div>
        <div class="section-sub">Quick admin actions.</div>

        <div class="mini-list">
          <div class="mini-item">
            <div class="left"><div class="strong">Register Asset</div><div class="muted">Create a new asset record</div></div>
            <button class="btn-xs" type="button" id="btnAddAsset2"><i class="fa-solid fa-plus"></i></button>
          </div>
          <div class="mini-item">
            <div class="left"><div class="strong">Assignments</div><div class="muted">Track issued assets</div></div>
            <a class="btn-xs" href="/admin/assets?view=assignments"><i class="fa-solid fa-user-check"></i></a>
          </div>
          <div class="mini-item">
            <div class="left"><div class="strong">Maintenance</div><div class="muted">Repair and servicing logs</div></div>
            <a class="btn-xs" href="/admin/assets?view=maintenance"><i class="fa-solid fa-screwdriver-wrench"></i></a>
          </div>
        </div>

        <div class="section-title" style="margin-top:14px;">Recent Movement</div>
        <div class="mini-list">
          <% if (!movements.length) { %>
            <div class="mini-item"><div class="left"><div class="strong">No activity</div><div class="muted">Asset events will appear here</div></div><span class="muted">—</span></div>
          <% } %>
          <% movements.slice(0,4).forEach(function(m){ %>
            <div class="mini-item">
              <div class="left">
                <div class="strong"><%= m.type %></div>
                <div class="muted"><%= m.assetTag %> — <%= m.note || "No note" %></div>
              </div>
              <span class="muted"><%= helpers.formatDate(m.date) %></span>
            </div>
          <% }) %>
        </div>
      </aside>
    </div>
  </main>

  <!-- Add/Edit Asset Modal -->
  <div class="modal-backdrop" id="mAsset">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="mAssetTitle">Add Asset</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mAsset"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form id="assetForm" method="POST" action="/admin/assets">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-grid">
            <div class="field"><label>Asset Tag</label><input class="input" name="assetTag" id="aTag" placeholder="AST-001"></div>
            <div class="field"><label>Asset Name</label><input class="input" name="name" id="aName" placeholder="HP Laptop"></div>
            <div class="field">
              <label>Category</label>
              <select class="select" name="category" id="aCategory">
                <option>Furniture</option>
                <option>Electronics</option>
                <option>Vehicle</option>
                <option>Lab Equipment</option>
                <option>ICT</option>
                <option>Office Equipment</option>
                <option>Library</option>
                <option>Sports</option>
                <option selected>Other</option>
              </select>
            </div>

            <div class="field"><label>Brand</label><input class="input" name="brand" id="aBrand"></div>
            <div class="field"><label>Model</label><input class="input" name="model" id="aModel"></div>
            <div class="field"><label>Serial Number</label><input class="input" name="serialNumber" id="aSerial"></div>

            <div class="field"><label>Quantity</label><input class="input" type="number" min="1" name="quantity" id="aQuantity" value="1"></div>
            <div class="field"><label>Unit Cost</label><input class="input" type="number" min="0" name="unitCost" id="aUnitCost" value="0"></div>
            <div class="field"><label>Purchase Date</label><input class="input" type="date" name="purchaseDate" id="aPurchaseDate"></div>

            <div class="field"><label>Supplier</label><input class="input" name="supplier" id="aSupplier"></div>
            <div class="field"><label>Location</label><input class="input" name="location" id="aLocation"></div>
            <div class="field">
              <label>Condition</label>
              <select class="select" name="condition" id="aCondition">
                <option>Excellent</option>
                <option selected>Good</option>
                <option>Fair</option>
                <option>Damaged</option>
              </select>
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" name="status" id="aStatus">
                <option selected>Available</option>
                <option>Assigned</option>
                <option>Maintenance</option>
                <option>Disposed</option>
              </select>
            </div>

            <div class="field" style="grid-column:1 / -1;">
              <label>Notes</label>
              <textarea class="textarea" name="notes" id="aNotes" placeholder="Asset notes"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn light js-close-modal" type="button" data-modal="mAsset">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- View Asset Modal -->
  <div class="modal-backdrop" id="mViewAsset">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Asset Details</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mViewAsset"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="detail-grid">
          <div class="detail-card"><div class="label">Asset Tag</div><div class="value" id="vTag">—</div></div>
          <div class="detail-card"><div class="label">Name</div><div class="value" id="vName">—</div></div>
          <div class="detail-card"><div class="label">Category</div><div class="value" id="vCategory">—</div></div>
          <div class="detail-card"><div class="label">Brand</div><div class="value" id="vBrand">—</div></div>
          <div class="detail-card"><div class="label">Model</div><div class="value" id="vModel">—</div></div>
          <div class="detail-card"><div class="label">Serial Number</div><div class="value" id="vSerial">—</div></div>
          <div class="detail-card"><div class="label">Quantity</div><div class="value" id="vQty">—</div></div>
          <div class="detail-card"><div class="label">Unit Cost</div><div class="value" id="vCost">—</div></div>
          <div class="detail-card"><div class="label">Location</div><div class="value" id="vLocation">—</div></div>
          <div class="detail-card"><div class="label">Condition</div><div class="value" id="vCondition">—</div></div>
          <div class="detail-card"><div class="label">Status</div><div class="value" id="vStatus">—</div></div>
          <div class="detail-card"><div class="label">Supplier</div><div class="value" id="vSupplier">—</div></div>
          <div class="detail-card"><div class="label">Purchase Date</div><div class="value" id="vPurchaseDate">—</div></div>
        </div>

        <div class="section-title" style="margin-top:16px;">Notes</div>
        <div class="detail-card"><div class="value" id="vNotes">—</div></div>

        <div class="section-title" style="margin-top:16px;">Quick Summary</div>
        <div class="detail-list">
          <div class="item"><strong>Assignments:</strong> <span id="vAssignments">0</span></div>
          <div class="item"><strong>Maintenance Logs:</strong> <span id="vMaintenance">0</span></div>
          <div class="item"><strong>Movements:</strong> <span id="vMovements">0</span></div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn light js-close-modal" type="button" data-modal="mViewAsset">Close</button>
      </div>
    </div>
  </div>

  <!-- Assign Asset Modal -->
  <div class="modal-backdrop" id="mAssign">
    <div class="modal" style="width:min(760px,100%);">
      <div class="modal-header">
        <div class="modal-title">Assign Asset</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mAssign"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form method="POST" id="assignForm" action="">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-grid" style="grid-template-columns:repeat(2,minmax(0,1fr));">
            <div class="field"><label>Assigned To</label><input class="input" name="assignedTo" placeholder="Name / Office / Department"></div>
            <div class="field">
              <label>Assignee Type</label>
              <select class="select" name="assigneeType">
                <option>Staff</option>
                <option>Department</option>
                <option>Office</option>
                <option>Student</option>
                <option>Other</option>
              </select>
            </div>
            <div class="field"><label>Due Back Date</label><input class="input" type="date" name="dueBackAt"></div>
          </div>
          <div class="field" style="margin-top:12px;">
            <label>Note</label>
            <textarea class="textarea" name="note" placeholder="Optional note"></textarea>
          </div>
          <div class="note" style="margin-top:12px;">Asset: <strong id="assignAssetTag">—</strong></div>
        </div>
        <div class="modal-footer">
          <button class="btn light js-close-modal" type="button" data-modal="mAssign">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Assign</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Maintenance Modal -->
  <div class="modal-backdrop" id="mMaint">
    <div class="modal" style="width:min(760px,100%);">
      <div class="modal-header">
        <div class="modal-title">Create Maintenance Ticket</div>
        <button class="btn-xs js-close-modal" type="button" data-modal="mMaint"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <form method="POST" id="maintForm" action="">
        <div class="modal-body">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="form-grid" style="grid-template-columns:repeat(2,minmax(0,1fr));">
            <div class="field">
              <label>Priority</label>
              <select class="select" name="priority">
                <option>Low</option>
                <option selected>Normal</option>
                <option>High</option>
                <option>Urgent</option>
              </select>
            </div>
            <div class="field">
              <label>Status</label>
              <select class="select" name="status">
                <option selected>Open</option>
                <option>In Progress</option>
                <option>Resolved</option>
              </select>
            </div>
          </div>
          <div class="field" style="margin-top:12px;">
            <label>Issue</label>
            <input class="input" name="issue" placeholder="Describe the issue">
          </div>
          <div class="field" style="margin-top:12px;">
            <label>Note</label>
            <textarea class="textarea" name="note" placeholder="Extra internal note"></textarea>
          </div>
          <div class="note" style="margin-top:12px;">Asset: <strong id="maintAssetTag">—</strong></div>
        </div>
        <div class="modal-footer">
          <button class="btn light js-close-modal" type="button" data-modal="mMaint">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Save Ticket</button>
        </div>
      </form>
    </div>
  </div>

  <script src="/js/tenant-admin-assets.js"></script>
  <script>
    document.getElementById("btnAddAsset2")?.addEventListener("click", function () {
      document.getElementById("btnAddAsset")?.click();
    });
  </script>
  <script src="/js/navbar.js"></script>
</body>
</html>