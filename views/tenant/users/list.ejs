<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Users — Classic Academy</title>
  <link rel="icon" href="data:,">
  <style>
    :root{
      --blue:#0a3d62; --blue2:#083454; --bg:#f4f8ff; --card:#fff;
      --muted:#6b7280; --text:#0f172a; --accent:#0a6fbf;
      --success:#16a34a; --danger:#ef4444; --warn:#f59e0b;
      --radius:14px; --shadow:0 10px 30px rgba(2,6,23,.08);
      --line:rgba(2,6,23,.08);
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}
    a{color:inherit;text-decoration:none}
    .app{display:grid;grid-template-columns:260px 1fr;min-height:100vh}
    aside{background:linear-gradient(180deg,var(--blue),var(--blue2));color:#fff;padding:18px;position:sticky;top:0;height:100vh}
    .brand{display:flex;gap:10px;align-items:center;margin-bottom:18px}
    .logo{width:40px;height:40px;border-radius:12px;background:rgba(255,255,255,.14);display:grid;place-items:center;font-weight:800}
    .brand h1{font-size:14px;line-height:1.2;margin:0}
    .brand p{margin:0;font-size:12px;opacity:.85}
    .nav{margin-top:10px;display:flex;flex-direction:column;gap:8px}
    .nav a{padding:10px 12px;border-radius:12px;display:flex;gap:10px;align-items:center;background:rgba(255,255,255,.08)}
    .nav a.active{background:rgba(255,255,255,.16)}
    main{padding:18px 18px 30px}
    header{background:rgba(255,255,255,.7);backdrop-filter: blur(10px);border:1px solid var(--line);
      padding:14px 14px;border-radius:18px;box-shadow:var(--shadow);display:flex;justify-content:space-between;align-items:center;gap:12px}
    .title{display:flex;flex-direction:column;gap:3px}
    .title h2{margin:0;font-size:16px}
    .title span{font-size:12px;color:var(--muted)}
    .actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .btn{border:0;background:var(--accent);color:#fff;padding:10px 12px;border-radius:12px;font-weight:700;cursor:pointer}
    .btn.secondary{background:#fff;color:var(--text);border:1px solid var(--line)}
    .search{display:flex;align-items:center;gap:8px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:10px 12px}
    .search input{border:0;outline:none;width:240px}
    .grid{margin-top:14px;display:grid;grid-template-columns:1fr;gap:14px}
    .card{background:var(--card);border:1px solid var(--line);border-radius:18px;box-shadow:var(--shadow)}
    .card .pad{padding:14px}
    table{width:100%;border-collapse:separate;border-spacing:0}
    th,td{padding:12px 12px;border-bottom:1px solid var(--line);font-size:13px;text-align:left}
    th{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
    tr:hover td{background:rgba(10,111,191,.04)}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:999px;font-size:12px;font-weight:800}
    .pill.active{background:#ecfdf3;color:#15803d}
    .pill.invited{background:#eff6ff;color:#1d4ed8}
    .pill.suspended{background:#fee2e2;color:#b91c1c}
    .roles{display:flex;gap:6px;flex-wrap:wrap}
    .tag{padding:4px 8px;border-radius:999px;background:rgba(2,6,23,.06);font-size:12px;font-weight:700}
    .muted{color:var(--muted);font-size:12px}
    .empty{padding:18px;text-align:center;color:var(--muted)}
    @media (max-width: 980px){
      .app{grid-template-columns:1fr}
      aside{height:auto;position:relative;border-bottom-left-radius:18px;border-bottom-right-radius:18px}
      .search input{width:160px}
    }
  </style>
</head>
<body>
<div class="app">

  <aside>
    <div class="brand">
      <div class="logo">CC</div>
      <div>
        <h1>Classic Academy</h1>
        <p class="muted" style="color:rgba(255,255,255,.8)">Tenant Admin</p>
      </div>
    </div>

    <nav class="nav">
      <a href="/admin/dashboard">Dashboard</a>
      <a class="active" href="/admin/users">Users</a>
      <a href="/admin/students">Students</a>
      <a href="/admin/staff">Staff</a>
      <a href="/admin/subjects">Subjects</a>
      <a href="/logout">Logout</a>
    </nav>
  </aside>

  <main>
    <header>
      <div class="title">
        <h2>Users</h2>
        <span>Manage tenant users: admins, staff, lecturers, students</span>
      </div>

      <div class="actions">
        <div class="search">
          <span style="font-weight:900;color:var(--muted)">🔎</span>
          <input id="q" type="search" placeholder="Search name/email/role..." />
        </div>
        <a class="btn" href="/admin/users/new">+ New User</a>
        <button class="btn secondary" onclick="location.reload()">Refresh</button>
      </div>
    </header>

    <div class="grid">
      <div class="card">
        <div class="pad" style="padding-bottom:0">
          <div class="muted">
            Total: <b><%= (users && users.length) ? users.length : 0 %></b>
          </div>
        </div>

        <% if (!users || users.length === 0) { %>
          <div class="empty">No users found. Click <b>New User</b> to invite someone.</div>
        <% } else { %>
          <div style="overflow:auto;border-radius:18px">
            <table id="tbl">
              <thead>
                <tr>
                  <th>User</th>
                  <th>Email</th>
                  <th>Roles</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th style="width:120px">Action</th>
                  <th>Send Invite</th>
                </tr>
              </thead>
              <tbody>
              <% users.forEach(u => { %>
                <tr data-row="<%= [u.firstName,u.lastName,u.email,(u.roles||[]).join(' '),u.status].join(' ').toLowerCase() %>">
                  <td>
                    <div style="font-weight:900"><%= (u.firstName||'') %> <%= (u.lastName||'') %></div>
                    <div class="muted">ID: <%= String(u._id) %></div>
                  </td>
                  <td><%= (u.email||'') %></td>
                  <td>
                    <div class="roles">
                      <% (u.roles || []).forEach(r => { %>
                        <span class="tag"><%= r %></span>
                      <% }) %>
                      <% if (!u.roles || u.roles.length === 0) { %>
                        <span class="muted">—</span>
                      <% } %>
                    </div>
                  </td>
                  <td>
                    <span class="pill <%= (u.status || 'invited') %>">
                      <%= (u.status || 'invited') %>
                    </span>
                  </td>
                  <td class="muted">
                    <%= u.createdAt ? new Date(u.createdAt).toLocaleString() : "—" %>
                  </td>
                  <td>
                    <a class="btn secondary" href="/admin/users/<%= String(u._id) %>" style="padding:8px 10px;border-radius:10px">Open</a>
                  </td>
                  <td>
                    <form method="POST"
                          action="/admin/users/<%= String(u._id) %>/resend-invite"
                          onsubmit="return confirm('Generate a NEW invite link for this user? Old ones will stop working.')">
                      <button class="btn" type="submit">Resend Invite</button>
                    </form>

                  </td>
                </tr>
              <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

  </main>
</div>

<script>
  const q = document.getElementById('q');
  const rows = Array.from(document.querySelectorAll('#tbl tbody tr'));
  if(q){
    q.addEventListener('input', () => {
      const v = (q.value || '').trim().toLowerCase();
      rows.forEach(r => {
        const hay = r.getAttribute('data-row') || '';
        r.style.display = hay.includes(v) ? '' : 'none';
      });
    });
  }
</script>
</body>
</html>
