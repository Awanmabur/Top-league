<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>User Invited — Classic Academy</title>
  <link rel="icon" href="data:,">
  <style>
    :root{
      --blue:#0a3d62; --blue2:#083454; --bg:#f4f8ff; --card:#fff;
      --muted:#6b7280; --text:#0f172a; --accent:#0a6fbf;
      --success:#16a34a; --danger:#ef4444;
      --shadow:0 10px 30px rgba(2,6,23,.08); --line:rgba(2,6,23,.08);
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text)}
    .wrap{max-width:900px;margin:24px auto;padding:0 14px}
    .card{background:var(--card);border:1px solid var(--line);border-radius:18px;box-shadow:var(--shadow);padding:16px}
    .top{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center}
    .title{display:flex;flex-direction:column;gap:4px}
    .title h2{margin:0;font-size:18px}
    .title span{font-size:12px;color:var(--muted)}
    .btn{border:0;background:var(--accent);color:#fff;padding:10px 12px;border-radius:12px;font-weight:800;cursor:pointer}
    .btn.secondary{background:#fff;color:var(--text);border:1px solid var(--line)}
    .success{background:#ecfdf3;border:1px solid rgba(21,128,61,.2);color:#14532d;padding:10px 12px;border-radius:12px;font-weight:900}
    .field{margin-top:12px}
    textarea{width:100%;min-height:90px;border-radius:12px;border:1px solid var(--line);padding:12px;outline:none;resize:vertical}
    .hint{font-size:12px;color:var(--muted);line-height:1.5}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:12px}
    @media(max-width:760px){.row{grid-template-columns:1fr}}
  </style>
</head>
<body data-portal="tenant">
  <div class="wrap">
    <div class="card">
      <div class="top">
        <div class="title">
          <h2>User invited successfully</h2>
          <span>Send this link to the user so they can set their password.</span>
        </div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <a class="btn secondary" href="/admin/users">Users</a>
          <a class="btn secondary" href="/admin/users/new">Invite another</a>
          <% if (createdUser && createdUser._id) { %>
            <a class="btn" href="/admin/users/<%= String(createdUser._id) %>">Open user</a>
          <% } %>
        </div>
      </div>

      <div style="height:10px"></div>
      <div class="success">✅ Account created as “invited”. Once password is set, the user can login.</div>

      <div class="row">
        <div class="field">
          <div class="hint"><b>User</b></div>
          <div style="font-weight:900">
            <%= (createdUser && createdUser.firstName) ? createdUser.firstName : "" %>
            <%= (createdUser && createdUser.lastName) ? createdUser.lastName : "" %>
          </div>
          <div class="hint"><%= (createdUser && createdUser.email) ? createdUser.email : "" %></div>
          <div class="hint">Roles: <b><%= (createdUser && createdUser.roles && createdUser.roles.length) ? createdUser.roles.join(", ") : "—" %></b></div>
        </div>

        <div class="field">
          <div class="hint"><b>Invite link (valid for limited time)</b></div>
          <textarea id="link" readonly><%= inviteLink %></textarea>
          <div style="display:flex;gap:10px;margin-top:10px;flex-wrap:wrap">
            <button class="btn" onclick="copyLink()">Copy Link</button>
            <a class="btn secondary" href="<%= inviteLink %>" target="_blank" rel="noopener">Open Link</a>
          </div>
          <div class="hint" style="margin-top:8px">
            Production: send via email/SMS. Never post invite links publicly.
          </div>
        </div>
      </div>
    </div>
  </div>

<script>
  function copyLink(){
    const el = document.getElementById('link');
    el.select(); el.setSelectionRange(0, 999999);
    document.execCommand('copy');
    alert("Invite link copied.");
  }
</script>
</body>
</html>

