<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Admin • Backup — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea{
      padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none
    }
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(320px,.8fr);gap:12px}

    .chips{display:flex;gap:8px;flex-wrap:wrap}
    .chip{border:1px solid rgba(13,64,96,.14);background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer;font-weight:900;font-size:12px}
    .chip.active{background:rgba(10,111,191,.12);border-color:rgba(10,111,191,.35)}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{overflow:auto;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%}
    table{width:100%;border-collapse:separate;border-spacing:0;min-width:1220px;background:#fff}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1}
    tr:hover td{background:rgba(10,111,191,.04)}

    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:wrap;max-width:100%}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}

    .modal-backdrop{
      position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;
      padding:30px 18px;z-index:9999;overflow-y:auto;overflow-x:hidden
    }
    .modal-backdrop.show{display:flex}
    .modal{
      width:min(920px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column;margin:auto
    }
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;flex:1 1 auto;min-height:0;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);flex:0 0 auto;background:#fff;flex-wrap:wrap}

    .json-data{display:none !important}

    .view-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin-bottom:14px}
    .view-card{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;min-width:0}
    .view-label{font-size:12px;color:#6b7280;margin-bottom:6px}
    .view-value{font-weight:800;word-break:break-word}
    .view-message{padding:14px;border:1px solid rgba(13,64,96,.10);border-radius:16px;background:#fff;white-space:pre-wrap;line-height:1.65;font-family:ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;font-size:12px}

    .timeline{display:grid;gap:10px}
    .timeline-item{padding:12px 14px;border:1px solid rgba(13,64,96,.10);border-radius:14px;background:#fff}
    .timeline-head{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-bottom:6px}
    .timeline-body{color:#0d4060;line-height:1.6}

    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }
    @media (max-width:680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
      .view-grid{grid-template-columns:1fr}
    }
    @media (max-width:520px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .toolbar .left,.toolbar .right{width:100%}
      .toolbar .left > *,.toolbar .right > *{max-width:100%}
      .top-actions .btn{font-size:12px}
      .actions{justify-content:flex-start}
      table{min-width:1040px}
      .modal-backdrop{padding:30px 12px}
      .modal{max-height:calc(100dvh - 60px);border-radius:20px}
      .modal-header,.modal-body,.modal-footer{padding-left:14px;padding-right:14px}
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Backup</div>
          <div class="subtitle">Manage backup jobs, retention policy, storage usage, and restore history for tenant data protection.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnRetention" type="button"><i class="fa-solid fa-box-archive"></i> Retention</button>
          <button class="btn light" id="btnStorage" type="button"><i class="fa-solid fa-hard-drive"></i> Storage</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Create Backup</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Successful</div>
          <div class="kpi-value"><%= stats?.successful || 0 %></div>
          <div class="muted">Completed backups</div>
        </div>
        <div class="card">
          <div class="section-title">Scheduled</div>
          <div class="kpi-value" style="color:#0a6fbf"><%= stats?.scheduled || 0 %></div>
          <div class="muted">Recurring jobs</div>
        </div>
        <div class="card">
          <div class="section-title">Storage Used</div>
          <div class="kpi-value" style="color:#15803d"><%= stats?.storageUsed || '0 GB' %></div>
          <div class="muted">Tenant backup storage</div>
        </div>
        <div class="card">
          <div class="section-title">Failed</div>
          <div class="kpi-value" style="color:#b91c1c"><%= stats?.failed || 0 %></div>
          <div class="muted">Need retry/attention</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/backup">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search backup name, type, storage, status..." />
            <select class="select" name="status">
              <option value="all" <%= query?.status === 'all' ? 'selected' : '' %>>All Status</option>
              <option value="Completed" <%= query?.status === 'Completed' ? 'selected' : '' %>>Completed</option>
              <option value="Running" <%= query?.status === 'Running' ? 'selected' : '' %>>Running</option>
              <option value="Scheduled" <%= query?.status === 'Scheduled' ? 'selected' : '' %>>Scheduled</option>
              <option value="Failed" <%= query?.status === 'Failed' ? 'selected' : '' %>>Failed</option>
              <option value="Archived" <%= query?.status === 'Archived' ? 'selected' : '' %>>Archived</option>
            </select>
            <select class="select" name="type">
              <option value="all" <%= query?.type === 'all' ? 'selected' : '' %>>All Types</option>
              <option value="Manual" <%= query?.type === 'Manual' ? 'selected' : '' %>>Manual</option>
              <option value="Scheduled" <%= query?.type === 'Scheduled' ? 'selected' : '' %>>Scheduled</option>
              <option value="Full" <%= query?.type === 'Full' ? 'selected' : '' %>>Full</option>
              <option value="Database" <%= query?.type === 'Database' ? 'selected' : '' %>>Database</option>
              <option value="Media" <%= query?.type === 'Media' ? 'selected' : '' %>>Media</option>
            </select>
            <select class="select" name="storage">
              <option value="all" <%= query?.storage === 'all' ? 'selected' : '' %>>All Storage</option>
              <option value="Local" <%= query?.storage === 'Local' ? 'selected' : '' %>>Local</option>
              <option value="S3" <%= query?.storage === 'S3' ? 'selected' : '' %>>S3</option>
              <option value="Cloudinary" <%= query?.storage === 'Cloudinary' ? 'selected' : '' %>>Cloudinary</option>
            </select>
          </div>

          <div class="right">
            <div class="chips" id="viewChips">
              <button class="chip active" data-view="list" type="button"><i class="fa-solid fa-list"></i> List</button>
              <button class="chip" data-view="storage" type="button"><i class="fa-solid fa-chart-column"></i> Storage</button>
              <button class="chip" data-view="restore" type="button"><i class="fa-solid fa-clock-rotate-left"></i> Restore</button>
            </div>
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/backup"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">backups</span>
          </div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkRun" type="button"><i class="fa-solid fa-play"></i> Run</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkExport" type="button"><i class="fa-solid fa-file-export"></i> Export</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title" id="panelTitle">Backup Jobs</div>
              <div class="section-sub" id="panelSub">Manage backup runs, schedule, storage target and restore points.</div>
            </div>
            <div class="muted" id="resultMeta">—</div>
          </div>

          <div id="view-list" style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:42px;"><input type="checkbox" id="checkAll" /></th>
                    <th>Backup</th>
                    <th>Type</th>
                    <th>Scope</th>
                    <th>Storage</th>
                    <th>Size</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th style="text-align:right;width:230px;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbody"></tbody>
              </table>
            </div>
          </div>

          <div id="view-storage" style="display:none;margin-top:10px;">
            <div class="note">Storage view summarizes backup counts, size, and latest backup per storage target.</div>
            <div class="table-wrap" style="margin-top:10px;">
              <table>
                <thead>
                  <tr>
                    <th>Storage</th>
                    <th>Backups</th>
                    <th>Total Size</th>
                    <th>Completed</th>
                    <th>Failed</th>
                    <th>Latest Backup</th>
                  </tr>
                </thead>
                <tbody id="tbodyEng"></tbody>
              </table>
            </div>
          </div>

          <div id="view-restore" style="display:none;margin-top:10px;">
            <div class="toolbar">
              <div class="left">
                <input class="input" id="rSearch" placeholder="Search backup, actor, restore note...">
                <select class="select" id="rFilter">
                  <option value="all">All</option>
                  <option value="Completed">Completed</option>
                  <option value="Failed">Failed</option>
                  <option value="Pending">Pending</option>
                </select>
              </div>
              <div class="right">
                <button class="btn light" id="btnRestoreNow" type="button"><i class="fa-solid fa-clock-rotate-left"></i> Restore Selected</button>
              </div>
            </div>

            <div class="timeline" id="timelineList" style="margin-top:10px;"></div>
          </div>

          <div class="note" style="margin-top:12px;">
            <strong>Backup coverage included:</strong> backup jobs, scope, storage target, size, retention, checksum/meta, and restore history.
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="mini-list" style="margin-top:10px;">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Manual Full Backup</div>
                <div class="muted">Create a complete backup now</div>
              </div>
              <button class="btn-xs" id="quickFull" type="button"><i class="fa-solid fa-database"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Database Only</div>
                <div class="muted">Fast DB-only snapshot</div>
              </div>
              <button class="btn-xs" id="quickDb" type="button"><i class="fa-solid fa-server"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Latest Backup</div>
                <div class="muted">Inspect newest backup details</div>
              </div>
              <button class="btn-xs" id="quickLatest" type="button"><i class="fa-solid fa-clock"></i></button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mCreate">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Create Backup</div>
        <button class="btn-xs" type="button" data-close-modal="mCreate"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="backupForm" method="POST" action="/admin/backup">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="view-grid">
            <div class="view-card">
              <div class="view-label">Backup Name</div>
              <input class="input" id="bName" name="name" placeholder="e.g., Nightly Full Backup">
            </div>
            <div class="view-card">
              <div class="view-label">Type</div>
              <select class="select" id="bType" name="type">
                <option>Manual</option>
                <option>Scheduled</option>
                <option>Full</option>
                <option>Database</option>
                <option>Media</option>
              </select>
            </div>
            <div class="view-card">
              <div class="view-label">Scope</div>
              <select class="select" id="bScope" name="scope">
                <option>Full System</option>
                <option>Database Only</option>
                <option>Media Only</option>
                <option>Config Only</option>
              </select>
            </div>
            <div class="view-card">
              <div class="view-label">Storage Target</div>
              <select class="select" id="bStorage" name="storage">
                <option>Local</option>
                <option>S3</option>
                <option>Cloudinary</option>
              </select>
            </div>
            <div class="view-card">
              <div class="view-label">Retention Days</div>
              <input class="input" id="bRetentionDays" name="retentionDays" type="number" min="1" value="30">
            </div>
            <div class="view-card">
              <div class="view-label">Schedule At</div>
              <input class="input" id="bScheduleAt" name="scheduleAt" type="datetime-local">
            </div>
          </div>

          <div class="view-label">Notes</div>
          <textarea class="textarea" id="bNotes" name="notes" placeholder="Optional backup notes..."></textarea>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mCreate">Cancel</button>
          <button class="btn primary" id="saveBtn" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title">Backup Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="view-grid">
          <div class="view-card"><div class="view-label">Name</div><div class="view-value" id="vName">—</div></div>
          <div class="view-card"><div class="view-label">Type</div><div class="view-value" id="vType">—</div></div>
          <div class="view-card"><div class="view-label">Scope</div><div class="view-value" id="vScope">—</div></div>
          <div class="view-card"><div class="view-label">Storage</div><div class="view-value" id="vStorage">—</div></div>
          <div class="view-card"><div class="view-label">Status</div><div class="view-value" id="vStatus">—</div></div>
          <div class="view-card"><div class="view-label">Size</div><div class="view-value" id="vSize">—</div></div>
          <div class="view-card"><div class="view-label">Created</div><div class="view-value" id="vCreated">—</div></div>
          <div class="view-card"><div class="view-label">Retention Days</div><div class="view-value" id="vRetention">—</div></div>
        </div>

        <div class="view-label">Metadata</div>
        <div class="view-message" id="vMeta">—</div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/admin/backup/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="ids" id="bulkIds">
    <input type="hidden" name="action" id="bulkActionInput">
  </form>

  <textarea id="backupsData" class="json-data" aria-hidden="true"><%- JSON.stringify(backups || []) %></textarea>
  <textarea id="storageData" class="json-data" aria-hidden="true"><%- JSON.stringify(storageSummary || []) %></textarea>
  <textarea id="restoreData" class="json-data" aria-hidden="true"><%- JSON.stringify(restoreHistory || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/backup.js"></script>
</body>
</html>