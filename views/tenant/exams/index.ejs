<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Exams</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1650px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}
    .col-check{width:48px}
    .col-title{width:260px}
    .col-class{width:160px}
    .col-section{width:140px}
    .col-stream{width:140px}
    .col-subject{width:180px}
    .col-type{width:120px}
    .col-date{width:180px}
    .col-marks{width:130px}
    .col-status{width:120px}
    .col-actions{width:180px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .exam-title{font-weight:900}
    .exam-sub{font-size:12px;color:#6b7280;margin-top:2px}
    .actions{display:flex;gap:6px;justify-content:flex-end}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1080px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(760px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}
    .json-data{display:none !important}
    @media (max-width: 900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (messages?.success?.length || messages?.error?.length) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %>
          <% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Exams</div>
          <div class="subtitle">Create, schedule and manage academy exams.</div>
        </div>
        <div class="top-actions">
          <button class="btn primary" id="btnCreate" type="button">Add Exam</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div></div>
        <div class="card"><div class="section-title">Draft</div><div class="kpi-value"><%= kpis?.draft || 0 %></div></div>
        <div class="card"><div class="section-title">Scheduled</div><div class="kpi-value"><%= kpis?.scheduled || 0 %></div></div>
        <div class="card"><div class="section-title">Completed</div><div class="kpi-value"><%= kpis?.completed || 0 %></div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/tenant/exams" data-academic-selector>
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search exam, code, room..." />

            <select class="select" name="classGroup" data-role="class" data-placeholder="All Classes">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= String(c._id) %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>><%= c.name || c.code || 'Class' %></option>
              <% }) %>
            </select>

            <select class="select" name="sectionId" data-role="section" data-placeholder="All Sections" data-selected="<%= query?.sectionId || '' %>">
              <option value="">All Sections</option>
            </select>

            <select class="select" name="streamId" data-role="stream" data-placeholder="All Streams" data-selected="<%= query?.streamId || '' %>">
              <option value="">All Streams</option>
            </select>

            <select class="select" name="subject" data-role="subject" data-placeholder="All Subjects">
              <option value="">All Subjects</option>
              <% (subjects || []).forEach(function(s){ %>
                <option value="<%= String(s._id) %>" <%= String(query?.subject || '') === String(s._id) ? 'selected' : '' %>><%= s.title || s.code || 'Subject' %></option>
              <% }) %>
            </select>

            <select class="select" name="examType">
              <option value="">All Types</option>
              <% (examTypes || []).forEach(function(t){ %>
                <option value="<%= t %>" <%= query?.examType === t ? 'selected' : '' %>><%= t %></option>
              <% }) %>
            </select>

            <input class="input" name="academicYear" value="<%= query?.academicYear || '' %>" placeholder="Academic Year" />

            <select class="select" name="term">
              <option value="">All Terms</option>
              <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
              <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
              <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
            </select>

            <input class="input" type="datetime-local" name="from" value="<%= query?.from || '' %>" />
            <input class="input" type="datetime-local" name="to" value="<%= query?.to || '' %>" />

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="draft" <%= query?.status === 'draft' ? 'selected' : '' %>>Draft</option>
              <option value="scheduled" <%= query?.status === 'scheduled' ? 'selected' : '' %>>Scheduled</option>
              <option value="completed" <%= query?.status === 'completed' ? 'selected' : '' %>>Completed</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button">Bulk</button>
            <a class="btn light" href="/tenant/exams">Reset</a>
            <button class="btn primary" type="submit">Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div><strong>Selected</strong> <span class="badge-count" id="selCount">0</span></div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;">
            <button class="btn-xs" id="bulkDraft" type="button">Draft</button>
            <button class="btn-xs" id="bulkScheduled" type="button">Scheduled</button>
            <button class="btn-xs" id="bulkCompleted" type="button">Completed</button>
            <button class="btn-xs" id="bulkArchived" type="button">Archived</button>
            <button class="btn-xs" id="bulkDelete" type="button">Delete</button>
            <button class="btn-xs" id="bulkClear" type="button">Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap;">
            <div>
              <div class="section-title">Exams Table</div>
              <div class="section-sub">Showing <%= exams.length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-title">Exam</th>
                    <th class="col-class">Class</th>
                    <th class="col-section">Section</th>
                    <th class="col-stream">Stream</th>
                    <th class="col-subject">Subject</th>
                    <th class="col-type">Type</th>
                    <th class="col-date">Date</th>
                    <th class="col-marks">Marks</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyExams"></tbody>
              </table>
            </div>
          </div>

          <div class="pagination">
            <div class="muted">Rows per page: <strong><%= query?.perPage || 20 %></strong></div>
            <div class="pagination-links">
              <%
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.classGroup) params.set("classGroup", query.classGroup);
                  if (query?.sectionId) params.set("sectionId", query.sectionId);
                  if (query?.streamId) params.set("streamId", query.streamId);
                  if (query?.subject) params.set("subject", query.subject);
                  if (query?.examType) params.set("examType", query.examType);
                  if (query?.status) params.set("status", query.status);
                  if (query?.academicYear) params.set("academicYear", query.academicYear);
                  if (query?.term) params.set("term", query.term);
                  if (query?.from) params.set("from", query.from);
                  if (query?.to) params.set("to", query.to);
                  params.set("page", String(targetPage));
                  return "/tenant/exams?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
              %>

              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">&lt;</a>
              <% for (let p = startPage; p <= endPage; p++) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
              <% } %>
              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">&gt;</a>
            </div>
          </div>
        </section>

        <aside class="card">
          <div class="section-title">Quick Actions</div>
          <div class="mini-list">
            <div class="mini-item">
              <div><strong>Quick Test</strong><div class="muted">Preset to Test</div></div>
              <button class="btn-xs" id="quickTest" type="button">Open</button>
            </div>
            <div class="mini-item">
              <div><strong>Quick Endterm</strong><div class="muted">Preset to Endterm</div></div>
              <button class="btn-xs" id="quickEndterm" type="button">Open</button>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitleBar">Add Exam</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit">×</button>
      </div>

      <form id="examForm" method="POST" action="/tenant/exams" data-academic-selector>
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
        <div class="modal-body">
          <div class="form-grid">
            <div class="field"><label>Title</label><input class="input" id="mTitle" name="title" required /></div>
            <div class="field"><label>Code</label><input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" /></div>
            <div class="field"><label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="draft">Draft</option>
                <option value="scheduled">Scheduled</option>
                <option value="completed">Completed</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field"><label>Class</label>
              <select class="select" id="mClassGroup" name="classGroup" data-role="class" data-placeholder="Select Class" required>
                <option value="">— Select Class —</option>
                <% (classes || []).forEach(function(c){ %>
                  <option value="<%= String(c._id) %>"><%= c.name || c.code || 'Class' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field"><label>Section</label>
              <select class="select" id="mSection" name="sectionId" data-role="section" data-placeholder="Whole Class">
                <option value="">â€” Whole Class â€”</option>
              </select>
            </div>

            <div class="field"><label>Stream</label>
              <select class="select" id="mStream" name="streamId" data-role="stream" data-placeholder="All Streams">
                <option value="">â€” All Streams â€”</option>
              </select>
            </div>

            <div class="field"><label>Subject</label>
              <select class="select" id="mSubject" name="subject" data-role="subject" data-placeholder="Select Subject" required>
                <option value="">— Select Subject —</option>
                <% (subjects || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.title || s.code || 'Subject' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field"><label>Teacher</label>
              <select class="select" id="mTeacher" name="teacher">
                <option value="">— Select Teacher —</option>
                <% (staffList || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field"><label>Academic Year</label><input class="input" id="mAcademicYear" name="academicYear" data-role="academicYear" /></div>

            <div class="field"><label>Term</label>
              <select class="select" id="mTerm" name="term" data-role="term">
                <option value="1">Term 1</option>
                <option value="2">Term 2</option>
                <option value="3">Term 3</option>
              </select>
            </div>

            <div class="field"><label>Exam Type</label>
              <select class="select" id="mExamType" name="examType">
                <% (examTypes || []).forEach(function(t){ %>
                  <option value="<%= t %>"><%= t %></option>
                <% }) %>
              </select>
            </div>

            <div class="field"><label>Exam Date</label><input class="input" id="mExamDate" name="examDate" type="datetime-local" required /></div>
            <div class="field"><label>Start Time</label><input class="input" id="mStartTime" name="startTime" placeholder="08:00" /></div>
            <div class="field"><label>End Time</label><input class="input" id="mEndTime" name="endTime" placeholder="10:00" /></div>
            <div class="field"><label>Duration (Minutes)</label><input class="input" id="mDurationMinutes" name="durationMinutes" type="number" min="0" max="1440" /></div>
            <div class="field"><label>Max Marks</label><input class="input" id="mMaxMarks" name="maxMarks" type="number" min="0" max="1000" /></div>
            <div class="field"><label>Pass Mark</label><input class="input" id="mPassMark" name="passMark" type="number" min="0" max="1000" /></div>
            <div class="field"><label>Room</label><input class="input" id="mRoom" name="room" /></div>
            <div class="field"><label>Campus</label><input class="input" id="mCampus" name="campus" /></div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Instructions</label>
            <textarea class="textarea" id="mInstructions" name="instructions" maxlength="3000"></textarea>
            <div class="muted" id="instructionsCount">0 / 3000</div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button">Save Exam</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Exam Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView">×</button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Title</label><div class="view-input" id="vTitle">—</div></div>
          <div class="field"><label>Code</label><div class="view-input" id="vCode">—</div></div>
          <div class="field"><label>Class</label><div class="view-input" id="vClassGroup">—</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vSection">—</div></div>
          <div class="field"><label>Stream</label><div class="view-input" id="vStream">—</div></div>
          <div class="field"><label>Subject</label><div class="view-input" id="vSubject">—</div></div>
          <div class="field"><label>Teacher</label><div class="view-input" id="vTeacher">—</div></div>
          <div class="field"><label>Academic</label><div class="view-input" id="vAcademic">—</div></div>
          <div class="field"><label>Type</label><div class="view-input" id="vType">—</div></div>
          <div class="field"><label>Exam Date</label><div class="view-input" id="vExamDate">—</div></div>
          <div class="field"><label>Time</label><div class="view-input" id="vTime">—</div></div>
          <div class="field"><label>Duration</label><div class="view-input" id="vDuration">—</div></div>
          <div class="field"><label>Marks</label><div class="view-input" id="vMarks">—</div></div>
          <div class="field"><label>Room</label><div class="view-input" id="vRoom">—</div></div>
          <div class="field"><label>Campus</label><div class="view-input" id="vCampus">—</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div>
        </div>

        <div class="divider"></div>
        <div class="field"><label>Instructions</label><div class="view-input multiline" id="vInstructions">—</div></div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn">Edit</button>
      </div>
    </div>
  </div>

  <form id="deleteForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <form id="bulkForm" method="POST" action="/tenant/exams/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkAction">
    <input type="hidden" name="ids" id="bulkIds">
  </form>

  <textarea id="examsData" class="json-data" aria-hidden="true"><%- JSON.stringify((exams || []).map(function(e){
    const examDateObj = e.examDate ? new Date(e.examDate) : null;
    const examDateLabel = examDateObj && !isNaN(examDateObj.getTime()) ? examDateObj.toLocaleString() : '';
    const examDateInput = examDateObj && !isNaN(examDateObj.getTime()) ? new Date(examDateObj.getTime() - examDateObj.getTimezoneOffset() * 60000).toISOString().slice(0,16) : '';
    return {
      id: String(e._id || ''),
      title: e.title || '',
      code: e.code || '',
      classGroupId: e.classGroup?._id ? String(e.classGroup._id) : '',
      className: e.classGroup?.name || '',
      sectionId: e.sectionId?._id ? String(e.sectionId._id) : String(e.sectionId || ''),
      sectionName: e.sectionName || e.sectionId?.name || '',
      streamId: e.streamId?._id ? String(e.streamId._id) : String(e.streamId || ''),
      streamName: e.streamName || e.streamId?.name || '',
      subjectId: e.subject?._id ? String(e.subject._id) : '',
      subjectName: e.subject?.title || e.subject?.code || '',
      teacherId: e.teacher?._id ? String(e.teacher._id) : '',
      teacherName: e.teacher?.fullName || e.teacher?.name || '',
      academicYear: e.academicYear || '',
      term: Number(e.term || 1),
      examType: e.examType || 'test',
      examDateInput,
      examDateLabel,
      startTime: e.startTime || '',
      endTime: e.endTime || '',
      durationMinutes: Number(e.durationMinutes || 0),
      maxMarks: Number(e.maxMarks || 0),
      passMark: Number(e.passMark || 0),
      room: e.room || '',
      campus: e.campus || '',
      instructions: e.instructions || '',
      status: e.status || 'draft'
    };
  })) %></textarea>

  <textarea id="classesData" class="json-data" aria-hidden="true"><%- JSON.stringify(classes || []) %></textarea>
  <textarea id="sectionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="streamsData" class="json-data" aria-hidden="true"><%- JSON.stringify(streams || []) %></textarea>
  <textarea id="subjectOptionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(subjectOptions || subjects || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/academic-selector.js"></script>
  <script src="/js/exams.js"></script>
</body>
</html>
