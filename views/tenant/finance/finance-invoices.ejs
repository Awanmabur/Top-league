<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>Admin • Invoice Detail — Classic Academy</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center
    }

    .toolbar .left,
    .toolbar .right {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center
    }

    .input,
    .select,
    .textarea {
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgba(13, 64, 96, .16);
      background: #fff;
      outline: none
    }

    .input {
      min-width: 220px;
      width: 100%
    }

    .textarea {
      width: 100%;
      min-height: 110px;
      resize: vertical
    }

    .input:focus,
    .select:focus,
    .textarea:focus {
      border-color: rgba(10, 111, 191, .45);
      box-shadow: 0 0 0 3px rgba(10, 111, 191, .12)
    }

    .muted {
      font-size: 12px;
      color: #6b7280
    }

    .strong {
      font-weight: 900
    }

    .grid-4 {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px
    }

    .grid-2 {
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(320px, .75fr);
      gap: 12px
    }

    .grid-2b {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px
    }

    .chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap
    }

    .chip {
      border: 1px solid rgba(13, 64, 96, .14);
      background: #fff;
      border-radius: 999px;
      padding: 8px 12px;
      cursor: pointer;
      font-weight: 900;
      font-size: 12px
    }

    .chip.active {
      background: rgba(10, 111, 191, .12);
      border-color: rgba(10, 111, 191, .35)
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900;
      white-space: nowrap
    }

    .ok {
      background: #ecfdf3;
      color: #15803d
    }

    .warn {
      background: #fef9c3;
      color: #92400e
    }

    .bad {
      background: #fee2e2;
      color: #b91c1c
    }

    .info {
      background: #eef2ff;
      color: #3730a3
    }

    .pin {
      background: rgba(10, 111, 191, .12);
      color: #0a6fbf
    }

    .table-wrap {
      overflow: auto;
      border: 1px solid rgba(13, 64, 96, .10);
      border-radius: 12px;
      max-width: 100%
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 920px;
      background: #fff
    }

    th,
    td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(13, 64, 96, .08);
      vertical-align: middle
    }

    th {
      font-size: 12px;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: .04em;
      text-align: left;
      background: rgba(13, 64, 96, .03);
      position: sticky;
      top: 0;
      z-index: 1
    }

    tr:hover td {
      background: rgba(10, 111, 191, .04)
    }

    .right-text {
      text-align: right
    }

    .actions {
      display: flex;
      gap: 6px;
      justify-content: flex-end;
      flex-wrap: wrap;
      max-width: 100%
    }

    .btn-xs {
      padding: 6px 8px;
      border-radius: 10px;
      border: 1px solid rgba(13, 64, 96, .14);
      background: #fff;
      cursor: pointer;
      font-size: 12px;
      flex: 0 0 auto
    }

    .btn-xs:hover {
      background: rgba(10, 111, 191, .06)
    }

    .note {
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px dashed rgba(13, 64, 96, .18);
      background: rgba(13, 64, 96, .03)
    }

    .mini-list {
      display: grid;
      gap: 10px;
      margin-top: 10px
    }

    .mini-item {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      padding: 10px 12px;
      border: 1px solid rgba(13, 64, 96, .10);
      border-radius: 12px;
      background: #fff
    }

    .mini-item .left {
      display: grid;
      gap: 2px
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 14px;
      flex-wrap: nowrap
    }

    .topbar>div:first-child {
      min-width: 0;
      flex: 1 1 auto
    }

    .top-actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
      align-items: center;
      flex: 0 0 auto;
      margin-left: auto
    }

    .tabs {
      display: flex;
      gap: 8px;
      flex-wrap: wrap
    }

    .tab {
      border: 1px solid rgba(13, 64, 96, .14);
      background: #fff;
      border-radius: 999px;
      padding: 8px 12px;
      cursor: pointer;
      font-weight: 900;
      font-size: 12px
    }

    .tab.active {
      background: rgba(10, 111, 191, .12);
      border-color: rgba(10, 111, 191, .35)
    }

    .pane {
      display: none;
      margin-top: 10px
    }

    .pane.active {
      display: block
    }

    .timeline {
      display: grid;
      gap: 10px
    }

    .timeline-item {
      border: 1px solid rgba(13, 64, 96, .10);
      border-radius: 14px;
      padding: 12px;
      background: #fff
    }

    .timeline-top {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: flex-start
    }

    .flash-wrap {
      display: grid;
      gap: 10px;
      margin-bottom: 12px
    }

    .flash {
      padding: 12px 14px;
      border-radius: 12px;
      font-weight: 700
    }

    .flash-success {
      background: #ecfdf3;
      color: #166534;
      border: 1px solid #bbf7d0
    }

    .flash-error {
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca
    }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, .45);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 30px 18px;
      z-index: 9999;
      overflow-y: auto;
      overflow-x: hidden
    }

    .modal-backdrop.show {
      display: flex
    }

    .modal {
      width: min(960px, 100%);
      max-height: calc(100dvh - 60px);
      background: #fff;
      border-radius: 22px;
      box-shadow: 0 24px 70px rgba(0, 0, 0, .25);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      margin: auto
    }

    .modal.sm {
      width: min(760px, 100%)
    }

    .modal.lg {
      width: min(1080px, 100%)
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(13, 64, 96, .10);
      flex: 0 0 auto;
      background: #fff
    }

    .modal-title {
      font-weight: 900;
      font-size: 18px
    }

    .modal-body {
      padding: 16px 18px;
      flex: 1 1 auto;
      min-height: 0;
      overflow-y: auto;
      overflow-x: hidden;
      -webkit-overflow-scrolling: touch
    }

    .modal-footer {
      display: flex;
      justify-content: flex-end;
      gap: 10px;
      padding: 14px 18px;
      border-top: 1px solid rgba(13, 64, 96, .10);
      flex: 0 0 auto;
      background: #fff;
      flex-wrap: wrap;
      position: relative;
      z-index: 2;
      box-shadow: 0 -8px 18px rgba(0, 0, 0, .04)
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px
    }

    .field label {
      display: block;
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 6px
    }

    .field input,
    .field select,
    .field textarea {
      width: 100%
    }

    .divider {
      height: 1px;
      background: rgba(13, 64, 96, .10);
      margin: 12px 0
    }

    .flag-list {
      display: grid;
      gap: 10px
    }

    .flag-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #6b7280;
      font-size: 13px
    }

    @media print {

      .top-actions,
      .mini-list,
      .tabs,
      .btn,
      .btn-xs {
        display: none !important
      }

      .app {
        display: block
      }

      .main {
        padding: 0
      }

      .card {
        box-shadow: none !important
      }
    }

    @media (max-width: 1100px) {
      .grid-2 {
        grid-template-columns: 1fr
      }
    }

    @media (max-width: 900px) {

      .form-grid,
      .grid-2b {
        grid-template-columns: 1fr
      }

      .topbar {
        flex-wrap: wrap
      }

      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px) {
      .grid-4 {
        grid-template-columns: repeat(2, minmax(0, 1fr))
      }

      .input {
        min-width: 160px
      }
    }

    @media (max-width: 520px) {
      .grid-4 {
        grid-template-columns: 1fr
      }

      .toolbar .left,
      .toolbar .right {
        width: 100%
      }

      .toolbar .left>*,
      .toolbar .right>* {
        max-width: 100%
      }

      .actions {
        justify-content: flex-start
      }

      table {
        min-width: 760px
      }

      .modal-backdrop {
        padding: 30px 12px
      }

      .modal {
        max-height: calc(100dvh - 60px);
        border-radius: 20px
      }

      .modal-header,
      .modal-body,
      .modal-footer {
        padding-left: 14px;
        padding-right: 14px
      }
    }
  </style>
</head>

<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

      <main class="main">
        <% if (typeof messages !=="undefined" && (messages.success?.length || messages.error?.length)) { %>
          <div class="flash-wrap">
            <% (messages.success || []).forEach(function(msg){ %>
              <div class="flash flash-success">
                <%= msg %>
              </div>
              <% }) %>
                <% (messages.error || []).forEach(function(msg){ %>
                  <div class="flash flash-error">
                    <%= msg %>
                  </div>
                  <% }) %>
          </div>
          <% } %>

            <div class="topbar">
              <div>
                <div class="title">Invoice Detail</div>
                <div class="subtitle">View invoice items, payment history, balance, waivers, penalties, receipts and
                  audit trail.</div>
              </div>

              <div class="top-actions">
                <button class="btn light" id="btnBack" type="button"><i class="fa-solid fa-arrow-left"></i>
                  Back</button>
                <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
                <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i>
                  Export</button>
                <button class="btn light" id="btnReceipt" type="button"><i class="fa-solid fa-receipt"></i>
                  Receipt</button>
                <button class="btn light" id="btnReminder" type="button"><i class="fa-solid fa-bell"></i> Send
                  Reminder</button>
                <button class="btn light" id="btnWaive" type="button"><i class="fa-solid fa-hand-holding-heart"></i>
                  Apply Waiver</button>
                <button class="btn primary" id="btnPay" type="button"><i class="fa-solid fa-coins"></i> Record
                  Payment</button>
                <button class="btn light" id="btnVoid" type="button"><i class="fa-solid fa-ban"></i> Void
                  Invoice</button>
              </div>
            </div>

            <div class="grid-4">
              <div class="card">
                <div class="section-title">Invoice</div>
                <div class="kpi-value" id="kInv">INV-0001</div>
                <div class="muted" id="kMeta">Semester: 2025/2026 - Sem 1</div>
              </div>
              <div class="card">
                <div class="section-title">Total</div>
                <div class="kpi-value" style="color:#0a6fbf" id="kTotal">UGX 2,500,000</div>
                <div class="muted">All line items</div>
              </div>
              <div class="card">
                <div class="section-title">Paid</div>
                <div class="kpi-value" style="color:#15803d" id="kPaid">UGX 1,500,000</div>
                <div class="muted">Payments received</div>
              </div>
              <div class="card">
                <div class="section-title">Balance</div>
                <div class="kpi-value" style="color:#92400e" id="kBal">UGX 1,000,000</div>
                <div class="muted" id="kStatusWrap">
                  <span class="pill warn"><i class="fa-solid fa-circle-half-stroke"></i> Partially Paid</span>
                </div>
              </div>
            </div>

            <div class="grid-2" style="margin-top:12px;">
              <section class="card" style="min-width:0;">
                <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
                  <div>
                    <div class="section-title">Student & Billing Info</div>
                    <div class="section-sub" id="sMeta">Student: Jonathan Kuipers (CS/2025/011) • Due: 2025-12-05</div>
                  </div>
                  <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <button class="btn light" id="btnEdit" type="button"><i class="fa-solid fa-pen"></i> Edit</button>
                    <button class="btn light" id="btnAddItem" type="button"><i class="fa-solid fa-plus"></i> Add
                      Item</button>
                    <button class="btn light" id="btnPenalty" type="button"><i
                        class="fa-solid fa-triangle-exclamation"></i> Add Penalty</button>
                  </div>
                </div>

                <div class="grid-2b" style="margin-top:12px;">
                  <div class="field">
                    <label>Student</label>
                    <input class="input" id="fStudent" value="Jonathan Kuipers (CS/2025/011)" disabled>
                  </div>
                  <div class="field">
                    <label>Semester</label>
                    <select class="select" id="fSem" disabled>
                      <option selected>2025/2026 - Sem 1</option>
                      <option>2024/2025 - Sem 2</option>
                    </select>
                  </div>

                  <div class="field">
                    <label>Invoice Date</label>
                    <input class="input" id="fInvDate" type="date" value="2025-11-10" disabled>
                  </div>
                  <div class="field">
                    <label>Due Date</label>
                    <input class="input" id="fDue" type="date" value="2025-12-05" disabled>
                  </div>

                  <div class="field">
                    <label>Status</label>
                    <select class="select" id="fStatus" disabled>
                      <option>Unpaid</option>
                      <option selected>Partially Paid</option>
                      <option>Paid</option>
                      <option>Overdue</option>
                      <option>Waived</option>
                      <option>Voided</option>
                    </select>
                  </div>
                  <div class="field">
                    <label>Payment Plan</label>
                    <select class="select" id="fPlan" disabled>
                      <option selected>None</option>
                      <option>Installments</option>
                      <option>Sponsored</option>
                    </select>
                  </div>
                </div>

                <div class="divider"></div>

                <div class="tabs" id="tabs">
                  <button class="tab active" data-pane="pane-items" type="button"><i class="fa-solid fa-list"></i> Line
                    Items</button>
                  <button class="tab" data-pane="pane-pay" type="button"><i class="fa-solid fa-receipt"></i>
                    Payments</button>
                  <button class="tab" data-pane="pane-notes" type="button"><i class="fa-solid fa-note-sticky"></i>
                    Notes</button>
                  <button class="tab" data-pane="pane-audit" type="button"><i class="fa-solid fa-clock-rotate-left"></i>
                    Audit Trail</button>
                </div>

                <div class="pane active" id="pane-items">
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>Item</th>
                          <th>Description</th>
                          <th class="right-text">Qty</th>
                          <th class="right-text">Unit</th>
                          <th class="right-text">Amount</th>
                          <th class="right-text" style="width:170px;">Actions</th>
                        </tr>
                      </thead>
                      <tbody id="itemsBody"></tbody>
                      <tfoot>
                        <tr>
                          <td colspan="4" class="right-text strong">Total</td>
                          <td class="right-text strong" id="itemsTotal">UGX 0</td>
                          <td></td>
                        </tr>
                      </tfoot>
                    </table>
                  </div>
                </div>

                <div class="pane" id="pane-pay">
                  <div class="table-wrap">
                    <table>
                      <thead>
                        <tr>
                          <th>Payment</th>
                          <th>Method</th>
                          <th>Reference</th>
                          <th>Date</th>
                          <th class="right-text">Amount</th>
                          <th class="right-text" style="width:170px;">Actions</th>
                        </tr>
                      </thead>
                      <tbody id="payBody"></tbody>
                    </table>
                  </div>
                </div>

                <div class="pane" id="pane-notes">
                  <div class="field">
                    <label>Internal Notes</label>
                    <textarea class="textarea" id="notes"
                      placeholder="Add internal notes, waiver reasons, reminders, disputes..."></textarea>
                    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;">
                      <button class="btn light" id="btnSaveNotes" type="button"><i class="fa-solid fa-check"></i> Save
                        Notes</button>
                      <button class="btn light" id="btnStudentMsg" type="button"><i class="fa-solid fa-envelope"></i>
                        Message Student</button>
                    </div>
                  </div>
                </div>

                <div class="pane" id="pane-audit">
                  <div class="timeline" id="auditList"></div>
                  <div class="divider"></div>
                  <div style="display:flex;gap:8px;flex-wrap:wrap;">
                    <button class="btn light" id="btnAddAudit" type="button"><i class="fa-solid fa-plus"></i> Add Audit
                      Note</button>
                    <button class="btn light" id="btnExportAudit" type="button"><i
                        class="fa-solid fa-file-arrow-down"></i> Export Audit</button>
                  </div>
                </div>

                <div class="note" style="margin-top:12px;">
                  <strong>Finance controls included:</strong> edit invoice details, add/remove items, record/delete
                  payments, apply waivers, penalties, reminders and audit history.
                </div>
              </section>

              <aside class="card" style="min-width:0;">
                <div class="section-title">Collections Actions</div>
                <div class="section-sub">Quick finance operations.</div>

                <div class="mini-list">
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Balance</div>
                      <div class="muted" id="balanceHint">Due balance for this invoice</div>
                    </div>
                    <div class="strong" id="balanceCard">UGX 1,000,000</div>
                  </div>

                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Quick Payment</div>
                      <div class="muted">Record student payment now</div>
                    </div>
                    <button class="btn-xs" id="quickPay" type="button"><i class="fa-solid fa-coins"></i></button>
                  </div>

                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Receipt</div>
                      <div class="muted">Open receipt / payment print</div>
                    </div>
                    <button class="btn-xs" id="quickReceipt" type="button"><i class="fa-solid fa-receipt"></i></button>
                  </div>

                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Statement</div>
                      <div class="muted">Open student statement</div>
                    </div>
                    <button class="btn-xs" id="quickStatement" type="button"><i
                        class="fa-solid fa-file-lines"></i></button>
                  </div>
                </div>

                <div class="divider"></div>

                <div class="section-title">Risk / Flags</div>
                <div class="section-sub">Use flags for collections follow-up.</div>
                <div class="flag-list" style="margin-top:10px;">
                  <label class="flag-item"><input type="checkbox" id="flagOverdue"> <span>Overdue
                      follow-up</span></label>
                  <label class="flag-item"><input type="checkbox" id="flagDispute"> <span>Disputed
                      invoice</span></label>
                  <label class="flag-item"><input type="checkbox" id="flagHold"> <span>Apply registration
                      hold</span></label>
                </div>

                <div class="divider"></div>

                <div class="section-title">Next Actions</div>
                <div class="mini-list">
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Send Reminder</div>
                      <div class="muted">Notify the student</div>
                    </div>
                    <button class="btn-xs" id="sideReminder" type="button"><i class="fa-solid fa-bell"></i></button>
                  </div>
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Apply Waiver</div>
                      <div class="muted">Scholarship / fee support</div>
                    </div>
                    <button class="btn-xs" id="sideWaive" type="button"><i
                        class="fa-solid fa-hand-holding-heart"></i></button>
                  </div>
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Add Penalty</div>
                      <div class="muted">Late payment charge</div>
                    </div>
                    <button class="btn-xs" id="sidePenalty" type="button"><i
                        class="fa-solid fa-triangle-exclamation"></i></button>
                  </div>
                  <div class="mini-item">
                    <div class="left">
                      <div class="strong">Void Invoice</div>
                      <div class="muted">Authorized finance action</div>
                    </div>
                    <button class="btn-xs" id="sideVoid" type="button"><i class="fa-solid fa-ban"></i></button>
                  </div>
                </div>
              </aside>
            </div>
      </main>
  </div>

  <!-- Add/Edit Item -->
  <div class="modal-backdrop" id="mItem">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title" id="mItemTitle">Add Line Item</div>
        <button class="btn-xs" type="button" data-close-modal="mItem"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Item</label>
            <input class="input" id="itName" placeholder="Tuition / Hostel / Library Fine">
          </div>
          <div class="field">
            <label>Qty</label>
            <input class="input" id="itQty" type="number" min="1" value="1">
          </div>
          <div class="field">
            <label>Unit Price (UGX)</label>
            <input class="input" id="itUnit" type="number" min="0" value="0">
          </div>
          <div class="field">
            <label>Description</label>
            <input class="input" id="itDesc" placeholder="Optional">
          </div>
        </div>
        <input type="hidden" id="itId">
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mItem">Cancel</button>
        <button class="btn primary" id="saveItem" type="button"><i class="fa-solid fa-check"></i> Save Item</button>
      </div>
    </div>
  </div>

  <!-- Record Payment -->
  <div class="modal-backdrop" id="mPay">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Record Payment</div>
        <button class="btn-xs" type="button" data-close-modal="mPay"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Amount Paid (UGX)</label>
            <input class="input" id="pAmt" type="number" min="0" value="500000">
          </div>
          <div class="field">
            <label>Method</label>
            <select class="select" id="pMethod">
              <option>Mobile Money</option>
              <option>Bank</option>
              <option>Cash</option>
              <option>Card</option>
            </select>
          </div>
          <div class="field">
            <label>Reference</label>
            <input class="input" id="pRef" placeholder="Txn/Bank ref">
          </div>
          <div class="field">
            <label>Date</label>
            <input class="input" id="pDate" type="date">
          </div>
          <div class="field">
            <label>Received By</label>
            <input class="input" id="pBy" placeholder="Cashier">
          </div>
          <div class="field">
            <label>Notes</label>
            <input class="input" id="pNotes" placeholder="Optional">
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mPay">Cancel</button>
        <button class="btn primary" id="savePay" type="button"><i class="fa-solid fa-receipt"></i> Save Payment</button>
      </div>
    </div>
  </div>

  <!-- Apply Waiver -->
  <div class="modal-backdrop" id="mWaive">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Apply Waiver / Scholarship</div>
        <button class="btn-xs" type="button" data-close-modal="mWaive"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Type</label>
            <select class="select" id="wType">
              <option>Fee Waiver</option>
              <option>Partial Scholarship</option>
              <option>Full Scholarship</option>
            </select>
          </div>
          <div class="field">
            <label>Amount (UGX)</label>
            <input class="input" id="wAmt" type="number" min="0" value="200000">
          </div>
        </div>
        <div class="divider"></div>
        <div class="field">
          <label>Reason</label>
          <textarea class="textarea" id="wReason"
            placeholder="Waiver reason, approval ref, scholarship name..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mWaive">Cancel</button>
        <button class="btn light" id="saveWaive" type="button"><i class="fa-solid fa-hand-holding-heart"></i>
          Apply</button>
      </div>
    </div>
  </div>

  <!-- Add Penalty -->
  <div class="modal-backdrop" id="mPenalty">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Add Penalty</div>
        <button class="btn-xs" type="button" data-close-modal="mPenalty"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Penalty Name</label>
            <input class="input" id="penName" value="Late payment penalty">
          </div>
          <div class="field">
            <label>Amount (UGX)</label>
            <input class="input" id="penAmt" type="number" min="0" value="50000">
          </div>
        </div>
        <div class="divider"></div>
        <div class="field">
          <label>Reason</label>
          <textarea class="textarea" id="penReason" placeholder="Reason and policy reference..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mPenalty">Cancel</button>
        <button class="btn light" id="savePenalty" type="button"><i class="fa-solid fa-triangle-exclamation"></i>
          Add</button>
      </div>
    </div>
  </div>

  <script src="/js/navbar.js"></script>
  <script>
    (function () {
      const $ = (id) => document.getElementById(id);

      function openModal(id) {
        const el = $(id);
        if (!el) return;
        el.classList.add("show");
      }

      function closeModal(id) {
        const el = $(id);
        if (!el) return;
        el.classList.remove("show");
      }

      function fmt(n) {
        try {
          return new Intl.NumberFormat("en-US").format(Number(n || 0));
        } catch (e) {
          return String(n || 0);
        }
      }

      const invoice = {
        id: "INV-0001",
        student: "Jonathan Kuipers (CS/2025/011)",
        semester: "2025/2026 - Sem 1",
        invDate: "2025-11-10",
        due: "2025-12-05",
        status: "Partially Paid",
        plan: "None",
        notes: "",
        items: [
          { id: "I1", name: "Tuition", desc: "Main tuition fee", qty: 1, unit: 2500000 }
        ],
        payments: [
          { id: "PAY-1001", method: "Mobile Money", ref: "MTN-33A99", date: "2025-11-18", amount: 1500000 }
        ],
        audit: [
          { title: "Invoice created", meta: "2025-11-10 10:00", who: "Finance" },
          { title: "Payment recorded: UGX 1,500,000", meta: "2025-11-18 14:22", who: "Cashier" }
        ]
      };

      function sumItems() {
        return invoice.items.reduce((acc, it) => acc + (Number(it.qty || 0) * Number(it.unit || 0)), 0);
      }

      function sumPaid() {
        return invoice.payments.reduce((acc, p) => acc + Number(p.amount || 0), 0);
      }

      function balance() {
        return Math.max(sumItems() - sumPaid(), 0);
      }

      function statusPill(status) {
        if (status === "Paid") return '<span class="pill ok"><i class="fa-solid fa-check"></i> Paid</span>';
        if (status === "Overdue") return '<span class="pill bad"><i class="fa-solid fa-clock"></i> Overdue</span>';
        if (status === "Waived") return '<span class="pill info"><i class="fa-solid fa-hand-holding-heart"></i> Waived</span>';
        if (status === "Voided") return '<span class="pill bad"><i class="fa-solid fa-ban"></i> Voided</span>';
        if (status === "Partially Paid") return '<span class="pill warn"><i class="fa-solid fa-circle-half-stroke"></i> Partially Paid</span>';
        return '<span class="pill bad"><i class="fa-solid fa-triangle-exclamation"></i> Unpaid</span>';
      }

      function addAudit(title, who) {
        invoice.audit.unshift({
          title,
          meta: new Date().toLocaleString(),
          who: who || "Finance"
        });
        renderAudit();
      }

      function recomputeStatus() {
        const bal = balance();
        if (invoice.status === "Voided") return;

        const today = new Date();
        const dueDate = new Date(invoice.due + "T00:00:00");

        if (bal <= 0) invoice.status = "Paid";
        else if (dueDate < today && sumPaid() < sumItems()) invoice.status = "Overdue";
        else if (sumPaid() > 0) invoice.status = "Partially Paid";
        else invoice.status = "Unpaid";
      }

      function renderHeader() {
        $("kInv").textContent = invoice.id;
        $("kMeta").textContent = "Semester: " + invoice.semester;
        $("sMeta").textContent = `Student: ${invoice.student} • Due: ${invoice.due}`;

        $("fStudent").value = invoice.student;
        $("fInvDate").value = invoice.invDate;
        $("fDue").value = invoice.due;
        $("fSem").value = invoice.semester;
        $("fStatus").value = invoice.status;
        $("fPlan").value = invoice.plan;

        const total = sumItems();
        const paid = sumPaid();
        const bal = balance();

        $("kTotal").textContent = "UGX " + fmt(total);
        $("kPaid").textContent = "UGX " + fmt(paid);
        $("kBal").textContent = "UGX " + fmt(bal);
        $("itemsTotal").textContent = "UGX " + fmt(total);
        $("balanceCard").textContent = "UGX " + fmt(bal);
        $("kStatusWrap").innerHTML = statusPill(invoice.status);
      }

      function renderItems() {
        $("itemsBody").innerHTML = invoice.items.map((it) => {
          const amount = Number(it.qty || 0) * Number(it.unit || 0);
          return `
            <tr data-id="${it.id}">
              <td class="strong">${it.name}</td>
              <td class="muted">${it.desc || "—"}</td>
              <td class="right-text">${it.qty}</td>
              <td class="right-text">UGX ${fmt(it.unit)}</td>
              <td class="right-text strong">UGX ${fmt(amount)}</td>
              <td>
                <div class="actions">
                  <button class="btn-xs actEditItem" type="button" title="Edit"><i class="fa-solid fa-pen"></i></button>
                  <button class="btn-xs actDelItem" type="button" title="Delete"><i class="fa-solid fa-trash"></i></button>
                </div>
              </td>
            </tr>
          `;
        }).join("") || `
          <tr>
            <td colspan="6" style="padding:18px;">
              <div class="muted">No line items found.</div>
            </td>
          </tr>
        `;
      }

      function renderPayments() {
        $("payBody").innerHTML = invoice.payments.map((p) => `
          <tr data-id="${p.id}">
            <td class="strong">${p.id}</td>
            <td class="muted">${p.method}</td>
            <td class="muted">${p.ref}</td>
            <td class="muted">${p.date}</td>
            <td class="right-text strong">UGX ${fmt(p.amount)}</td>
            <td>
              <div class="actions">
                <button class="btn-xs actPrintReceipt" type="button" title="Receipt"><i class="fa-solid fa-print"></i></button>
                <button class="btn-xs actDelPay" type="button" title="Delete"><i class="fa-solid fa-trash"></i></button>
              </div>
            </td>
          </tr>
        `).join("") || `
          <tr>
            <td colspan="6" style="padding:18px;">
              <div class="muted">No payments yet.</div>
            </td>
          </tr>
        `;
      }

      function renderAudit() {
        $("auditList").innerHTML = invoice.audit.map((a) => `
          <div class="timeline-item">
            <div class="timeline-top">
              <div>
                <div class="strong">${a.title}</div>
                <div class="muted" style="margin-top:4px;">${a.meta}</div>
              </div>
              <span class="pill info"><i class="fa-solid fa-user"></i> ${a.who}</span>
            </div>
          </div>
        `).join("");
      }

      function renderAll() {
        recomputeStatus();
        renderHeader();
        renderItems();
        renderPayments();
        renderAudit();
      }

      function setActivePane(paneId) {
        document.querySelectorAll("#tabs .tab").forEach((tab) => {
          tab.classList.toggle("active", tab.dataset.pane === paneId);
        });
        document.querySelectorAll(".pane").forEach((pane) => {
          pane.classList.toggle("active", pane.id === paneId);
        });
      }

      function openPenalty() {
        openModal("mPenalty");
      }

      function openWaive() {
        openModal("mWaive");
      }

      function openPay() {
        openModal("mPay");
      }

      $("tabs").addEventListener("click", function (e) {
        const btn = e.target.closest(".tab");
        if (!btn) return;
        setActivePane(btn.dataset.pane);
      });

      $("btnBack").addEventListener("click", function () {
        history.back();
      });

      $("btnPrint").addEventListener("click", function () {
        window.print();
      });

      $("btnExport").addEventListener("click", function () {
        alert("Export invoice (PDF/CSV) — backend later.");
      });

      $("btnReceipt").addEventListener("click", function () {
        alert("Receipt print page (next).");
      });

      $("btnReminder").addEventListener("click", function () {
        addAudit("Reminder sent to student", "Finance");
        alert("Reminder sent (UI).");
      });

      $("btnEdit").addEventListener("click", function () {
        const enable = $("fDue").disabled;
        ["fSem", "fInvDate", "fDue", "fStatus", "fPlan"].forEach((id) => {
          $(id).disabled = !enable;
        });
        addAudit(enable ? "Editing invoice fields" : "Locked invoice fields", "Finance");
      });

      $("btnAddItem").addEventListener("click", function () {
        $("mItemTitle").textContent = "Add Line Item";
        $("itId").value = "";
        $("itName").value = "";
        $("itDesc").value = "";
        $("itQty").value = 1;
        $("itUnit").value = 0;
        openModal("mItem");
      });

      $("btnPenalty").addEventListener("click", openPenalty);
      $("sidePenalty").addEventListener("click", openPenalty);

      $("btnWaive").addEventListener("click", openWaive);
      $("sideWaive").addEventListener("click", openWaive);

      $("btnPay").addEventListener("click", openPay);
      $("quickPay").addEventListener("click", openPay);

      $("quickReceipt").addEventListener("click", function () {
        alert("Receipt page next.");
      });

      $("quickStatement").addEventListener("click", function () {
        alert("Student statement page next.");
      });

      function voidInvoice() {
        if (!window.confirm("Void this invoice? This should be done only by authorized finance staff.")) return;
        invoice.status = "Voided";
        addAudit("Invoice voided", "Finance Admin");
        renderAll();
      }

      $("btnVoid").addEventListener("click", voidInvoice);
      $("sideVoid").addEventListener("click", voidInvoice);

      $("btnSaveNotes").addEventListener("click", function () {
        invoice.notes = $("notes").value;
        addAudit("Notes updated", "Finance");
        alert("Notes saved (UI).");
      });

      $("btnStudentMsg").addEventListener("click", function () {
        alert("Message student (email/SMS) — backend later.");
      });

      $("btnAddAudit").addEventListener("click", function () {
        const note = prompt("Add audit note:");
        if (note) addAudit(note, "Finance");
      });

      $("btnExportAudit").addEventListener("click", function () {
        alert("Export audit logs — backend later.");
      });

      $("saveItem").addEventListener("click", function () {
        const id = $("itId").value || ("I" + Math.floor(Math.random() * 9000 + 1000));
        const obj = {
          id,
          name: $("itName").value || "Fee Item",
          desc: $("itDesc").value || "",
          qty: Number($("itQty").value || 1),
          unit: Number($("itUnit").value || 0)
        };

        const idx = invoice.items.findIndex((x) => x.id === id);
        if (idx > -1) invoice.items[idx] = obj;
        else invoice.items.push(obj);

        addAudit(`Line item saved: ${obj.name} (UGX ${fmt(obj.qty * obj.unit)})`, "Finance");
        closeModal("mItem");
        renderAll();
      });

      $("saveWaive").addEventListener("click", function () {
        const wType = $("wType").value;
        const wAmt = Number($("wAmt").value || 0);
        if (wAmt > 0) {
          invoice.items.push({
            id: "W" + Math.floor(Math.random() * 9000 + 1000),
            name: wType,
            desc: $("wReason").value || "Waiver applied",
            qty: 1,
            unit: -Math.abs(wAmt)
          });
          addAudit(`Waiver applied: ${wType} (UGX ${fmt(wAmt)})`, "Finance Admin");
        }
        closeModal("mWaive");
        renderAll();
      });

      $("savePenalty").addEventListener("click", function () {
        const name = $("penName").value || "Penalty";
        const amt = Number($("penAmt").value || 0);
        if (amt > 0) {
          invoice.items.push({
            id: "P" + Math.floor(Math.random() * 9000 + 1000),
            name,
            desc: $("penReason").value || "Penalty added",
            qty: 1,
            unit: amt
          });
          addAudit(`Penalty added: ${name} (UGX ${fmt(amt)})`, "Finance");
        }
        closeModal("mPenalty");
        renderAll();
      });

      $("savePay").addEventListener("click", function () {
        const amount = Number($("pAmt").value || 0);
        const method = $("pMethod").value;
        const ref = $("pRef").value || ("REF-" + Math.floor(Math.random() * 9000 + 1000));
        const date = $("pDate").value || new Date().toISOString().slice(0, 10);
        const by = $("pBy").value || "Cashier";
        const notes = $("pNotes").value || "";

        if (amount <= 0) {
          alert("Enter amount greater than 0");
          return;
        }

        const pid = "PAY-" + Math.floor(Math.random() * 9000 + 1000);
        invoice.payments.unshift({ id: pid, method, ref, date, amount });
        addAudit(`Payment recorded: ${pid} • UGX ${fmt(amount)} • ${method} • ${by}${notes ? (" • " + notes) : ""}`, "Finance");

        closeModal("mPay");
        renderAll();
      });

      $("itemsBody").addEventListener("click", function (e) {
        const tr = e.target.closest("tr[data-id]");
        if (!tr) return;

        const id = tr.dataset.id;
        const item = invoice.items.find((x) => x.id === id);
        if (!item) return;

        if (e.target.closest(".actEditItem")) {
          $("mItemTitle").textContent = "Edit Line Item";
          $("itId").value = item.id;
          $("itName").value = item.name;
          $("itDesc").value = item.desc || "";
          $("itQty").value = item.qty;
          $("itUnit").value = item.unit;
          openModal("mItem");
        }

        if (e.target.closest(".actDelItem")) {
          if (!window.confirm("Remove this line item?")) return;
          invoice.items = invoice.items.filter((x) => x.id !== id);
          addAudit(`Line item removed: ${item.name}`, "Finance");
          renderAll();
        }
      });

      $("payBody").addEventListener("click", function (e) {
        const tr = e.target.closest("tr[data-id]");
        if (!tr) return;

        const id = tr.dataset.id;
        const p = invoice.payments.find((x) => x.id === id);
        if (!p) return;

        if (e.target.closest(".actPrintReceipt")) {
          alert("Print receipt (next page)");
        }

        if (e.target.closest(".actDelPay")) {
          if (!window.confirm("Delete this payment record?")) return;
          invoice.payments = invoice.payments.filter((x) => x.id !== id);
          addAudit(`Payment removed: ${p.id} (UGX ${fmt(p.amount)})`, "Finance Admin");
          renderAll();
        }
      });

      $("sideReminder").addEventListener("click", function () {
        $("btnReminder").click();
      });

      document.querySelectorAll("[data-close-modal]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          closeModal(btn.dataset.closeModal);
        });
      });

      ["mItem", "mPay", "mWaive", "mPenalty"].forEach(function (mid) {
        const el = $(mid);
        if (!el) return;
        el.addEventListener("click", function (e) {
          if (e.target.id === mid) closeModal(mid);
        });
      });

      document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          document.querySelectorAll(".modal-backdrop.show").forEach(function (el) {
            el.classList.remove("show");
          });
        }
      });

      $("notes").value = invoice.notes || "";
      renderAll();
    })();
  </script>
</body>

</html>
