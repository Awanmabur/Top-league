<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %>  -  Timetable</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.65fr) minmax(300px,.35fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:2000px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}
    .col-check{width:48px}
    .col-subject{width:280px}
    .col-class{width:180px}
    .col-section{width:150px}
    .col-stream{width:150px}
    .col-teacher{width:180px}
    .col-day{width:100px}
    .col-time{width:150px}
    .col-room{width:150px}
    .col-campus{width:150px}
    .col-academic{width:150px}
    .col-week{width:110px}
    .col-status{width:120px}
    .col-actions{width:240px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .entry-main{min-width:0}
    .entry-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .entry-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}
    .badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03);overflow-wrap:anywhere;word-break:break-word}
    .csv-columns{display:flex;flex-wrap:wrap;gap:8px;margin-top:8px}
    .csv-columns span{display:inline-flex;align-items:center;justify-content:center;padding:5px 10px;border-radius:999px;border:1px solid rgba(13,64,96,.12);background:#fff;color:#0b2f4b;font-size:12px;font-weight:800;max-width:100%}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}
    .topbar > div:first-child{min-width:0;flex:1 1 auto}
    .top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1080px,100%);max-height:calc(100dvh - 60px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(560px,100%)}
    .modal.md{width:min(920px,100%)}
    .modal.lg{width:min(1080px,100%)}
    .modal > form{display:flex;flex-direction:column;flex:1 1 auto;min-height:0;overflow:hidden}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:16px 18px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}
    .tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px}
    .tabbtn{display:inline-flex;align-items:center;justify-content:center;min-height:38px;padding:0 14px;border-radius:999px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-weight:800}
    .tabbtn.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .ttwrap{display:none}
    .ttwrap.active{display:block}
    .ttgrid{display:grid;grid-template-columns:100px repeat(6,minmax(140px,1fr));gap:8px;overflow-x:auto}
    .tthead{font-size:12px;color:#6b7280;font-weight:900;padding:8px 10px;background:rgba(13,64,96,.03);border-radius:10px;text-align:center}
    .tthour{border:1px dashed rgba(13,64,96,.18);border-radius:10px;min-height:82px;padding:8px;background:#fbfdff;color:#64748b;font-weight:900;font-size:12px}
    .ttcell{border:1px solid rgba(13,64,96,.10);border-radius:10px;min-height:82px;padding:8px;background:#fff}
    .block{border:1px solid #cfe0ff;background:#eef4ff;border-radius:10px;padding:8px;margin-bottom:6px}
    .block .b1{font-weight:900;font-size:12px;color:#0a6fbf}
    .block .b2{font-size:11px;color:#475569;margin-top:2px}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}
    .pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}
    .page-link.disabled{pointer-events:none;opacity:.45}
    @media (max-width: 1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width: 900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width: 680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width: 520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left > *,.toolbar .right > *{max-width:100%}table{min-width:1700px}}
    @media print{body *{visibility:hidden !important}#printArea, #printArea *{visibility:visible !important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>
<body data-portal="tenant">
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Timetable</div>
          <div class="subtitle">Create, edit, import, export, print and manage timetable slots.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnImport" type="button"><i class="fa-solid fa-file-import"></i> Import CSV</button>
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Slot</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Total</div>
          <div class="kpi-value"><%= kpis?.total || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Active</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div>
          <div class="muted">Live timetable slots</div>
        </div>
        <div class="card">
          <div class="section-title">Inactive</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.inactive || 0 %></div>
          <div class="muted">Disabled but saved</div>
        </div>
        <div class="card">
          <div class="section-title">Archived</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div>
          <div class="muted">Ignored in conflicts</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/timetable" data-academic-selector>
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search room, location, note..." />

            <select class="select" name="academicYear">
              <option value="">Any Year</option>
              <% (academicYears || []).forEach(function(y){ %>
                <option value="<%= y %>" <%= query?.academicYear === y ? 'selected' : '' %>><%= y %></option>
              <% }) %>
            </select>

            <select class="select" name="term">
              <option value="">Any Term</option>
              <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
              <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
              <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
            </select>

            <select class="select" name="classGroup" data-role="class" data-placeholder="All Classes">
              <option value="">All Classes</option>
              <% (classes || []).forEach(function(c){ %>
                <option value="<%= String(c._id) %>" <%= String(query?.classGroup || '') === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
              <% }) %>
            </select>

            <select class="select" name="sectionId" data-role="section" data-placeholder="All Sections" data-selected="<%= query?.sectionId || '' %>">
              <option value="">All Sections</option>
            </select>

            <select class="select" name="streamId" data-role="stream" data-placeholder="All Streams" data-selected="<%= query?.streamId || '' %>">
              <option value="">All Streams</option>
            </select>

            <select class="select" name="teacher">
              <option value="">All Teachers</option>
              <% (staffList || []).forEach(function(s){ %>
                <option value="<%= String(s._id) %>" <%= String(query?.teacher || '') === String(s._id) ? 'selected' : '' %>>
                  <%= s.fullName || s.name || 'Staff' %>
                </option>
              <% }) %>
            </select>

            <select class="select" name="dayOfWeek">
              <option value="">All Days</option>
              <% (days || []).forEach(function(d){ %>
                <option value="<%= d %>" <%= query?.dayOfWeek === d ? 'selected' : '' %>><%= d %></option>
              <% }) %>
            </select>

            <select class="select" name="status">
              <option value="">All Status</option>
              <option value="active" <%= query?.status === 'active' ? 'selected' : '' %>>Active</option>
              <option value="inactive" <%= query?.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
              <option value="archived" <%= query?.status === 'archived' ? 'selected' : '' %>>Archived</option>
            </select>
          </div>

          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/timetable"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
            <strong>Selected</strong> <span class="badge-count" id="selCount">0</span>
            <span class="muted">slot(s)</span>
          </div>

          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <button class="btn-xs" id="bulkDeactivate" type="button"><i class="fa-solid fa-circle-pause"></i> Inactivate</button>
            <button class="btn-xs" id="bulkArchive" type="button"><i class="fa-solid fa-box-archive"></i> Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button"><i class="fa-solid fa-trash"></i> Delete</button>
            <button class="btn-xs" id="bulkClear" type="button"><i class="fa-solid fa-xmark"></i> Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div class="tabs">
            <button class="tabbtn active" id="tabList" type="button">List View</button>
            <button class="tabbtn" id="tabGrid" type="button">Grid View</button>
          </div>

          <div id="listWrap" class="ttwrap active">
            <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
              <div>
                <div class="section-title">Timetable Table</div>
                <div class="section-sub">Showing <%= entries.length %> of <%= query?.total || 0 %> records.</div>
              </div>
              <div class="muted">
                Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
              </div>
            </div>

            <div style="margin-top:10px;">
              <div class="table-wrap" id="printArea">
                <table>
                  <thead>
                    <tr>
                      <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                      <th class="col-subject">Subject</th>
                      <th class="col-class">Class</th>
                      <th class="col-section">Section</th>
                      <th class="col-stream">Stream</th>
                      <th class="col-teacher">Teacher</th>
                      <th class="col-day">Day</th>
                      <th class="col-time">Time</th>
                      <th class="col-room">Room</th>
                      <th class="col-campus">Location</th>
                      <th class="col-academic">Academic</th>
                      <th class="col-week">Week</th>
                      <th class="col-status">Status</th>
                      <th class="col-actions" style="text-align:right;">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="tbodyEntries"></tbody>
                </table>
              </div>
            </div>

            <div class="pagination">
              <div class="muted">Rows per page: <strong><%= query?.perPage || 10 %></strong></div>

              <div class="pagination-links">
                <%
                  const currentPage = Number(query?.page || 1);
                  const totalPages = Number(query?.totalPages || 1);

                  function buildPageUrl(targetPage) {
                    const params = new URLSearchParams();
                    if (query?.q) params.set("q", query.q);
                    if (query?.academicYear) params.set("academicYear", query.academicYear);
                    if (query?.term) params.set("term", query.term);
                    if (query?.classGroup) params.set("classGroup", query.classGroup);
                    if (query?.sectionId) params.set("sectionId", query.sectionId);
                    if (query?.streamId) params.set("streamId", query.streamId);
                    if (query?.teacher) params.set("teacher", query.teacher);
                    if (query?.dayOfWeek) params.set("dayOfWeek", query.dayOfWeek);
                    if (query?.status) params.set("status", query.status);
                    params.set("page", String(targetPage));
                    return "/admin/timetable?" + params.toString();
                  }

                  const startPage = Math.max(1, currentPage - 2);
                  const endPage = Math.min(totalPages, currentPage + 2);
                %>

                <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                  <i class="fa-solid fa-angle-left"></i>
                </a>

                <% for (let p = startPage; p <= endPage; p++) { %>
                  <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
                <% } %>

                <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                  <i class="fa-solid fa-angle-right"></i>
                </a>
              </div>
            </div>
          </div>

          <div id="gridWrap" class="ttwrap">
            <div class="note" style="margin-bottom:10px;">
              Grid view uses the currently loaded page. Filter by one class or one term for the cleanest layout.
            </div>
            <div id="ttMeta" class="muted" style="margin-bottom:10px;"></div>
            <div class="ttgrid" id="ttGrid"></div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Morning Slot</div>
                <div class="muted">Starts 08:00 by default</div>
              </div>
              <button class="btn-xs" id="quickMorning" type="button"><i class="fa-solid fa-sun"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Add Afternoon Slot</div>
                <div class="muted">Starts 14:00 by default</div>
              </div>
              <button class="btn-xs" id="quickAfternoon" type="button"><i class="fa-solid fa-clock"></i></button>
            </div>

            <div class="mini-item">
              <div class="left">
                <div class="strong">Import From CSV</div>
                <div class="muted">Bulk create timetable slots</div>
              </div>
              <button class="btn-xs" id="quickImport" type="button"><i class="fa-solid fa-file-import"></i></button>
            </div>
          </div>

          <div class="divider"></div>

          <div class="section-title">CSV Import Format</div>
          <div class="note" style="margin-top:10px;">
            <div class="strong">Required columns</div>
            <div class="csv-columns">
              <span>classCode</span>
              <span>subjectCode</span>
              <span>dayOfWeek</span>
              <span>startTime</span>
              <span>endTime</span>
            </div>
            <div class="strong" style="margin-top:10px;">Optional columns</div>
            <div class="csv-columns">
              <span>sectionCode</span>
              <span>streamCode</span>
              <span>academicYear</span>
              <span>term</span>
              <span>teacherEmail</span>
              <span>room</span>
              <span>campus</span>
              <span>weekPattern</span>
              <span>status</span>
              <span>note</span>
            </div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Add Timetable Slot</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="entryForm" method="POST" action="/admin/timetable" data-academic-selector>
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Class</label>
              <select class="select" id="mClass" name="classGroup" data-role="class" data-placeholder="Select Class" required>
                <option value="">Select Class</option>
              </select>
            </div>

            <div class="field">
              <label>Section</label>
              <select class="select" id="mSection" name="sectionId" data-role="section" data-placeholder="Whole Class">
                <option value="">Whole Class</option>
              </select>
            </div>

            <div class="field">
              <label>Stream</label>
              <select class="select" id="mStream" name="streamId" data-role="stream" data-placeholder="All Streams">
                <option value="">All Streams</option>
              </select>
            </div>

            <div class="field">
              <label>Subject</label>
              <select class="select" id="mSubject" name="subject" data-role="subject" data-placeholder="Select Subject" required>
                <option value="">Select Subject</option>
              </select>
            </div>

            <div class="field">
              <label>Teacher</label>
              <select class="select" id="mTeacher" name="teacher">
                <option value="">- Not Assigned -</option>
                <% (staffList || []).forEach(function(s){ %>
                  <option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' - ' + s.role) : '' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Day</label>
              <select class="select" id="mDay" name="dayOfWeek" required>
                <% (days || []).forEach(function(d){ %>
                  <option value="<%= d %>"><%= d %></option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Start Time</label>
              <input class="input" id="mStart" name="startTime" placeholder="08:00" required />
            </div>

            <div class="field">
              <label>End Time</label>
              <input class="input" id="mEnd" name="endTime" placeholder="10:00" required />
            </div>

            <div class="field">
              <label>Academic Year</label>
              <input class="input" id="mAY" name="academicYear" placeholder="e.g. 2026" />
            </div>

            <div class="field">
              <label>Term</label>
              <select class="select" id="mTerm" name="term">
                <option value="1">Term 1</option>
                <option value="2">Term 2</option>
                <option value="3">Term 3</option>
              </select>
            </div>

            <div class="field">
              <label>Room</label>
              <input class="input" id="mRoom" name="room" />
            </div>

            <div class="field">
              <label>Location</label>
              <input class="input" id="mCampus" name="campus" />
            </div>

            <div class="field">
              <label>Week Pattern</label>
              <select class="select" id="mWeek" name="weekPattern">
                <option value="all">All Weeks</option>
                <option value="odd">Odd Weeks</option>
                <option value="even">Even Weeks</option>
              </select>
            </div>

            <div class="field">
              <label>Status</label>
              <select class="select" id="mStatus" name="status">
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
                <option value="archived">Archived</option>
              </select>
            </div>

            <div class="field">
              <label>Duration</label>
              <div class="view-input" id="mDurationPreview">-</div>
            </div>

            <div class="field">
              <label>Conflict Rules</label>
              <div class="note">Class, teacher and room conflicts are blocked within the same academic year and term unless archived.</div>
            </div>
          </div>

          <div class="divider"></div>

          <div class="field">
            <label>Note</label>
            <textarea class="textarea" id="mNote" name="note" maxlength="500"></textarea>
            <div class="muted" id="noteCount">0 / 500</div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button"><i class="fa-solid fa-floppy-disk"></i> Save Slot</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal md">
      <div class="modal-header">
        <div class="modal-title">Timetable Slot Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Subject</label>
            <div class="view-input" id="vSubject">-</div>
          </div>

          <div class="field">
            <label>Class</label>
            <div class="view-input" id="vClass">-</div>
          </div>

          <div class="field">
            <label>Section</label>
            <div class="view-input" id="vSection">-</div>
          </div>

          <div class="field">
            <label>Stream</label>
            <div class="view-input" id="vStream">-</div>
          </div>

          <div class="field">
            <label>Teacher</label>
            <div class="view-input" id="vTeacher">-</div>
          </div>

          <div class="field">
            <label>Day</label>
            <div class="view-input" id="vDay">-</div>
          </div>

          <div class="field">
            <label>Time</label>
            <div class="view-input" id="vTime">-</div>
          </div>

          <div class="field">
            <label>Status</label>
            <div class="view-input" id="vStatus">-</div>
          </div>

          <div class="field">
            <label>Room</label>
            <div class="view-input" id="vRoom">-</div>
          </div>

          <div class="field">
            <label>Location</label>
            <div class="view-input" id="vCampus">-</div>
          </div>

          <div class="field">
            <label>Academic</label>
            <div class="view-input" id="vAcademic">-</div>
          </div>
        </div>

        <div class="divider"></div>

        <div class="field">
          <label>Note</label>
          <div class="view-input multiline" id="vNote">-</div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <div class="modal-backdrop" id="mImport">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Import Timetable CSV</div>
        <button class="btn-xs" type="button" data-close-modal="mImport"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="importForm" method="POST" action="/admin/timetable/import" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="field">
            <label>CSV File</label>
            <input class="input" type="file" name="file" accept=".csv,text/csv" required />
          </div>

          <div class="note" style="margin-top:12px;">
            <div class="strong">Required columns</div>
            <div class="csv-columns">
              <span>classCode</span>
              <span>subjectCode</span>
              <span>dayOfWeek</span>
              <span>startTime</span>
              <span>endTime</span>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mImport">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-upload"></i> Import</button>
        </div>
      </form>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusValue">
  </form>

  <form id="bulkForm" method="POST" action="/admin/timetable/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionValue">
    <input type="hidden" name="ids" id="bulkIdsValue">
  </form>

  <textarea id="entriesData" class="json-data" aria-hidden="true"><%- JSON.stringify((entries || []).map(function(e){
    return {
      id: String(e._id || ''),
      academicYear: e.academicYear || '',
      term: Number(e.term ?? 1),
      classId: e.classGroup?._id ? String(e.classGroup._id) : '',
      className: e.classGroup?.name || '',
      sectionId: e.sectionId?._id ? String(e.sectionId._id) : String(e.sectionId || ''),
      sectionName: e.sectionName || e.sectionId?.name || '',
      streamId: e.streamId?._id ? String(e.streamId._id) : String(e.streamId || ''),
      streamName: e.streamName || e.streamId?.name || '',
      subjectId: e.subject?._id ? String(e.subject._id) : '',
      subjectCode: e.subject?.code || '',
      subjectTitle: e.subject?.title || '',
      teacherId: e.teacher?._id ? String(e.teacher._id) : '',
      teacherName: e.teacher?.fullName || e.teacher?.name || '',
      dayOfWeek: e.dayOfWeek || '',
      startTime: e.startTime || '',
      endTime: e.endTime || '',
      startMinutes: Number(e.startMinutes || 0),
      endMinutes: Number(e.endMinutes || 0),
      room: e.room || '',
      campus: e.campus || '',
      weekPattern: e.weekPattern || 'all',
      status: e.status || 'active',
      note: e.note || ''
    };
  })) %></textarea>

  <script src="/js/navbar.js"></script>
  <textarea id="classesData" class="json-data" aria-hidden="true"><%- JSON.stringify(classes || []) %></textarea>
  <textarea id="sectionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="streamsData" class="json-data" aria-hidden="true"><%- JSON.stringify(streams || []) %></textarea>
  <textarea id="subjectOptionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(subjectOptions || subjects || []) %></textarea>
  <script src="/js/academic-selector.js"></script>
  <script src="/js/timetable.js"></script>
</body>
</html>
