<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <title>Admin • Students — Promotions | <%= (tenant && tenant.name) ? tenant.name : "Classic Academy" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <% if (csrfToken) { %><meta name="csrf-token" content="<%= csrfToken %>"><% } %>

  <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer"/>
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input:focus,.select:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(320px,.4fr);gap:12px}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1100px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(900px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}
    .modal-body{padding:16px 18px;overflow-y:auto;min-height:0;flex:1 1 auto}
    .modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 18px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
    }

    @media (max-width: 520px){
      table{min-width:980px}
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Promotions</div>
          <div class="subtitle">Select students, move them to the next class and term, and keep audit logs.</div>
        </div>
        <div class="top-actions">
          <button class="btn primary" type="button" data-open="mPromote">
            <i class="fa-solid fa-arrow-up"></i> Promote Selected
          </button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Filtered Students</div>
          <div class="kpi-value"><%= kpis?.filtered || 0 %></div>
          <div class="muted">Matching filter</div>
        </div>
        <div class="card">
          <div class="section-title">Selected</div>
          <div class="kpi-value" id="selCount" style="color:#0a6fbf">0</div>
          <div class="muted">Ready to promote</div>
        </div>
        <div class="card">
          <div class="section-title">Active Students</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.activeStudents || 0 %></div>
          <div class="muted">All active</div>
        </div>
        <div class="card">
          <div class="section-title">Recent Logs</div>
          <div class="kpi-value" style="color:#92400e"><%= kpis?.logs || 0 %></div>
          <div class="muted">Last activity</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <div class="card-head" style="padding:14px 16px;border-bottom:1px solid rgba(13,64,96,.10);">
          <div>
            <div class="section-title">Filter Students</div>
            <div class="section-sub">Search and narrow before promoting.</div>
          </div>
        </div>

        <div class="card-body" style="padding:14px 16px;">
          <form class="toolbar" method="GET" action="/admin/promotions">
            <div class="left">
              <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="regNo, name, email, phone">

              <select class="select" name="schoolLevel">
                <option value="">All School Levels</option>
                <option value="nursery" <%= String(query?.schoolLevel || '') === 'nursery' ? 'selected' : '' %>>Nursery</option>
                <option value="primary" <%= String(query?.schoolLevel || '') === 'primary' ? 'selected' : '' %>>Primary</option>
                <option value="secondary" <%= String(query?.schoolLevel || '') === 'secondary' ? 'selected' : '' %>>Secondary</option>
              </select>

              <select class="select" name="classId">
                <option value="">All Classes</option>
                <% (classes || []).forEach(function(c){ %>
                  <option value="<%= c._id %>" <%= String(query?.classId || '') === String(c._id) ? 'selected' : '' %>>
                    <%= c.name || c.title || 'Class' %>
                  </option>
                <% }) %>
              </select>

              <select class="select" name="classLevel">
                <option value="">All Class Levels</option>
                <% (classLevels || []).forEach(function(level){ %>
                  <option value="<%= level %>" <%= String(query?.classLevel || '') === String(level) ? 'selected' : '' %>><%= level %></option>
                <% }) %>
              </select>

              <select class="select" name="term">
                <option value="">All Terms</option>
                <option value="1" <%= String(query?.term || '') === '1' ? 'selected' : '' %>>Term 1</option>
                <option value="2" <%= String(query?.term || '') === '2' ? 'selected' : '' %>>Term 2</option>
                <option value="3" <%= String(query?.term || '') === '3' ? 'selected' : '' %>>Term 3</option>
              </select>

              <select class="select" name="status">
                <option value="">Any Status</option>
                <option value="active" <%= String(query?.status || '') === 'active' ? 'selected' : '' %>>Active</option>
                <option value="on_hold" <%= String(query?.status || '') === 'on_hold' ? 'selected' : '' %>>On Hold</option>
                <option value="suspended" <%= String(query?.status || '') === 'suspended' ? 'selected' : '' %>>Suspended</option>
                <option value="graduated" <%= String(query?.status || '') === 'graduated' ? 'selected' : '' %>>Graduated</option>
              </select>
            </div>

            <div class="right">
              <a class="btn light" href="/admin/promotions"><i class="fa-solid fa-rotate-left"></i> Reset</a>
              <button class="btn primary" type="submit"><i class="fa-solid fa-filter"></i> Filter</button>
            </div>
          </form>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;padding:14px 16px 0;">
            <div>
              <div class="section-title">Students Table</div>
              <div class="section-sub">Showing <%= (students || []).length %> of <%= query?.total || 0 %> records.</div>
            </div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>

          <div style="padding:14px 16px;">
            <div class="table-wrap">
              <table>
                <thead>
                  <tr>
                    <th style="width:44px"><input type="checkbox" id="checkAll"></th>
                    <th>Student</th>
                    <th>Placement</th>
                    <th>Academic</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!(students || []).length) { %>
                    <tr><td colspan="5" class="muted">No students found.</td></tr>
                  <% } %>

                  <% (students || []).forEach(function(s){ %>
                    <tr>
                      <td><input type="checkbox" class="rowChk" value="<%= s._id %>"></td>
                      <td>
                        <div class="strong"><%= s.fullName || 'Student' %></div>
                        <div class="muted"><%= s.regNo || '' %> <%= s.email ? ('• ' + s.email) : '' %></div>
                      </td>
                      <td>
                        <div><%= [s.schoolUnitName, s.campusName].filter(Boolean).join(' / ') || '—' %></div>
                        <div class="muted"><%= [s.className || s.classLevel, s.section || s.stream].filter(Boolean).join(' / ') || '—' %></div>
                      </td>
                      <td>
                        <div class="strong"><%= s.academicYear || '—' %></div>
                        <div class="muted"><%= s.classLevel || '—' %> • Term <%= s.term || 1 %></div>
                      </td>
                      <td class="muted"><%= s.status || 'active' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <div class="pagination">
              <div class="muted">Rows per page: <strong><%= query?.limit || 24 %></strong></div>
              <div class="pagination-links">
                <%
                  const currentPage = Number(query?.page || 1);
                  const totalPages = Number(query?.totalPages || 1);
                  function buildPageUrl(targetPage) {
                    const params = new URLSearchParams();
                    if (query?.q) params.set("q", query.q);
                    if (query?.schoolLevel) params.set("schoolLevel", query.schoolLevel);
                    if (query?.classId) params.set("classId", query.classId);
                    if (query?.classLevel) params.set("classLevel", query.classLevel);
                    if (query?.term) params.set("term", query.term);
                    if (query?.status) params.set("status", query.status);
                    if (query?.limit) params.set("limit", String(query.limit));
                    params.set("page", String(targetPage));
                    return "/admin/promotions?" + params.toString();
                  }
                  const startPage = Math.max(1, currentPage - 2);
                  const endPage = Math.min(totalPages, currentPage + 2);
                %>

                <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
                  <i class="fa-solid fa-angle-left"></i>
                </a>

                <% for (let p = startPage; p <= endPage; p++) { %>
                  <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
                <% } %>

                <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
                  <i class="fa-solid fa-angle-right"></i>
                </a>
              </div>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div style="padding:14px 16px;">
            <div class="section-title">Recent Logs</div>
            <div class="section-sub">Last 10 promotions</div>

            <div class="divider"></div>

            <% if (!(logs || []).length) { %>
              <div class="muted">No promotions yet.</div>
            <% } %>

            <% (logs || []).forEach(function(l){ %>
              <div style="margin-bottom:12px;">
                <div class="strong"><%= l.student ? (l.student.fullName || l.student.regNo || 'Student') : 'Student' %></div>
                <div class="muted"><%= l.fromClassLevel || l.fromYearLevel || '—' %> / Term <%= l.fromTerm || l.fromSemester || '—' %> → <%= l.toClassLevel || l.toYearLevel || '—' %> / Term <%= l.toTerm || l.toSemester || '—' %></div>
                <div class="muted"><%= l.createdAt ? new Date(l.createdAt).toLocaleString() : '' %></div>
              </div>
            <% }) %>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mPromote">
    <div class="modal">
      <div class="modal-header">
        <div class="modal-title"><i class="fa-solid fa-arrow-up"></i> Promote Selected Students</div>
        <button class="btn light small" type="button" data-close="mPromote"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="promoForm" method="POST" action="/admin/promotions/apply">
        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>"/>
        <input type="hidden" name="ids" id="ids" value=""/>

        <div class="modal-body">
          <div class="muted">Selected: <b id="promoCount">0</b></div>
          <div class="divider"></div>

          <div class="form-grid">
            <div class="field">
              <label>To Academic Year *</label>
              <input class="input" name="toAcademicYear" placeholder="2026/2027" required>
            </div>

            <div class="field">
              <label>To Term</label>
              <select class="select" name="toTerm" required>
                <option value="1">Term 1</option>
                <option value="2">Term 2</option>
                <option value="3">Term 3</option>
              </select>
            </div>

            <div class="field">
              <label>Destination Status</label>
              <select class="select" name="toStatus">
                <option value="active">Active</option>
                <option value="on_hold">On Hold</option>
                <option value="suspended">Suspended</option>
                <option value="graduated">Graduated</option>
              </select>
            </div>

            <div class="field">
              <label>To Class *</label>
              <select class="select" name="toClassId" required>
                <option value="">— select —</option>
                <% (classes || []).forEach(function(c){ %>
                  <option value="<%= c._id %>"><%= c.name || c.title || 'Class' %></option>
                <% }) %>
              </select>
            </div>

            <div class="field" style="grid-column:1/-1">
              <label>Reason</label>
              <input class="input" name="reason" placeholder="End of term promotion">
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close="mPromote">Cancel</button>
          <button class="btn primary" type="submit"><i class="fa-solid fa-check"></i> Promote</button>
        </div>
      </form>
    </div>
  </div>

  <script defer src="/js/navbar.js"></script>
  <script defer src="/js/promotions.js"></script>
</body>
</html>
