<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Student Docs</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}

    .input,.select,.textarea,.view-input{
      padding:10px 12px;
      border-radius:12px;
      border:1px solid rgba(13,64,96,.16);
      background:#fff;
      outline:none;
    }

    .input{min-width:220px}
    .textarea{width:100%;min-height:110px;resize:vertical}

    .input:focus,.select:focus,.textarea:focus{
      border-color:rgba(10,111,191,.45);
      box-shadow:0 0 0 3px rgba(10,111,191,.12);
    }

    .view-input{
      min-height:44px;
      display:flex;
      align-items:center;
      font-weight:800;
      color:#0f172a;
      background:#fbfdff;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .view-input.multiline{
      min-height:96px;
      align-items:flex-start;
      white-space:pre-wrap;
      overflow:auto;
      text-overflow:unset;
      line-height:1.55;
    }

    .muted{font-size:12px;color:#6b7280}
    .strong{font-weight:900}

    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}

    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}
    .warn{background:#fef9c3;color:#92400e}
    .bad{background:#fee2e2;color:#b91c1c}
    .info{background:#eef2ff;color:#3730a3}

    .table-wrap{
      overflow-x:auto;
      overflow-y:hidden;
      border:1px solid rgba(13,64,96,.10);
      border-radius:12px;
      max-width:100%;
      -webkit-overflow-scrolling:touch;
    }

    table{
      width:100%;
      min-width:1360px;
      border-collapse:separate;
      border-spacing:0;
      background:#fff;
      table-layout:fixed;
    }

    th,td{
      padding:10px 12px;
      border-bottom:1px solid rgba(13,64,96,.08);
      vertical-align:middle;
    }

    th{
      font-size:12px;
      color:#6b7280;
      text-transform:uppercase;
      letter-spacing:.04em;
      text-align:left;
      background:rgba(13,64,96,.03);
      position:sticky;
      top:0;
      z-index:1;
      white-space:nowrap;
    }

    tr:hover td{background:rgba(10,111,191,.04)}
    tr.row-clickable{cursor:pointer}

    .col-student{width:270px}
    .col-type{width:140px}
    .col-title{width:260px}
    .col-file{width:260px}
    .col-size{width:120px}
    .col-date{width:180px}
    .col-actions{width:220px}

    .cell-ellipsis{
      display:block;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
      max-width:100%;
    }

    .doc-main{min-width:0}

    .doc-title{
      font-weight:900;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .doc-sub{
      font-size:12px;
      color:#6b7280;
      margin-top:2px;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }

    .actions{
      display:flex;
      gap:6px;
      justify-content:flex-end;
      flex-wrap:nowrap;
      overflow:hidden;
    }

    .btn-xs{
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      cursor:pointer;
      font-size:12px;
      position:relative;
      z-index:2;
      flex:0 0 auto;
    }

    .btn-xs:hover{background:rgba(10,111,191,.06)}

    .note{padding:10px 12px;border-radius:12px;border:1px dashed rgba(13,64,96,.18);background:rgba(13,64,96,.03)}
    .mini-list{display:grid;gap:10px;margin-top:10px}
    .mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}
    .mini-item .left{display:grid;gap:2px}
    .coverage-table{min-width:1180px}
    .col-coverage-student{width:280px}
    .col-coverage-count{width:160px}
    .col-coverage-missing{width:250px}
    .col-coverage-docs{width:330px}
    .col-coverage-actions{width:190px}
    .doc-chip-list{display:flex;gap:6px;flex-wrap:wrap;align-items:center}
    .doc-chip{
      display:inline-flex;
      align-items:center;
      gap:6px;
      max-width:150px;
      padding:6px 8px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      font-size:12px;
      font-weight:800;
      cursor:pointer;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .doc-chip.present{background:#ecfdf3;color:#15803d;border-color:#bbf7d0}
    .doc-chip.missing{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
    .doc-chip.other{background:#eef2ff;color:#3730a3;border-color:#c7d2fe}
    .doc-count{display:grid;gap:3px}

    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}
    .flash{padding:12px 14px;border-radius:12px;font-weight:700}
    .flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}
    .flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}

    .topbar{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:14px;
      flex-wrap:nowrap;
    }

    .topbar > div:first-child{
      min-width:0;
      flex:1 1 auto;
    }

    .top-actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      justify-content:flex-end;
      align-items:center;
      flex:0 0 auto;
      margin-left:auto;
    }

    .modal-backdrop{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.45);
      display:none;
      align-items:center;
      justify-content:center;
      padding:30px 18px;
      z-index:9999;
      overflow-y:auto;
    }

    .modal-backdrop.show{display:flex}

    .modal{
      width:min(980px,100%);
      max-height:calc(100dvh - 60px);
      background:#fff;
      border-radius:22px;
      box-shadow:0 24px 70px rgba(0,0,0,.25);
      overflow:hidden;
      display:flex;
      flex-direction:column;
    }

    .modal.sm{width:min(900px,100%)}
    .modal.lg{width:min(980px,100%)}

    .modal > form{
      display:flex;
      flex-direction:column;
      flex:1 1 auto;
      min-height:0;
      overflow:hidden;
    }

    .modal-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:16px 18px;
      border-bottom:1px solid rgba(13,64,96,.10);
      background:#fff;
    }

    .modal-title{font-weight:900;font-size:18px}

    .modal-body{
      padding:16px 18px;
      overflow-y:auto;
      min-height:0;
      flex:1 1 auto;
    }

    .modal-footer{
      display:flex;
      justify-content:flex-end;
      gap:10px;
      padding:14px 18px;
      border-top:1px solid rgba(13,64,96,.10);
      background:#fff;
      flex-wrap:wrap;
    }

    .form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px}
    .field label{display:block;font-size:12px;color:#6b7280;margin-bottom:6px}
    .field input,.field select,.field textarea{width:100%}
    .divider{height:1px;background:rgba(13,64,96,.10);margin:12px 0}
    .json-data{display:none !important}

    .pagination{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .pagination-links{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
      align-items:center;
    }

    .page-link{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:38px;
      height:38px;
      padding:0 12px;
      border-radius:10px;
      border:1px solid rgba(13,64,96,.14);
      background:#fff;
      color:#0f172a;
      text-decoration:none;
      font-weight:800;
    }

    .page-link.active{
      background:#0a6fbf;
      color:#fff;
      border-color:#0a6fbf;
    }

    .page-link.disabled{
      pointer-events:none;
      opacity:.45;
    }

    .link-inline{
      color:#0a6fbf;
      text-decoration:none;
      font-weight:800;
    }

    .link-inline:hover{text-decoration:underline}

    @media (max-width: 1100px){
      .grid-2{grid-template-columns:1fr}
    }

    @media (max-width: 900px){
      .form-grid{grid-template-columns:1fr}
      .topbar{flex-wrap:wrap}
      .top-actions{width:100%;justify-content:flex-start}
    }

    @media (max-width: 680px){
      .grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}
      .input{min-width:160px}
    }

    @media (max-width: 520px){
      .toolbar .left,
      .toolbar .right{width:100%}
      .toolbar .left > *,
      .toolbar .right > *{max-width:100%}
      table{min-width:1360px}
    }

    @media print{
      body *{visibility:hidden !important}
      #printArea, #printArea *{visibility:visible !important}
      #printArea{
        position:absolute;
        inset:0;
        background:#fff;
        padding:20px;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %>
            <div class="flash flash-success"><%= msg %></div>
          <% }) %>
          <% (messages.error || []).forEach(function(msg){ %>
            <div class="flash flash-error"><%= msg %></div>
          <% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Student Docs</div>
          <div class="subtitle">Track each student, their uploaded files, missing required documents and document updates.</div>
        </div>

        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Upload Doc</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card">
          <div class="section-title">Students</div>
          <div class="kpi-value"><%= kpis?.students || 0 %></div>
          <div class="muted">Tracked for documents</div>
        </div>
        <div class="card">
          <div class="section-title">Uploaded Docs</div>
          <div class="kpi-value" style="color:#3730a3"><%= kpis?.uploaded || 0 %></div>
          <div class="muted">All stored files</div>
        </div>
        <div class="card">
          <div class="section-title">Missing Required</div>
          <div class="kpi-value" style="color:#b91c1c"><%= kpis?.missingRequired || 0 %></div>
          <div class="muted">Passport, ID, transcript gaps</div>
        </div>
        <div class="card">
          <div class="section-title">Complete</div>
          <div class="kpi-value" style="color:#15803d"><%= kpis?.completeStudents || 0 %></div>
          <div class="muted">Students with required docs</div>
        </div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/student-docs">
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search student name, regNo, email, title..." />

            <select class="select" name="type">
              <option value="">All Types</option>
              <% (types || []).forEach(function(t){ %>
                <option value="<%= t %>" <%= query?.type === t ? "selected" : "" %>><%= t %></option>
              <% }) %>
            </select>

            <select class="select" name="student">
              <option value="">All Students</option>
              <% (students || []).forEach(function(st){ %>
                <option value="<%= String(st._id) %>" <%= String(query?.student || "") === String(st._id) ? "selected" : "" %>>
                  <%= (st.regNo ? st.regNo + " — " : "") + (st.fullName || st.email || "Student") %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="right">
            <a class="btn light" href="/admin/student-docs"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div>
              <div class="section-title">Students & Documents</div>
              <div class="section-sub">Uploaded and missing document coverage per student.</div>
            </div>
            <div class="muted" id="resultMeta">
              <%= (studentDocSummaries || []).length %> student(s)
            </div>
          </div>

          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table class="coverage-table">
                <thead>
                  <tr>
                    <th class="col-coverage-student">Student</th>
                    <th class="col-coverage-count">Coverage</th>
                    <th class="col-coverage-missing">Missing Required</th>
                    <th class="col-coverage-docs">Uploaded Documents</th>
                    <th class="col-coverage-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodyStudentDocs">
                  <%
                    const typeLabels = { passport: "Passport", id: "ID", transcript: "Transcript", certificate: "Certificate", other: "Other" };
                    const coverageRows = studentDocSummaries || [];
                  %>
                  <% if (!coverageRows.length) { %>
                    <tr>
                      <td colspan="5" style="padding:18px;">
                        <div class="muted">No students found for document tracking.</div>
                      </td>
                    </tr>
                  <% } %>
                  <% coverageRows.forEach(function(row){ %>
                    <tr>
                      <td class="col-coverage-student">
                        <div class="doc-main">
                          <div class="doc-title" title="<%= row.label %>"><%= row.label %></div>
                          <div class="doc-sub"><%= row.email || "No email recorded" %></div>
                        </div>
                      </td>
                      <td class="col-coverage-count">
                        <div class="doc-count">
                          <strong><%= row.requiredUploadedCount || 0 %>/<%= row.requiredCount || 3 %> required</strong>
                          <span class="muted"><%= row.uploadedCount || 0 %> total uploaded</span>
                        </div>
                      </td>
                      <td class="col-coverage-missing">
                        <div class="doc-chip-list">
                          <% if (row.missing && row.missing.length) { %>
                            <% row.missing.forEach(function(type){ %>
                              <button class="doc-chip missing missingUpload" type="button" data-student="<%= row.id %>" data-type="<%= type %>">
                                <i class="fa-solid fa-upload"></i> <%= typeLabels[type] || type %>
                              </button>
                            <% }) %>
                          <% } else { %>
                            <span class="pill ok"><i class="fa-solid fa-circle-check"></i> Complete</span>
                          <% } %>
                        </div>
                      </td>
                      <td class="col-coverage-docs">
                        <div class="doc-chip-list">
                          <% if (row.docs && row.docs.length) { %>
                            <% row.docs.slice(0, 6).forEach(function(doc){ %>
                              <button class="doc-chip <%= doc.type === 'other' ? 'other' : 'present' %> docMiniEdit" type="button" data-doc="<%= doc.id %>" title="<%= doc.title || doc.originalName || '' %>">
                                <i class="fa-solid fa-file-lines"></i> <%= typeLabels[doc.type] || doc.type || "Doc" %>
                              </button>
                            <% }) %>
                            <% if (row.docs.length > 6) { %>
                              <span class="muted">+<%= row.docs.length - 6 %> more</span>
                            <% } %>
                          <% } else { %>
                            <span class="muted">No uploaded documents.</span>
                          <% } %>
                        </div>
                      </td>
                      <td class="col-coverage-actions" style="text-align:right;">
                        <button class="btn-xs missingUpload" type="button" data-student="<%= row.id %>" data-type="<%= (row.missing && row.missing[0]) || 'other' %>">
                          <i class="fa-solid fa-upload"></i> <%= row.missing && row.missing.length ? "Upload Missing" : "Upload More" %>
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast upload helpers and missing required docs.</div>

          <div class="mini-list">
            <div class="mini-item">
              <div class="left">
                <div class="strong">Upload Passport</div>
                <div class="muted">Pre-fill type as passport</div>
              </div>
              <button class="btn-xs" id="quickPassport" type="button"><i class="fa-solid fa-passport"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Upload Transcript</div>
                <div class="muted">Pre-fill type as transcript</div>
              </div>
              <button class="btn-xs" id="quickTranscript" type="button"><i class="fa-solid fa-file-lines"></i></button>
            </div>
            <div class="mini-item">
              <div class="left">
                <div class="strong">Upload Certificate</div>
                <div class="muted">Pre-fill type as certificate</div>
              </div>
              <button class="btn-xs" id="quickCertificate" type="button"><i class="fa-solid fa-certificate"></i></button>
            </div>
          </div>

          <div class="note" style="margin-top:12px;">
            Keep uploads small and relevant. Replacing a file during edit automatically removes the old cloud asset.
          </div>

          <div class="divider"></div>

          <div class="section-title">Missing Documents</div>
          <div class="section-sub">Passport, ID and transcript are tracked per student.</div>

          <div class="mini-list">
            <%
              const missingDocRows = (studentDocSummaries || []).filter(function(row){ return row.missing && row.missing.length; }).slice(0, 8);
            %>
            <% if (!missingDocRows.length) { %>
              <div class="muted">No missing required documents for listed students.</div>
            <% } %>
            <% missingDocRows.forEach(function(row){ %>
              <div class="mini-item">
                <div class="left">
                  <div class="strong"><%= row.label %></div>
                  <div class="muted">Missing: <%= row.missing.join(", ") %></div>
                </div>
                <button class="btn-xs missingUpload" type="button" data-student="<%= row.id %>" data-type="<%= row.missing[0] %>">
                  <i class="fa-solid fa-upload"></i>
                </button>
              </div>
            <% }) %>
          </div>
        </aside>
      </div>

      <section class="card" style="margin-top:12px;min-width:0;">
        <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
          <div>
            <div class="section-title">Document Records</div>
            <div class="section-sub">Showing <%= docs.length %> of <%= query?.total || 0 %> uploaded document record(s).</div>
          </div>
          <div class="muted">
            Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %>
          </div>
        </div>

        <div style="margin-top:10px;">
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th class="col-student">Student</th>
                  <th class="col-type">Type</th>
                  <th class="col-title">Title</th>
                  <th class="col-file">File</th>
                  <th class="col-size">Size</th>
                  <th class="col-date">Uploaded</th>
                  <th class="col-actions" style="text-align:right;">Actions</th>
                </tr>
              </thead>
              <tbody id="tbodyDocs"></tbody>
            </table>
          </div>
        </div>

        <div class="pagination">
          <div class="muted">
            Rows per page: <strong>10</strong>
          </div>

          <div class="pagination-links">
            <%
              {
                const currentPage = Number(query?.page || 1);
                const totalPages = Number(query?.totalPages || 1);

                function buildPageUrl(targetPage) {
                  const params = new URLSearchParams();
                  if (query?.q) params.set("q", query.q);
                  if (query?.type) params.set("type", query.type);
                  if (query?.student) params.set("student", query.student);
                  params.set("page", String(targetPage));
                  return "/admin/student-docs?" + params.toString();
                }

                const startPage = Math.max(1, currentPage - 2);
                const endPage = Math.min(totalPages, currentPage + 2);
            %>

            <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.max(1, currentPage - 1)) %>">
              <i class="fa-solid fa-angle-left"></i>
            </a>

            <% for (let p = startPage; p <= endPage; p++) { %>
              <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= buildPageUrl(p) %>"><%= p %></a>
            <% } %>

            <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= buildPageUrl(Math.min(totalPages, currentPage + 1)) %>">
              <i class="fa-solid fa-angle-right"></i>
            </a>

            <% } %>
          </div>
        </div>
      </section>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitle">Upload Document</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="docForm" method="POST" action="/admin/student-docs" enctype="multipart/form-data">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field">
              <label>Student</label>
              <select class="select" id="mStudent" name="student" required>
                <option value="">— Select Student —</option>
                <% (students || []).forEach(function(st){ %>
                  <option value="<%= String(st._id) %>">
                    <%= (st.regNo ? st.regNo + " — " : "") + (st.fullName || st.email || "Student") %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="field">
              <label>Type</label>
              <select class="select" id="mType" name="type">
                <% (types || []).forEach(function(t){ %>
                  <option value="<%= t %>"><%= t %></option>
                <% }) %>
              </select>
            </div>

            <div class="field" style="grid-column:1/-1;">
              <label>Title</label>
              <input class="input" id="mTitleInput" name="title" required />
            </div>

            <div class="field" style="grid-column:1/-1;">
              <label>Replace / Upload File</label>
              <input class="input" id="mFile" name="file" type="file" />
              <div class="muted" id="currentFileHint">Required when creating a new document.</div>
            </div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="submit"><i class="fa-solid fa-floppy-disk"></i> Save Document</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Document Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>Student</label>
            <div class="view-input" id="vStudent">—</div>
          </div>

          <div class="field">
            <label>Type</label>
            <div class="view-input" id="vType">—</div>
          </div>

          <div class="field" style="grid-column:1/-1;">
            <label>Title</label>
            <div class="view-input" id="vTitle">—</div>
          </div>

          <div class="field">
            <label>Uploaded At</label>
            <div class="view-input" id="vUploadedAt">—</div>
          </div>

          <div class="field">
            <label>File Size</label>
            <div class="view-input" id="vBytes">—</div>
          </div>

          <div class="field" style="grid-column:1/-1;">
            <label>Current File</label>
            <div class="view-input multiline" id="vFileWrap">
              <a id="vFileLink" class="link-inline" href="#" target="_blank" rel="noreferrer noopener">Open file</a>
            </div>
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn"><i class="fa-solid fa-pen"></i> Edit</button>
      </div>
    </div>
  </div>

  <form id="rowDeleteForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
  </form>

  <script id="docsData" type="application/json"><%- JSON.stringify((docs || []).map(function(d){
    return {
      id: String(d._id || ""),
      studentId: d.student?._id ? String(d.student._id) : "",
      studentLabel: ((d.student?.regNo ? d.student.regNo + " — " : "") + (d.student?.fullName || d.student?.email || "Student")).trim(),
      type: d.type || "other",
      title: d.title || "",
      url: d.doc?.url || "",
      originalName: d.doc?.originalName || "",
      bytes: Number(d.doc?.bytes || 0),
      mimeType: d.doc?.mimeType || "",
      uploadedAt: d.createdAt || null
    };
  })) %></script>

  <script id="studentDocSummariesData" type="application/json"><%- JSON.stringify(studentDocSummaries || []) %></script>

  <script src="/js/navbar.js"></script>
  <script src="/js/student-docs.js" defer></script>
</body>
</html>
