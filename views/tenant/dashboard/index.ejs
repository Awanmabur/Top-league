<%- include("../partials/header") %>
<%- include("../partials/navbar") %>

<%
  const tenantAccess = locals.tenantAccess || {};
  const roleAccess = locals.roleAccess || { role: "admin", can: () => true };
  const schoolLevel = tenantAccess.schoolLevel || "high";
  const isHigh = schoolLevel === "high";
  const ui = locals.ui || {};
  const isTenantAdmin = roleAccess.role === "admin";
  const canAdmissions = roleAccess.can("admissions.view");
  const canStudents = roleAccess.can("students.view");
  const canFinance = roleAccess.can("finance.view");
  const canReports = roleAccess.can("reports.view");
  const canNotifications = roleAccess.can("notifications.view");
  const canAnnouncements = roleAccess.can("announcements.view");
  const canSubjects = roleAccess.can("subjects.view");
  const focusCardsData = Array.isArray(focusCards) ? focusCards : [];
  const dashboardModuleCards = Array.isArray(dashboardModules) ? dashboardModules : [];
  const shortcutCards = Array.isArray(dashboardShortcuts) ? dashboardShortcuts : [];
  const workspaceAnnouncements = Array.isArray(roleWorkspace?.announcements) ? roleWorkspace.announcements : [];
%>

<main class="main">
  <section class="tab active" id="dashboard">
    <div class="topbar">
      <div class="topbar-left">
        <div class="page-title">
          <h2>Dashboard Overview</h2>
          <p>
            Welcome back, <%= user?.name || user?.fullName || "Admin" %>.
            <% if (roleWorkspace?.subtitle) { %>
              <%= roleWorkspace.subtitle %>
            <% } else { %>
              Here's what's happening across your <%= ui.schoolWord %> as <%= roleAccess.role %>.
            <% } %>
          </p>
        </div>

        <div class="topbar-right">
          <form class="search" role="search" method="GET" action="/admin/search">
            <i class="fa fa-magnifying-glass"></i>
            <input id="searchInput" name="q" placeholder="<%= ui.searchPlaceholder %>" />
          </form>

          <% if (canNotifications) { %>
            <a class="notif-pill" href="/admin/notifications">
              <span>Notifications</span>
              <span class="chip" id="notifCount"><%= dashboardData?.notificationsCount || 0 %></span>
            </a>
          <% } %>

          <div class="avatar">
            <div class="avatar-circle">
              <%= ((user?.name || user?.fullName || "A").charAt(0)).toUpperCase() %>
            </div>
            <div class="avatar-meta">
              <strong><%= user?.name || user?.fullName || "Admin User" %></strong>
              <span><%= user?.role || "Admin" %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="grid grid-4">
      <% focusCardsData.forEach(function(card) { %>
        <article class="card stat">
          <div class="stat-head">
            <div>
              <div class="label"><%= card.label %></div>
              <div class="value"><%= card.value %></div>
            </div>
            <% if (card.note) { %>
              <div class="stat-meta">
                <span><%= card.note %></span>
              </div>
            <% } %>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="workspace-grid">
      <section class="card workspace-card">
        <div class="card-head">
          <div>
            <h3><%= roleWorkspace?.title || "My Modules" %></h3>
            <p><%= roleWorkspace?.subtitle || "Only the modules available to your role are shown here." %></p>
          </div>
        </div>

        <% if (dashboardModuleCards.length) { %>
          <div class="module-grid">
            <% dashboardModuleCards.forEach(function(module) { %>
              <a class="module-card" href="<%= module.href %>">
                <div class="module-card-top">
                  <i class="fa-solid <%= module.icon %>"></i>
                  <span class="module-card-title"><%= module.title %></span>
                </div>
                <div class="module-card-meta"><%= module.meta %></div>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state">No tenant modules are available for this role right now.</div>
        <% } %>
      </section>

      <aside class="card workspace-card">
        <div class="card-head">
          <div>
            <h3>Quick Access</h3>
            <p>Shortcuts and updates for the work your role can do right now.</p>
          </div>
        </div>

        <% if (shortcutCards.length) { %>
          <div class="shortcut-grid">
            <% shortcutCards.forEach(function(shortcut) { %>
              <a class="shortcut-chip" href="<%= shortcut.href %>">
                <i class="fa-solid <%= shortcut.icon %>"></i>
                <span><%= shortcut.label %></span>
              </a>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-state">No quick actions are available for this role.</div>
        <% } %>

        <% if (workspaceAnnouncements.length) { %>
          <div class="workspace-block">
            <div class="softhead">
              <h4>Latest Updates</h4>
              <span>shared announcements</span>
            </div>

            <div class="list compact-list">
              <% workspaceAnnouncements.forEach(function(item) { %>
                <div class="list-item">
                  <span><%= item.title || "Announcement" %></span>
                  <span class="muted"><%= item.status || "Live" %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </aside>
    </section>

    <% if (canAdmissions) { %>
    <section class="card">
      <div class="card-head">
        <div>
          <h3>Admissions Snapshot</h3>
          <p>Intake: Live - Current Month</p>
        </div>
        <div class="card-actions">
          <a class="btn" href="/admin/admissions/applicants">View Applications</a>
          <a class="btn secondary" href="/admin/admissions/applicants/export">Export CSV</a>
        </div>
      </div>

      <div class="grid grid-3 snap-grid">
        <div class="softbox">
          <div class="kpi"><span>Submitted</span><strong><%= dashboardData?.admissions?.submitted || 0 %></strong></div>
          <div class="bar"><div class="barfill" style="width:<%= dashboardData?.admissions?.submittedPct || 0 %>%"></div></div>

          <div class="kpi"><span>In Review</span><strong><%= dashboardData?.admissions?.verified || 0 %></strong></div>
          <div class="bar"><div class="barfill" style="width:<%= dashboardData?.admissions?.verifiedPct || 0 %>%"></div></div>

          <div class="kpi"><span>Accepted</span><strong><%= dashboardData?.admissions?.accepted || 0 %></strong></div>
          <div class="bar"><div class="barfill" style="width:<%= dashboardData?.admissions?.acceptedPct || 0 %>%"></div></div>
        </div>

        <div class="softbox">
          <div class="softhead">
            <h4>Top Nationalities</h4>
            <span>last 30 days</span>
          </div>

          <div class="donut-row">
            <svg class="donut" viewBox="0 0 42 42" id="donutCountries"></svg>
            <div class="legend" id="countriesLegend"></div>
          </div>
        </div>

        <div class="softbox">
          <div class="softhead">
            <h4><%= ui.distributionTitle %></h4>
            <span>updated live</span>
          </div>

          <svg class="dept" id="deptChart"></svg>

          <div class="soft-actions">
            <a class="btn secondary" href="/admin/students"><%= ui.learners %></a>
            <a class="btn secondary" href="<%= isHigh ? '/admin/sections' : '/admin/classes' %>"><%= ui.groupLabelPlural %></a>
            <a class="btn" href="/admin/subjects"><%= ui.subjects %></a>
          </div>
        </div>
      </div>
    </section>
    <% } %>

    <section class="grid grid-3">
      <section class="card">
        <div class="card-head">
          <div>
            <h3>Recent Activity</h3>
            <p>Last 10 actions</p>
          </div>
          <div class="card-actions">
            <% if (isTenantAdmin) { %><a class="btn secondary" href="/admin/helpdesk">Helpdesk</a><% } %>
            <% if (isTenantAdmin) { %><a class="btn" href="/admin/auditlogs">Audit Logs</a><% } %>
          </div>
        </div>

        <div class="list">
          <% if (dashboardData?.recentActivity?.length) { %>
            <% dashboardData.recentActivity.forEach(item => { %>
              <div class="list-item">
                <%= item.text %>
                <span class="muted"><%= item.time %></span>
              </div>
            <% }) %>
          <% } else { %>
            <div class="list-item">No recent activity <span class="muted">Live</span></div>
          <% } %>
        </div>
      </section>

      <section class="card">
        <div class="card-head">
          <div>
            <h3>Announcements</h3>
            <p>Internal updates</p>
          </div>
          <div class="card-actions">
            <% if (canAnnouncements) { %><a class="btn" href="/admin/announcements">Open</a><% } %>
            <% if (canAnnouncements && isTenantAdmin) { %><a class="btn secondary" href="/admin/announcements">Manage</a><% } %>
          </div>
        </div>

        <div class="list">
          <% if (dashboardData?.announcements?.length) { %>
            <% dashboardData.announcements.forEach(item => { %>
              <div class="list-item">
                <i class="fa-solid fa-bullhorn"></i> <%= item.title %>
                <span class="muted"><%= item.status %></span>
              </div>
            <% }) %>
          <% } else { %>
            <div class="list-item">No announcements yet <span class="muted">Empty</span></div>
          <% } %>
        </div>
      </section>

      <% if (isTenantAdmin) { %>
      <section class="card">
        <div class="card-head">
          <div>
            <h3>System Status</h3>
            <p>Last 24 hours</p>
          </div>
          <div class="card-actions">
            <a class="btn secondary" href="/admin/system">Monitoring</a>
            <a class="btn" href="/admin/system">Diagnostics</a>
          </div>
        </div>

        <div class="sys">
          <div class="sys-row">
            <div class="kpi"><span>Uptime</span><strong class="ok"><%= dashboardData?.systemStatus?.uptime ?? 99.2 %>%</strong></div>
            <div class="bar"><div class="barfill" style="width:<%= dashboardData?.systemStatus?.uptime ?? 99.2 %>%"></div></div>
          </div>

          <div class="sys-row">
            <div class="kpi"><span>Alerts (24h)</span><strong class="danger"><%= dashboardData?.systemStatus?.errors24h ?? 0 %></strong></div>
            <div class="bar dangerbar"><div class="barfill" style="width:<%= Math.min((dashboardData?.systemStatus?.errors24h ?? 0) * 2, 100) %>%"></div></div>
          </div>

          <div class="sys-row">
            <div class="kpi"><span>DB lag</span><strong><%= dashboardData?.systemStatus?.dbLag ?? "0s" %></strong></div>
            <div class="bar okbar"><div class="barfill" style="width:2%"></div></div>
          </div>

          <div class="sys-row">
            <div class="kpi"><span>Storage</span><strong><%= dashboardData?.systemStatus?.storage ?? 0 %>%</strong></div>
            <div class="bar"><div class="barfill" style="width:<%= dashboardData?.systemStatus?.storage ?? 0 %>%"></div></div>
          </div>
        </div>
      </section>
      <% } %>
    </section>

    <section class="grid grid-3">
      <% if (canStudents) { %>
      <section class="card">
        <div class="card-head">
          <div>
            <h3><%= ui.recentLearnersTitle %></h3>
            <p><%= ui.recentLearnersSub %></p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/students">View All</a>
            <a class="btn secondary" href="/admin/students/import">Import</a>
          </div>
        </div>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th><%= ui.learner %></th>
                <th><%= ui.groupLabel %></th>
                <th>Status</th>
                <th class="right">Balance</th>
              </tr>
            </thead>
            <tbody id="recentStudents"></tbody>
          </table>
        </div>
      </section>
      <% } %>

      <% if (canAdmissions) { %>
      <section class="card">
        <div class="card-head">
          <div>
            <h3>Pending Applications</h3>
            <p>Action required</p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/admissions/applicants">View All</a>
            <a class="btn secondary" href="/admin/admissions/intakes">Intakes</a>
          </div>
        </div>

        <div class="table-wrap">
          <table class="table">
            <thead>
              <tr>
                <th>Applicant</th>
                <th><%= ui.groupLabel %></th>
                <th>Location</th>
                <th class="right">Action</th>
              </tr>
            </thead>
            <tbody id="pendingAppsTable"></tbody>
          </table>
        </div>
      </section>
      <% } %>

      <% if (canFinance) { %>
      <section class="card">
        <div class="card-head">
          <div>
            <h3>Finance Snapshot</h3>
            <p>Month-to-date</p>
          </div>
          <div class="card-actions">
            <a class="btn" href="/admin/finance">Open</a>
            <a class="btn secondary" href="/admin/finance-reports">Reports</a>
          </div>
        </div>

        <div class="fin">
          <div class="kpi">
            <span>Collected</span>
            <strong>
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.collected || 0) %>
            </strong>
          </div>

          <div class="kpi">
            <span>Pending</span>
            <strong class="danger">
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.pending || 0) %>
            </strong>
          </div>

          <div class="kpi">
            <span>Refunds</span>
            <strong>
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.refunds || 0) %>
            </strong>
          </div>

          <div class="kpi">
            <span>Offline payments</span>
            <strong>
              <%= new Intl.NumberFormat("en-US", {
                style: "currency",
                currency: tenant?.currency || "USD",
                maximumFractionDigits: 0
              }).format(stats?.finance?.offlinePayments || 0) %>
            </strong>
          </div>
        </div>

        <div class="canvas-wrap">
          <canvas id="revenueChart"></canvas>
        </div>
      </section>
      <% } %>
    </section>

    <% if (canStudents || canSubjects || canFinance || canAnnouncements || isTenantAdmin) { %>
    <section class="card">
      <div class="card-head">
        <div>
          <h3>Administration Shortcuts</h3>
          <p>Quick admin actions</p>
        </div>
      </div>

      <div class="shortcuts">
        <% if (canStudents) { %><a class="btn" href="/admin/students"><%= ui.addLearner %></a><% } %>
        <% if (isTenantAdmin) { %><a class="btn" href="/admin/staff">+ Add Staff</a><% } %>
        <% if (canAdmissions) { %><a class="btn" href="<%= isHigh ? '/admin/sections' : '/admin/classes' %>"><%= ui.addGroup %></a><% } %>
        <% if (canSubjects) { %><a class="btn" href="/admin/subjects"><%= ui.addSubject %></a><% } %>
        <% if (isTenantAdmin) { %><a class="btn secondary" href="/admin/settings">Settings</a><% } %>
        <% if (canFinance) { %><a class="btn secondary" href="/admin/invoices">Billing</a><% } %>
        <% if (roleAccess.can("studentDocs.view")) { %><a class="btn secondary" href="/admin/student-docs">Storage</a><% } %>
        <% if (canAnnouncements) { %><a class="btn" href="/admin/announcements">Announcements</a><% } %>
      </div>
    </section>
    <% } %>
  </section>
</main>

<script id="dashboard-json" type="application/json"><%- JSON.stringify(dashboardData || {}).replace(/</g, "\\u003c") %></script>

<%- include("../partials/footer") %>
