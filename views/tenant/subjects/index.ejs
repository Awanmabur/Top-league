<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= (tenant?.name || "Classic Academy") %> • Subjects</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />
  <style>
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center}
    .toolbar .left,.toolbar .right{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .input,.select,.textarea,.view-input{padding:10px 12px;border-radius:12px;border:1px solid rgba(13,64,96,.16);background:#fff;outline:none}
    .input{min-width:220px}.textarea{width:100%;min-height:110px;resize:vertical}
    .input:focus,.select:focus,.textarea:focus{border-color:rgba(10,111,191,.45);box-shadow:0 0 0 3px rgba(10,111,191,.12)}
    .view-input{min-height:44px;display:flex;align-items:center;font-weight:800;color:#0f172a;background:#fbfdff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .view-input.multiline{min-height:96px;align-items:flex-start;white-space:pre-wrap;overflow:auto;text-overflow:unset;line-height:1.55}
    .muted{font-size:12px;color:#6b7280}.strong{font-weight:900}
    .grid-4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
    .grid-2{display:grid;grid-template-columns:minmax(0,1.5fr) minmax(280px,.5fr);gap:12px}
    .pill{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;font-size:12px;font-weight:900;white-space:nowrap}
    .ok{background:#ecfdf3;color:#15803d}.warn{background:#fef9c3;color:#92400e}.bad{background:#fee2e2;color:#b91c1c}
    .table-wrap{overflow-x:auto;overflow-y:hidden;border:1px solid rgba(13,64,96,.10);border-radius:12px;max-width:100%;-webkit-overflow-scrolling:touch}
    table{width:100%;min-width:1780px;border-collapse:separate;border-spacing:0;background:#fff;table-layout:fixed}
    th,td{padding:10px 12px;border-bottom:1px solid rgba(13,64,96,.08);vertical-align:middle}
    th{font-size:12px;color:#6b7280;text-transform:uppercase;letter-spacing:.04em;text-align:left;background:rgba(13,64,96,.03);position:sticky;top:0;z-index:1;white-space:nowrap}
    tr:hover td{background:rgba(10,111,191,.04)} tr.row-clickable{cursor:pointer}
    .col-check{width:48px}.col-subject{width:280px}.col-level{width:130px}.col-class{width:220px}.col-section{width:170px}.col-stream{width:160px}.col-term{width:110px}.col-category{width:140px}.col-teacher{width:180px}.col-status{width:140px}.col-actions{width:230px}
    .cell-ellipsis{display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%}
    .subject-main{min-width:0}.subject-title{font-weight:900;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}.subject-sub{font-size:12px;color:#6b7280;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
    .actions{display:flex;gap:6px;justify-content:flex-end;flex-wrap:nowrap;overflow:hidden}
    .btn-xs{padding:6px 8px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;cursor:pointer;font-size:12px;position:relative;z-index:2;flex:0 0 auto}
    .btn-xs:hover{background:rgba(10,111,191,.06)}
    .bulkbar{display:none;margin-top:10px;padding:10px 12px;border-radius:12px;background:rgba(10,111,191,.08);border:1px solid rgba(10,111,191,.18);justify-content:space-between;gap:10px;align-items:center;flex-wrap:wrap}
    .bulkbar.show{display:flex}.badge-count{display:inline-flex;align-items:center;justify-content:center;min-width:26px;height:22px;padding:0 8px;border-radius:999px;background:#0a6fbf;color:#fff;font-size:12px;font-weight:900}
    .flash-wrap{display:grid;gap:10px;margin-bottom:12px}.flash{padding:12px 14px;border-radius:12px;font-weight:700}.flash-success{background:#ecfdf3;color:#166534;border:1px solid #bbf7d0}.flash-error{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
    .topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:14px;flex-wrap:nowrap}.topbar>div:first-child{min-width:0;flex:1 1 auto}.top-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;align-items:center;flex:0 0 auto;margin-left:auto}
    .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.45);display:none;align-items:center;justify-content:center;padding:30px 18px;z-index:9999;overflow-y:auto}
    .modal-backdrop.show{display:flex}
    .modal{width:min(1180px,100%);max-height:calc(100dvh - 40px);background:#fff;border-radius:22px;box-shadow:0 24px 70px rgba(0,0,0,.25);overflow:hidden;display:flex;flex-direction:column}
    .modal.sm{width:min(980px,100%)}.modal.lg{width:min(1180px,100%)}.modal>form{display:flex;flex-direction:column;min-height:0;flex:1 1 auto}
    .modal-header{display:flex;justify-content:space-between;align-items:center;gap:12px;padding:18px 20px;border-bottom:1px solid rgba(13,64,96,.10);background:#fff}
    .modal-title{font-weight:900;font-size:18px;color:#0f172a}.modal-body{padding:18px 20px;overflow-y:auto;flex:1 1 auto}.modal-footer{display:flex;justify-content:flex-end;gap:10px;padding:14px 20px;border-top:1px solid rgba(13,64,96,.10);background:#fff;flex-wrap:wrap}
    .form-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.field{display:flex;flex-direction:column;gap:6px}.field.full{grid-column:1 / -1}.field label{font-size:12px;font-weight:800;color:#475569}
    .char-count{font-size:12px;color:#6b7280;text-align:right}.json-data{display:none!important}
    .mini-list{display:grid;gap:10px;margin-top:10px}.mini-item{display:flex;justify-content:space-between;gap:10px;align-items:center;padding:10px 12px;border:1px solid rgba(13,64,96,.10);border-radius:12px;background:#fff}.mini-item .left{display:grid;gap:2px}
    .pagination{display:flex;justify-content:space-between;align-items:center;gap:12px;margin-top:14px;flex-wrap:wrap}.pagination-links{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
    .page-link{display:inline-flex;align-items:center;justify-content:center;min-width:38px;height:38px;padding:0 12px;border-radius:10px;border:1px solid rgba(13,64,96,.14);background:#fff;color:#0f172a;text-decoration:none;font-weight:800}
    .page-link.active{background:#0a6fbf;color:#fff;border-color:#0a6fbf}.page-link.disabled{pointer-events:none;opacity:.45}
    @media (max-width:1100px){.grid-2{grid-template-columns:1fr}}
    @media (max-width:900px){.form-grid{grid-template-columns:1fr}.topbar{flex-wrap:wrap}.top-actions{width:100%;justify-content:flex-start}}
    @media (max-width:680px){.grid-4{grid-template-columns:repeat(2,minmax(0,1fr))}.input{min-width:160px}}
    @media (max-width:520px){.toolbar .left,.toolbar .right{width:100%}.toolbar .left>*,.toolbar .right>*{max-width:100%}table{min-width:1780px}}
    @media print{body *{visibility:hidden !important}#printArea, #printArea *{visibility:visible !important}#printArea{position:absolute;inset:0;background:#fff;padding:20px}}
  </style>
</head>
<body>
  <div class="app">
    <%- include("../partials/navbar") %>

    <main class="main">
      <% if (typeof messages !== "undefined" && (messages.success?.length || messages.error?.length)) { %>
        <div class="flash-wrap">
          <% (messages.success || []).forEach(function(msg){ %><div class="flash flash-success"><%= msg %></div><% }) %>
          <% (messages.error || []).forEach(function(msg){ %><div class="flash flash-error"><%= msg %></div><% }) %>
        </div>
      <% } %>

      <div class="topbar">
        <div>
          <div class="title">Subjects</div>
          <div class="subtitle">Manage subjects by class, with optional section or stream scope.</div>
        </div>
        <div class="top-actions">
          <button class="btn light" id="btnExport" type="button"><i class="fa-solid fa-file-arrow-down"></i> Export CSV</button>
          <button class="btn light" id="btnPrint" type="button"><i class="fa-solid fa-print"></i> Print</button>
          <button class="btn primary" id="btnCreate" type="button"><i class="fa-solid fa-plus"></i> Add Subject</button>
        </div>
      </div>

      <div class="grid-4">
        <div class="card"><div class="section-title">Total</div><div class="kpi-value"><%= kpis?.total || 0 %></div><div class="muted">Matching filter</div></div>
        <div class="card"><div class="section-title">Active</div><div class="kpi-value" style="color:#15803d"><%= kpis?.active || 0 %></div><div class="muted">Published subjects</div></div>
        <div class="card"><div class="section-title">Draft</div><div class="kpi-value" style="color:#92400e"><%= kpis?.draft || 0 %></div><div class="muted">Work in progress</div></div>
        <div class="card"><div class="section-title">Archived</div><div class="kpi-value" style="color:#b91c1c"><%= kpis?.archived || 0 %></div><div class="muted">Hidden or inactive</div></div>
      </div>

      <section class="card" style="margin-top:12px;">
        <form class="toolbar" method="GET" action="/admin/subjects" data-academic-selector>
          <div class="left">
            <input class="input" name="q" value="<%= query?.q || '' %>" placeholder="Search subject, code, class..." />
            <select class="select" name="schoolUnitId"><option value="">All School Units</option><% (structure || []).forEach(function(su){ %><option value="<%= su.id %>" <%= query?.schoolUnitId===su.id?'selected':'' %>><%= su.name %></option><% }) %></select>
            <select class="select" name="campusId"><option value="">All Campuses</option><% (structure || []).forEach(function(su){ (su.campuses || []).forEach(function(c){ %><option value="<%= c.id %>" <%= query?.campusId===c.id?'selected':'' %>><%= su.name %> • <%= c.name %></option><% }) }) %></select>
            <select class="select" name="levelType"><option value="">All Levels</option><option value="nursery" <%= query?.levelType==='nursery'?'selected':'' %>>Nursery</option><option value="primary" <%= query?.levelType==='primary'?'selected':'' %>>Primary</option><option value="secondary" <%= query?.levelType==='secondary'?'selected':'' %>>Secondary</option></select>
            <select class="select" name="classId" data-role="class" data-placeholder="All Classes"><option value="">All Classes</option><% (classes || []).forEach(function(c){ %><option value="<%= String(c._id) %>" <%= query?.classId===String(c._id)?'selected':'' %>><%= c.name %> • <%= c.stream || 'A' %> • <%= c.academicYear || '' %></option><% }) %></select>
            <select class="select" name="sectionId" data-role="section" data-placeholder="All Sections" data-selected="<%= query?.sectionId || '' %>"><option value="">All Sections</option><% (sections || []).forEach(function(s){ %><option value="<%= String(s._id || s.id) %>" <%= String(query?.sectionId||'')===String(s._id || s.id)?'selected':'' %>><%= s.name || s.label || 'Section' %></option><% }) %></select>
            <select class="select" name="streamId" data-role="stream" data-placeholder="All Streams" data-selected="<%= query?.streamId || '' %>"><option value="">All Streams</option><% (streams || []).forEach(function(s){ %><option value="<%= String(s._id || s.id) %>" <%= String(query?.streamId||'')===String(s._id || s.id)?'selected':'' %>><%= s.name || s.label || 'Stream' %></option><% }) %></select>
            <select class="select" name="academicYear"><option value="">All Years</option><% (academicYears || []).forEach(function(y){ %><option value="<%= y %>" <%= query?.academicYear===y?'selected':'' %>><%= y %></option><% }) %></select>
            <select class="select" name="term"><option value="">All Terms</option><option value="1" <%= String(query?.term||'')==='1'?'selected':'' %>>Term 1</option><option value="2" <%= String(query?.term||'')==='2'?'selected':'' %>>Term 2</option><option value="3" <%= String(query?.term||'')==='3'?'selected':'' %>>Term 3</option></select>
            <select class="select" name="category"><option value="">All Categories</option><option value="core" <%= query?.category==='core'?'selected':'' %>>Core</option><option value="practical" <%= query?.category==='practical'?'selected':'' %>>Practical</option><option value="language" <%= query?.category==='language'?'selected':'' %>>Language</option><option value="religious" <%= query?.category==='religious'?'selected':'' %>>Religious</option><option value="co-curricular" <%= query?.category==='co-curricular'?'selected':'' %>>Co-curricular</option><option value="general" <%= query?.category==='general'?'selected':'' %>>General</option></select>
            <select class="select" name="status"><option value="">All Status</option><option value="active" <%= query?.status==='active'?'selected':'' %>>Active</option><option value="draft" <%= query?.status==='draft'?'selected':'' %>>Draft</option><option value="archived" <%= query?.status==='archived'?'selected':'' %>>Archived</option></select>
          </div>
          <div class="right">
            <button class="btn light" id="btnBulk" type="button"><i class="fa-solid fa-layer-group"></i> Bulk</button>
            <a class="btn light" href="/admin/subjects"><i class="fa-solid fa-rotate-left"></i> Reset</a>
            <button class="btn primary" type="submit"><i class="fa-solid fa-magnifying-glass"></i> Filter</button>
          </div>
        </form>

        <div class="bulkbar" id="bulkbar">
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap"><strong>Selected</strong><span class="badge-count" id="selCount">0</span><span class="muted">subject(s)</span></div>
          <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center">
            <button class="btn-xs" id="bulkActivate" type="button">Activate</button>
            <button class="btn-xs" id="bulkDraft" type="button">Draft</button>
            <button class="btn-xs" id="bulkArchive" type="button">Archive</button>
            <button class="btn-xs" id="bulkDelete" type="button">Delete</button>
            <button class="btn-xs" id="bulkClear" type="button">Clear</button>
          </div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:12px;">
        <section class="card" style="min-width:0;">
          <div style="display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;align-items:center;">
            <div><div class="section-title">Subjects Table</div><div class="section-sub">Showing <%= subjects.length %> of <%= query?.total || 0 %> records.</div></div>
            <div class="muted">Page <%= query?.page || 1 %> of <%= query?.totalPages || 1 %></div>
          </div>
          <div style="margin-top:10px;">
            <div class="table-wrap" id="printArea">
              <table>
                <thead>
                  <tr>
                    <th class="col-check"><input type="checkbox" id="checkAll" /></th>
                    <th class="col-subject">Subject</th>
                    <th class="col-level">Level</th>
                    <th class="col-class">Class</th>
                    <th class="col-section">Section</th>
                    <th class="col-stream">Stream</th>
                    <th class="col-term">Term</th>
                    <th class="col-category">Category</th>
                    <th class="col-teacher">Teacher</th>
                    <th class="col-status">Status</th>
                    <th class="col-actions" style="text-align:right;">Actions</th>
                  </tr>
                </thead>
                <tbody id="tbodySubjects"></tbody>
              </table>
            </div>
          </div>

          <% const currentPage = Number(query?.page || 1); const totalPages = Number(query?.totalPages || 1); function pageUrl(p){ const params = new URLSearchParams(); if (query?.q) params.set('q', query.q); if (query?.status) params.set('status', query.status); if (query?.category) params.set('category', query.category); if (query?.levelType) params.set('levelType', query.levelType); if (query?.classId) params.set('classId', query.classId); if (query?.sectionId) params.set('sectionId', query.sectionId); if (query?.streamId) params.set('streamId', query.streamId); if (query?.term) params.set('term', query.term); if (query?.schoolUnitId) params.set('schoolUnitId', query.schoolUnitId); if (query?.campusId) params.set('campusId', query.campusId); if (query?.academicYear) params.set('academicYear', query.academicYear); params.set('page', String(p)); return '/admin/subjects?' + params.toString(); } %>
          <div class="pagination">
            <div class="muted">Total records: <%= query?.total || 0 %></div>
            <div class="pagination-links">
              <a class="page-link <%= currentPage <= 1 ? 'disabled' : '' %>" href="<%= currentPage <= 1 ? '#' : pageUrl(currentPage - 1) %>">Prev</a>
              <% for (let p = 1; p <= totalPages; p++) { if (p === 1 || p === totalPages || Math.abs(p - currentPage) <= 1) { %>
                <a class="page-link <%= p === currentPage ? 'active' : '' %>" href="<%= pageUrl(p) %>"><%= p %></a>
              <% } else if (Math.abs(p - currentPage) === 2) { %>
                <span class="muted">…</span>
              <% } } %>
              <a class="page-link <%= currentPage >= totalPages ? 'disabled' : '' %>" href="<%= currentPage >= totalPages ? '#' : pageUrl(currentPage + 1) %>">Next</a>
            </div>
          </div>
        </section>

        <aside class="card" style="min-width:0;">
          <div class="section-title">Quick Actions</div>
          <div class="section-sub">Fast create helpers.</div>
          <div class="mini-list">
            <div class="mini-item"><div class="left"><div class="strong">Add Core Subject</div><div class="muted">Pre-fill category as Core</div></div><button class="btn-xs" id="quickCore" type="button"><i class="fa-solid fa-book"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add Language Subject</div><div class="muted">Pre-fill category as Language</div></div><button class="btn-xs" id="quickLanguage" type="button"><i class="fa-solid fa-language"></i></button></div>
            <div class="mini-item"><div class="left"><div class="strong">Add Secondary Subject</div><div class="muted">Pre-fill level as Secondary</div></div><button class="btn-xs" id="quickSecondary" type="button"><i class="fa-solid fa-graduation-cap"></i></button></div>
          </div>
        </aside>
      </div>
    </main>
  </div>

  <div class="modal-backdrop" id="mEdit">
    <div class="modal lg">
      <div class="modal-header">
        <div class="modal-title" id="mTitleBar">Add Subject</div>
        <button class="btn-xs" type="button" data-close-modal="mEdit"><i class="fa-solid fa-xmark"></i></button>
      </div>

      <form id="subjectForm" method="POST" action="/admin/subjects">
        <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>

        <div class="modal-body">
          <div class="form-grid">
            <div class="field full"><label>Subject Name</label><input class="input" id="mTitle" name="title" required /></div>
            <div class="field"><label>Subject Code</label><input class="input" id="mCode" name="code" placeholder="Auto-generated if blank" /></div>
            <div class="field"><label>Status</label><select class="select" id="mStatus" name="status"><option value="active">Active</option><option value="draft">Draft</option><option value="archived">Archived</option></select></div>
            <div class="field"><label>Short Title</label><input class="input" id="mShortTitle" name="shortTitle" /></div>
            <div class="field"><label>School Unit</label><select class="select" id="mSchoolUnitId" name="schoolUnitId" required><option value="">— Select School Unit —</option><% (structure || []).forEach(function(su){ %><option value="<%= su.id %>"><%= su.name %></option><% }) %></select></div>
            <div class="field"><label>Campus</label><select class="select" id="mCampusId" name="campusId" required><option value="">— Select Campus —</option></select></div>
            <div class="field"><label>School Level</label><select class="select" id="mLevelType" name="levelType" required><option value="">— Select Level —</option></select></div>
            <div class="field"><label>Class</label><select class="select" id="mClassId" name="classId" required><option value="">— Select Class —</option></select></div>
            <div class="field"><label>Section</label><select class="select" id="mSectionId" name="sectionId"><option value="">— Whole Class —</option></select></div>
            <div class="field"><label>Stream</label><select class="select" id="mStreamId" name="streamId"><option value="">— All Streams —</option></select></div>
            <div class="field"><label>Term</label><select class="select" id="mTerm" name="term"><option value="1">Term 1</option><option value="2">Term 2</option><option value="3">Term 3</option></select></div>
            <div class="field"><label>Academic Year</label><input class="input" id="mAcademicYear" name="academicYear" placeholder="2026" /></div>
            <div class="field"><label>Category</label><select class="select" id="mCategory" name="category"><option value="core">Core</option><option value="practical">Practical</option><option value="language">Language</option><option value="religious">Religious</option><option value="co-curricular">Co-curricular</option><option value="general">General</option></select></div>
            <div class="field"><label>Teacher</label><select class="select" id="mTeacher" name="teacher"><option value="">— Select Teacher —</option><% (staffList || []).forEach(function(s){ %><option value="<%= String(s._id) %>"><%= s.fullName || s.name || 'Staff' %><%= s.role ? (' — ' + s.role) : '' %></option><% }) %></select></div>
            <div class="field"><label>Weekly Periods</label><input class="input" id="mWeeklyPeriods" name="weeklyPeriods" type="number" min="0" max="50" /></div>
            <div class="field"><label>Pass Mark (%)</label><input class="input" id="mPassMark" name="passMark" type="number" min="0" max="100" /></div>
            <div class="field"><label>Compulsory</label><input id="mIsCompulsory" name="isCompulsory" type="checkbox" checked style="width:auto;height:18px;" /></div>
            <div class="field full"><label>Assessment Method</label><input class="input" id="mAssessmentMethod" name="assessmentMethod" /></div>
            <div class="field full"><label>Description</label><textarea class="textarea" id="mDescription" name="description" maxlength="1200"></textarea><div class="char-count" id="descCount">0 / 1200</div></div>
            <div class="field full"><label>Objectives</label><textarea class="textarea" id="mObjectives" name="objectives" maxlength="1200"></textarea><div class="char-count" id="objCount">0 / 1200</div></div>
            <div class="field full"><label>Outline</label><textarea class="textarea" id="mOutline" name="outline" maxlength="5000"></textarea><div class="char-count" id="outlineCount">0 / 5000</div></div>
          </div>
        </div>

        <div class="modal-footer">
          <button class="btn light" type="button" data-close-modal="mEdit">Cancel</button>
          <button class="btn primary" id="saveBtn" type="button">Save Subject</button>
        </div>
      </form>
    </div>
  </div>

  <div class="modal-backdrop" id="mView">
    <div class="modal sm">
      <div class="modal-header">
        <div class="modal-title">Subject Details</div>
        <button class="btn-xs" type="button" data-close-modal="mView"><i class="fa-solid fa-xmark"></i></button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field"><label>Subject</label><div class="view-input" id="vTitle">—</div></div>
          <div class="field"><label>Code</label><div class="view-input" id="vCode">—</div></div>
          <div class="field"><label>Status</label><div class="view-input" id="vStatus">—</div></div>
          <div class="field"><label>Class</label><div class="view-input" id="vClass">—</div></div>
          <div class="field"><label>School Level</label><div class="view-input" id="vLevel">—</div></div>
          <div class="field"><label>Section</label><div class="view-input" id="vSection">—</div></div>
          <div class="field"><label>Stream</label><div class="view-input" id="vStream">—</div></div>
          <div class="field"><label>Term</label><div class="view-input" id="vTerm">—</div></div>
          <div class="field"><label>Category / Type</label><div class="view-input" id="vCategoryType">—</div></div>
          <div class="field"><label>Periods / Pass Mark</label><div class="view-input" id="vPeriodsPass">—</div></div>
          <div class="field"><label>Assessment</label><div class="view-input" id="vAssessment">—</div></div>
          <div class="field"><label>Teacher</label><div class="view-input" id="vTeacher">—</div></div>
        </div>
        <div class="field" style="margin-top:12px;"><label>Description</label><div class="view-input multiline" id="vDescription">—</div></div>
        <div class="field" style="margin-top:12px;"><label>Objectives</label><div class="view-input multiline" id="vObjectives">—</div></div>
        <div class="field" style="margin-top:12px;"><label>Outline</label><div class="view-input multiline" id="vOutline">—</div></div>
      </div>
      <div class="modal-footer">
        <button class="btn light" type="button" id="viewActivateBtn">Activate</button>
        <button class="btn light" type="button" id="viewDraftBtn">Draft</button>
        <button class="btn light" type="button" id="viewArchiveBtn">Archive</button>
        <button class="btn light" type="button" data-close-modal="mView">Close</button>
        <button class="btn primary" type="button" id="viewEditBtn">Edit</button>
      </div>
    </div>
  </div>

  <form id="rowActionForm" method="POST" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="status" id="rowStatusField">
  </form>

  <form id="bulkForm" method="POST" action="/admin/subjects/bulk" style="display:none;">
    <% if (csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
    <input type="hidden" name="action" id="bulkActionField">
    <input type="hidden" name="ids" id="bulkIdsField">
  </form>

  <textarea id="subjectsData" class="json-data" aria-hidden="true"><%- JSON.stringify((subjects || []).map(function(s){
    return {
      id: String(s._id || ''),
      title: s.title || '',
      code: s.code || '',
      shortTitle: s.shortTitle || '',
      schoolUnitId: s.schoolUnitId || '',
      schoolUnitName: s.schoolUnitName || '',
      campusId: s.campusId || '',
      campusName: s.campusName || '',
      levelType: s.levelType || '',
      classId: s.classId?._id ? String(s.classId._id) : String(s.classId || ''),
      className: s.className || s.classId?.name || '',
      classLevel: s.classLevel || s.classId?.classLevel || '',
      sectionId: s.sectionId?._id ? String(s.sectionId._id) : String(s.sectionId || ''),
      sectionName: s.sectionName || '',
      streamId: s.streamId?._id ? String(s.streamId._id) : String(s.streamId || ''),
      streamName: s.streamName || s.streamId?.name || '',
      term: Number(s.term ?? 1),
      academicYear: s.academicYear || '',
      category: s.category || 'core',
      isCompulsory: !!s.isCompulsory,
      weeklyPeriods: Number(s.weeklyPeriods || 0),
      passMark: Number(s.passMark || 0),
      assessmentMethod: s.assessmentMethod || '',
      status: s.status || 'active',
      description: s.description || '',
      objectives: s.objectives || '',
      outline: s.outline || '',
      teacherId: s.teacher?._id ? String(s.teacher._id) : (s.teacher ? String(s.teacher) : ''),
      teacherName: s.teacher?.fullName || s.teacher?.name || ''
    };
  })) %></textarea>

  <textarea id="classesData" class="json-data" aria-hidden="true"><%- JSON.stringify((classes || []).map(function(c){
    return {
      id: String(c._id || ''),
      name: c.name || '',
      schoolUnitId: c.schoolUnitId || '',
      schoolUnitName: c.schoolUnitName || '',
      campusId: c.campusId || '',
      campusName: c.campusName || '',
      levelType: c.levelType || '',
      classLevel: c.classLevel || '',
      stream: c.stream || '',
      academicYear: c.academicYear || ''
    };
  })) %></textarea>

  <textarea id="structureData" class="json-data" aria-hidden="true"><%- JSON.stringify(structure || []) %></textarea>
  <textarea id="sectionsMap" class="json-data" aria-hidden="true"><%- JSON.stringify(sectionsMap || {}) %></textarea>
  <textarea id="sectionsData" class="json-data" aria-hidden="true"><%- JSON.stringify(sections || []) %></textarea>
  <textarea id="streamsData" class="json-data" aria-hidden="true"><%- JSON.stringify(streams || []) %></textarea>

  <script src="/js/navbar.js"></script>
  <script src="/js/academic-selector.js"></script>
  <script src="/js/subjects.js"></script>
</body>
</html>
