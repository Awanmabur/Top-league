<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Set Password - Classic Academy</title>
  <link rel="icon" href="data:,">
  <style>
    :root{
      --bg:#f4f8ff; --card:#fff; --text:#0f172a; --muted:#6b7280;
      --accent:#0a6fbf; --line:rgba(2,6,23,.08); --danger:#ef4444;
      --shadow:0 14px 40px rgba(2,6,23,.10);
    }
    *{box-sizing:border-box}
    body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:var(--bg);color:var(--text);min-height:100vh;display:grid;place-items:center;padding:18px}
    .card{width:min(520px,100%);background:var(--card);border:1px solid var(--line);border-radius:18px;box-shadow:var(--shadow);padding:16px}
    h1{margin:0;font-size:18px}
    .sub{margin-top:4px;color:var(--muted);font-size:12px;line-height:1.5}
    label{display:block;font-size:12px;color:var(--muted);font-weight:900;margin:12px 0 6px}
    input{width:100%;padding:12px;border-radius:12px;border:1px solid var(--line);outline:none}
    input:focus{border-color:rgba(10,111,191,.5);box-shadow:0 0 0 4px rgba(10,111,191,.10)}
    .btn{width:100%;border:0;background:var(--accent);color:#fff;padding:12px;border-radius:12px;font-weight:900;margin-top:14px;cursor:pointer}
    .error{background:#fee2e2;border:1px solid rgba(185,28,28,.25);color:#991b1b;padding:10px 12px;border-radius:12px;font-weight:900;font-size:13px;margin-top:12px}
    .hint{color:var(--muted);font-size:12px;margin-top:10px;line-height:1.5}
  </style>
</head>
<body>
  <div class="card">
    <h1>Set your password</h1>
    <div class="sub">
      Create a strong password to activate your account.
    </div>

    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>

    <form method="POST" action="/set-password" autocomplete="off">
      <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>" />
      <input type="hidden" name="token" value="<%= token || '' %>" />

      <label>New Password</label>
      <input name="password" type="password" required minlength="10" />

      <label>Confirm Password</label>
      <input name="confirmPassword" type="password" required minlength="10" />

      <button class="btn" type="submit">Activate Account</button>
    </form>

    <div class="hint">
      Password policy: 10+ characters with uppercase, lowercase, number, and a symbol.
      After activation you'll be redirected to login.
    </div>
  </div>
</body>
</html>
