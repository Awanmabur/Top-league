    .cform textarea {
      width: 100%;
      padding: .85rem 1rem;
      border-radius: 22px;
      border: 1px solid rgba(74, 144, 226, .35);
      background: rgba(255, 255, 255, .80);
      outline: none;
      resize: vertical;
    }

    .cform input:focus,
    .cform textarea:focus {
      border-color: rgba(74, 144, 226, .65);
      box-shadow: 0 0 0 4px rgba(74, 144, 226, .12);
    }

    .cform .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .8rem;
    }

    .form-actions {
      display: flex;
      gap: .6rem;
      flex-wrap: nowrap;
      margin-top: .25rem;
      align-items: center;
    }

    .form-actions>* {
      flex: 1 1 0;
    }

    @media (max-width: 520px) {
      .form-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .6rem;
      }

      .form-actions .btn,
      .form-actions button.btn {
        width: 100%;
      }
    }

    .form-note {
      margin: .75rem 0 0 0;
      color: #64748b;
      font-size: .9rem;
    }

    @media (max-width: 860px) {
      .cgrid {
        grid-template-columns: 1fr;
      }

      .cform .row {
        grid-template-columns: 1fr;
      }
    }

    /* FOOTER */
    .footer {
      background-color: #f9f9f9;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      font-size: 0.95rem;
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(10px);
      border-radius: 25px;
      margin: 2rem var(--page-pad);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
      gap: 0;
    }

    .footer div {
      margin: 1rem;
      flex: 1 1 220px;
      min-width: 220px;
    }

    .footer h4 {
      font-size: 1rem;
      margin-bottom: 1rem;
    }

    .footer ul {
      list-style: none;
      padding: 0;
    }

    .footer ul li {
      margin-bottom: 0.5rem;
    }

    .footer ul li a {
      color: #333;
    }

    .footer ul li a:hover {
      text-decoration: underline;
    }

    #toTopBtn {
      position: fixed;
      bottom: 30px;
      right: 30px;
      background-color: var(--primary);
      color: white;
      border: none;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1.5rem;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
      display: none;
      z-index: 1000;
      transition: transform 0.2s ease;
    }

    #toTopBtn:hover {
      transform: scale(1.08);
    }

    .fab-container {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      align-items: center;
      position: fixed;
      bottom: 170px;
      right: 20px;
      z-index: 999;
    }

    .whatsapp-icon {
      transition: fill 0.3s ease;
      cursor: pointer;
    }

    .whatsapp-icon:hover {
      fill: white;
    }

    .fab-container:hover {
      height: 100%;
    }

    .fab-container:hover .sub-button:nth-child(2) {
      transform: translateY(-80px);
    }

    .fab-container:hover .sub-button:nth-child(3) {
      transform: translateY(-140px);
    }

    .fab-container:hover .sub-button:nth-child(4) {
      transform: translateY(-200px);
    }

    .fab-container .sub-button {
      position: absolute;
      display: flex;
      align-items: center;
      justify-content: center;
      bottom: 10px;
      right: 10px;
      height: 50px;
      width: 50px;
      background-color: #4ba2ff;
      border-radius: 50%;
      transition: all 0.3s ease;
    }

    .fab-container .sub-button:hover {
      cursor: pointer;
    }

    .fab-container .sub-button .material-icons {
      color: #2e2e2e;
      padding-top: 6px;
    }

    .fab-container .sub-button .material-icons:hover {
      color: #FEFEFE;
    }

    .fab-container .fab {
      position: relative;
      height: 70px;
      width: 70px;
      background-color: #4ba2ff;
      border-radius: 50%;
      z-index: 2;
    }

    .fab-container .fab:before {
      content: " ";
      position: absolute;
      bottom: 0;
      right: 0;
      height: 35px;
      width: 35px;
      background-color: inherit;
      border-radius: 0 0 10px 0;
      z-index: -1;
    }

    .fab-container .fab .fab-content {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
      width: 100%;
      border-radius: 50%;
      cursor: pointer;
      user-select: none;
    }

    .fab-container .fab .fab-content .material-icons {
      color: #2e2e2e;
      font-size: 48px;
    }

    /* Mobile perf */
    @media (max-width: 600px) {

      .header,
      .hero,
      .features,
      .p4-wrap,
      .tcard,
      .blogs-wrap,
      .cinfo,
      .cform,
      .footer,
      .navbar {
        backdrop-filter: none !important;
      }

      .header {
        box-shadow: 0 10px 26px rgba(15, 23, 42, .10);
      }

      .hero {
        box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
      }

      .p4-wrap {
        box-shadow: 0 16px 50px rgba(15, 23, 42, .10);
      }

      .tcard {
        box-shadow: 0 14px 40px rgba(15, 23, 42, .10);
      }
    }

    @media (max-width: 1024px) {
      .features {
        padding: 1.2rem 1.2rem;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .orbit-wrapper {
        padding: 2.2rem var(--page-pad);
      }

      .feature-list {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 480px) {
      .features {
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      }

      .orbit-section {
        height: min(420px, 92vw);
      }

      .orbit-ring {
        width: min(260px, 72vw);
        height: min(260px, 72vw);
      }

      .fab-container {
        bottom: 180px;
      }

      .footer h4 {
        font-size: 1.15rem;
      }
    }

    @media (max-width: 920px) and (orientation: landscape) {
      .orbit-section {
        height: min(420px, 70vw);
      }
    }


    /* ===========================
   Schools page (uniform with main page)
   =========================== */
    .schools-page {
      position: relative;
      margin: 0 var(--page-pad);
      margin-bottom: 2rem;
      border-radius: calc(var(--radius) + 6px);
      overflow: hidden;
      background:
        radial-gradient(900px 420px at 10% 15%, rgba(74, 144, 226, .18), transparent 60%),
        radial-gradient(760px 420px at 90% 0%, rgba(217, 120, 0, .12), transparent 55%),
        linear-gradient(180deg, rgba(255, 255, 255, .75), rgba(255, 255, 255, .55));
      border: 1px solid rgba(255, 255, 255, .65);
      box-shadow: var(--shadow2);
    }

    .schools-shell {
      padding: clamp(1rem, 2.2vw, 1.35rem);
    }

    .schools-hero {
      border-radius: var(--radius);
      padding: clamp(1rem, 2.3vw, 1.4rem);
      background:
        radial-gradient(920px 320px at 10% 10%, rgba(74, 144, 226, .24), transparent 62%),
        radial-gradient(800px 300px at 90% 0%, rgba(0, 159, 139, .18), transparent 55%),
        linear-gradient(180deg, rgba(255, 255, 255, .82), rgba(255, 255, 255, .58));
      border: 1px solid rgba(255, 255, 255, .78);
      box-shadow: 0 12px 28px rgba(15, 23, 42, .10);
    }

    .schools-kicker {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      padding: .45rem .75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .70);
      border: 1px solid rgba(255, 255, 255, .82);
      color: #1b2a4e;
      font-weight: 800;
      width: fit-content;
    }

    .schools-hero h1 {
      margin-top: .85rem;
      font-size: clamp(1.55rem, 2.55vw, 2.35rem);
      line-height: 1.15;
      letter-spacing: -.02em;
      color: var(--ink);
    }

    .schools-hero h1 span {
      color: var(--primary);
    }

    .schools-sub {
      margin-top: .65rem;
      color: var(--muted);
      font-weight: 650;
      max-width: 58rem;
    }

    .schools-stats {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      margin-top: 1rem;
    }

    .schools-stat {
      display: flex;
      align-items: center;
      gap: .6rem;
      padding: .55rem .75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .62);
      border: 1px solid rgba(255, 255, 255, .80);
      box-shadow: 0 10px 22px rgba(15, 23, 42, .06);
      color: #1b2a4e;
      font-weight: 800;
    }

    .schools-stat span {
      color: var(--muted);
      font-weight: 700;
    }

    .schools-controls {
      display: grid;
      grid-template-columns: 1.2fr .8fr .8fr .8fr;
      gap: .75rem;
      margin-top: var(--section-gap);
    }

    .schools-control {
      display: flex;
      align-items: center;
      gap: .65rem;
      padding: .75rem .85rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(255, 255, 255, .86);
      box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
    }

    .schools-control i {
      color: rgba(15, 23, 42, .55);
    }

    .schools-control input,
    .schools-control select {
      width: 100%;
      border: none;
      outline: none;
      background: transparent;
      font: inherit;
      color: var(--ink);
      font-weight: 700;
    }

    .schools-control select {
      cursor: pointer;
    }

    .schools-chips {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      margin-top: .9rem;
    }

    .schools-chip {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      padding: .55rem .75rem;
      border-radius: 999px;
      border: 1px solid rgba(15, 23, 42, .10);
      background: rgba(255, 255, 255, .70);
      color: var(--ink);
      font-weight: 800;
      cursor: pointer;
    }

    .schools-chip i {
      color: var(--primary);
    }

    .schools-chip.is-active {
      background: linear-gradient(135deg, var(--primary), var(--highlight));
      border-color: transparent;
      color: #fff;
    }

    .schools-chip.is-active i {
      color: #fff;
    }

    .schools-empty {
      display: none;
      margin-top: 1rem;
      padding: 1rem;
      border-radius: var(--radius);
      background: rgba(255, 255, 255, .72);
      border: 1px solid rgba(255, 255, 255, .86);
      box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
      text-align: center;
    }

    .schools-empty-icon {
      width: 44px;
      height: 44px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      margin: 0 auto .5rem;
      background: rgba(74, 144, 226, .12);
      border: 1px solid rgba(74, 144, 226, .18);
      color: var(--primary);
    }

    .schools-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .9rem;
      margin-top: 1rem;
      padding-bottom: .35rem;
    }

    .school-card {
      background: rgba(255, 255, 255, .82);
      border: 1px solid rgba(255, 255, 255, .88);
      border-radius: calc(var(--radius) - 2px);
      overflow: hidden;
      box-shadow: 0 14px 30px rgba(15, 23, 42, .08);
      transition: transform .18s ease, box-shadow .18s ease;
      cursor: pointer;
    }

    .school-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 20px 46px rgba(15, 23, 42, .12);
    }

    .school-cover {
      height: 120px;
      position: relative;
      overflow: hidden;
    }

    .school-cover::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(600px 220px at 70% 10%, rgba(255, 255, 255, 0.22), transparent 60%);
      opacity: .95;
    }

    .school-avatar {
      position: absolute;
      left: 14px;
      bottom: -22px;
      width: 52px;
      height: 52px;
      border-radius: 16px;
      background: rgba(255, 255, 255, .92);
      border: 1px solid rgba(255, 255, 255, .92);
      display: grid;
      place-items: center;
      font-weight: 900;
      color: #1b2a4e;
      box-shadow: 0 14px 28px rgba(15, 23, 42, .12);
      z-index: 2;
    }

    .school-badge {
      position: absolute;
      top: 12px;
      right: 12px;
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .4rem .6rem;
      border-radius: 999px;
      font-size: .82rem;
      font-weight: 800;
      background: rgba(255, 255, 255, .30);
      border: 1px solid rgba(255, 255, 255, .45);
      color: #fff;
      backdrop-filter: blur(10px);
      z-index: 2;
    }

    .school-badge.ok {
      background: rgba(236, 253, 243, .92);
      border-color: rgba(187, 247, 208, .95);
      color: #15803d;
      backdrop-filter: none;
    }

    .school-body {
      padding: 2.1rem .95rem .95rem;
    }

    .school-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: .7rem;
    }

    .school-name {
      margin: 0;
      font-size: 1rem;
      letter-spacing: -.01em;
      line-height: 1.2;
      color: var(--ink);
    }

    .school-pill {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      padding: .38rem .6rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, .70);
      border: 1px solid rgba(15, 23, 42, .10);
      color: var(--ink);
      font-weight: 800;
      font-size: .82rem;
      white-space: nowrap;
    }

    .school-pill i {
      color: var(--primary);
    }

    .school-tagline {
      margin-top: .55rem;
      color: var(--muted);
      font-weight: 650;
      font-size: .92rem;
      min-height: 2.2rem;
    }

    .school-meta {
      display: flex;
      flex-wrap: wrap;
      gap: .65rem;
      margin-top: .6rem;
      color: rgba(15, 23, 42, .85);
      font-weight: 750;
      font-size: .86rem;
    }

    .school-meta i {
      color: var(--primary);
    }

    .school-kpis {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: .55rem;
      margin-top: .75rem;
    }

    .school-kpi {
      border-radius: 16px;
      border: 1px solid rgba(15, 23, 42, .08);
      background: rgba(15, 23, 42, .03);
      padding: .55rem .6rem;
    }

    .school-kpi .v {
      font-weight: 900;
      color: #1b2a4e;
      font-size: .92rem;
    }

    .school-kpi .l {
      margin-top: .15rem;
      color: var(--muted);
      font-weight: 800;
      font-size: .75rem;
    }

    .school-actions {
      display: flex;
      flex-wrap: wrap;
      gap: .55rem;
      margin-top: .75rem;
    }

    .schools-btn {
      padding: .55rem .8rem !important;
      border-radius: 999px !important;
      font-size: .92rem !important;
    }

    /* Drawer */
    .schools-drawer {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, .55);
      display: none;
      z-index: 1000;
    }

    .schools-drawer.show {
      display: block;
    }

    .schools-sheet {
      position: absolute;
      top: 0;
      right: 0;
      width: min(520px, 92vw);
      height: 100%;
      background: rgba(255, 255, 255, .94);
      border-left: 1px solid rgba(255, 255, 255, .85);
      box-shadow: -20px 0 60px rgba(2, 8, 23, .25);
      padding: 1rem;
      overflow: auto;
    }

    .schools-sheet-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: .8rem;
      padding-bottom: .75rem;
      border-bottom: 1px solid rgba(15, 23, 42, .08);
      margin-bottom: .85rem;
    }

    .schools-sheet-top h3 {
      margin: 0;
      color: #1b2a4e;
      letter-spacing: -.01em;
    }

    .schools-sheet-close {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      border: 1px solid rgba(15, 23, 42, .10);
      background: rgba(255, 255, 255, .9);
      cursor: pointer;
      display: grid;
      place-items: center;
    }

    .schools-sheet-card {
      border-radius: calc(var(--radius) - 2px);
      border: 1px solid rgba(15, 23, 42, .08);
      background: rgba(15, 23, 42, .02);
      padding: .85rem;
      margin-bottom: .85rem;
    }

    .schools-sheet-row {
      display: flex;
      gap: .75rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .schools-sheet-logo {
      width: 56px;
      height: 56px;
      border-radius: 16px;
      background: rgba(255, 255, 255, .92);
      border: 1px solid rgba(15, 23, 42, .10);
      display: grid;
      place-items: center;
      font-weight: 900;
      color: #1b2a4e;
    }

    .schools-sheet-name {
      font-weight: 900;
      color: var(--ink);
    }

    .schools-sheet-tag {
      color: var(--muted);
      font-weight: 650;
      font-size: .92rem;
      margin-top: .2rem;
    }

    .schools-sheet-meta {
      display: flex;
      flex-wrap: wrap;
      gap: .6rem;
      margin-top: .75rem;
      color: rgba(15, 23, 42, .9);
      font-weight: 750;
      font-size: .86rem;
    }

    .schools-sheet-meta i {
      color: var(--primary);
    }

    .schools-sheet-actions {
      display: flex;
      gap: .65rem;
      flex-wrap: wrap;
      margin-top: .85rem;
    }

    .schools-sheet-title {
      color: #1b2a4e;
    }

    .schools-ul {
      margin-top: .55rem;
      padding-left: 1.1rem;
      color: var(--ink);
      font-weight: 700;
    }

    .schools-muted {
      color: var(--muted);
      font-weight: 650;
    }

    @media (max-width: 980px) {
      .schools-controls {
        grid-template-columns: 1fr 1fr;
      }

      .schools-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 760px) {
      .schools-controls {
        grid-template-columns: 1fr;
      }

      .schools-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>

