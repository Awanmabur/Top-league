  <!-- libs -->
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

  <script>
    (() => {
      // ---------- Data (Mock) ----------
      const schools = [
        {
          id: "s1",
          name: "Classic Academy",
          short: "CA",
          type: "Secondary School",
          city: "Kampala",
          country: "Uganda",
          verified: true,
          system: "Day & Boarding",
          tagline: "Discipline • Excellence • Technology-driven learning",
          programs: 18,
          students: 1240,
          awards: 8,
          tags: ["boarding", "day", "science", "ict", "verified"],
          phone: "+256 781 977 217"
        },
        {
          id: "s2",
          name: "Junub International College",
          short: "JIC",
          type: "College",
          city: "Jinja",
          country: "Uganda",
          verified: false,
          system: "Day",
          tagline: "Career-focused education with modern skills.",
          programs: 12,
          students: 640,
          awards: 3,
          tags: ["day", "ict"],
          phone: "+256 700 000 001"
        },
        {
          id: "s3",
          name: "Nile View Primary School",
          short: "NV",
          type: "Primary School",
          city: "Entebbe",
          country: "Uganda",
          verified: true,
          system: "Day",
          tagline: "Strong foundation, caring teachers, happy learners.",
          programs: 8,
          students: 980,
          awards: 5,
          tags: ["day", "verified"],
          phone: "+256 700 000 002"
        },
        {
          id: "s4",
          name: "Gulu Science & Tech Institute",
          short: "GST",
          type: "Institute",
          city: "Gulu",
          country: "Uganda",
          verified: true,
          system: "Day & Boarding",
          tagline: "Hands-on science, labs, and real-world projects.",
          programs: 20,
          students: 720,
          awards: 6,
          tags: ["boarding", "day", "science", "ict", "verified"],
          phone: "+256 700 000 003"
        },
        {
          id: "s5",
          name: "Mbarara Excellence High School",
          short: "ME",
          type: "Secondary School",
          city: "Mbarara",
          country: "Uganda",
          verified: false,
          system: "Boarding",
          tagline: "High performance with strong discipline culture.",
          programs: 15,
          students: 1100,
          awards: 4,
          tags: ["boarding", "science"],
          phone: "+256 700 000 004"
        },
        {
          id: "s6",
          name: "Kampala Business University",
          short: "KBU",
          type: "University",
          city: "Kampala",
          country: "Uganda",
          verified: true,
          system: "Day",
          tagline: "Business, leadership and innovation for tomorrow.",
          programs: 26,
          students: 3200,
          awards: 10,
          tags: ["day", "ict", "verified"],
          phone: "+256 700 000 005"
        }
      ];

      // ---------- Helpers ----------
      function coverGradient(seed) {
        const combos = [
          ["rgba(74,144,226,.92)", "rgba(0,159,139,.45)"],
          ["rgba(0,159,139,.82)", "rgba(217,120,0,.42)"],
          ["rgba(217,120,0,.72)", "rgba(74,144,226,.52)"],
          ["rgba(15,23,42,.78)", "rgba(74,144,226,.55)"],
        ];
        const idx = seed % combos.length;
        return `linear-gradient(135deg, ${combos[idx][0]}, ${combos[idx][1]})`;
      }
      function fmt(n) {
        return String(n).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
      }

      // ---------- Elements ----------
      const qEl = document.getElementById("schoolsQ");
      const cityEl = document.getElementById("schoolsCity");
      const typeEl = document.getElementById("schoolsType");
      const sortEl = document.getElementById("schoolsSort");
      const gridEl = document.getElementById("schoolsGrid");
      const emptyEl = document.getElementById("schoolsEmpty");

      // Drawer
      const drawer = document.getElementById("schoolsDrawer");
      const drawerClose = document.getElementById("schoolsDrawerClose");
      const sheetLogo = document.getElementById("schoolsSheetLogo");
      const sheetName = document.getElementById("schoolsSheetName");
      const sheetTag = document.getElementById("schoolsSheetTag");
      const sheetMeta = document.getElementById("schoolsSheetMeta");
      const btnView = document.getElementById("schoolsBtnView");
      const btnApply = document.getElementById("schoolsBtnApply");

      let selectedId = null;
      let activeChip = "all";

      function openDrawer(s) {
        selectedId = s.id;
        sheetLogo.textContent = s.short || (s.name || "S").slice(0, 2).toUpperCase();
        sheetName.textContent = s.name;
        sheetTag.textContent = s.tagline;

        const pills = [];
        pills.push(`<span><i class="fa-solid fa-location-dot"></i> ${s.city}, ${s.country}</span>`);
        pills.push(`<span><i class="fa-solid fa-building-columns"></i> ${s.type}</span>`);
        pills.push(`<span><i class="fa-solid fa-bed"></i> ${s.system}</span>`);
        pills.push(`<span><i class="fa-solid fa-phone"></i> ${s.phone}</span>`);
        pills.push(`<span><i class="fa-solid fa-users"></i> ${fmt(s.students)} students</span>`);
        pills.push(`<span><i class="fa-solid fa-graduation-cap"></i> ${fmt(s.programs)} programs</span>`);
        pills.push(`<span><i class="fa-solid fa-award"></i> ${fmt(s.awards)} awards</span>`);
        sheetMeta.innerHTML = pills.join("");
        drawer.classList.add("show");
        drawer.setAttribute("aria-hidden", "false");
      }
      function closeDrawer() {
        drawer.classList.remove("show");
        drawer.setAttribute("aria-hidden", "true");
        selectedId = null;
      }

      drawerClose?.addEventListener("click", closeDrawer);
      drawer?.addEventListener("click", (e) => { if (e.target === drawer) closeDrawer(); });

      btnView?.addEventListener("click", () => {
        if (!selectedId) return;
        alert("Mock: open public profile → /schools/" + selectedId);
      });
      btnApply?.addEventListener("click", () => {
        if (!selectedId) return;
        alert("Mock: start application → /admissions/apply?school=" + selectedId);
      });

      // ---------- Chips ----------
      document.querySelectorAll(".schools-chip").forEach(ch => {
        ch.addEventListener("click", () => {
          document.querySelectorAll(".schools-chip").forEach(x => x.classList.remove("is-active"));
          ch.classList.add("is-active");
          activeChip = ch.dataset.chip || "all";
          render();
        });
      });

      // ---------- Filtering / sorting ----------
      function getFiltered() {
        const q = (qEl?.value || "").trim().toLowerCase();
        const city = cityEl?.value || "";
        const type = typeEl?.value || "";

        let list = schools.slice();

        if (activeChip && activeChip !== "all") {
          list = list.filter(s => (s.tags || []).includes(activeChip));
        }

        if (q) {
          list = list.filter(s => {
            const hay = [
              s.name, s.city, s.type, s.tagline,
              (s.tags || []).join(" ")
            ].join(" ").toLowerCase();
            return hay.includes(q);
          });
        }

        if (city) list = list.filter(s => s.city === city);
        if (type) list = list.filter(s => s.type === type);

        const sort = sortEl?.value || "rank";
        if (sort === "students_desc") list.sort((a, b) => (b.students || 0) - (a.students || 0));
        else if (sort === "programs_desc") list.sort((a, b) => (b.programs || 0) - (a.programs || 0));
        else if (sort === "name_asc") list.sort((a, b) => (a.name || "").localeCompare(b.name || ""));
        else {
          list.sort((a, b) => {
            const av = (a.verified ? 1 : 0), bv = (b.verified ? 1 : 0);
            if (bv !== av) return bv - av;
            const aa = (a.awards || 0), ba = (b.awards || 0);
            if (ba !== aa) return ba - aa;
            return (b.students || 0) - (a.students || 0);
          });
        }

        return list;
      }

      // ---------- Render cards ----------
      function render() {
        const list = getFiltered();
        if (!gridEl) return;
        gridEl.innerHTML = "";
        if (emptyEl) emptyEl.style.display = list.length ? "none" : "block";

        list.forEach((s, idx) => {
          const card = document.createElement("article");
          card.className = "school-card";
          card.setAttribute("role", "button");
          card.setAttribute("tabindex", "0");

          const cover = document.createElement("div");
          cover.className = "school-cover";
          cover.style.background = coverGradient(idx);

          const avatar = document.createElement("div");
          avatar.className = "school-avatar";
          avatar.textContent = s.short || (s.name || "S").slice(0, 2).toUpperCase();
          cover.appendChild(avatar);

          const badge = document.createElement("div");
          badge.className = s.verified ? "school-badge ok" : "school-badge";
          badge.innerHTML = s.verified
            ? `<i class="fa-solid fa-circle-check"></i> Verified`
            : `<i class="fa-solid fa-circle-info"></i> Listed`;
          cover.appendChild(badge);

          const body = document.createElement("div");
          body.className = "school-body";
          body.innerHTML = `
        <div class="school-top">
          <h3 class="school-name">${s.name}</h3>
          <span class="school-pill"><i class="fa-solid fa-building-columns"></i> ${s.type}</span>
        </div>
        <div class="school-tagline">${s.tagline}</div>
        <div class="school-meta">
          <span><i class="fa-solid fa-location-dot"></i> ${s.city}, ${s.country}</span>
          <span><i class="fa-solid fa-bed"></i> ${s.system}</span>
        </div>

        <div class="school-kpis">
          <div class="school-kpi"><div class="v">${fmt(s.students)}</div><div class="l">Students</div></div>
          <div class="school-kpi"><div class="v">${fmt(s.programs)}</div><div class="l">Programs</div></div>
          <div class="school-kpi"><div class="v">${fmt(s.awards)}</div><div class="l">Awards</div></div>
        </div>

        <div class="school-actions">
          <button class="btn schools-btn" type="button" data-action="view"><i class="fa-solid fa-id-card"></i> View</button>
          <button class="btn ghost schools-btn" type="button" data-action="apply"><i class="fa-solid fa-file-circle-plus"></i> Apply</button>
        </div>
      `;

          const viewBtn = body.querySelector('[data-action="view"]');
          const applyBtn = body.querySelector('[data-action="apply"]');

          viewBtn?.addEventListener("click", (e) => { e.stopPropagation(); openDrawer(s); });
          applyBtn?.addEventListener("click", (e) => {
            e.stopPropagation();
            alert("Mock: start application → /admissions/apply?school=" + s.id);
          });

          card.addEventListener("click", () => openDrawer(s));
          card.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") { e.preventDefault(); openDrawer(s); }
          });

          card.appendChild(cover);
          card.appendChild(body);
          gridEl.appendChild(card);
        });
      }

      // Live input
      [qEl, cityEl, typeEl, sortEl].forEach(el => el && el.addEventListener("input", render));
      [cityEl, typeEl, sortEl].forEach(el => el && el.addEventListener("change", render));

      render();
    })();
  </script>
  <script>
    // Loader
    setTimeout(() => {
      const loader = document.getElementById("loader");
      if (loader) loader.style.display = "none";
    }, 2000);

    const navbar = document.querySelector('.header .navbar');
    const menuBtn = document.getElementById('menu-btn');
    const toTopBtn = document.getElementById("toTopBtn");

    // Toggle navbar (mobile)
    menuBtn?.addEventListener("click", () => {
      const isOpen = navbar?.classList.toggle('active');
      menuBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    // Close navbar when clicking a link (mobile)
    document.querySelectorAll(".header .navbar a").forEach(a => {
      a.addEventListener("click", () => {
        navbar?.classList.remove("active");
        menuBtn?.setAttribute('aria-expanded', 'false');
      });
    });

    // Close menu if tapping outside
    document.addEventListener("click", (e) => {
      const header = document.getElementById("siteHeader");
      if (!header) return;
      if (!header.contains(e.target)) {
        navbar?.classList.remove("active");
        menuBtn?.setAttribute('aria-expanded', 'false');
      }
    }, { passive: true });

    // Scroll to top button
    window.addEventListener('scroll', () => {
      if (toTopBtn) toTopBtn.style.display = (window.scrollY > 300) ? "block" : "none";
    }, { passive: true });

    toTopBtn?.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));

    // Duplicate featured cards for seamless loop
    (function duplicateFeatured() {
      const track = document.getElementById("featuredTrack");
      if (!track || track.dataset.duplicated === "true") return;
      const cards = Array.from(track.children);
      cards.forEach(card => track.appendChild(card.cloneNode(true)));
      track.dataset.duplicated = "true";
    })();

    // Swiper for testimonials
    const isMobile = window.matchMedia("(max-width: 700px)").matches;
    new Swiper(".testimonial-wrapper", {
      slidesPerView: 1,
      spaceBetween: 18,
      loop: true,
      speed: 800,
      autoplay: isMobile ? false : { delay: 2800, disableOnInteraction: false },
      pagination: { el: ".swiper-pagination", clickable: true },
      nested: true,
      passiveListeners: true,
      touchStartPreventDefault: false,
      touchMoveStopPropagation: false,
      touchAngle: 35,
      threshold: 8,
      breakpoints: {
        520: { slidesPerView: 2 },
        768: { slidesPerView: 3 }
      }
    });

    // Reveal animations
    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        if (entry.target.classList.contains("feature") || entry.target.classList.contains("hero")) {
          entry.target.classList.add("visible");
        }
        if (entry.target.classList.contains("reveal")) {
          entry.target.classList.add("in");
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll(".feature, .hero, .reveal").forEach(el => io.observe(el));

    // Contact form stub
    document.getElementById("contactSendBtn")?.addEventListener("click", () => {
      alert("Message captured. (Connect this to your backend/email endpoint.)");
    });
  </script>
