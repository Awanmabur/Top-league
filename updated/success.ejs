<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" /><title>Academy Created — Classic Academy</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" /><link rel="stylesheet" href="/css/navbar.css" /><style>body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}*{box-sizing:border-box;min-width:0}.main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}.card{background:#fff;border-radius:12px;padding:18px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}.title{font-size:22px;font-weight:800;color:#083454}.subtitle{font-size:13px;color:#6b7280;line-height:1.6}.alert{padding:12px 14px;border-radius:10px;background:#ecfdf5;color:#166534;border:1px solid #bbf7d0}.code-box{background:#0f172a;color:#e2e8f0;padding:12px;border-radius:10px;font-size:13px;overflow:auto}.actions{display:flex;gap:10px;flex-wrap:wrap}.btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}.btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.meta-label{font-size:12px;color:#6b7280}.meta-value{font-size:14px;font-weight:600;color:#0f172a;margin-top:4px}.chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:6px}.chip{padding:7px 10px;border-radius:999px;background:#f8fbff;border:1px solid #dbe7ff;color:#184069;font-size:12px;font-weight:600}@media (max-width:900px){.grid{grid-template-columns:1fr}.main{padding:16px}}</style></head><body><%- include("./navbar") %><main class="main"><div class="card"><div class="alert">Academy created successfully and admin invitation email sent.</div><div class="title" style="margin-top:14px;"><%= tenant?.name || 'Academy Created' %></div><div class="subtitle">The invited admin should check email, set a password, then continue building school unit profiles and campus-scoped operations.</div><% const academics = tenant?.settings?.academics || {}; %><div class="grid" style="margin-top:16px;"><div><div class="meta-label">Tenant</div><div class="meta-value"><%= tenant?.name || '—' %></div></div><div><div class="meta-label">Code</div><div class="meta-value"><%= tenant?.code || '—' %></div></div><div><div class="meta-label">Invited Admin Email</div><div class="meta-value"><%= invitedEmail || tenant?.ownerEmail || '—' %></div></div><div><div class="meta-label">Invitation Status</div><div class="meta-value"><%= inviteSent ? 'Sent' : 'Pending' %></div></div><div><div class="meta-label">School Units</div><div class="meta-value"><%= (academics.schoolUnits || []).length %></div></div><div><div class="meta-label">Campuses</div><div class="meta-value"><%= (academics.campuses || []).length %></div></div></div><div style="margin-top:16px;"><div class="meta-label">School Units Created</div><div class="chips"><% (academics.schoolUnits || []).forEach(function(unit){ %><span class="chip"><%= unit.name %></span><% }) %></div></div><div style="margin-top:16px;"><div class="meta-label">Login URL</div><div class="code-box"><%= loginUrl || '—' %></div></div><div class="actions" style="margin-top:16px;"><a href="/super-admin/universities" class="btn"><i class="fa-solid fa-arrow-left"></i> Back to Academies</a><a href="/super-admin/universities/<%= tenant?._id %>" class="btn primary"><i class="fa-solid fa-building"></i> View Academy</a></div></div></main></body></html>
