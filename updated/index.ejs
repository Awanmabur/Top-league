<!DOCTYPE html>
<html lang="en"><head><meta charset="utf-8" /><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" /><title>Academies — Classic Academy</title><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" /><link rel="stylesheet" href="/css/navbar.css" /><style>body{margin:0;background:#f5f8ff;font-family:Poppins,Segoe UI,Arial,sans-serif;color:#0f172a;overflow-x:hidden}*{box-sizing:border-box;min-width:0}.main{flex:1;padding:20px 26px;display:flex;flex-direction:column;gap:16px}.topbar{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;flex-wrap:wrap}.title{font-size:20px;font-weight:700;color:#083454}.subtitle{font-size:13px;color:#6b7280;margin-top:4px;line-height:1.5}.btn{padding:10px 14px;border-radius:10px;border:1px solid #dbe3f6;background:#eef4ff;color:#0a3d62;text-decoration:none;font-weight:700;display:inline-flex;align-items:center;gap:8px;cursor:pointer}.btn.primary{background:#0a3d62;color:#fff;border-color:#0a3d62}.btn.small{padding:8px 10px;font-size:12px}.card{background:#fff;border-radius:12px;padding:14px;border:1px solid #e4ecfb;box-shadow:0 6px 18px rgba(12,38,73,.04)}.filters{display:grid;grid-template-columns:2fr 1fr 1fr auto;gap:12px;margin-top:10px}input,select{width:100%;padding:10px 12px;border:1px solid #dbe3f6;border-radius:10px;background:#fff}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse;min-width:1240px}th,td{padding:12px 10px;border-bottom:1px solid #edf2ff;text-align:left;font-size:13px;vertical-align:top}th{font-size:12px;text-transform:uppercase;color:#6b7280}.badge{display:inline-flex;padding:5px 9px;border-radius:999px;font-size:11px;font-weight:800;text-transform:capitalize}.green{background:#e6f9ee;color:#166534}.amber{background:#fffbeb;color:#b45309}.red{background:#fff1f2;color:#b91c1c}.gray{background:#f1f5f9;color:#475569}.row-actions{display:flex;gap:8px;flex-wrap:wrap}.empty{padding:24px;text-align:center;color:#6b7280;border:1px dashed #dbe3f6;border-radius:12px;margin-top:12px}.alert{padding:12px 14px;border-radius:10px;background:#fff1f2;color:#991b1b;border:1px solid #fecdd3}.chips{display:flex;gap:6px;flex-wrap:wrap}.chip{display:inline-flex;padding:5px 8px;border-radius:999px;background:#f8fbff;border:1px solid #dbe7ff;color:#184069;font-size:11px;font-weight:700}.muted{font-size:12px;color:#6b7280}form.inline{display:inline}@media (max-width:900px){.filters{grid-template-columns:1fr}.main{padding:16px}}</style></head><body><%- include("./navbar") %><main class="main"><div class="topbar"><div><div class="title">Academies / Tenants</div><div class="subtitle">Manage tenant access, school units, campuses and platform plans from one clean workspace.</div></div><div><a href="/super-admin/universities/create" class="btn primary"><i class="fa-solid fa-building-circle-plus"></i> Add Academy</a></div></div><% if (error) { %><div class="alert"><%= error %></div><% } %><div class="card"><form method="GET" action="/super-admin/universities" class="filters"><input type="text" name="q" value="<%= filters?.q || '' %>" placeholder="Search by name, code, city, school unit or profile..." /><select name="status"><option value="">All Statuses</option><option value="trial" <%= filters?.status === 'trial' ? 'selected' : '' %>>Trial</option><option value="active" <%= filters?.status === 'active' ? 'selected' : '' %>>Active</option><option value="suspended" <%= filters?.status === 'suspended' ? 'selected' : '' %>>Suspended</option><option value="cancelled" <%= filters?.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option></select><select name="plan"><option value="">All Plans</option><% (plans || []).forEach(function(plan){ %><option value="<%= plan._id %>" <%= String(filters?.plan || '') === String(plan._id) ? 'selected' : '' %>><%= plan.name %></option><% }) %></select><button class="btn" type="submit"><i class="fa-solid fa-filter"></i> Filter</button></form><% if (!tenants || tenants.length === 0) { %><div class="empty">No academies found.</div><% } else { %><div class="table-wrap" style="margin-top:14px;"><table><thead><tr><th>Tenant</th><th>School Units</th><th>Campuses</th><th>Levels / Sections</th><th>Owner</th><th>Plan</th><th>Status</th><th>Actions</th></tr></thead><tbody><% tenants.forEach(function(tenant){ const academics = tenant.settings?.academics || {}; const schoolUnits = academics.schoolUnits || []; const campuses = academics.campuses || []; %><tr><td><strong><%= tenant.name %></strong><br><span class="muted">Code: <%= tenant.code %></span><br><span class="muted"><%= tenant.customDomain || tenant.subdomain || '—' %></span></td><td><div class="chips"><% if (schoolUnits.length) { schoolUnits.forEach(function(unit){ %><span class="chip"><%= unit.name %></span><% }) } else { %><span class="muted">No school units</span><% } %></div></td><td><strong><%= campuses.length %></strong><div class="muted"><%= academics.hasMultipleCampuses ? 'Multiple campuses' : (campuses.length ? 'Single campus' : 'No campuses') %></div></td><td><div class="chips"><% (academics.educationLevels || []).forEach(function(level){ %><span class="chip"><%= level %></span><% }) %></div><div class="muted" style="margin-top:6px"><%= (academics.schoolSections || []).join(', ') || 'No sections yet' %></div></td><td><%= tenant.ownerName || '—' %><br><span class="muted"><%= tenant.ownerEmail || '—' %></span></td><td><%= tenant.planId?.name || '—' %></td><td><span class="badge <%= tenant.status === 'active' ? 'green' : tenant.status === 'trial' ? 'amber' : tenant.status === 'suspended' ? 'red' : 'gray' %>"><%= tenant.status %></span></td><td><div class="row-actions"><a class="btn small" href="/super-admin/universities/<%= tenant._id %>">View</a><a class="btn small" href="/super-admin/universities/<%= tenant._id %>/edit">Edit</a><form action="/super-admin/universities/<%= tenant._id %>/resend-invite" method="POST" class="inline"><button type="submit" class="btn small"><i class="fa-solid fa-paper-plane"></i> Resend</button></form></div></td></tr><% }) %></tbody></table></div><% } %></div></main><script src="/js/navbar.js"></script></body></html>
