<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>
    <%= (tenant?.name || "Classic Academy" ) %> • Student Statements
  </title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css" />
  <link rel="stylesheet" href="/css/student-portal.css" />

  <style>
    :root {
      --blue: #0a3d62;
      --blue2: #083454;
      --accent: #0a6fbf;
      --bg: #f4f8ff;
      --card: #fff;
      --muted: #6b7280;
      --success: #16a34a;
      --danger: #ef4444;
      --warn: #f59e0b;
      --info: #4f46e5;
      --radius: 16px;
      --line: rgba(13, 64, 96, .12);
      --shadow: 0 10px 30px rgba(0, 0, 0, .08);
    }

    * {
      box-sizing: border-box
    }

    html,
    body {
      height: 100%
    }

    body {
      margin: 0;
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
      background: var(--bg);
      color: #0f172a
    }

    .app {
      display: flex;
      min-height: 100vh
    }

    .main {
      flex: 1;
      padding: 18px
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      align-items: flex-start
    }

    .title {
      font-size: 18px;
      font-weight: 1000
    }

    .subtitle {
      font-size: 12px;
      color: var(--muted);
      margin-top: 4px
    }

    .top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap
    }

    .btn {
      border: none;
      border-radius: 12px;
      padding: 10px 12px;
      font-weight: 900;
      cursor: pointer;
      display: inline-flex;
      gap: 8px;
      align-items: center
    }

    .btn.primary {
      background: var(--accent);
      color: #fff
    }

    .btn.light {
      background: #fff;
      border: 1px solid var(--line);
      color: #0f172a
    }

    .btn:hover {
      filter: brightness(.98)
    }

    .btn.small {
      padding: 8px 10px;
      border-radius: 10px;
      font-size: 12px
    }

    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow)
    }

    .card-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      padding: 12px 14px;
      border-bottom: 1px solid var(--line)
    }

    .card-title {
      font-weight: 1000
    }

    .card-sub {
      font-size: 12px;
      color: var(--muted)
    }

    .card-body {
      padding: 14px
    }

    .grid-4 {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 12px
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1.2fr .8fr;
      gap: 12px;
      margin-top: 12px
    }

    .kpi {
      padding: 14px
    }

    .kpi .label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 800
    }

    .kpi .value {
      font-size: 22px;
      font-weight: 1000;
      margin-top: 6px
    }

    .kpi .hint {
      font-size: 12px;
      color: var(--muted);
      margin-top: 4px
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 900
    }

    .ok {
      background: #ecfdf3;
      color: #15803d
    }

    .bad {
      background: #fee2e2;
      color: #b91c1c
    }

    .warnpill {
      background: #fef9c3;
      color: #92400e
    }

    .infopill {
      background: #eef2ff;
      color: #3730a3
    }

    .archpill {
      background: #f1f5f9;
      color: #334155
    }

    .muted {
      color: var(--muted);
      font-size: 12px
    }

    .strong {
      font-weight: 1000
    }

    .divider {
      height: 1px;
      background: var(--line);
      margin: 12px 0
    }

    .row {
      display: flex;
      gap: 10px;
      align-items: center
    }

    .filters {
      display: grid;
      grid-template-columns: 1.3fr 1fr 1fr 1fr;
      gap: 10px
    }

    .field {
      display: grid;
      gap: 6px
    }

    .field label {
      font-size: 12px;
      color: var(--muted);
      font-weight: 800
    }

    .input,
    .select {
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: #fff;
      outline: none
    }

    .input:focus,
    .select:focus {
      border-color: rgba(10, 111, 191, .45);
      box-shadow: 0 0 0 3px rgba(10, 111, 191, .12)
    }

    .table-wrap {
      overflow: auto;
      border: 1px solid var(--line);
      border-radius: 12px
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 1200px;
      background: #fff
    }

    th,
    td {
      padding: 10px 12px;
      border-bottom: 1px solid rgba(13, 64, 96, .08);
      vertical-align: top
    }

    th {
      font-size: 12px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .04em;
      text-align: left;
      background: rgba(13, 64, 96, .03);
      position: sticky;
      top: 0;
      z-index: 1
    }

    tr:hover td {
      background: rgba(10, 111, 191, .04)
    }

    .right {
      text-align: right
    }

    .chipbar {
      display: flex;
      gap: 8px;
      flex-wrap: wrap
    }

    .chip {
      border: 1px solid var(--line);
      background: #fff;
      border-radius: 999px;
      padding: 8px 12px;
      font-weight: 900;
      font-size: 12px;
      cursor: pointer
    }

    .chip.active {
      background: rgba(10, 111, 191, .12);
      border-color: rgba(10, 111, 191, .35)
    }

    .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      background: #eef2ff;
      color: #3730a3;
      font-size: 12px;
      font-weight: 800
    }

    .flash-wrap {
      display: grid;
      gap: 10px;
      margin-bottom: 12px
    }

    .flash {
      padding: 12px 14px;
      border-radius: 12px;
      font-weight: 700
    }

    .flash-success {
      background: #ecfdf3;
      color: #166534;
      border: 1px solid #bbf7d0
    }

    .flash-error {
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca
    }

    .json-data {
      display: none !important
    }

    @media print {

      .top-actions,
      .filters,
      .chipbar,
      .no-print,
      .card-head .row {
        display: none !important
      }

      body {
        background: #fff
      }

      .card {
        box-shadow: none
      }

      .main {
        padding: 0
      }

      table {
        min-width: unset
      }
    }

    @media(max-width:1050px) {
      .grid-2 {
        grid-template-columns: 1fr
      }

      .grid-4 {
        grid-template-columns: 1fr 1fr
      }

      .filters {
        grid-template-columns: 1fr 1fr
      }

      table {
        min-width: 1000px
      }
    }

    @media(max-width:650px) {
      .main {
        padding: 14px
      }

      .grid-4 {
        grid-template-columns: 1fr
      }

      .filters {
        grid-template-columns: 1fr
      }

      table {
        min-width: 860px
      }
    }
  </style>
</head>

<body>

  <div class="app">
    <%- include("../partials/navbar") %>

      <main class="main">
        <% if (typeof messages !=="undefined" && (messages.success?.length || messages.error?.length)) { %>
          <div class="flash-wrap">
            <% (messages.success || []).forEach(function(msg){ %>
              <div class="flash flash-success">
                <%= msg %>
              </div>
              <% }) %>
                <% (messages.error || []).forEach(function(msg){ %>
                  <div class="flash flash-error">
                    <%= msg %>
                  </div>
                  <% }) %>
          </div>
          <% } %>

            <div class="topbar">
              <div>
                <div class="title">Student Statements</div>
                <div class="subtitle">Running statement of invoices and payments for academy students.</div>
              </div>
              <div class="top-actions">
                <button class="btn light" id="btnBack"><i class="fa-solid fa-arrow-left"></i> Back</button>
                <button class="btn light" id="btnPrint"><i class="fa-solid fa-print"></i> Print</button>
                <button class="btn primary" id="btnCSV"><i class="fa-solid fa-file-csv"></i> Export CSV</button>
              </div>
            </div>

            <div class="grid-4">
              <div class="card kpi">
                <div class="label">Students</div>
                <div class="value" id="kStudents">
                  <%= totals?.students || 0 %>
                </div>
                <div class="hint">Matching current filters</div>
              </div>
              <div class="card kpi">
                <div class="label">Total Billed</div>
                <div class="value" id="kBilled">UGX 0</div>
                <div class="hint">Invoices raised</div>
              </div>
              <div class="card kpi">
                <div class="label">Total Paid</div>
                <div class="value" id="kPaid">UGX 0</div>
                <div class="hint">Payments received</div>
              </div>
              <div class="card kpi">
                <div class="label">Current Balance</div>
                <div class="value" id="kBalance">UGX 0</div>
                <div class="hint"><span class="pill warnpill" id="kStatus"><i
                      class="fa-solid fa-circle-half-stroke"></i> Outstanding</span></div>
              </div>
            </div>

            <div class="grid-2">
              <section class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Filters</div>
                    <div class="card-sub">Search and filter student statements.</div>
                  </div>
                  <div class="chipbar no-print" id="chipBar">
                    <button class="chip active" data-range="term">This Term</button>
                    <button class="chip" data-range="30">Last 30 Days</button>
                    <button class="chip" data-range="90">Last 90 Days</button>
                    <button class="chip" data-range="all">All Time</button>
                  </div>
                </div>

                <div class="card-body">
                  <form class="filters" method="GET" action="/tenant/student-statements">
                    <div class="field">
                      <label>Search</label>
                      <input class="input" name="q" id="fStudentSearch" placeholder="Name / Reg No / Class / Subject"
                        value="<%= query?.q || '' %>">
                    </div>

                    <div class="field">
                      <label>Student</label>
                      <select class="select" name="student" id="fStudent">
                        <option value="all">All Students</option>
                        <% (students || []).forEach(function(s){ %>
                          <option value="<%= s.id %>" <%=query?.student===s.id ? 'selected' : '' %>>
                            <%= (s.name || 'Student' ) + (s.regNo ? ' — ' + s.regNo : '' ) %>
                          </option>
                          <% }) %>
                      </select>
                    </div>

                    <div class="field">
                      <label>School Level</label>
                      <select class="select" name="schoolLevel" id="fSchoolLevel">
                        <option value="all" <%=query?.schoolLevel==='all' ? 'selected' : '' %>>All Levels</option>
                        <option value="nursery" <%=query?.schoolLevel==='nursery' ? 'selected' : '' %>>Nursery</option>
                        <option value="primary" <%=query?.schoolLevel==='primary' ? 'selected' : '' %>>Primary</option>
                        <option value="secondary" <%=query?.schoolLevel==='secondary' ? 'selected' : '' %>>Secondary
                        </option>
                      </select>
                    </div>

                    <div class="field">
                      <label>Class Level</label>
                      <select class="select" name="classLevel" id="fClassLevel">
                        <option value="all" <%=query?.classLevel==='all' ? 'selected' : '' %>>All Classes</option>
                        <option value="BABY" <%=query?.classLevel==='BABY' ? 'selected' : '' %>>BABY</option>
                        <option value="MIDDLE" <%=query?.classLevel==='MIDDLE' ? 'selected' : '' %>>MIDDLE</option>
                        <option value="TOP" <%=query?.classLevel==='TOP' ? 'selected' : '' %>>TOP</option>
                        <option value="P1" <%=query?.classLevel==='P1' ? 'selected' : '' %>>P1</option>
                        <option value="P2" <%=query?.classLevel==='P2' ? 'selected' : '' %>>P2</option>
                        <option value="P3" <%=query?.classLevel==='P3' ? 'selected' : '' %>>P3</option>
                        <option value="P4" <%=query?.classLevel==='P4' ? 'selected' : '' %>>P4</option>
                        <option value="P5" <%=query?.classLevel==='P5' ? 'selected' : '' %>>P5</option>
                        <option value="P6" <%=query?.classLevel==='P6' ? 'selected' : '' %>>P6</option>
                        <option value="P7" <%=query?.classLevel==='P7' ? 'selected' : '' %>>P7</option>
                        <option value="S1" <%=query?.classLevel==='S1' ? 'selected' : '' %>>S1</option>
                        <option value="S2" <%=query?.classLevel==='S2' ? 'selected' : '' %>>S2</option>
                        <option value="S3" <%=query?.classLevel==='S3' ? 'selected' : '' %>>S3</option>
                        <option value="S4" <%=query?.classLevel==='S4' ? 'selected' : '' %>>S4</option>
                        <option value="S5" <%=query?.classLevel==='S5' ? 'selected' : '' %>>S5</option>
                        <option value="S6" <%=query?.classLevel==='S6' ? 'selected' : '' %>>S6</option>
                      </select>
                    </div>

                    <div class="field">
                      <label>Term</label>
                      <select class="select" name="term" id="fTerm">
                        <option value="all" <%=query?.term==='all' ? 'selected' : '' %>>All Terms</option>
                        <option value="1" <%=String(query?.term || '' )==='1' ? 'selected' : '' %>>Term 1</option>
                        <option value="2" <%=String(query?.term || '' )==='2' ? 'selected' : '' %>>Term 2</option>
                        <option value="3" <%=String(query?.term || '' )==='3' ? 'selected' : '' %>>Term 3</option>
                      </select>
                    </div>

                    <div class="field" style="align-self:end">
                      <button class="btn primary" type="submit"><i class="fa-solid fa-filter"></i> Apply
                        Filters</button>
                    </div>
                  </form>
                </div>
              </section>

              <aside class="card">
                <div class="card-head">
                  <div>
                    <div class="card-title">Selected Student Profile</div>
                    <div class="card-sub">Academic and finance summary.</div>
                  </div>
                </div>
                <div class="card-body">
                  <div class="row" style="justify-content:space-between">
                    <div>
                      <div class="strong" id="pStudentName">—</div>
                      <div class="muted" id="pRegNo">—</div>
                    </div>
                    <span class="pill infopill" id="pStudentStatus"><i class="fa-solid fa-user"></i> —</span>
                  </div>

                  <div class="divider"></div>

                  <div class="row" style="justify-content:space-between">
                    <span class="muted">School Level</span>
                    <span class="strong" id="pSchoolLevel">—</span>
                  </div>
                  <div class="row" style="justify-content:space-between">
                    <span class="muted">Class Level</span>
                    <span class="strong" id="pClassLevel">—</span>
                  </div>
                  <div class="row" style="justify-content:space-between">
                    <span class="muted">Term</span>
                    <span class="strong" id="pTerm">—</span>
                  </div>
                  <div class="row" style="justify-content:space-between">
                    <span class="muted">Academic Year</span>
                    <span class="strong" id="pAcademicYear">—</span>
                  </div>
                  <div class="row" style="justify-content:space-between">
                    <span class="muted">Registration Hold</span>
                    <span class="strong" id="pHold">No</span>
                  </div>

                  <div class="divider"></div>

                  <div class="strong">Subjects</div>
                  <div class="divider"></div>
                  <div class="tag-list" id="pSubjects">
                    <span class="muted">No subjects</span>
                  </div>
                </div>
              </aside>
            </div>

            <section class="card" style="margin-top:12px">
              <div class="card-head">
                <div>
                  <div class="card-title">Statement Entries</div>
                  <div class="card-sub" id="tableMeta">Showing entries and running balance.</div>
                </div>
                <div class="row no-print">
                  <span class="muted" id="countMeta">0 entries</span>
                </div>
              </div>
              <div class="card-body">
                <div class="table-wrap">
                  <table id="stmtTable">
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>Student</th>
                        <th>Reference</th>
                        <th>Description</th>
                        <th>Class</th>
                        <th>Term</th>
                        <th class="right">Debit (UGX)</th>
                        <th class="right">Credit (UGX)</th>
                        <th class="right">Running Balance</th>
                        <th>Status</th>
                      </tr>
                    </thead>
                    <tbody id="stmtBody"></tbody>
                  </table>
                </div>
              </div>
            </section>
      </main>
  </div>

  <textarea id="statementsData" class="json-data" aria-hidden="true"><%- JSON.stringify(statements || []) %></textarea>

  <script>
    const $ = (id) => document.getElementById(id);
    const fmt = (n) => {
      try { return new Intl.NumberFormat("en-US").format(Number(n || 0)); }
      catch (e) { return String(n || 0); }
    };

    function readStatements() {
      const el = $("statementsData");
      if (!el) return [];
      try { return JSON.parse(el.value || "[]"); }
      catch (err) {
        console.error("Failed to parse statements data:", err);
        return [];
      }
    }

    const STATEMENTS = readStatements();

    function schoolLevelLabel(v) {
      const map = { nursery: "Nursery", primary: "Primary", secondary: "Secondary" };
      return map[String(v || "").toLowerCase()] || "—";
    }

    function statusPill(status) {
      const s = String(status || "").toLowerCase();
      if (s === "active") return '<span class="pill ok"><i class="fa-solid fa-circle-check"></i> Active</span>';
      if (s === "on_hold") return '<span class="pill warnpill"><i class="fa-solid fa-ban"></i> On Hold</span>';
      if (s === "suspended") return '<span class="pill bad"><i class="fa-solid fa-triangle-exclamation"></i> Suspended</span>';
      if (s === "graduated") return '<span class="pill infopill"><i class="fa-solid fa-graduation-cap"></i> Graduated</span>';
      if (s === "archived") return '<span class="pill archpill"><i class="fa-solid fa-box-archive"></i> Archived</span>';
      return '<span class="pill infopill"><i class="fa-solid fa-user"></i> ' + (status || "—") + '</span>';
    }

    function entryStatusPill(status) {
      const s = String(status || "").toLowerCase();
      if (s.includes("paid") && !s.includes("partial")) return '<span class="pill ok">Paid</span>';
      if (s.includes("partial")) return '<span class="pill warnpill">Partial</span>';
      if (s.includes("cancel")) return '<span class="pill archpill">Cancelled</span>';
      if (s.includes("draft")) return '<span class="pill infopill">Draft</span>';
      if (s.includes("void") || s.includes("refund")) return '<span class="pill bad">' + (status || "—") + '</span>';
      return '<span class="pill warnpill">' + (status || "Unpaid") + '</span>';
    }

    function flattenEntries(statements) {
      const rows = [];
      statements.forEach((st) => {
        (st.ledger || []).forEach((row) => {
          rows.push({
            studentId: st.id,
            studentName: st.studentName || "—",
            regNo: st.regNo || "—",
            schoolLevel: st.schoolLevel || "",
            classLevel: st.classLevel || "",
            term: Number(st.term || row.term || 1),
            academicYear: st.academicYear || row.academicYear || "",
            studentStatus: st.status || "active",
            holdType: st.holdType || "",
            holdReason: st.holdReason || "",
            subjectNames: Array.isArray(st.subjectNames) ? st.subjectNames : [],
            date: row.rawDate || "",
            type: row.type || "",
            ref: row.ref || "—",
            description: row.description || "—",
            debit: Number(row.debit || 0),
            credit: Number(row.credit || 0),
            runningBalance: Number(row.runningBalance || 0),
            status: row.status || "",
          });
        });
      });
      return rows.sort((a, b) => new Date(a.date) - new Date(b.date));
    }

    function setKpis(rows) {
      const billed = rows.reduce((a, r) => a + (r.debit || 0), 0);
      const paid = rows.reduce((a, r) => a + (r.credit || 0), 0);
      const balance = Math.max(0, billed - paid);

      $("kBilled").textContent = "UGX " + fmt(billed);
      $("kPaid").textContent = "UGX " + fmt(paid);
      $("kBalance").textContent = "UGX " + fmt(balance);

      const statusEl = $("kStatus");
      if (balance <= 0 && rows.length) {
        statusEl.className = "pill ok";
        statusEl.innerHTML = '<i class="fa-solid fa-check"></i> Cleared';
      } else {
        statusEl.className = "pill warnpill";
        statusEl.innerHTML = '<i class="fa-solid fa-circle-half-stroke"></i> Outstanding';
      }
    }

    function setProfile(statement) {
      if (!statement) {
        $("pStudentName").textContent = "—";
        $("pRegNo").textContent = "—";
        $("pStudentStatus").innerHTML = statusPill("—");
        $("pSchoolLevel").textContent = "—";
        $("pClassLevel").textContent = "—";
        $("pTerm").textContent = "—";
        $("pAcademicYear").textContent = "—";
        $("pHold").textContent = "No";
        $("pSubjects").innerHTML = '<span class="muted">No subjects</span>';
        return;
      }

      $("pStudentName").textContent = statement.studentName || "—";
      $("pRegNo").textContent = statement.regNo || "—";
      $("pStudentStatus").innerHTML = statusPill(statement.status || "active");
      $("pSchoolLevel").textContent = schoolLevelLabel(statement.schoolLevel);
      $("pClassLevel").textContent = statement.classLevel || "—";
      $("pTerm").textContent = statement.term ? "Term " + Number(statement.term) : "—";
      $("pAcademicYear").textContent = statement.academicYear || "—";
      $("pHold").textContent = statement.holdType ? `${statement.holdType}${statement.holdReason ? " • " + statement.holdReason : ""}` : "No";

      const tags = Array.isArray(statement.subjectNames) ? statement.subjectNames : [];
      $("pSubjects").innerHTML = tags.length
        ? tags.map((s) => `<span class="tag">${String(s).replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;")}</span>`).join("")
        : '<span class="muted">No subjects</span>';
    }

    function renderTable(rows) {
      let running = 0;

      $("stmtBody").innerHTML = rows.map((r) => {
        running += (r.debit || 0) - (r.credit || 0);
        return `
        <tr>
          <td class="muted">${r.date || "—"}</td>
          <td>
            <div class="strong">${r.studentName || "—"}</div>
            <div class="muted">${r.regNo || "—"}</div>
          </td>
          <td class="strong">${r.ref || "—"}</td>
          <td class="muted">${r.description || "—"}</td>
          <td>${schoolLevelLabel(r.schoolLevel)}${r.classLevel ? " • " + r.classLevel : ""}</td>
          <td>${r.term ? "Term " + Number(r.term) : "—"}</td>
          <td class="right ${r.debit ? 'strong' : ''}">${r.debit ? "UGX " + fmt(r.debit) : "—"}</td>
          <td class="right ${r.credit ? 'strong' : ''}">${r.credit ? "UGX " + fmt(r.credit) : "—"}</td>
          <td class="right strong">UGX ${fmt(Math.max(running, 0))}</td>
          <td>${entryStatusPill(r.status)}</td>
        </tr>
      `;
      }).join("") || `<tr><td colspan="10" class="muted" style="padding:18px">No statement entries found.</td></tr>`;

      $("countMeta").textContent = `${rows.length} entries`;
      $("tableMeta").textContent = rows.length
        ? `Statement period: ${rows[0].date || "—"} to ${rows[rows.length - 1].date || "—"}`
        : "Showing entries and running balance.";

      setKpis(rows);
    }

    function getActiveStatement() {
      const selectedId = $("fStudent") ? $("fStudent").value : "all";
      if (selectedId && selectedId !== "all") {
        return STATEMENTS.find((s) => String(s.id) === String(selectedId)) || null;
      }
      return STATEMENTS.length === 1 ? STATEMENTS[0] : null;
    }

    function exportCsv() {
      const rows = flattenEntries(STATEMENTS);
      if (!rows.length) {
        alert("Nothing to export.");
        return;
      }

      const esc = (value) => {
        const s = String(value ?? "");
        return /[,"\n]/.test(s) ? `"${s.replace(/"/g, '""')}"` : s;
      };

      const header = [
        "Date",
        "Student",
        "RegNo",
        "Reference",
        "Description",
        "SchoolLevel",
        "ClassLevel",
        "Term",
        "Debit",
        "Credit",
        "RunningBalance",
        "Status",
      ];

      const lines = [header.join(",")];
      let running = 0;

      rows.forEach((r) => {
        running += (r.debit || 0) - (r.credit || 0);
        lines.push([
          esc(r.date || ""),
          esc(r.studentName || ""),
          esc(r.regNo || ""),
          esc(r.ref || ""),
          esc(r.description || ""),
          esc(r.schoolLevel || ""),
          esc(r.classLevel || ""),
          esc(r.term || ""),
          esc(r.debit || 0),
          esc(r.credit || 0),
          esc(Math.max(running, 0)),
          esc(r.status || ""),
        ].join(","));
      });

      const blob = new Blob([lines.join("\n")], { type: "text/csv;charset=utf-8;" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "student-statements.csv";
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    }

    $("btnBack").addEventListener("click", () => history.back());
    $("btnPrint").addEventListener("click", () => window.print());
    $("btnCSV").addEventListener("click", exportCsv);

    document.querySelectorAll(".chip").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
        btn.classList.add("active");
      });
    });

    const initialStatement = getActiveStatement();
    setProfile(initialStatement);
    renderTable(flattenEntries(STATEMENTS));
  </script>

</body>

</html>